							<Name><![CDATA[wrapUpTaskPolicyType]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[wrapUpTaskPriority]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[wrapUpTaskPreemptionPolicy]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[customizeResourceChoice]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[resourceChoiceCondition]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[resourceSelectionMode]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[resourceRating]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[resourceComparison]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onResourcesArrived]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onDelayStarts]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onDelayEnds]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onExit]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[Resource trayRes = (Resource) agent;
Tray tray = trayRes.getTray();
if (tray == null) {
    Logger.error("RackStore FG: trayRes has no payload!");
    return;
}

if (tray.getFgIds() == null || tray.getFgIds().isEmpty()) {
    Logger.error("RackStore FG: tray has no fgIds! variant=", tray.getFgSkuVariant());
    return;
}

FgSlot slot = this.services.slotting.getFgSlot(
        tray.getFgSkuVariant(),
        trayRes.rackTargetRow,
        trayRes.rackTargetCell,
        trayRes.rackTargetLevel
);

if (slot == null) {

    Logger.error("RackStore FG: cannot find logical slot for sku=", tray.getFgSkuVariant(),
            " row=", trayRes.rackTargetRow,
            " cell=", trayRes.rackTargetCell,
            " level=", trayRes.rackTargetLevel);
    return;
}

// Commit logical placement (intact tray)
boolean ok = this.services.slotting.placeTrayIntoFgSlot(trayRes, slot);

if (!ok) {
    Logger.error(getName(), " - RackStore FG: logical placement failed for sku=", tray.getFgSkuVariant(),
            " row=", slot.row, " cell=", slot.cell, " level=", slot.level);
    return;
}

// Commit in Odoo as stowed (only after successful placement)
try {
    OdooMrpGateway.storeFgInWarehouse(this, tray.getFgIds());
    // tray.setOdooStowed(true); // if you add such a flag
} catch (Exception e) {
    Logger.error(getName(), " - RackStore FG: Odoo stow commit FAILED for fgIds=", tray.getFgIds(), " err=", e);
    return;
}

// Clear target flag (same pattern you used in rackStoreMB)
trayRes.itemAssigned = false;
trayRes.hasRackTarget = false;
trayRes.fgStowTask = null;

this.services.whDispatch.tryDispatchFgPicking();
]]></Code>
							</Value>
						</Parameter>
