		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1765733900023</Id>
			<Name><![CDATA[TrayAssignment]]></Name>
			<Folder>1771726185934</Folder>
			<Text><![CDATA[/**
 * TrayAssignment (aligned)
 *
 * - markIncomingReserved() increments slot.incomingTrays (by 1) AND slot.incoming (by trayUnits)
 * - rollbackIncomingReservation() decrements both
 */

public class TrayAssignment {
    public final Resource trayRes;
    public final Tray trayPayload;
    public final FgSlot targetSlot;
    public final int rackIdx;

    public final FG_SKU fgSkuVariant;
    public final int trayUnits;

    private boolean incomingReserved = false;

    public TrayAssignment(Resource trayRes, Tray trayPayload, FgSlot targetSlot, int rackIdx) {
        this.trayRes = trayRes;
        this.trayPayload = trayPayload;
        this.targetSlot = targetSlot;
        this.rackIdx = rackIdx;

        this.fgSkuVariant = (trayPayload != null) ? trayPayload.getFgSkuVariant() : null;
        this.trayUnits = (trayPayload != null) ? trayPayload.totalUnits() : 0;
    }

    public boolean isValid() {
        if (trayRes == null || trayPayload == null || targetSlot == null) return false;
        if (trayUnits <= 0 || trayUnits > Constants.FG_MAX_UNITS_PER_SLOT) return false;

        // tray-position capacity
        if (targetSlot.freeTrayCapacity() <= 0) return false;

        // unit capacity (only if you implemented incoming as units + occupiedUnits)
        if (targetSlot.freeUnitCapacity() < trayUnits) return false;

        return true;
    }

    public void markIncomingReserved() {
        if (incomingReserved) return;
        if (targetSlot == null) return;
        
        targetSlot.reserveIncomingTray(trayUnits);
        incomingReserved = true;
    }

    public void rollbackIncomingReservation(String reason) {
        if (!incomingReserved) return;
        if (targetSlot == null) return;
        
        targetSlot.rollbackIncomingTray(trayUnits, reason);
        incomingReserved = false;
    }

    @Override
    public String toString() {
        return "TrayAssignment{sku=" + fgSkuVariant +
                ", trayUnits=" + trayUnits +
                ", row=" + (targetSlot != null ? targetSlot.row : -1) +
                ", cell=" + (targetSlot != null ? targetSlot.cell : -1) +
                ", level=" + (targetSlot != null ? targetSlot.level : -1) +
                ", rackIdx=" + rackIdx +
                "}";
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1766095404369</Id>
			<Name><![CDATA[PurchaseOrderSim]]></Name>
			<Folder>1771726185934</Folder>
			<Text><![CDATA[/**
 * PurchaseOrderSim
 */	
public class PurchaseOrderSim {
	public int simId;
    public int vendorId;
    public String vendorName;
    public double etaSec;
    
    // skuId -> orderedUnits
    public LinkedHashMap<String,Integer> orderedUnitsBySkuId = new LinkedHashMap<>();

    // skuId -> acceptedUnits (passed QC and stored)
    public LinkedHashMap<String,Integer> goodUnitsBySkuId = new LinkedHashMap<>();

    // skuId -> rejectedUnits
    public LinkedHashMap<String,Integer> badUnitsBySkuId = new LinkedHashMap<>();

    // Odoo
    public int odooPoId = -1;
    public int odooPickingId = -1;

    public boolean inboundSpawned = false;
    public boolean receiptPostedToOdoo = false;
    
    public Resource inboundTruck;
    public int assignedDockIdx = -1;
    public int expectedBoxes = 0;
    public int unloadedBoxes = 0;
    public boolean boxesInjected = false;
    
    // KPI
    public double createdAt;   // time() at PO creation
    public double completedAt; // time() when fully processed
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1766097095319</Id>
			<Name><![CDATA[OdooPurchaseGateway]]></Name>
			<Folder>1771290666693</Folder>
			<Text><![CDATA[/**
 * OdooPurchaseGateway
 *
 * Handles purchase.order + incoming stock.picking for Procurement / Inbound.
 *
 * Public API:
 *  - createPurchaseOrderForSim(main, po)
 *  - receiveIncomingForPo(main, po)
 *
 * Behavior:
 *  - Creates PO and PO lines with required fields (uom, price_unit, date_planned, name).
 *  - Confirms PO to generate receipt pickings.
 *  - Receives based on po.goodUnitsBySkuId only; rejected qty triggers backorder wizard -> we prefer cancel-backorder.
 *  - Idempotent: if picking already done, returns true.
 *
 * Notes:
 *  - For 3-step receipts, this validates only the "incoming" picking (picking_type_code="incoming").
 *    You can extend later to validate internal transfers as your sim progresses.
 */
import java.util.*;

public final class OdooPurchaseGateway {

    // -------------------- Public API --------------------

    /** Create a purchase.order & purchase.order.line in Odoo for this PurchaseOrderSim. */
    public static void createPurchaseOrderForSim(Main main, PurchaseOrderSim po) {
        try {
            if (main == null || main.m_odooSession == null || po == null)
            	return;

            // Already created
            if (po.odooPoId > 0)
            	return;

            int vendorPartnerId = po.vendorId;
            if (vendorPartnerId <= 0) {
                Logger.warn("OdooPurchaseGateway: vendorId missing for PO(sim)=", po.simId);
                return;
            }

            if (po.orderedUnitsBySkuId == null || po.orderedUnitsBySkuId.isEmpty()) {
                Logger.warn("OdooPurchaseGateway: no lines for PO(sim)=", po.simId);
                return;
            }

            // Create purchase.order
            int poId = doCreatePurchaseOrder(main, vendorPartnerId);
            if (poId <= 0) {
                Logger.warn("OdooPurchaseGateway: failed create purchase.order for PO(sim)=", po.simId);
                return;
            }
            po.odooPoId = poId;
            
            // force sim time into PO header dates
            String simNow = simDateTime(main, po.createdAt);
            forcePoDates(main, poId, simNow);

            // Create purchase.order.line for each skuId
            for (Map.Entry<String, Integer> e : po.orderedUnitsBySkuId.entrySet()) {
                String skuId = e.getKey();
                int qtyUnits = e.getValue();

                if (skuId == null || skuId.isEmpty() || qtyUnits <= 0)
                	continue;

                Integer productIdObj = main.productIdBySkuId.get(skuId);
                int productId = (productIdObj == null ? -1 : productIdObj);
                if (productId <= 0) {
                    Logger.warn("OdooPurchaseGateway: no productId for skuId=", skuId, " PO(sim)=", po.simId);
                    continue;
                }

                ProductPurchaseMeta meta = readProductPurchaseMeta(main, productId);

                String lineName = (meta != null && meta.displayName != null && !meta.displayName.isEmpty())
                        ? meta.displayName
                        : skuId;
                
                int uomId = (meta != null ? meta.uomId : -1); 

                double priceUnit = (meta != null ? meta.standardPrice : 0.0);
                if (priceUnit <= 0.0)
                	priceUnit = 1.0;

                // planned date: if you have ETA, use that; else use current sim time
                double plannedSimSec = (po.etaSec > 0 ? po.etaSec : main.time());
                String planned = DateTimeUtil.convertSimulationTimeToDate(
                        main.getEngine().getStartDate(),
                        plannedSimSec,
                        false
                );

                doCreatePurchaseOrderLine(main, poId, productId, qtyUnits, uomId, priceUnit, lineName, planned);
            }

            // Confirm PO => generates incoming picking(s)
            doConfirmPurchaseOrder(main, poId);
            forcePoDates(main, poId, simNow);

            // Resolve incoming picking id (may not exist immediately in some setups; safe to call again later)
            ensureIncomingPickingId(main, po);

            Logger.info("OdooPurchaseGateway: created purchase.order=", po.odooPoId,
                    " picking=", po.odooPickingId,
                    " vendorPartnerId=", vendorPartnerId,
                    " lines=", po.orderedUnitsBySkuId);

        } catch (Exception ex) {
            Logger.error("OdooPurchaseGateway.createPurchaseOrderForSim failed", ex);
        }
    }

    /**
     * Validate the incoming receipt for this PO based on "good" quantities only.
     * - Writes qty_done / quantity_done
     * - button_validate
     * - Cancels backorder wizard if it appears (preferred)
     */
    public static boolean receiveIncomingForPo(Main main, PurchaseOrderSim po) {
        try {
            if (main == null || main.m_odooSession == null || po == null)
            	return false;
            
            if (po.odooPoId <= 0)
            	return false;

            ensureIncomingPickingId(main, po);
            if (po.odooPickingId <= 0) {
                Logger.warn("OdooPurchaseGateway.receiveIncomingForPo: no incoming picking for PO=", po.odooPoId,
                        " simId=", po.simId);
                return false;
            }

            // If already done -> idempotent success
            if (isPickingDone(main, po.odooPickingId))
            	return true;
            
            // If nothing accepted, cancel picking (represents full rejection/return)
            if (po.goodUnitsBySkuId == null || po.goodUnitsBySkuId.isEmpty()) {
                Logger.warn("OdooPurchaseGateway: all rejected -> cancelling pickingId=", po.odooPickingId, " PO=", po.odooPoId);
                return cancelPicking(main, po.odooPickingId);
            }

            // Reserve (safe for receipts; may no-op)
            try {
                OdooUtils.executeKw(
                        main.m_odooSession,
                        OdooUtils.DATABASE_NAME,
                        OdooUtils.SERVER_PASSWORD,
                        "stock.picking",
                        "action_assign",
                        Arrays.asList(Arrays.asList(po.odooPickingId)),
                        null
                );
            } catch (Exception ignore) {}

            // Validate and handle wizard(s) (prefer cancel backorder)
            ensureDoneQuantitiesForPicking(main, po.odooPickingId, po.goodUnitsBySkuId);
            boolean ok = validatePickingHandlingWizardsPreferCancelBackorder(main, po.odooPickingId);
            if (!ok)
            	return false;
            
            // picking done stamps "now" in Odoo; overwrite with sim receipt time
            // double receiptSimSec = (po.etaSec > 0 ? po.etaSec : main.time()); // choose what "arrival" should mean
            String receiptUtc = simDateTime(main, main.time());

            // set date_done + align moves/move lines (recommended)
            forcePickingDates(main, po.odooPickingId, receiptUtc, true);

            // Final state check
            return isPickingDone(main, po.odooPickingId);

        } catch (Exception ex) {
            Logger.error("OdooPurchaseGateway.receiveIncomingForPo failed pickingId=", po.odooPickingId, " ERR: ", ex);
            return false;
        }
    }
    
    private static void forcePoDates(Main main, int poId, String simUtc) {
        try {
            if (main == null || main.m_odooSession == null) return;
            if (poId <= 0) return;

            Map<String, Object> vals = new HashMap<>();
            // Shows on PO header as "Order Date" in many views
            vals.put("date_order", simUtc);

            // Many Odoo 16 views use this as "Confirmation Date"
            // If your DB doesn't have it, write() will fail -> catch will log.
            vals.put("date_approve", simUtc);

            Object ok = OdooUtils.executeKw(
                    main.m_odooSession,
                    OdooUtils.DATABASE_NAME,
                    OdooUtils.SERVER_PASSWORD,
                    "purchase.order",
                    "write",
                    Arrays.asList(Arrays.asList(poId), vals),
                    null
            );

            Logger.info("forcePoDates poId=" + poId + " simUtc=" + simUtc + " ok=" + ok);

        } catch (Exception e) {
            Logger.warn("forcePoDates failed poId=" + poId + " simUtc=" + simUtc + " err=" + e.getMessage());
        }
    }
    
    private static void forcePickingDates(Main main, int pickingId, String simUtc, boolean alsoMoves) {
        try {
            if (main == null || main.m_odooSession == null) return;
            if (pickingId <= 0) return;

            // 1) stock.picking.date_done => "Arrival" / completion timestamp
            Map<String, Object> vals = new HashMap<>();
            vals.put("date_done", simUtc);

            Object ok = OdooUtils.executeKw(
                    main.m_odooSession,
                    OdooUtils.DATABASE_NAME,
                    OdooUtils.SERVER_PASSWORD,
                    "stock.picking",
                    "write",
                    Arrays.asList(Arrays.asList(pickingId), vals),
                    null
            );

            Logger.info("forcePickingDates pickingId=" + pickingId + " date_done=" + simUtc + " ok=" + ok);

            if (!alsoMoves) return;

            // 2) align stock.move.date and stock.move.line.date for reporting consistency
            List<Object> domainMove = Arrays.asList(Arrays.asList("picking_id", "=", pickingId));

            Map<String, Object> kwMove = new HashMap<>();
            kwMove.put("fields", Arrays.asList("id"));

            Object movesObj = OdooUtils.executeKw(
                    main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
                    "stock.move", "search_read",
                    Arrays.asList(domainMove),
                    kwMove
            );
            List<Map<String, Object>> moves = OdooUtils.asListOfMaps(movesObj);
            if (moves != null && !moves.isEmpty()) {
                List<Integer> ids = new ArrayList<>();
                for (Map<String, Object> m : moves) ids.add(OdooUtils.safeCastToInteger(m.get("id")));

                Map<String, Object> mvVals = new HashMap<>();
                mvVals.put("date", simUtc);

                Object ok2 = OdooUtils.executeKw(
                        main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
                        "stock.move", "write",
                        Arrays.asList(ids, mvVals),
                        null
                );
                Logger.info("forcePickingDates: updated stock.move count=" + ids.size() + " ok=" + ok2);
            }

            // move lines
            List<Object> domainMl = Arrays.asList(Arrays.asList("picking_id", "=", pickingId));
            Map<String, Object> kwMl = new HashMap<>();
            kwMl.put("fields", Arrays.asList("id"));

            Object mlsObj = OdooUtils.executeKw(
                    main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
                    "stock.move.line", "search_read",
                    Arrays.asList(domainMl),
                    kwMl
            );
            List<Map<String, Object>> mls = OdooUtils.asListOfMaps(mlsObj);
            if (mls != null && !mls.isEmpty()) {
                List<Integer> ids = new ArrayList<>();
                for (Map<String, Object> ml : mls) ids.add(OdooUtils.safeCastToInteger(ml.get("id")));

                Map<String, Object> mlVals = new HashMap<>();
                mlVals.put("date", simUtc);

                Object ok3 = OdooUtils.executeKw(
                        main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
                        "stock.move.line", "write",
                        Arrays.asList(ids, mlVals),
                        null
                );
                Logger.info("forcePickingDates: updated stock.move.line count=" + ids.size() + " ok=" + ok3);
            }

        } catch (Exception e) {
            Logger.warn("forcePickingDates failed pickingId=" + pickingId + " simUtc=" + simUtc + " err=" + e.getMessage());
        }
    }

    // -------------------- Create / Confirm helpers --------------------
    private static int doCreatePurchaseOrder(Main main, int vendorPartnerId) throws Exception {
        Map<String, Object> vals = new HashMap<>();
        vals.put("partner_id", vendorPartnerId);

        Object poIdObj = OdooUtils.executeKw(
                main.m_odooSession,
                OdooUtils.DATABASE_NAME,
                OdooUtils.SERVER_PASSWORD,
                "purchase.order",
                "create",
                Arrays.asList(vals),
                null
        );

        return OdooUtils.safeCastToInteger(poIdObj);
    }

    private static void doCreatePurchaseOrderLine(
            Main main,
            int poId,
            int productId,
            int qtyUnits,
            int uomId,
            double priceUnit,
            String name,
            String plannedDateUtc
    ) throws Exception {

        Map<String, Object> lineVals = new HashMap<>();
        lineVals.put("order_id", poId);
        lineVals.put("product_id", productId);

        // required in most configs
        lineVals.put("product_qty", (double) qtyUnits);
        if (uomId > 0) lineVals.put("product_uom", uomId);
        if (name != null && !name.isEmpty()) lineVals.put("name", name);
        if (plannedDateUtc != null && !plannedDateUtc.isEmpty()) lineVals.put("date_planned", plannedDateUtc);
        lineVals.put("price_unit", priceUnit);

        OdooUtils.executeKw(
                main.m_odooSession,
                OdooUtils.DATABASE_NAME,
                OdooUtils.SERVER_PASSWORD,
                "purchase.order.line",
                "create",
                Arrays.asList(lineVals),
                null
        );
    }

    private static void doConfirmPurchaseOrder(Main main, int poId) throws Exception {
        OdooUtils.executeKw(
                main.m_odooSession,
                OdooUtils.DATABASE_NAME,
                OdooUtils.SERVER_PASSWORD,
                "purchase.order",
                "button_confirm",
                Arrays.asList(Arrays.asList(poId)),
                null
        );
    }

    // -------------------- Incoming picking resolution --------------------
    private static void ensureIncomingPickingId(Main main, PurchaseOrderSim po) {
        try {
            if (main == null || main.m_odooSession == null || po == null)
            	return;
            
            if (po.odooPoId <= 0)
            	return;

            // If we already have a pickingId, verify it's still usable
            if (po.odooPickingId > 0) {
                String st = getPickingState(main, po.odooPickingId);
                if (st != null && ("done".equals(st) || "cancel".equals(st))) {
                    po.odooPickingId = -1;
                }
            }

            // Resolve if missing/stale
            if (po.odooPickingId <= 0) {
                int pid = resolveActiveIncomingPickingId(main, po.odooPoId);
                if (pid > 0)
                	po.odooPickingId = pid;
            }

        } catch (Exception e) {
            Logger.error("ensureIncomingPickingId failed for poId=" + (po != null ? po.odooPoId : -1), e);
        }
    }

    private static String getPickingState(Main main, int pickingId) throws Exception {
        Map<String, Object> kw = new HashMap<>();
        kw.put("fields", Arrays.asList("state"));

        Object rd = OdooUtils.executeKw(
                main.m_odooSession,
                OdooUtils.DATABASE_NAME,
                OdooUtils.SERVER_PASSWORD,
                "stock.picking",
                "read",
                Arrays.asList(Arrays.asList(pickingId)),
                kw
        );

        List<Map<String, Object>> rows = OdooUtils.asListOfMaps(rd);
        if (rows == null || rows.isEmpty())
        	return null;

        return OdooUtils.safeCastToString(rows.get(0).get("state"));
    }

    private static int resolveActiveIncomingPickingId(Main main, int poId) throws Exception {
        // Read PO picking_ids and name (name used only as fallback)
        Map<String, Object> kwPo = new HashMap<>();
        kwPo.put("fields", Arrays.asList("name", "picking_ids"));

        Object poRead = OdooUtils.executeKw(
                main.m_odooSession,
                OdooUtils.DATABASE_NAME,
                OdooUtils.SERVER_PASSWORD,
                "purchase.order",
                "read",
                Arrays.asList(Arrays.asList(poId)),
                kwPo
        );

        List<Map<String, Object>> poRows = OdooUtils.asListOfMaps(poRead);
        if (poRows == null || poRows.isEmpty())
        	return -1;

        Map<String, Object> po = poRows.get(0);
        String poName = OdooUtils.safeCastToString(po.get("name"));
        List<Integer> pickingIds = OdooUtils.asListOfInts(po.get("picking_ids"));

        // Choose newest active incoming from PO.picking_ids
        int pid = pickNewestActiveIncomingPicking(main, pickingIds);
        if (pid > 0)
        	return pid;

        // Fallback by origin (= PO name)
        if (poName != null && !poName.isEmpty()) {
            return searchActiveIncomingByOrigin(main, poName);
        }

        return -1;
    }

    private static int pickNewestActiveIncomingPicking(Main main, List<Integer> pickingIds) throws Exception {
        if (pickingIds == null || pickingIds.isEmpty())
        	return -1;

        List<Object> domain = Arrays.asList(
                Arrays.asList("id", "in", pickingIds),
                Arrays.asList("picking_type_code", "=", "incoming"),
                Arrays.asList("state", "not in", Arrays.asList("done", "cancel"))
        );

        Map<String, Object> kw = new HashMap<>();
        kw.put("fields", Arrays.asList("id", "state", "scheduled_date"));
        kw.put("order", "id desc");
        kw.put("limit", 1);

        Object res = OdooUtils.executeKw(
                main.m_odooSession,
                OdooUtils.DATABASE_NAME,
                OdooUtils.SERVER_PASSWORD,
                "stock.picking",
                "search_read",
                Arrays.asList(domain),
                kw
        );

        List<Map<String, Object>> rows = OdooUtils.asListOfMaps(res);
        if (rows == null || rows.isEmpty())
        	return -1;

        return OdooUtils.safeCastToInteger(rows.get(0).get("id"));
    }

    private static int searchActiveIncomingByOrigin(Main main, String poName) throws Exception {
        List<Object> domain = Arrays.asList(
                Arrays.asList("origin", "=", poName),
                Arrays.asList("picking_type_code", "=", "incoming"),
                Arrays.asList("state", "not in", Arrays.asList("done", "cancel"))
        );

        Map<String, Object> kw = new HashMap<>();
        kw.put("fields", Arrays.asList("id", "state"));
        kw.put("order", "id desc");
        kw.put("limit", 1);

        Object res = OdooUtils.executeKw(
                main.m_odooSession,
                OdooUtils.DATABASE_NAME,
                OdooUtils.SERVER_PASSWORD,
                "stock.picking",
                "search_read",
                Arrays.asList(domain),
                kw
        );

        List<Map<String, Object>> rows = OdooUtils.asListOfMaps(res);
        if (rows == null || rows.isEmpty())
        	return -1;

        return OdooUtils.safeCastToInteger(rows.get(0).get("id"));
    }

    // -------------------- Receipt qty-done logic (same style as SalesGateway) --------------------
    private static boolean isPickingDone(Main main, int pickingId) throws Exception {
        Map<String, Object> kw = new HashMap<>();
        kw.put("fields", Arrays.asList("state"));

        Object rd = OdooUtils.executeKw(
                main.m_odooSession,
                OdooUtils.DATABASE_NAME,
                OdooUtils.SERVER_PASSWORD,
                "stock.picking",
                "read",
                Arrays.asList(Arrays.asList(pickingId)),
                kw
        );

        List<Map<String, Object>> rows = OdooUtils.asListOfMaps(rd);
        if (rows == null || rows.isEmpty()) return false;

        String state = OdooUtils.safeCastToString(rows.get(0).get("state"));
        return "done".equals(state);
    }

    private static boolean cancelPicking(Main main, int pickingId) {
        try {
            Object ok = OdooUtils.executeKw(
                    main.m_odooSession,
                    OdooUtils.DATABASE_NAME,
                    OdooUtils.SERVER_PASSWORD,
                    "stock.picking",
                    "action_cancel",
                    Arrays.asList(Arrays.asList(pickingId)),
                    null
            );
            return Boolean.TRUE.equals(ok);
        } catch (Exception e) {
            Logger.error("cancelPicking failed pickingId=" + pickingId, e);
            return false;
        }
    }

    // -------------------- Validate picking + wizard handling --------------------
    private static void ensureDoneQuantitiesForPicking(
            Main main,
            int pickingId,
            Map<String, Integer> doneBySkuId
    ) throws Exception {

        Logger.debug("ensureDoneQuantitiesForPicking pickingId=" + pickingId + " doneBySkuId=" + doneBySkuId);

        if (main == null || main.m_odooSession == null) return;
        if (pickingId <= 0) return;
        if (doneBySkuId == null || doneBySkuId.isEmpty()) return;

        // ------------------------------------------------------------
        // 1) Map SKU -> product_id
        // ------------------------------------------------------------
        Map<Integer, Double> doneByProductId = new HashMap<>();
        for (Map.Entry<String, Integer> e : doneBySkuId.entrySet()) {
            String sku = e.getKey();
            int units = e.getValue() == null ? 0 : e.getValue();
            Integer productId = main.productIdBySkuId.get(sku);   // your mapping: SKU -> productId
            if (productId == null || productId <= 0) {
                Logger.warn("ensureDoneQuantitiesForPicking: unknown sku=" + sku + " (no productId mapping)");
                continue;
            }
            if (units <= 0) continue;
            doneByProductId.put(productId, (double) units);
        }

        if (doneByProductId.isEmpty()) {
            Logger.warn("ensureDoneQuantitiesForPicking: nothing to write (no valid product ids)");
            return;
        }

        // ------------------------------------------------------------
        // 2) Confirm + Assign (safe; may no-op)
        // ------------------------------------------------------------
        try {
            Object r = OdooUtils.executeKw(
                    main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
                    "stock.picking", "action_confirm",
                    Arrays.asList(Arrays.asList(pickingId)),
                    null
            );
            Logger.debug("ensureDoneQuantitiesForPicking: action_confirm -> " + r);
        } catch (Exception ignore) {}

        try {
            Object r = OdooUtils.executeKw(
                    main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
                    "stock.picking", "action_assign",
                    Arrays.asList(Arrays.asList(pickingId)),
                    null
            );
            Logger.debug("ensureDoneQuantitiesForPicking: action_assign -> " + r);
        } catch (Exception ignore) {}

        // NOTE:
        // Do NOT call action_set_quantities_to_reservation via XML-RPC here.
        // In many setups it returns None and triggers: "cannot marshal None unless allow_none is enabled"

        // ------------------------------------------------------------
        // 3) Read stock.moves of this picking
        // ------------------------------------------------------------
        List<Object> domainMove = Arrays.asList(Arrays.asList("picking_id", "=", pickingId));

        Map<String, Object> kwMove = new HashMap<>();
        kwMove.put("fields", Arrays.asList(
                "id", "product_id", "product_uom_qty", "quantity_done",
                "location_id", "location_dest_id", "product_uom"
        ));

        Object movesObj = OdooUtils.executeKw(
                main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
                "stock.move", "search_read",
                Arrays.asList(domainMove),
                kwMove
        );

        List<Map<String, Object>> moves = OdooUtils.asListOfMaps(movesObj);
        if (moves == null) moves = new ArrayList<>();

        // Group moves by product_id
        Map<Integer, List<Map<String, Object>>> movesByProduct = new HashMap<>();
        for (Map<String, Object> m : moves) {
            int pid = OdooUtils.m2oId(m.get("product_id"));
            movesByProduct.computeIfAbsent(pid, k -> new ArrayList<>()).add(m);
        }

        // ------------------------------------------------------------
        // 4) Write stock.move.quantity_done (helps some configs)
        //    Put all qty on first move per product, set others to 0
        // ------------------------------------------------------------
        for (Map.Entry<Integer, Double> e : doneByProductId.entrySet()) {
            int productId = e.getKey();
            double doneQty = e.getValue();

            List<Map<String, Object>> pmoves = movesByProduct.get(productId);
            if (pmoves == null || pmoves.isEmpty()) {
                Logger.warn("ensureDoneQuantitiesForPicking: no stock.move for productId=" + productId);
                continue;
            }

            boolean first = true;
            for (Map<String, Object> mv : pmoves) {
                int moveId = OdooUtils.safeCastToInteger(mv.get("id"));

                double q = first ? doneQty : 0.0;
                first = false;

                Map<String, Object> vals = new HashMap<>();
                vals.put("quantity_done", q);

                Object ok = OdooUtils.executeKw(
                        main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
                        "stock.move", "write",
                        Arrays.asList(Arrays.asList(moveId), vals),
                        null
                );

                Logger.warn("ensureDoneQuantitiesForPicking: stock.move write ok=" + ok
                        + " moveId=" + moveId + " quantity_done=" + q);
            }
        }

        // ------------------------------------------------------------
        // 5) Read stock.move.lines of this picking for these products
        // ------------------------------------------------------------
        List<Integer> productIds = new ArrayList<>(doneByProductId.keySet());
        List<Object> domainMl = Arrays.asList(
                Arrays.asList("picking_id", "=", pickingId),
                Arrays.asList("product_id", "in", productIds)
        );

        Map<String, Object> kwMl = new HashMap<>();
        kwMl.put("fields", Arrays.asList(
                "id", "product_id", "qty_done", "move_id", "picking_id",
                "location_id", "location_dest_id", "product_uom_id"
        ));

        Object mlObj = OdooUtils.executeKw(
                main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
                "stock.move.line", "search_read",
                Arrays.asList(domainMl),
                kwMl
        );

        List<Map<String, Object>> moveLines = OdooUtils.asListOfMaps(mlObj);
        if (moveLines == null) moveLines = new ArrayList<>();

        // Group move lines by product_id
        Map<Integer, List<Map<String, Object>>> linesByProduct = new HashMap<>();
        for (Map<String, Object> ml : moveLines) {
            int pid = OdooUtils.m2oId(ml.get("product_id"));
            linesByProduct.computeIfAbsent(pid, k -> new ArrayList<>()).add(ml);
        }

        // ------------------------------------------------------------
        // 6) Ensure at least 1 move line exists per product (create if missing)
        // ------------------------------------------------------------
        for (Map.Entry<Integer, Double> e : doneByProductId.entrySet()) {
            int productId = e.getKey();
            double doneQty = e.getValue();

            List<Map<String, Object>> lines = linesByProduct.get(productId);
            if (lines != null && !lines.isEmpty()) continue;

            // Create a move line using first move of that product
            List<Map<String, Object>> pmoves = movesByProduct.get(productId);
            if (pmoves == null || pmoves.isEmpty()) {
                Logger.warn("ensureDoneQuantitiesForPicking: cannot create move line; no move for productId=" + productId);
                continue;
            }

            Map<String, Object> mv = pmoves.get(0);
            int moveId = OdooUtils.safeCastToInteger(mv.get("id"));
            int locId = OdooUtils.m2oId(mv.get("location_id"));
            int locDestId = OdooUtils.m2oId(mv.get("location_dest_id"));
            int uomId = OdooUtils.m2oId(mv.get("product_uom"));

            Map<String, Object> vals = new HashMap<>();
            vals.put("picking_id", pickingId);
            vals.put("move_id", moveId);
            vals.put("product_id", productId);
            if (uomId > 0) vals.put("product_uom_id", uomId);
            if (locId > 0) vals.put("location_id", locId);
            if (locDestId > 0) vals.put("location_dest_id", locDestId);
            vals.put("qty_done", 0.0);

            Object newId = OdooUtils.executeKw(
                    main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
                    "stock.move.line", "create",
                    Arrays.asList(vals),
                    null
            );

            int mlId = OdooUtils.safeCastToInteger(newId);
            Logger.warn("ensureDoneQuantitiesForPicking: created missing move_line id=" + mlId
                    + " for productId=" + productId);

            // Refresh local structures (so next step can write qty_done)
            Map<String, Object> fake = new HashMap<>();
            fake.put("id", mlId);
            fake.put("product_id", Arrays.asList(productId, ""));
            linesByProduct.computeIfAbsent(productId, k -> new ArrayList<>()).add(fake);
        }

        // ------------------------------------------------------------
        // 7) Write stock.move.line.qty_done
        //    Put all qty on first line per product, set others to 0
        // ------------------------------------------------------------
        for (Map.Entry<Integer, Double> e : doneByProductId.entrySet()) {
            int productId = e.getKey();
            double doneQty = e.getValue();

            Logger.warn("ensureDoneQuantitiesForPicking: qty done = " + doneQty);

            List<Map<String, Object>> lines = linesByProduct.get(productId);
            if (lines == null || lines.isEmpty()) {
                Logger.warn("ensureDoneQuantitiesForPicking: No move line found for productId=" + productId);
                continue;
            }

            boolean first = true;
            for (Map<String, Object> ml : lines) {
                int mlId = OdooUtils.safeCastToInteger(ml.get("id"));
                double q = first ? doneQty : 0.0;
                first = false;

                Map<String, Object> vals = new HashMap<>();
                vals.put("qty_done", q);

                Object ok = OdooUtils.executeKw(
                        main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
                        "stock.move.line", "write",
                        Arrays.asList(Arrays.asList(mlId), vals),
                        null
                );

                Logger.warn("ensureDoneQuantitiesForPicking: move_line write ok=" + ok
                        + " mlId=" + mlId + " qty_done=" + q);

                // Readback to confirm it stuck
                Object rd = OdooUtils.executeKw(
                        main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
                        "stock.move.line", "read",
                        Arrays.asList(
                                Arrays.asList(mlId),
                                Arrays.asList("id", "qty_done", "product_id", "move_id", "picking_id")
                        ),
                        null
                );
                Logger.warn("ensureDoneQuantitiesForPicking: readback mlId=" + mlId
                        + " -> " + OdooUtils.asListOfMaps(rd));
            }
        }

        // ------------------------------------------------------------
        // 8) Final readback (keep while debugging)
        // ------------------------------------------------------------
        Object checkMoves = OdooUtils.executeKw(
                main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
                "stock.move", "search_read",
                Arrays.asList(domainMove),
                kwMove
        );
        Logger.debug("ensureDoneQuantitiesForPicking: final stock.moves=" + OdooUtils.asListOfMaps(checkMoves));

        Object checkLines = OdooUtils.executeKw(
                main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
                "stock.move.line", "search_read",
                Arrays.asList(domainMl),
                kwMl
        );
        Logger.debug("ensureDoneQuantitiesForPicking: final move_lines=" + OdooUtils.asListOfMaps(checkLines));
    }
    
    private static boolean validatePickingHandlingWizardsPreferCancelBackorder(Main main, int pickingId) throws Exception {

        // Base context for validate + wizards
        Map<String, Object> baseCtx = new HashMap<>();
        baseCtx.put("skip_sanity_check", true);

        // Ensure wizard defaults have the picking in context
        baseCtx.put("active_model", "stock.picking");
        baseCtx.put("active_id", pickingId);
        baseCtx.put("active_ids", Arrays.asList(pickingId));

        // CRITICAL for stock.immediate.transfer.process in Odoo 15/16:
        // Without this, process() may return true but does NOT close the picking,
        // so button_validate keeps returning the wizard forever.
        baseCtx.put("button_validate_picking_ids", Arrays.asList(pickingId));

        for (int guard = 0; guard < 6; guard++) {

            Logger.warn("validatePicking: guard=" + guard + " pickingId=" + pickingId);

            Map<String, Object> kwValidate = new HashMap<>();
            kwValidate.put("context", baseCtx);

            Object result = OdooUtils.executeKw(
                    main.m_odooSession,
                    OdooUtils.DATABASE_NAME,
                    OdooUtils.SERVER_PASSWORD,
                    "stock.picking",
                    "button_validate",
                    Arrays.asList(Arrays.asList(pickingId)),
                    kwValidate
            );

            // If validate returned boolean => done / failed
            if (result instanceof Boolean) {
                Logger.warn("validatePicking: button_validate returned boolean=" + result);
                return (Boolean) result;
            }

            if (!(result instanceof Map)) {
                Logger.warn("validatePicking: unexpected button_validate result=" + result);
                return false;
            }

            Map<String, Object> action = (Map<String, Object>) result;
            String resModel = OdooUtils.safeCastToString(action.get("res_model"));
            int resId = OdooUtils.safeCastToInteger(action.get("res_id"));

            Logger.warn("validatePicking: wizard action res_model=" + resModel + " res_id=" + resId);

            if (resModel == null || resModel.isEmpty()) {
                Logger.warn("validatePicking: wizard action missing res_model. action=" + action);
                return false;
            }

            // Merge action context + baseCtx
            Map<String, Object> ctx = new HashMap<>(baseCtx);
            Object ctxObj = action.get("context");
            if (ctxObj instanceof Map) {
                ctx.putAll((Map<String, Object>) ctxObj);
            }

            // Always enforce the critical keys (don’t use putIfAbsent here)
            ctx.put("active_model", "stock.picking");
            ctx.put("active_id", pickingId);
            ctx.put("active_ids", Arrays.asList(pickingId));
            ctx.put("skip_sanity_check", true);
            ctx.put("button_validate_picking_ids", Arrays.asList(pickingId));

            Map<String, Object> kw = new HashMap<>();
            kw.put("context", ctx);

            // Create wizard record if needed (IMPORTANT: attach pick_ids explicitly)
            if (resId <= 0) {
                Map<String, Object> wizardVals = new HashMap<>();

                // Most stock wizards use pick_ids = Many2many(stock.picking)
                wizardVals.put("pick_ids", Arrays.asList(Arrays.asList(6, 0, Arrays.asList(pickingId))));

                // For immediate transfer wizard, ALSO add a line so process() has work to do
                if ("stock.immediate.transfer".equals(resModel)) {
                    Map<String, Object> lineVals = new HashMap<>();
                    lineVals.put("to_immediate", true);
                    lineVals.put("picking_id", pickingId);
                    wizardVals.put("immediate_transfer_line_ids",
                            Arrays.asList(Arrays.asList(0, 0, lineVals)));
                }

                Object newId = OdooUtils.executeKw(
                        main.m_odooSession,
                        OdooUtils.DATABASE_NAME,
                        OdooUtils.SERVER_PASSWORD,
                        resModel,
                        "create",
                        Arrays.asList(wizardVals),
                        kw
                );
                resId = OdooUtils.safeCastToInteger(newId);
                Logger.warn("validatePicking: created wizard res_id=" + resId + " model=" + resModel);
            }

            if (resId <= 0) {
                Logger.warn("validatePicking: wizard missing res_id, cannot proceed. action=" + action);
                return false;
            }

            // ---- Handle known wizards ----

            if ("stock.backorder.confirmation".equals(resModel)) {

                // Prefer cancel backorder (reject remainder)
                if (tryWizardMethod(main, resModel, resId, "process_cancel_backorder", kw)) {
                    if (isPickingDone(main, pickingId)) return true;
                    continue;
                }

                // Fallback: create backorder
                OdooUtils.executeKw(
                        main.m_odooSession,
                        OdooUtils.DATABASE_NAME,
                        OdooUtils.SERVER_PASSWORD,
                        resModel,
                        "process",
                        Arrays.asList(Arrays.asList(resId)),
                        kw
                );

                if (isPickingDone(main, pickingId)) return true;
                continue;
            }

            if ("stock.immediate.transfer".equals(resModel)) {
                // Confirm immediate transfer
                OdooUtils.executeKw(
                        main.m_odooSession,
                        OdooUtils.DATABASE_NAME,
                        OdooUtils.SERVER_PASSWORD,
                        resModel,
                        "process",
                        Arrays.asList(Arrays.asList(resId)),
                        kw
                );

                if (isPickingDone(main, pickingId)) return true;
                continue;
            }

            if ("confirm.stock.sms".equals(resModel)) {
                // Don’t send SMS
                if (!tryWizardMethod(main, resModel, resId, "dont_send_sms", kw)) {
                    tryWizardMethod(main, resModel, resId, "cancel", kw);
                }

                if (isPickingDone(main, pickingId)) return true;
                continue;
            }

            Logger.warn("validatePicking: unknown wizard model=" + resModel + " action=" + action);
            return false;
        }

        Logger.warn("validatePickingHandlingWizardsPreferCancelBackorder: too many wizard loops for pickingId=" + pickingId);
        return false;
    }

    private static boolean tryWizardMethod(Main main, String model, int resId, String method, Map<String, Object> kw) {
        try {
            Object r = OdooUtils.executeKw(
                    main.m_odooSession,
                    OdooUtils.DATABASE_NAME,
                    OdooUtils.SERVER_PASSWORD,
                    model,
                    method,
                    Arrays.asList(Arrays.asList(resId)),
                    kw
            );
            Logger.warn("validatePicking: wizard " + model + "." + method + " resId=" + resId + " -> " + r);
            return true;
        } catch (Exception ex) {
            Logger.warn("validatePicking: wizard " + model + "." + method + " failed resId=" + resId + " err=" + ex.getMessage());
            return false;
        }
    }
    
    private static String simDateTime(Main main, double simSec) {
        return DateTimeUtil.convertSimulationTimeToDate(
                main.getEngine().getStartDate(),
                simSec,
                false
        );
    }

    // -------------------- Product meta (to make PO line creation reliable) --------------------

    private static class ProductPurchaseMeta {
        int uomId;
        String displayName;
        double standardPrice;
    }

    private static ProductPurchaseMeta readProductPurchaseMeta(Main main, int productId) {
        try {
            Map<String, Object> kw = new HashMap<>();
            kw.put("fields", Arrays.asList("display_name", "uom_po_id", "uom_id", "standard_price"));

            Object rd = OdooUtils.executeKw(
                    main.m_odooSession,
                    OdooUtils.DATABASE_NAME,
                    OdooUtils.SERVER_PASSWORD,
                    "product.product",
                    "read",
                    Arrays.asList(Arrays.asList(productId)),
                    kw
            );

            List<Map<String, Object>> rows = OdooUtils.asListOfMaps(rd);
            if (rows == null || rows.isEmpty())
            	return null;

            Map<String, Object> r = rows.get(0);

            ProductPurchaseMeta m = new ProductPurchaseMeta();
            m.displayName = OdooUtils.safeCastToString(r.get("display_name"));
            m.uomId = OdooUtils.m2oId(r.get("uom_id"));
            m.standardPrice = OdooUtils.safeCastToDouble(r.get("standard_price"));
            return m;

        } catch (Exception ex) {
            Logger.warn("readProductPurchaseMeta failed productId=", productId, " err=", ex.getMessage());
            return null;
        }
    }
}
