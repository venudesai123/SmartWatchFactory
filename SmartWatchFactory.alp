					<BasicProperties Width="140" Height="30">
                        <EmbeddedIcon>false</EmbeddedIcon>	
						<TextColor>-16777216</TextColor>
						<Enabled>true</Enabled>
						<ActionCode><![CDATA[for (Picker p : rmPickers) {
	if (!p.isIdle()) {
		p.cancelJob("manual cancel");
		Logger.info("Manually cancelled picker ", p.getIndex());
		return;
	}
}
Logger.info("No active picker to cancel.");
]]></ActionCode>
					</BasicProperties>
