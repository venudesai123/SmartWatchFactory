		<JavaClass>
			<Id>1764710592746</Id>
			<Name><![CDATA[FgSlot]]></Name>
			<Folder>1771726185934</Folder>
			<Text><![CDATA[/**
 * FgSlot (recommended final)
 *
 * Semantics:
 * - units			= available FG units across all trays in this slot
 * - reservedUnits	= reserved FG units for outbound pick across trays
 * - incomingUnits	= incoming FG units for inbound stowing (trays in-flight)
 * - incomingTrays	= number of incoming trays in-flight
 *
 * - trays			= tray Resources currently stored in this slot
 */
import java.util.*;

public class FgSlot {

    public String skuId;               // e.g. "MET"
    public FG_SKU skuType;   // MET/FW/FB
    
    public int rackIdx;
    public int row, cell, level, deep;

    public final Deque<Resource> trays = new ArrayDeque<>();

    public int units = 0;
    public int reservedUnits = 0;

    public int incomingUnits = 0;		// incoming UNITS
    public int incomingTrays = 0;		// incoming TRAY COUNT
    
    public RackSystem rackSystem = null; 
    public boolean emptyRemovalInFlight = false;
    
    public FgSlot(RackSystem rs, FG_SKU skuType, String skuId,
                  int row, int cell, int level, int deep) {
        this.rackSystem = rs;
    	this.skuId = skuId;
        this.skuType = skuType;
        this.rackIdx = skuType.ordinal();
        this.row = row;
        this.cell = cell;
        this.level = level;
        this.deep = deep;        
        recalc();
    }

    // --------------------------
    // Capacity
    // --------------------------
    public int occupiedUnits() {
        return Math.max(0, units) + Math.max(0, reservedUnits) + Math.max(0, incomingUnits);
    }

    public int freeUnitCapacity() {
        return Math.max(0, Constants.FG_MAX_UNITS_PER_SLOT - occupiedUnits());
    }

    public int maxTraysForCell() {
        int traySize = Math.max(1, Constants.TRAY_SIZE);
        return Math.max(1, Constants.FG_MAX_UNITS_PER_SLOT / traySize);
    }

    public int freeTrayCapacity() {
        return maxTraysForCell() - (trays.size() + incomingTrays);
    }

    // --------------------------
    // Incoming reservation helpers (stowing)
    // --------------------------
    public void reserveIncomingTray(int trayUnits) {
        incomingTrays += 1;
        incomingUnits += Math.max(0, trayUnits);
    }

    public void rollbackIncomingTray(int trayUnits, String reason) {
        if (incomingTrays <= 0) {
            Logger.warn("FG incomingTrays underflow rollback sku=", skuId, " reason=", reason);
        }
        incomingTrays = Math.max(0, incomingTrays - 1);

        int dec = Math.max(0, trayUnits);
        if (incomingUnits < dec) {
            Logger.warn("FG incoming(units) underflow rollback sku=", skuId,
                    " incoming=", incomingUnits, " dec=", dec, " reason=", reason);
        }
        incomingUnits = Math.max(0, incomingUnits - dec);
    }

    // --------------------------
    // Picking: reserve exact IDs from trays
    // --------------------------
    public List<Integer> reserveIdsFromTrays(int want, List<FgPickAlloc> allocOut) {
        ArrayList<Integer> all = new ArrayList<>();
        if (want <= 0) return all;

        int remaining = want;

        for (Resource trRes : trays) {
            if (remaining <= 0) break;
            if (trRes == null) continue;

            Tray t = trRes.getTray();
            if (t == null) continue;

            List<Integer> ids = t.reserveIds(remaining);
            if (ids == null || ids.isEmpty()) continue;

            all.addAll(ids);
            if (allocOut != null) allocOut.add(new FgPickAlloc(trRes, ids));

            remaining -= ids.size();
        }

        recalc();
        return all;
    }

    // --------------------------
    // Recalc from actual Trays
    // --------------------------
    public void recalc() {
        int u = 0, r = 0;

        for (Resource trRes : trays) {
            Tray t = trRes.getTray();
            if (t == null) continue;

            u += t.availableUnits();
            r += t.reservedUnits();
        }

        this.units = u;
        this.reservedUnits = r;
    }

    @Override
    public String toString() {
        return "FG[row=" + row + " cell=" + cell + " L=" + level + " D=" + deep +
                " sku=" + skuId +
                " units=" + units + " reserved=" + reservedUnits +
                " inU=" + incomingUnits + " inT=" + incomingTrays +
                " trays=" + trays.size() + "]";
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1765059407154</Id>
			<Name><![CDATA[OdooSalesGateway]]></Name>
			<Folder>1771290666693</Folder>
			<Text><![CDATA[/**
 * OdooSalesGateway
 *
 * Handles sale.order + outgoing stock.picking for CustomerOrder.
 */
import java.util.*;

public final class OdooSalesGateway {

    // ---------- Public API ----------

    /** Create a sale.order & sale.order.line in Odoo for this CustomerOrder. */
	public static void createSaleOrderForCustomer(Main main, CustomerOrder co) {
	    try {
	        if (main == null || main.m_odooSession == null || co == null || co.distributor == null)
	            return;

	        // Already created
	        if (co.saleOrderId > 0)
	            return;

	        // Make sure we have some lines to send to Odoo.
	        // If lines is empty but fgSku/qty is set, build a single line for backward compatibility.
	        List<CustomerOrderLine> lines = co.lines;
	        if (lines == null || lines.isEmpty()) {
	        	Logger.warn("OdooSalesGateway: customer order has no lines: ", co);
	            return;
	        }

	        // Resolve partner (Odoo customer) from distributor
	        int partnerId = co.distributor.id;
	        if (partnerId <= 0) {
	            Logger.warn("OdooSalesGateway: distributor has no partnerId for ", co);
	            return;
	        }

	        // Create sale.order
	        int soId = doCreateSaleOrder(main, co, partnerId);
	        if (soId <= 0) {
	            Logger.warn("OdooSalesGateway: doCreateSaleOrder returned invalid id for ", co);
	            return;
	        }
	        co.saleOrderId = soId;

	        // Create sale.order.line rows for each line in the order
	        int totalQty = 0;
	        int createdLines = 0;

	        for (CustomerOrderLine line : lines) {
	            if (line == null || line.sku == null || line.qty <= 0)
	                continue;

	            String skuId = (line.skuId != null && !line.skuId.isEmpty())
	                    ? line.skuId
	                    : line.sku.skuId();

	            Integer productId = main.saleableProductIdBySkuId.get(skuId);
	            if (productId == null || productId <= 0) {
	                Logger.warn("OdooSalesGateway: No saleable product_id for FG skuId=", skuId,
	                            " in customer order ", co);
	                continue;
	            }

	            doCreateSaleOrderLine(main, soId, productId, line.qty, line);
	            totalQty += line.qty;
	            createdLines++;
	        }

	        if (createdLines == 0) {
	            Logger.warn("OdooSalesGateway: all lines for ", co,
	                        " had invalid productId/qty; not confirming sale.order.");
	            return;
	        }

	        // Read back SO name and store in co.orderName (for logs + picking lookup)
	        String soName = readSaleOrderName(main, soId);
	        if (soName != null && !soName.isEmpty()) {
	            co.orderName = soName;
	        }

	        Logger.info("OdooSalesGateway: created sale.order ", soId,
	                    " for ", co,
	                    " partnerId=", partnerId,
	                    " lines=", createdLines,
	                    " totalQty=", totalQty);

	        // Confirm SO so that Odoo generates an outgoing picking
	        doConfirmSaleOrder(main, soId, co);

	        // Optionally: resolve outgoing picking now
	        ensureOutgoingPickingId(main, co);

	    } catch (Exception e) {
	        Logger.error("OdooSalesGateway.createSaleOrderForCustomer failed for " + co, e);
	    }
	}
	
	public static boolean shipCustomerOrder(Main main, CustomerOrder co) {
	    try {
	        if (main == null || main.m_odooSession == null || co == null)
	        	return false;
	        
	        if (co.saleOrderId <= 0)
	        	return false;

	        ensureOutgoingPickingId(main, co);
	        if (co.pickingId <= 0)
	        	return false;

	        // If already done -> idempotent success
	        if (isPickingDone(main, co.pickingId))
	        	return true;

	        // Build desired quantities from the order
	        Map<Integer, Double> desiredByProduct = buildDesiredQtyByProduct(main, co);
	        if (desiredByProduct.isEmpty()) {
	            Logger.warn("shipCustomerOrder: desiredByProduct empty for ", co);
	            return false;
	        }

	        // Reserve
	        OdooUtils.executeKw(
	            main.m_odooSession,
	            OdooUtils.DATABASE_NAME,
	            OdooUtils.SERVER_PASSWORD,
	            "stock.picking",
	            "action_assign",
	            Arrays.asList(Arrays.asList(co.pickingId)),
	            null
	        );

	        // If nothing done yet, force qty_done/quantity_done from our order quantities
	        forceDoneQuantitiesIfNeeded(main, co.pickingId, desiredByProduct);

	        // Validate & handle wizards
	        boolean validated = validatePickingHandlingWizards(main, co.pickingId);
	        
	        if (validated) {
	        	// Actual completion time = simulation ship moment
	        	String simNow = DateTimeUtil.convertSimulationTimeToDate(
	        	        main.getEngine().getStartDate(),
	        	        main.time(),
	        	        false
	        	);

	        	Map<String, Object> vals = new HashMap<>();
	        	vals.put("date_done", simNow);

	        	OdooUtils.executeKw(
	        	    main.m_odooSession,
	        	    OdooUtils.DATABASE_NAME,
	        	    OdooUtils.SERVER_PASSWORD,
	        	    "stock.picking",
	        	    "write",
	        	    Arrays.asList(Arrays.asList(co.pickingId), vals),
	        	    null
	        	);
	        }
	        
	        return validated;
	    } catch (Exception e) {
	        Logger.error("shipCustomerOrder failed for " + co, e);
	        return false;
	    }
	}
	
	private static Map<Integer, Double> buildDesiredQtyByProduct(Main main, CustomerOrder co) {
	    Map<Integer, Double> desired = new HashMap<>();
	    if (co == null || co.lines == null)
	    	return desired;

	    for (CustomerOrderLine line : co.lines) {
	        if (line == null || line.qty <= 0)
	        	continue;

	        String skuId = (line.skuId != null && !line.skuId.isEmpty())
	            ? line.skuId
	            : (line.sku != null ? line.sku.skuId() : null);

	        if (skuId == null)
	        	continue;

	        Integer productId = main.saleableProductIdBySkuId.get(skuId);
	        if (productId == null || productId <= 0) {
	            Logger.warn("buildDesiredQtyByProduct: no productId for skuId=", skuId, " co=", co);
	            continue;
	        }

	        desired.merge(productId, (double) line.qty, Double::sum);
	    }
	    return desired;
	}

	private static void forceDoneQuantitiesIfNeeded(Main main, int pickingId, Map<Integer, Double> desiredByProduct) throws Exception {
	    if (desiredByProduct == null || desiredByProduct.isEmpty())
	    	return;

	    // If any qty already done, don’t override (prevents double-shipping)
	    if (hasAnyDone(main, pickingId))
	    	return;

	    // Try writing qty_done on move lines (if they exist)
	    boolean changed = setQtyDoneOnMoveLines(main, pickingId, desiredByProduct);

	    // If still leftover (or no move lines exist), write quantity_done on stock.moves
	    if (!changed) {
	        setQuantityDoneOnMoves(main, pickingId, desiredByProduct);
	    }
	}

	private static boolean hasAnyDone(Main main, int pickingId) throws Exception {
	    // Check move lines first
	    List<Object> domain = Arrays.asList(Arrays.asList("picking_id", "=", pickingId));
	    Map<String, Object> kw = new HashMap<>();
	    kw.put("fields", Arrays.asList("id", "qty_done"));
	    kw.put("limit", 1);

	    Object mlRes = OdooUtils.executeKw(
	        main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
	        "stock.move.line", "search_read",
	        Arrays.asList(domain), kw
	    );

	    List<Map<String, Object>> mlRows = OdooUtils.asListOfMaps(mlRes);
	    if (mlRows != null && !mlRows.isEmpty()) {
	        double done = OdooUtils.safeCastToDouble(mlRows.get(0).get("qty_done"));
	        if (done > 1e-12) return true;
	    }

	    // Check moves
	    Map<String, Object> kwMv = new HashMap<>();
	    kwMv.put("fields", Arrays.asList("id", "quantity_done"));
	    kwMv.put("limit", 1);

	    Object mvRes = OdooUtils.executeKw(
	        main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
	        "stock.move", "search_read",
	        Arrays.asList(domain), kwMv
	    );

	    List<Map<String, Object>> mvRows = OdooUtils.asListOfMaps(mvRes);
	    if (mvRows != null && !mvRows.isEmpty()) {
	        double done = OdooUtils.safeCastToDouble(mvRows.get(0).get("quantity_done"));
	        if (done > 1e-12) return true;
	    }

	    return false;
	}

	private static boolean setQtyDoneOnMoveLines(Main main, int pickingId, Map<Integer, Double> desiredByProduct) throws Exception {
	    List<Object> domain = Arrays.asList(Arrays.asList("picking_id", "=", pickingId));

	    Map<String, Object> kw = new HashMap<>();
	    kw.put("fields", Arrays.asList("id", "product_id", "qty_done"));
	    kw.put("limit", 1000);

	    Object res = OdooUtils.executeKw(
	        main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
	        "stock.move.line", "search_read",
	        Arrays.asList(domain), kw
	    );

	    List<Map<String, Object>> rows = OdooUtils.asListOfMaps(res);
	    if (rows == null || rows.isEmpty()) return false;

	    Map<Integer, Double> remaining = new HashMap<>(desiredByProduct);
	    boolean changed = false;

	    for (Map<String, Object> r : rows) {
	        int mlId = OdooUtils.safeCastToInteger(r.get("id"));
	        int pid = OdooUtils.m2oId(r.get("product_id"));
	        if (mlId <= 0 || pid <= 0) continue;

	        double left = remaining.getOrDefault(pid, 0.0);
	        if (left <= 1e-12) continue;

	        // No reservation? Still OK to set qty_done here to force transfer.
	        double addNow = left;

	        Map<String, Object> w = new HashMap<>();
	        w.put("qty_done", addNow);

	        Object ok = OdooUtils.executeKw(
	            main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
	            "stock.move.line", "write",
	            Arrays.asList(Arrays.asList(mlId), w),
	            null
	        );

	        if (Boolean.TRUE.equals(ok)) {
	            remaining.put(pid, 0.0);
	            changed = true;
	        }
	    }

	    return changed;
	}

	private static void setQuantityDoneOnMoves(Main main, int pickingId, Map<Integer, Double> desiredByProduct) throws Exception {
	    List<Object> domain = Arrays.asList(
	        Arrays.asList("picking_id", "=", pickingId),
	        Arrays.asList("state", "not in", Arrays.asList("done", "cancel"))
	    );

	    Map<String, Object> kw = new HashMap<>();
	    kw.put("fields", Arrays.asList("id", "product_id", "product_uom_qty", "quantity_done"));
	    kw.put("limit", 1000);

	    Object res = OdooUtils.executeKw(
	        main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
	        "stock.move", "search_read",
	        Arrays.asList(domain), kw
	    );

	    List<Map<String, Object>> moves = OdooUtils.asListOfMaps(res);
	    if (moves == null || moves.isEmpty()) return;

	    Map<Integer, Double> remaining = new HashMap<>(desiredByProduct);

	    for (Map<String, Object> mv : moves) {
	        int moveId = OdooUtils.safeCastToInteger(mv.get("id"));
	        int pid = OdooUtils.m2oId(mv.get("product_id"));
	        if (moveId <= 0 || pid <= 0) continue;

	        double left = remaining.getOrDefault(pid, 0.0);
	        if (left <= 1e-12) continue;

	        double req = OdooUtils.safeCastToDouble(mv.get("product_uom_qty"));
	        double done = OdooUtils.safeCastToDouble(mv.get("quantity_done"));
	        double room = req - done;
	        if (room <= 1e-12) continue;

	        double addNow = Math.min(left, room);

	        Map<String, Object> w = new HashMap<>();
	        w.put("quantity_done", done + addNow);

	        Object ok = OdooUtils.executeKw(
	            main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
	            "stock.move", "write",
	            Arrays.asList(Arrays.asList(moveId), w),
	            null
	        );

	        if (Boolean.TRUE.equals(ok)) {
	            remaining.put(pid, left - addNow);
	        }
	    }
	}

	private static boolean isPickingDone(Main main, int pickingId) throws Exception {
	    Map<String, Object> kw = new HashMap<>();
	    kw.put("fields", Arrays.asList("state"));

	    Object rd = OdooUtils.executeKw(
	        main.m_odooSession,
	        OdooUtils.DATABASE_NAME,
	        OdooUtils.SERVER_PASSWORD,
	        "stock.picking",
	        "read",
	        Arrays.asList(Arrays.asList(pickingId)),
	        kw
	    );

	    List<Map<String, Object>> rows = OdooUtils.asListOfMaps(rd);
	    if (rows == null || rows.isEmpty())
	    	return false;

	    String state = OdooUtils.safeCastToString(rows.get(0).get("state"));
	    return "done".equals(state);
	}
	
	private static boolean validatePickingHandlingWizards(Main main, int pickingId) throws Exception {

	    // Guard against infinite wizard loops
	    for (int guard = 0; guard < 6; guard++) {

	        Object result = OdooUtils.executeKw(
	            main.m_odooSession,
	            OdooUtils.DATABASE_NAME,
	            OdooUtils.SERVER_PASSWORD,
	            "stock.picking",
	            "button_validate",
	            Arrays.asList(Arrays.asList(pickingId)),
	            null
	        );

	        // Done / failed
	        if (result instanceof Boolean) {
	            return (Boolean) result;
	        }

	        // Wizard action dict
	        if (!(result instanceof Map)) {
	            Logger.warn("Unexpected button_validate result for pickingId=", pickingId, " -> ", result);
	            return false;
	        }

	        Map<String, Object> action = OdooUtils.asMap(result);
	        String resModel = OdooUtils.safeCastToString(action.get("res_model"));
	        int resId = OdooUtils.safeCastToInteger(action.get("res_id"));

	        Map<String, Object> kw = new HashMap<>();
	        Object ctxObj = action.get("context");
	        if (ctxObj instanceof Map) {
	            kw.put("context", (Map<String, Object>) ctxObj);
	        }

	        if (resModel == null || resModel.isEmpty() || resId <= 0) {
	            Logger.warn("Wizard returned but missing res_model/res_id. pickingId=", pickingId, " action=", action);
	            return false;
	        }

	        String method;

	        if ("stock.immediate.transfer".equals(resModel)) {
	            method = "process";

	        } else if ("stock.backorder.confirmation".equals(resModel)) {
	            // If you ever hit this, you can choose:
	            // method = "process"; // create backorder
	            method = "process";   // keep default for now

	        } else if ("confirm.stock.sms".equals(resModel)) {
	            // This wizard uses send_sms / dont_send_sms, NOT process
	            // If you want to send SMS: method = "send_sms" (needs credits/config)
	            method = "dont_send_sms";

	        } else {
	            Logger.warn("Unknown wizard model from button_validate: ", resModel, " pickingId=", pickingId);
	            return false;
	        }

	        OdooUtils.executeKw(
	            main.m_odooSession,
	            OdooUtils.DATABASE_NAME,
	            OdooUtils.SERVER_PASSWORD,
	            resModel,
	            method,
	            Arrays.asList(Arrays.asList(resId)),
	            kw
	        );

	        // Loop again: after wizard action, validate may still require another step
	    }

	    Logger.warn("validatePickingHandlingWizards: too many wizard loops for pickingId=", pickingId);
	    return false;
	}

    // ---------- Private helpers ----------
    private static int doCreateSaleOrder(Main main, CustomerOrder co, int partnerId) {
        try {        	
        	Map<String, Object> soVals = new HashMap<>();
            soVals.put("partner_id", partnerId);

            if (co.externalRef != null && !co.externalRef.isEmpty()) {
                soVals.put("client_order_ref", co.externalRef);
            }
            
            String simCreatedAt = DateTimeUtil.convertSimulationTimeToDate(
        			main.getEngine().getStartDate(),
        			co.createdAt,
        			false);
            soVals.put("date_order", simCreatedAt);
            
            // Promise to customer (ATP)
            if (co.atpPromisedDeliveryAt > 0) {
                String commitUtc = DateTimeUtil.convertSimulationTimeToDate(
                        main.getEngine().getStartDate(),
                        co.atpPromisedDeliveryAt,
                        false
                );
                soVals.put("commitment_date", commitUtc);
            }
            
            Object soIdObj = OdooUtils.executeKw(
                    main.m_odooSession,
                    OdooUtils.DATABASE_NAME,
                    OdooUtils.SERVER_PASSWORD,
                    "sale.order",
                    "create",
                    Arrays.asList(soVals),
                    null
            );
            return OdooUtils.safeCastToInteger(soIdObj);
        } catch (Exception e) {
        	Logger.warn("doCreateSaleOrder failed", e);
        	return -1;
        }
    }

    private static void doCreateSaleOrderLine(Main main, int soId, int productId, int qty, CustomerOrderLine line) {
		try {
			Map<String, Object> lineVals = new HashMap<>();
			lineVals.put("order_id", soId);
			lineVals.put("product_id", productId);
			lineVals.put("product_uom_qty", qty);
			
			String name = "FG";
			if (line != null && line.sku != null) 
				name = line.sku.skuId();
			
			lineVals.put("name", name); // Optional: set description or other fields if you want
			
			OdooUtils.executeKw(
					main.m_odooSession,
					OdooUtils.DATABASE_NAME,
					OdooUtils.SERVER_PASSWORD,
					"sale.order.line",
					"create",
					Arrays.asList(lineVals),
					null
			);
		} catch (Exception e) {
			Logger.warn("doCreateSaleOrderLine failed", e);
		}
	}
    
    private static void doConfirmSaleOrder(Main main, int soId, CustomerOrder co) {
        try {
            // Confirm (Odoo may overwrite date_order here)
            OdooUtils.executeKw(
                    main.m_odooSession,
                    OdooUtils.DATABASE_NAME,
                    OdooUtils.SERVER_PASSWORD,
                    "sale.order",
                    "action_confirm",
                    Arrays.asList(Arrays.asList(soId)),
                    null
            );

            // Re-apply simulation dates (IMPORTANT: fixes UI "Order Date")
            if (co != null) {
                Map<String, Object> vals = new HashMap<>();

                String orderUtc = DateTimeUtil.convertSimulationTimeToDate(
                        main.getEngine().getStartDate(),
                        co.createdAt,
                        false
                );
                vals.put("date_order", orderUtc);

                // If you have ATP promise, use it; otherwise keep existing commitment_date
                double promised = (co.atpPromisedDeliveryAt > 0) ? co.atpPromisedDeliveryAt : 0;
                if (promised > 0) {
                    String commitUtc = DateTimeUtil.convertSimulationTimeToDate(
                            main.getEngine().getStartDate(),
                            promised,
                            false
                    );
                    vals.put("commitment_date", commitUtc);
                }

                OdooUtils.executeKw(
                        main.m_odooSession,
                        OdooUtils.DATABASE_NAME,
                        OdooUtils.SERVER_PASSWORD,
                        "sale.order",
                        "write",
                        Arrays.asList(Arrays.asList(soId), vals),
                        null
                );
            }

        } catch (Exception e) {
            Logger.warn("doConfirmSaleOrder failed", e);
        }
    }

    private static String readSaleOrderName(Main main, int soId) {
    	try {
    		Map<String, Object> kw = new HashMap<>();
            kw.put("fields", Arrays.asList("name"));

            Object rd = OdooUtils.executeKw(
                    main.m_odooSession,
                    OdooUtils.DATABASE_NAME,
                    OdooUtils.SERVER_PASSWORD,
                    "sale.order",
                    "read",
                    Arrays.asList(Arrays.asList(soId)),
                    kw
            );
            List<java.util.Map<String, Object>> rows = OdooUtils.asListOfMaps(rd);
            if (rows.isEmpty())
                return null;

            return OdooUtils.safeCastToString(rows.get(0).get("name"));
    	} catch (Exception e) {
    		Logger.warn("readSaleOrderName failed", e);
    		return null;
    	}
    }
    
    /** Make sure co.pickingId is set for the outgoing stock.picking, if possible.
     *  Also writes scheduled_date ONLY ONCE (from ATP), to avoid repeated RPC writes.
     */
    private static void ensureOutgoingPickingId(Main main, CustomerOrder co) {
        if (main == null || main.m_odooSession == null || co == null)
            return;

        try {
            if (co.saleOrderId <= 0)
                return;

            // ------------------------------------------------------------------
            // 1) If we already have a pickingId, verify it's still usable
            // ------------------------------------------------------------------
            if (co.pickingId > 0) {

                String st = getPickingState(main, co.pickingId);

                // If stale -> force re-resolve
                if (st != null && ("done".equals(st) || "cancel".equals(st))) {
                    co.pickingId = -1;

                    // If picking became stale, allow scheduled_date to be written again
                    // for the newly resolved picking (backorder/new picking).
                    co.odooScheduledDateWritten = false;
                } else {
                    // picking is active -> write scheduled_date once if not written
                    writePickingScheduledDateOnce(main, co);
                    return; // nothing else to do
                }
            }

            // ------------------------------------------------------------------
            // 2) Resolve if missing (or became stale)
            // ------------------------------------------------------------------
            if (co.pickingId <= 0) {
                int pid = resolveActiveOutgoingPickingId(main, co.saleOrderId);
                if (pid > 0) {
                    co.pickingId = pid;

                    // Newly resolved picking -> push scheduled_date once (if ATP is available)
                    writePickingScheduledDateOnce(main, co);
                } else {
                    Logger.warn("ensureOutgoingPickingId: no active outgoing picking for soId=", co.saleOrderId, " co=", co);
                }
            }

        } catch (Exception e) {
            Logger.error("ensureOutgoingPickingId failed for " + co, e);
        }
    }

    /** Writes stock.picking.scheduled_date from ATP only once (per CO/picking) */
    private static void writePickingScheduledDateOnce(Main main, CustomerOrder co) throws Exception {
        if (co == null || co.pickingId <= 0)
            return;

        // If we already wrote it once for this picking, don't spam write again
        if (co.odooScheduledDateWritten)
            return;

        // Only write if we actually have an ATP planned value
        if (co.atpPickScheduledAt <= 0)
            return;

        String scheduledUtc = DateTimeUtil.convertSimulationTimeToDate(
                main.getEngine().getStartDate(),
                co.atpShipScheduledAt, // co.atpPickScheduledAt,
                false
        );

        Map<String, Object> vals = new HashMap<>();
        vals.put("scheduled_date", scheduledUtc);

        Object ok = OdooUtils.executeKw(
                main.m_odooSession,
                OdooUtils.DATABASE_NAME,
                OdooUtils.SERVER_PASSWORD,
                "stock.picking",
                "write",
                Arrays.asList(Arrays.asList(co.pickingId), vals),
                null
        );

        // Mark written only if RPC succeeded (be strict)
        if (Boolean.TRUE.equals(ok)) {
            co.odooScheduledDateWritten = true;
        }
    }
    
    private static String getPickingState(Main main, int pickingId) throws Exception {
        Map<String, Object> kw = new HashMap<>();
        kw.put("fields", Arrays.asList("state"));

        Object rd = OdooUtils.executeKw(
            main.m_odooSession,
            OdooUtils.DATABASE_NAME,
            OdooUtils.SERVER_PASSWORD,
            "stock.picking",
            "read",
            Arrays.asList(Arrays.asList(pickingId)),
            kw
        );

        List<Map<String, Object>> rows = OdooUtils.asListOfMaps(rd);
        if (rows == null || rows.isEmpty())
        	return null;

        return OdooUtils.safeCastToString(rows.get(0).get("state"));
    }
    
    private static int resolveActiveOutgoingPickingId(Main main, int soId) throws Exception {
        // 1) read SO picking_ids and name (name used only as fallback)
        Map<String, Object> kwSo = new HashMap<>();
        kwSo.put("fields", Arrays.asList("name", "picking_ids"));

        Object soRead = OdooUtils.executeKw(
            main.m_odooSession,
            OdooUtils.DATABASE_NAME,
            OdooUtils.SERVER_PASSWORD,
            "sale.order",
            "read",
            Arrays.asList(Arrays.asList(soId)),
            kwSo
        );

        List<Map<String, Object>> soRows = OdooUtils.asListOfMaps(soRead);
        if (soRows == null || soRows.isEmpty()) return -1;

        Map<String, Object> so = soRows.get(0);
        String soName = OdooUtils.safeCastToString(so.get("name"));
        List<Integer> pickingIds = OdooUtils.asListOfInts(so.get("picking_ids"));

        // 2) choose newest active outgoing from SO.picking_ids
        int pid = pickNewestActiveOutgoingPicking(main, pickingIds);
        if (pid > 0) return pid;

        // 3) fallback only if picking_ids empty or all done/cancel
        if (soName != null && !soName.isEmpty()) {
            return searchActiveOutgoingByOrigin(main, soName);
        }

        return -1;
    }

    private static int pickNewestActiveOutgoingPicking(Main main, List<Integer> pickingIds) throws Exception {
        if (pickingIds == null || pickingIds.isEmpty()) return -1;

        List<Object> domain = Arrays.asList(
            Arrays.asList("id", "in", pickingIds),
            Arrays.asList("picking_type_code", "=", "outgoing"),
            Arrays.asList("state", "not in", Arrays.asList("done", "cancel"))
        );

        Map<String, Object> kw = new HashMap<>();
        kw.put("fields", Arrays.asList("id", "state", "scheduled_date"));
        kw.put("order", "id desc"); // newest first (works well with backorders)
        kw.put("limit", 1);

        Object res = OdooUtils.executeKw(
            main.m_odooSession,
            OdooUtils.DATABASE_NAME,
            OdooUtils.SERVER_PASSWORD,
            "stock.picking",
            "search_read",
            Arrays.asList(domain),
            kw
        );

        List<Map<String, Object>> rows = OdooUtils.asListOfMaps(res);
        if (rows == null || rows.isEmpty()) return -1;
        return OdooUtils.safeCastToInteger(rows.get(0).get("id"));
    }

    private static int searchActiveOutgoingByOrigin(Main main, String soName) throws Exception {
        List<Object> domain = Arrays.asList(
            Arrays.asList("origin", "=", soName),
            Arrays.asList("picking_type_code", "=", "outgoing"),
            Arrays.asList("state", "not in", Arrays.asList("done", "cancel"))
        );

        Map<String, Object> kw = new HashMap<>();
        kw.put("fields", Arrays.asList("id", "state"));
        kw.put("order", "id desc");
        kw.put("limit", 1);

        Object res = OdooUtils.executeKw(
            main.m_odooSession,
            OdooUtils.DATABASE_NAME,
            OdooUtils.SERVER_PASSWORD,
            "stock.picking",
            "search_read",
            Arrays.asList(domain),
            kw
        );

        List<Map<String, Object>> rows = OdooUtils.asListOfMaps(res);
        if (rows == null || rows.isEmpty()) return -1;
        return OdooUtils.safeCastToInteger(rows.get(0).get("id"));
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1765492571425</Id>
			<Name><![CDATA[CustomerOrderLine]]></Name>
			<Folder>1771726185934</Folder>
			<Text><![CDATA[/**
 * CustomerOrderLine
 */

public class CustomerOrderLine {
	public FG_SKU sku;
    public String skuId;
    public int boxes;
    public int unitsPerBox;
    public int qty;

    public CustomerOrderLine(FG_SKU sku, String skuId, int boxes, int upb) {
        this.sku = sku;
        this.skuId = skuId;
        this.boxes = boxes;
        this.unitsPerBox = upb;
        this.qty = boxes <= 0 || unitsPerBox <= 0 ? 0 : boxes * unitsPerBox;
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1765538269571</Id>
			<Name><![CDATA[CustomerOrderPackStation]]></Name>
			<Folder>1771726185934</Folder>
			<Text><![CDATA[/**
 * CustomerOrderPackStation
 */	
public class CustomerOrderPackStation {
	public int index;
    public PointNode node;                       // packStation1Node / 2 / 3

    public LinkedList<CustomerOrder> queue = new LinkedList<>();
    public CustomerOrder current = null;
    public double finishTime = -1;              // packing completion time

    public CustomerOrderPackStation(int index, PointNode node) {
        this.index = index;
        this.node = node;
    }

    public boolean isBusy() {
        return current != null;
    }
}]]></Text>
