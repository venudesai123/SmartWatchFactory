		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1766266205857</Id>
			<Name><![CDATA[RoutingService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * RoutingService
 * 
 * skeleton to help split Main's Additional class code into services.
 * Purpose: SelectOutput routing helpers + workcenter output lists (ASSEMBLY_OUTS/SOFTWARE_OUTS/PACKAGE_OUTS/BATCH_OUTS).
 */	
public class RoutingService {
	private final Main main;
	
	public RoutingService(Main main) {
        this.main = main;
    }
	
	private static int findMin(int[] arr) {
	    // Check if the array is empty to prevent errors
	    if (arr == null || arr.length == 0) {
	        throw new IllegalArgumentException("Load Array is empty or null");
	    }
	    
	    // Initialize the minimum value with the first element
	    int min = arr[0];
	    
	    // Iterate over the array to find the minimum
	    for (int i = 1; i < arr.length; i++) {
	        if (arr[i] < min) {
	            min = arr[i];  // Update min if a smaller value is found
	        }
	    }
	    
	    return min;  // Return the minimum value found
	}
	
	public SelectOutputOut<WipUnit> chooseAsmOut(Agent a) {
		// Pick the least loaded assembly line    
	    int[] load = {
			main.qAsm1.size() + main.srvAsm1.delaySize() + main.inTransitAsm[0],
			main.qAsm2.size() + main.srvAsm2.delaySize() + main.inTransitAsm[1],
			main.qAsm3.size() + main.srvAsm3.delaySize() + main.inTransitAsm[2],
			main.qAsm4.size() + main.srvAsm4.delaySize() + main.inTransitAsm[3]
	    };
	    int min = this.findMin(load);

	    // collect ties
	    int[] idx = new int[ManufacturingConfigService.nAssembly]; 
	    int n = 0;
	    for (int i = 0; i < ManufacturingConfigService.nAssembly; i++) 
	    	if (load[i] == min) 
	    		idx[n++] = i;

	    int pick = idx[ main.uniform_discr(0, n - 1) ]; 	// random among minima
	    main.inTransitAsm[pick]++; 					// reserve immediately
	    
		Logger.debug(String.format("ASM load %s (inTransit %s) -> pick %d", Arrays.toString(load), Arrays.toString(main.inTransitAsm), pick+1));
		
	    return main.ASSEMBLY_OUTS.get(pick);
	}
	
	public SelectOutputOut<WipUnit> chooseSwOut(Agent a) {
		// Pick the least loaded software integration line
		int[] load = {
			main.qSw1.size() + main.srvSw1.delaySize() + main.inTransitSw[0],
			main.qSw2.size() + main.srvSw2.delaySize() + main.inTransitSw[1],
			main.qSw3.size() + main.srvSw3.delaySize() + main.inTransitSw[2]
	    };
	    
	    int min = this.findMin(load);
	    
	    // collect ties
	    int[] idx = new int[ManufacturingConfigService.nSoftwareIntegration]; 
	    int n = 0;
	    for (int i = 0; i < ManufacturingConfigService.nSoftwareIntegration; i++) 
	    	if (load[i] == min) 
	    		idx[n++] = i;

	    int pick = idx[ main.uniform_discr(0, n - 1) ]; 	// random among minima
	    main.inTransitSw[pick]++; 					// reserve immediately
	    
		Logger.debug(String.format("SW load %s (inTransit %s) -> pick %d", Arrays.toString(load), Arrays.toString(main.inTransitSw), pick+1));
		
	    return main.SOFTWARE_OUTS.get(pick);
	}
	
	public SelectOutputOut<WipUnit> choosePackOut(WipUnit agent) {
		// Pick the least loaded packaging line
		int[] load = {
			main.qPack1.size() + main.srvPack1.delaySize() + main.inTransitPs[0],
			main.qPack2.size() + main.srvPack2.delaySize() + main.inTransitPs[1]
	    };
	    
	    int min = this.findMin(load);
	    
	    // collect ties
	    int[] idx = new int[ManufacturingConfigService.nPackaging]; 
	    int n = 0;
	    for (int i = 0; i < ManufacturingConfigService.nPackaging; i++) 
	    	if (load[i] == min) 
	    		idx[n++] = i;

	    int pick = idx[ main.uniform_discr(0, n - 1) ]; 	// random among minima
	    main.inTransitPs[pick]++; 					// reserve immediately
	    
		Logger.debug(String.format("PS load %s (inTransit %s) -> pick %d", Arrays.toString(load), Arrays.toString(main.inTransitPs), pick+1));
		
	    return main.PACKAGE_OUTS.get(pick);
	}

	public SelectOutputOut<WipUnit> chooseBatchOut(WipUnit agent) {
		int idx = 0;
		switch (agent.getVariant()) {
		  case MET: idx = 0; break;
		  case FW:  idx = 1; break;
		  case FB:  idx = 2; break;
		}
		
		return main.BATCH_OUTS.get(idx);
	}
	
	public int assignPackStationForCO(CustomerOrder co) {

        int bestIdx = 0;
        int bestLoad = Integer.MAX_VALUE;

        for (int i = 0; i < Constants.CO_PACK_STATIONS; i++) {
            CustomerOrderPackStation ps = main.coPackStations[i];

            int q = ps.queue.size();
            int busy = ps.isBusy() ? 1 : 0;
            int load = q + busy;

            if (load < bestLoad) {
                bestLoad = load;
                bestIdx = i;
            }
        }

        co.packStationIndex = bestIdx;
        return bestIdx;
    }
	
	public SelectOutputOut<ProcurementOrder> chooseDockOut(ProcurementOrder agent) {
		int idx = agent.dockIdx;

	    if (idx < 0) idx = 0;
	    if (idx >= main.DOCK_OUTS.size()) idx = main.DOCK_OUTS.size() - 1;
	    
		return main.DOCK_OUTS.get(idx);
	}

}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1766267282538</Id>
			<Name><![CDATA[ManufacturingFlowService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * ManufacturingFlowService
 * 
 * skeleton to help split Main's Additional class code into services.
 * Purpose: Manufacturing Order flow: buffers, kitting readiness, spawning WIP, picker drop-off commit, scrap top-up logic.
 */

import java.util.*;

public class ManufacturingFlowService {
	private final Main main;
	
	// Components delivered for an Order but not yet kitted into a WipUnit
	// per-Order buffer: sku -> units delivered (not yet consumed into kits)
	private final Map<MrpOrder, Map<String,Integer>> bufferByMOrder = new IdentityHashMap<>();
	
	public ManufacturingFlowService(Main main) {
        this.main = main;
    }
	
	private Map<String,Integer> buf(MrpOrder o) {
		return this.bufferByMOrder.computeIfAbsent(o, __ -> new HashMap<>());
	}
	
	private void addToBuf(MrpOrder o, String skuId, int qty) {
		if (qty <= 0)
			return;
		this.buf(o).merge(skuId, qty, Integer::sum);
	}

	private boolean hasAtLeast(Map<String,Integer> b, String sku, int need) {
		return b.getOrDefault(sku, 0) >= need;
	}

	private void consume(Map<String,Integer> b, String sku, int q) {
		if (q <= 0)
			return;
		b.put(sku, b.getOrDefault(sku,0) - q);
	}

	private VARIANT pickVariantReady(MrpOrder mo) {
	    if (mo == null)
	    	return null;

	    Map<String,Integer> b = buf(mo);
	    if (b == null)
	    	return null;

	    // Base components must be present
	    boolean baseOk =
	        hasAtLeast(b, SHARED_SKU.DISPLAY.skuId(), 1) &&
	        hasAtLeast(b, SHARED_SKU.MICROCHIP.skuId(), 1) &&
	        hasAtLeast(b, SHARED_SKU.BATTERY.skuId(), 1);

	    if (!baseOk)
	        return null;

	    VARIANT v = mo.getMoVariant();
	    if (v == null)
	        return null;

	    switch (v) {
	        case MET:
	            if (hasAtLeast(b, CASE_SKU.MET.skuId(), 1) &&
	                hasAtLeast(b, STRAP_SKU.MET.skuId(), 1))
	                return v;
	            break;
	        case FW:
	            if (hasAtLeast(b, CASE_SKU.FW.skuId(), 1) &&
	                hasAtLeast(b, STRAP_SKU.FW.skuId(), 1))
	                return v;
	            break;
	        case FB:
	            if (hasAtLeast(b, CASE_SKU.FB.skuId(), 1) &&
	                hasAtLeast(b, STRAP_SKU.FB.skuId(), 1))
	                return v;
	            break;
	    }

	    return null;
	}

	private void buildOneAndStart(MrpOrder mo, VARIANT v) {
	    if (mo == null || v == null)
	    	return;

	    Map<String,Integer> b = buf(mo);
	    if (b == null)
	    	return;

	    // Consume base components
	    consume(b, SHARED_SKU.DISPLAY.skuId(), 1);
	    consume(b, SHARED_SKU.MICROCHIP.skuId(), 1);
	    consume(b, SHARED_SKU.BATTERY.skuId(), 1);

	    // Consume variant-specific pair
	    switch (v) {
	        case MET:
	            consume(b, CASE_SKU.MET.skuId(), 1);
	            consume(b, STRAP_SKU.MET.skuId(), 1);
	            break;
	        case FW:
	            consume(b, CASE_SKU.FW.skuId(), 1);
	            consume(b, STRAP_SKU.FW.skuId(), 1);
	            break;
	        case FB:
	            consume(b, CASE_SKU.FB.skuId(), 1);
	            consume(b, STRAP_SKU.FB.skuId(), 1);
	            break;
	    }

	    // Spawn WIP & inject into assembly
	    WipUnit wu = main.add_wipUnits();
	    wu.initWipUnit(mo, v);        // you already have this
	    wu.onEnterStage(STAGE.KIT);

	    main.enterProd.take(wu);
	}
	
	// ======================================================
	// MO buffer / kitting / WIP creation
	// ======================================================
	public void onPickerDropOff(MrpOrder mo, List<PickStop> plan) {
		if (plan == null)
			return;
		
		// Club the delivered components into MO buffers
		for (PickStop ps : plan) {

		    addToBuf(mo, ps.skuId, ps.unitsToPick);

		    for (RmPickAlloc a : ps.rmAllocs) {
		        MotherBox mb = a.mbRes.getMotherBox();
		        if (mb == null) continue;

		        mb.commitPick(a.qty);
		        main.rmConsumedTodayBySkuId.merge(ps.skuId, a.qty, Integer::sum); // Update consumption each time rm picked

		        if (mb.isEmpty()) {
		        	a.mbRes.isEmpty = true;
		        	ps.slotRef.recalc();
		        	main.services.whDispatch.tryDispatchEmptyRmFromSlot(ps.slotRef);
		        }
		    }
		}
		
		// post raw consumption to Odoo per-MO (incremental from the drop-off manifest)
		OdooMrpGateway.consumeRawFromPlanWithLock(main, mo, plan);
		
		// While we have a full kit for any MO, spawn WipUnits
		VARIANT variant;
		boolean spawned;
		
		do {
			variant = this.pickVariantReady(mo);
			spawned = (variant != null);
			if (spawned)
				this.buildOneAndStart(mo, variant);
		} while (spawned);
	}

	public void requestTopUpForScrap(MrpOrder o) {
	    if (o == null)
	    	return;

	    LinkedHashMap<String,Integer> rem = o.getRemainingInMo();
	    if (rem == null)
	    	return;

	    // Add one full BOM for this order's variant back into the remaining ledger
	    Map<String,Integer> bom1x = o.oneXBom(o.getMoVariant());
	    if (bom1x != null) {
		    for (Map.Entry<String,Integer> e : bom1x.entrySet()) {
		        rem.merge(e.getKey(), e.getValue(), Integer::sum);
		    }
	    }

	    // If a picker is already assigned/picking for this MO, DON'T dispatch another one
	    if (o.isAssigned() || o.isPickInFlight()) {
	        Logger.info("Top-up demand added for MO idx= ", o.getIndex(), 
	        			" but pick is already in-flight; deferring dispatch.");
	        return;
	    }

	    // Put order back into the dispatch queue and try assign immediately
	    o.markRequeued(); // important if you start using status checks elsewhere
	    
	    if (!main.waitingMrpOrders.contains(o))
	    	main.waitingMrpOrders.add(o);
	    
	    main.services.whDispatch.tryDispatchRmPicking();
	}
	
	public void createMrpOrder(int fgQty, VARIANT v, FG_SKU fgSku) {

        // Guard: your model currently needs Odoo for fgId mapping
        if (main.m_odooSession == null) {
            Logger.warn("createMrpOrderAuto: Odoo not connected, skipping MO creation.");
            return;
        }

        MrpOrder o = main.add_mrpOrders();
        o.initOrder(fgQty, v, fgSku);

        // creates MO in Odoo + sets ids + allocation ledger
        OdooMrpGateway.createMOsForOrder(main, o);

        if (!main.waitingMrpOrders.contains(o)) {
            main.waitingMrpOrders.add(o);
        }

        Logger.info("AUTO MO created: idx=", o.getIndex(),
        			"id=", o.getId(),
                    " moId=", o.getMoId(),
                    " sku=", o.getFgSkuVariant(),
                    " qty=", o.getTotalQuantity());

        // kick dispatch (optional if your global dispatch event is running)
        main.services.whDispatch.tryDispatchRmPicking();
    }
	
	public int fgInventoryPosition(FG_SKU sku) {
	    int pos = 0;

	    // FG already in rack (including reserved + incoming)
	    List<FgSlot> slots = main.fgSlotsBySku.get(sku);
	    if (slots != null) {
	        for (FgSlot s : slots) {
	            if (s == null) continue;
	            pos += Math.max(0, s.units)
	                 + Math.max(0, s.reservedUnits)
	                 + Math.max(0, s.incomingUnits);
	        }
	    }

	    // WIP / open MOs not finished yet
	    for (MrpOrder o : main.mrpOrders) {
	        if (o == null) continue;
	        if (o.getFgSkuVariant() != sku) continue;

	        // remaining to package (scrap does NOT reduce target in your model)
	        int remaining = Math.max(0, o.getTotalQuantity() - o.fgPackaged);
	        pos += remaining;
	    }

	    return pos;
	}
}]]></Text>
		</JavaClass>
