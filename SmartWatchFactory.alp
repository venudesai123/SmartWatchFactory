if (!isMoving() && nextArrivalMsg != null) {
    String msg = nextArrivalMsg;
    nextArrivalMsg = null; // clear BEFORE firing
    Logger.debug("Firing arrival message: " + msg);
    this.statechartMO.fireEvent(msg);
} else if (isMoving()) {
    this.arrivalPoller.restart();
}
