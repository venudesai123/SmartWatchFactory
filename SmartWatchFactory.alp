								<Code><![CDATA[Resource mbRes = (Resource) agent;
if (!mbRes.itemQueued && !mbRes.itemAssigned) {
    mbRes.itemQueued = true;
    mbRes.queuedAt = time();
    this.waitingRmBoxes.add(mbRes);
}
this.services.whDispatch.tryDispatchRmStowing();
]]></Code>
