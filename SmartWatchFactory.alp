		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1767740448793</Id>
			<Name><![CDATA[ProcurementPolicyService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * ProcurementPolicyService
 */

public class ProcurementPolicyService {

	private final Main main;
	
	// Use the same variability as your inbound scheduling
	private static final double a = 0.8, b = 1.0, c = 1.3;
	
	// JIT suppliers assumed more reliable (tighter variability)
	private static final double jitA = 0.9, jitB = 1.0, jitC = 1.1;
	
	// Two-tier service level
    private static final double zShared  = 2.05;  // 98% for shared components or 1.88 - 97%
    private static final double zVariant = 1.64;  // 95% for variant-specific
    // private static final int minDaysData = 7;    // Warm-up requirement: we won't compute until we have enough days
    
	private Map<Integer, Double> vendorMaxDelayDaysByVendorId = new HashMap<>();

    public ProcurementPolicyService(Main main) {
        this.main = main;
    }
    
    // ======================================================
    // Helpers - Getter for “proper + efficient” core
    // ====================================================== 
    public Collection<String> getProcurementSkuIds() {
	    return main.productIdBySkuId.keySet();
	}
	
	public int ropUnits(String skuId) {
	    Integer v = main.ropUnitsBySkuId.get(skuId);
	    if (v != null)
	    	return v;
	
	    PRODUCT_TYPE pt = PRODUCT_TYPE.fromSkuId(skuId);
	    return (pt != null) ? main.ropUnitsDefaultBySkuType.getOrDefault(pt, 0) : 0;
	}
	
	public int orderUpToUnits(String skuId) {
        Integer v = main.orderUpToUnitsBySkuId.get(skuId);
        if (v != null)
        	return v;

        PRODUCT_TYPE pt = PRODUCT_TYPE.fromSkuId(skuId);
        return (pt != null) ? main.orderUpToUnitsDefaultBySkuType.getOrDefault(pt, 0) : 0;
    }

    public double reviewPeriodHours(String skuId) {
        Double v = main.reviewPeriodHoursBySkuId.get(skuId);
        if (v != null)
        	return v;

        PRODUCT_TYPE pt = PRODUCT_TYPE.fromSkuId(skuId);
        return (pt != null) ? main.reviewPeriodHoursDefaultBySkuType.getOrDefault(pt, 0.0) : 0.0;
    }

    public int jitSafetyUnits(String skuId) {
        Integer v = main.jitSafetyUnitsBySkuId.get(skuId);
        if (v != null)
        	return v;

        PRODUCT_TYPE pt = PRODUCT_TYPE.fromSkuId(skuId);
        return (pt != null) ? main.jitSafetyUnitsDefaultBySkuType.getOrDefault(pt, 0) : 0;
    }
    
    public Map<String, Integer> snapshotRmAvailableUnitsBySkuId() {
        Map<String, Integer> avail = new HashMap<>();

        // slotted inventory
        for (PRODUCT_TYPE pt : PRODUCT_TYPE.values()) {
            List<RmSlot> list = main.rmSlotsBySku.get(pt);
            if (list == null) continue;

            for (RmSlot s : list) {
                if (s == null || s.skuId == null || s.skuId.isEmpty()) continue;

                // include reserved + incoming (see below)
                /* int onHandInSlot = Math.max(0, s.units)
                                 + Math.max(0, s.reservedUnits)
                                 + Math.max(0, s.incomingUnits);

                if (onHandInSlot > 0)
                    avail.merge(s.skuId, onHandInSlot, Integer::sum); */
                
	             // Procurement availability must exclude reserved units.
	             // "available-to-consume" = units - reservedUnits (floor at 0)
	             int availableInSlot = Math.max(0, s.units - s.reservedUnits);
	
	             // IMPORTANT: decide what incomingUnits represents:
	             // - If it's "arrived but not putaway": OK to add here.
	             // - If it's "in-transit from supplier": DO NOT add here; it belongs to onOrder.
	             int arrivedNotPutaway = Math.max(0, s.incomingUnits);
	
	             int onHandForProcurement = availableInSlot + arrivedNotPutaway;
	
	             if (onHandForProcurement > 0)
	                 avail.merge(s.skuId, onHandForProcurement, Integer::sum);
            }
        }

        // arrived but not slotted yet (in lanes/QC/putaway)
        for (Resource mbRes : main.motherBoxes) {
            if (mbRes == null) continue;
            
            MotherBox mb = mbRes.getMotherBox();
            if (mb == null) continue;
            
            if (mb.getInRmSlot()) continue; // skip boxes already in a slot

            String skuId = mb.getSkuId();
            int units = mb.availableUnits();
            
            if (units > 0)
                avail.merge(skuId, units, Integer::sum);
        }

        return avail;
    }


    public int inventoryPositionUnits(String skuId, Map<String,Integer> availSnap) {
        int avail = availSnap.getOrDefault(skuId, 0);
        int onOrder = main.rmOnOrderUnitsBySkuId.getOrDefault(skuId, 0);
        return avail + onOrder;
    }
    
	// ======================================================
	// JIT demand signal (REALISTIC pull-based)
	// Uses waitingMrpOrders (FIFO backlog for RM picking)
	// and limits to a small lookahead window.
	// ======================================================
    public int computeJitNeedUnits(String skuId) {

        if (skuId == null || skuId.isEmpty())
            return 0;

        PRODUCT_TYPE pt = PRODUCT_TYPE.fromSkuId(skuId);
        if (pt == null)
            return 0;

        // Lookahead: how many *waiting* MOs to include
        // Shared components affect all variants -> include more orders
        int lookaheadOrders = pt.isSharedComponent() ? 6 : 3;

        int need = 0;
        int count = 0;

        for (MrpOrder o : main.waitingMrpOrders) {
            if (o == null) continue;
            if (!o.hasPendingDemand()) continue;

            LinkedHashMap<String,Integer> rem = o.getRemainingInMo();
            if (rem == null) continue;

            need += Math.max(0, rem.getOrDefault(skuId, 0));

            count++;
            if (count >= lookaheadOrders) break;
        }

        return need;
    }
    
	// ======================================================
	// JIT safety buffer (REALISTIC)
	// buffer = a few hours worth of mean demand
	// uses your observed daily mean (Welford stats)
	// ======================================================
    public int jitSafetyUnitsDynamic(String skuId) {

        PRODUCT_TYPE pt = PRODUCT_TYPE.fromSkuId(skuId);
        if (pt == null)
            return 0;

        double dDaily = main.rmDailyMeanBySkuId.getOrDefault(skuId, 0.0); // units/day
        if (dDaily <= 0) {
            // fallback to your existing fixed map/defaults
            return jitSafetyUnits(skuId);
        }

        // Shared parts need higher protection than variant-specific parts
        double safetyHours = pt.isSharedComponent() ? 8.0 : 4.0;

        return (int) Math.ceil(dDaily * (safetyHours / 24.0));
    }

    // Vendor selection (using existing vendor maps)
    public Resource chooseVendorForSkuId(String skuId) {
        Integer pid = main.productIdBySkuId.get(skuId);
        if (pid == null)
        	return null;
        
        Resource best = null;
        double bestDelay = Integer.MAX_VALUE;
        
        for (Resource v : main.vendors) { // your vendors population
            Integer vPid = v.productIdBySku.get(skuId);
            if (vPid == null || vPid != pid)
            	continue;

            double leadDays = v.delayDaysByProduct.getOrDefault(pid, 7.0);
            if (leadDays < bestDelay) {
                bestDelay = leadDays;
                best = v;
            }
        }
        
        return best;
    }
    
    // Units→boxes + MOQ rounding (“order in boxes” requirement)
    public int applyBoxAndMoqRounding(Resource vendor, String skuId, int needUnits) {
        Integer productId = main.productIdBySkuId.get(skuId);
        int upb = main.unitsPerBoxBySkuId.getOrDefault(skuId, 1);

        int needBoxes = (int)Math.ceil(needUnits / (double)upb);

        // MOQ from vendor mapping (stored as units in your DB)
        double moqUnitsD = (vendor != null && productId != null)
                ? vendor.minQtyByProduct.getOrDefault(productId, 0.0)
                : 0.0;
        int moqUnits = (int)Math.ceil(moqUnitsD);
        int moqBoxes = (int)Math.ceil(moqUnits / (double)upb);

        int orderBoxes = Math.max(needBoxes, moqBoxes);
        return orderBoxes * upb;
    }
    
    
    
    public void updateDailyRmStatsAndRecompute() {
    	Collection<String> skuIds = this.getProcurementSkuIds();
        if (skuIds == null) return;
    	
        // Update mean & variance using today's consumption
        for (String skuId : skuIds) {

            int x = main.rmConsumedTodayBySkuId.getOrDefault(skuId, 0); // units consumed today

            int n = main.rmDaysObservedBySkuId.getOrDefault(skuId, 0) + 1;
            main.rmDaysObservedBySkuId.put(skuId, n);

            double meanPrev = main.rmDailyMeanBySkuId.getOrDefault(skuId, 0.0);
            double m2Prev   = main.rmDailyM2BySkuId.getOrDefault(skuId, 0.0);

            // Welford update
            double delta = x - meanPrev;
            double mean = meanPrev + delta / n;
            double delta2 = x - mean;
            double m2 = m2Prev + delta * delta2;

            main.rmDailyMeanBySkuId.put(skuId, mean);
            main.rmDailyM2BySkuId.put(skuId, m2);

            double var = (n > 1) ? (m2 / (n - 1)) : 0.0;
            main.rmDailyVarBySkuId.put(skuId, var);

            Logger.trace("[DailyStats] sku=" + skuId + " consumedToday=" + x);
        }

        // Reset today's counter
        main.rmConsumedTodayBySkuId.clear();
        
        switch(Configuration.inventoryPolicy) {
        	case ROP: { this.recomputeRopParametersFromStats(); } break; // Recompute ROP and Order-up-to using updated stats
        	case PR: { this.recomputePrParametersFromStats(); } break; // Recompute PR order-up-to S using updated stats (uses same orderUpToUnitsBySkuId map)
        	case JIT: break;
        }
        
        Logger.trace("[DailyStats] Updated demand stats + recomputed ROP/PR params at t=" + main.time());
    }
    
    public void recomputeRopParametersFromStats() {
        // Cover days (order-up-to buffer) - keep simple & realistic
        final double coverSharedDays = 7.0;   // shared components: protect continuity
        final double coverVariantDays = 5.0;  // variant-specific: less system-wide risk
        
        Collection<String> skuIds = this.getProcurementSkuIds();
        if (skuIds == null || skuIds.isEmpty()) return;
        
        for (String skuId : skuIds) {
        	int n = main.rmDaysObservedBySkuId.getOrDefault(skuId, 0);
            if (n < Constants.WARM_UP_DAYS) continue;	// wait until stats are stable
            
            // Demand stats (units/day)
            double d = main.rmDailyMeanBySkuId.getOrDefault(skuId, 0.0);
            if (d <= 0.0) continue;
        	
            double varD = main.rmDailyVarBySkuId.getOrDefault(skuId, 0.0);
            double sigmaD = Math.sqrt(Math.max(0.0, varD));
            // double sigmaD = Math.sqrt(Math.max(0.0, main.rmDailyVarBySkuId.getOrDefault(skuId, 0.0)));
        	
            PRODUCT_TYPE pt = PRODUCT_TYPE.fromSkuId(skuId);
            if (pt == null) {
                Logger.warn("Unknown PRODUCT_TYPE for skuId=" + skuId + ", using variant tier.");
            }
            
            boolean shared = (pt != null) && pt.isSharedComponent();
            
            double z = shared ? zShared : zVariant;
            double coverDays = shared ? coverSharedDays : coverVariantDays;
            
            // Lead time stats (days)
            /* LeadTimeStats lt = main.leadTimeStatsDaysForSkuId.computeIfAbsent(
	    	    skuId, k -> this.computeLeadTimeStatsDaysForSku(k)
	    	); */
            LeadTimeStats lt = this.computeLeadTimeStatsDaysForSku(skuId);
            main.leadTimeStatsDaysForSkuId.put(skuId, lt); 
            
            double L = Math.max(0.1, lt.meanDays); // avoid 0
            double sigmaL = Math.max(0.0, lt.stdDays);
            
            // ROP formula:
            // muLT = d*L
            // sigmaLT = sqrt(L*sigmaD^2 + d^2*sigmaL^2)
            // Compute ROP
            double muLT = d * L;
            double sigmaLT = Math.sqrt((L * sigmaD * sigmaD) + (d * d * sigmaL * sigmaL));

            int rop = (int) Math.ceil(muLT + z * sigmaLT);
            int upto = (int) Math.ceil(rop + d * coverDays);

            // Safety guards
            rop = Math.max(0, rop);
            upto = Math.max(rop, upto);

            // Write into the maps your planner already uses
            main.ropUnitsBySkuId.put(skuId, rop);
            main.orderUpToUnitsBySkuId.put(skuId, upto);
            
            Logger.trace("[ROP] sku=" + skuId + " pt=" + pt + " shared=" + shared + 
            					" d=" + d + " sigmaD=" + sigmaD + " L=" + L + " sigmaL=" + sigmaL + 
            					" z=" + z + " rop=" + rop + " upto=" + upto);
        }
    }
    
    private LeadTimeStats computeLeadTimeStatsDaysForSku(String skuId) {
    	
    	double ta = (Configuration.inventoryPolicy == INVENTORY_POLICY.JIT) ? jitA : a;
    	double tb = (Configuration.inventoryPolicy == INVENTORY_POLICY.JIT) ? jitB : b;
    	double tc = (Configuration.inventoryPolicy == INVENTORY_POLICY.JIT) ? jitC : c;

    	Resource vendor = this.chooseVendorForSkuId(skuId);
    	if (vendor == null) {
            return new LeadTimeStats(5.0, 1.0);
        }
    	
        if (vendor.id <= 0) {
            // fallback (no vendor known)
            return new LeadTimeStats(5.0, 1.0);
        }        

        // get productId for this sku
        Integer productId = main.productIdBySkuId.get(skuId);

        // base delay should come from that vendor for that productId
        // fallback chain: per-product delay -> vendorMaxDelay -> 5.0
        double baseDelayDays = 5.0;

        if (productId != null) {
            Double d = vendor.delayDaysByProduct.get(productId);
            if (d != null) baseDelayDays = d;
            else baseDelayDays = this.vendorMaxDelayDaysByVendorId.getOrDefault(vendor.id, 5.0);
        } else {
            baseDelayDays = this.vendorMaxDelayDaysByVendorId.getOrDefault(vendor.id, 5.0);
        }

        // apply triangular uncertainty factor
        final double meanFactor = triangularMean(ta, tb, tc);
        // final double varFactor  = triangularVariance(ta, tb, tc);
        final double stdFactor  = triangularStd(ta, tb, tc);

        double meanDays = baseDelayDays * meanFactor;
        double stdDays  = baseDelayDays * stdFactor;
        
        Logger.trace("[LT] sku=" + skuId + " vendor=" + vendor.name
        	    + " productId=" + productId + " baseDelay=" + baseDelayDays
        	    + " mean=" + meanDays + " std=" + stdDays);

        return new LeadTimeStats(meanDays, stdDays);
    }
    
    public void recomputePrParametersFromStats() {
        Collection<String> skuIds = this.getProcurementSkuIds();
        if (skuIds == null || skuIds.isEmpty()) return;

        for (String skuId : skuIds) {

            int n = main.rmDaysObservedBySkuId.getOrDefault(skuId, 0);
            if (n < Constants.WARM_UP_DAYS) continue;

            // Demand stats (units/day)
            double d = main.rmDailyMeanBySkuId.getOrDefault(skuId, 0.0);
            if (d <= 0.0) continue;

            double varD = main.rmDailyVarBySkuId.getOrDefault(skuId, 0.0);
            double sigmaD = Math.sqrt(Math.max(0.0, varD));

            PRODUCT_TYPE pt = PRODUCT_TYPE.fromSkuId(skuId);
            boolean shared = (pt != null) && pt.isSharedComponent();
            double z = shared ? zShared : zVariant;

            // Lead time stats (days) - reuse exactly like ROP
            LeadTimeStats lt = this.computeLeadTimeStatsDaysForSku(skuId);
            main.leadTimeStatsDaysForSkuId.put(skuId, lt);

            double L = Math.max(0.1, lt.meanDays);
            double sigmaL = Math.max(0.0, lt.stdDays);

            // Review period (days)
            double Rhours = this.reviewPeriodHours(skuId);
            if (Rhours <= 0.0) Rhours = 24.0; // safety fallback
            double R = Math.max(1.0 / 24.0, Rhours / 24.0); // min 1 hour

            // Protection period PP = L + R
            double PP = L + R;

            // Mean demand over PP
            double muPP = d * PP;

            // Variance over PP:
            // var = PP*sigmaD^2 + d^2*sigmaL^2
            // (this matches your ROP logic, but uses PP instead of L)
            double sigmaPP = Math.sqrt((PP * sigmaD * sigmaD) + (d * d * sigmaL * sigmaL));

            int S = (int) Math.ceil(muPP + z * sigmaPP);

            // Guards
            S = Math.max(0, S);

            // Write into the SAME map you already use
            main.orderUpToUnitsBySkuId.put(skuId, S);

            Logger.trace("[PR-S] sku=" + skuId + " pt=" + pt + " shared=" + shared
                    + " d=" + d + " sigmaD=" + sigmaD
                    + " L=" + L + " sigmaL=" + sigmaL
                    + " Rdays=" + R + " PP=" + PP
                    + " z=" + z + " S(orderUpTo)=" + S);
        }
    }
    
    public void initDefaults() {

        // Ensure maps exist (these should match what you already use in your model)
        if (main.ropUnitsBySkuId == null) main.ropUnitsBySkuId = new HashMap<>();
        if (main.orderUpToUnitsBySkuId == null) main.orderUpToUnitsBySkuId = new HashMap<>();
        if (main.reviewPeriodHoursBySkuId == null) main.reviewPeriodHoursBySkuId = new HashMap<>();
        if (main.nextReviewDueSecBySkuId == null) main.nextReviewDueSecBySkuId = new HashMap<>();
        if (main.jitSafetyUnitsBySkuId == null) main.jitSafetyUnitsBySkuId = new HashMap<>();
        if (main.leadTimeStatsDaysForSkuId == null) main.leadTimeStatsDaysForSkuId = new HashMap<>();
        if (main.reviewPeriodHoursDefaultBySkuType == null) main.reviewPeriodHoursDefaultBySkuType = new HashMap<>();
        
        // Seed defaults by PRODUCT_TYPE (used by reviewPeriodHours(skuId) fallback)
        for (PRODUCT_TYPE pt : PRODUCT_TYPE.values()) {
        	double rpHours = pt.isSharedComponent() ? 24.0 : 72.0;
        	main.reviewPeriodHoursDefaultBySkuType.put(pt, rpHours);
        }

        Collection<String> skuIds = getProcurementSkuIds();
        if (skuIds == null || skuIds.isEmpty()) {
            main.traceln("[ServiceProcurementPolicy] initDefaults: no procurement SKUs found.");
            return;
        }

        // Warm-up defaults (only used until you have ~7+ days of demand stats and recompute ROP/S)
        // Critical long-lead/line-stopping items: Display/Microchip/Battery -> higher starting buffers
        final int warmRopCritical = 250;
        final int warmUptoCritical = 650;

        // Cases/Straps often shorter lead-time -> smaller buffers
        final int warmRopNormal = 150;
        final int warmUptoNormal = 450;

        // PR review periods (if you run PR later)
        final int reviewHoursCritical = 24;  // daily
        final int reviewHoursNormal   = 72;  // every 3 days

        // JIT safety defaults (if you run JIT later)
        final int jitSafetyCritical = 80;
        final int jitSafetyNormal   = 40;
        
        final double warmupDelaySec = Constants.WARM_UP_DAYS * 24.0 * 3600.0; // ALWAYS 7 days

        int seeded = 0;

        for (String skuId : skuIds) {
            if (skuId == null || skuId.isEmpty()) continue;

            PRODUCT_TYPE pt = PRODUCT_TYPE.fromSkuId(skuId);
            boolean critical = (pt != null) && pt.isSharedComponent();

            // PR params
            double reviewHours = critical ? reviewHoursCritical : reviewHoursNormal;
            main.reviewPeriodHoursBySkuId.put(skuId, reviewHours);
            
            // --- First PR review due AFTER warm-up (7 days) ---
            // This prevents PR placing orders before demand stats are stable.
            main.nextReviewDueSecBySkuId.put(skuId, main.time() + warmupDelaySec);

            // JIT params
            main.jitSafetyUnitsBySkuId.put(skuId, critical ? jitSafetyCritical : jitSafetyNormal);

            // Warm-up ROP / UpTo
            int rop  = critical ? warmRopCritical : warmRopNormal;
            int upto = critical ? warmUptoCritical : warmUptoNormal;

            main.ropUnitsBySkuId.put(skuId, rop);
            main.orderUpToUnitsBySkuId.put(skuId, upto);

            seeded++;
        }
        
        // Build vendor max-delay index BEFORE computing LT stats
        this.rebuildVendorMaxDelayDaysIndex();
        
        // Seed lead time stats cache (optional but helpful)
        for (String skuId : skuIds) {
            LeadTimeStats lt = this.computeLeadTimeStatsDaysForSku(skuId);
            main.leadTimeStatsDaysForSkuId.put(skuId, lt);
        }
        
        Logger.trace("[ServiceProcurementPolicy] initDefaults: seeded " + seeded
                + " SKUs (warm-up buffers + review periods + nextReviewDueSec warm-up delay=" + Constants.WARM_UP_DAYS + " days)");
    }
    
    private void rebuildVendorMaxDelayDaysIndex() {

	    this.vendorMaxDelayDaysByVendorId.clear();

	    Collection<String> skuIds = this.getProcurementSkuIds();
	    if (skuIds == null || skuIds.isEmpty()) return;

	    for (String skuId : skuIds) {

	        // Choose vendor for sku the same way planner does
	        Resource vendor = this.chooseVendorForSkuId(skuId);
	        if (vendor == null) continue;

	        Integer productId = main.productIdBySkuId.get(skuId);
	        if (productId == null) {
	            Logger.warn("rebuildVendorMaxDelayDaysIndex: No productId for skuId=", skuId);
	            continue;
	        }

	        // Base delay for this sku from this vendor
	        double d = vendor.delayDaysByProduct.getOrDefault(productId, 0.0);

	        // If missing, don't keep 0 silently (use a safe default)
	        if (d <= 0.0) {
	            Logger.warn("rebuildVendorMaxDelayDaysIndex: delayDays missing/0 for vendor=",
	                        vendor.name, " productId=", productId, " skuId=", skuId,
	                        " using default=5");
	            d = 5.0;
	        }

	        // Update vendor's max
	        this.vendorMaxDelayDaysByVendorId.merge(vendor.id, d, Math::max);
	    }

	    Logger.trace("[ProcPolicy] vendorMaxDelayDaysByVendorId=" + vendorMaxDelayDaysByVendorId);
	}
    
    private static double triangularMean(double a, double b, double c) {
        return (a + b + c) / 3.0;
    }
    
    private static double triangularVariance(double a, double b, double c) {
        // assumes a <= b <= c
    	// variance = (a^2+b^2+c^2 - ab - ac - bc) / 18
        return (a*a + b*b + c*c - a*b - a*c - b*c) / 18.0;
    }

    private static double triangularStd(double a, double b, double c) {
        return Math.sqrt(Math.max(0.0, triangularVariance(a, b, c)));
    }
    
    public double triangular() {
    	return main.triangular(a, b, c);
    }
    
    boolean inWarmupTime() {
        return main.time() < Constants.WARM_UP_DAYS * main.day();   // or use your warmupDays variable
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1767741119548</Id>
			<Name><![CDATA[InboundProcurementFlowService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * InboundProcurementFlowService
 * 
 * skeleton to help split Main's Additional class code into services.
 * Purpose: Procurement policies (ROP/Periodic/JIT) + PO creation + inbound arrivals + Odoo receipt post.
 */

public class InboundProcurementFlowService {

	private final Main main;
    private final ProcurementPolicyService policy;
    
    private int nextPoSimId = 1;

    public InboundProcurementFlowService(Main main, ProcurementPolicyService policy) {
        this.main = main;
        this.policy = policy;
    }

    public void createPurchaseOrderSimAndScheduleInbound(Resource vendor, LinkedHashMap<String,Integer> linesUnits) {
    	// Guard clause (see next section)
        if (vendor == null || linesUnits == null || linesUnits.isEmpty()) {
            Logger.warn("createPurchaseOrderSimAndScheduleInbound: vendor/lines invalid");
            return;
        }
    	
    	PurchaseOrderSim po = new PurchaseOrderSim();
    	po.createdAt = main.time();
        po.simId = this.nextPoSimId++;
        po.vendorId = vendor.id;
        po.vendorName = vendor.name;
        
        // Initialize these RIGHT HERE (before any scheduling/queueing)
        po.unloadedBoxes = 0;
        po.assignedDockIdx = -1;
        po.inboundSpawned = false;
        po.receiptPostedToOdoo = false;

        po.orderedUnitsBySkuId.putAll(linesUnits);
        
        main.services.kpis.onPoCreated(po);
        
        // Compute expected boxes (needed for dock-release correctness)
        int totalBoxes = 0;
        for (Map.Entry<String,Integer> e : linesUnits.entrySet()) {
            String skuId = e.getKey();
            int units = Math.max(0, e.getValue());
            int upb = main.unitsPerBoxBySkuId.getOrDefault(skuId, 1);
            int boxes = (int) Math.ceil(units / (double) upb);
            totalBoxes += boxes;
        }
        po.expectedBoxes = totalBoxes;

        // Track on-order immediately (inventory position includes it)
        for (Map.Entry<String,Integer> e : linesUnits.entrySet()) {
        	int units = Math.max(0, e.getValue());
        	if (units > 0)
        	    main.rmOnOrderUnitsBySkuId.merge(e.getKey(), units, Integer::sum);
        }

        // Lead time (days) -> seconds: choose max of lines’ vendor delay or average; simplest: max
        double maxDelayDays = 0.0;
        for (String skuId : linesUnits.keySet()) {
            Integer productId = main.productIdBySkuId.get(skuId);
            if (productId == null) {
                Logger.warn("No productId for skuId=", skuId);
                continue; // or treat as default lead time
            }
            double d = vendor.delayDaysByProduct.getOrDefault(productId, 5.0);
            if (!vendor.delayDaysByProduct.containsKey(productId)) {
                Logger.warn("Missing vendor delayDaysByProduct for productId=", productId,
                            " skuId=", skuId, " vendor=", vendor.name, " using default=5");
            }
            maxDelayDays = Math.max(maxDelayDays, d);
        }
        
        if (maxDelayDays <= 0.0) {
            Logger.warn("PO(sim) lead time: maxDelayDays=0 (missing productIds/delays). Using default=5 days. vendor=" + vendor.name);
            maxDelayDays = 5.0;
        }
        
        // Add small variability
        double leadDays = Math.max(1.0, maxDelayDays) * this.policy.triangular();
        leadDays = Math.max(1.0, leadDays);
        
        po.etaSec = po.createdAt + leadDays * 24 * 3600.0;

        main.poBySimId.put(po.simId, po);
        main.inboundEtaQ.add(po);

        // Create in Odoo now (optional but recommended)
        if (main.m_odooSession != null) {
            OdooPurchaseGateway.createPurchaseOrderForSim(main, po);
        }

        this.armInboundArrivalEvent();
        Logger.info("PO(sim) ", po.simId, " created for vendor=", po.vendorName,
                    " lines=", po.orderedUnitsBySkuId, " etaDays=", leadDays);
    }

    // 
    private void armInboundArrivalEvent() {	
        if (main.inboundEtaQ.isEmpty())
    		return;
    	
    	PurchaseOrderSim next = main.inboundEtaQ.peek();
        if (next == null)
    		return;

        double dt = next.etaSec - main.time();
        if (dt < 0.01)
    		dt = 0.01;
    	
    	Logger.info("Inbound event scheduled in dt=", dt, " sec at time=", main.time());
    	
    	main.inboundArrivalEvent.restart(dt);
    }

    public void releaseInboundArrivals() {
    	Logger.info("Inbound event fired at time=", main.time());
        double now = main.time();

        while (!main.inboundEtaQ.isEmpty() && main.inboundEtaQ.peek().etaSec <= now + 1e-6) {
            PurchaseOrderSim po = main.inboundEtaQ.poll();
            if (po == null || po.inboundSpawned)
    			continue;
            
            this.startInboundPoJob(po);
            po.inboundSpawned = true;
        }

        this.armInboundArrivalEvent();
    }
    
    private void startInboundPoJob(PurchaseOrderSim poSim) {
        if (poSim == null)
        	return;

        ProcurementOrder po = main.add_procurementOrders(); // your custom population
        po.poSim = poSim;

        // vendor node for truck spawn
        po.vendorNode = getVendorNode(poSim.vendorId);

        // reset job flags just in case
        po.truckCreated = false;
        po.movedToEntry = false;
        po.movedToPark  = false;
        po.dockReserved = false;
        po.dockIdx = -1;

        main.poIn.take(po); // IMPORTANT: inject into PO process flow
    }
    
    private PointNode getVendorNode(int vendorPartnerId) {
        // vendorPartnerId from Odoo can be like 7, 12, etc. so we map it into 0..N-1
        PointNode[] arr = main.VENDOR_ENTRIES; // or main.VENDOR_ENTRIES if you already have it
        if (arr == null || arr.length == 0)
        	return main.inboundTruckEntryNode;

        int idx = Math.floorMod(vendorPartnerId, arr.length);
        PointNode n = arr[idx];
        return (n != null) ? n : main.inboundTruckEntryNode;
    }
    
    public void spawnInboundBoxesAfterUnload(ProcurementOrder po) {
        if (po == null)
        	return;
		if (po.poSim == null) {
			Logger.warn("spawnInboundBoxesAfterUnload: job.poSim is null");
			return;
		}
		
		if (po.dockIdx < 0) {
			Logger.warn("spawnInboundBoxesAfterUnload: dockIdx < 0 for poSimId=" + po.poSim.simId);
			return;
		}
        
        PurchaseOrderSim poSim = po.poSim;
        po.unloadedBoxes.clear();
        
        // prepare 5 lane lists
    	po.boxesByLane.clear();
    	for (int i = 0; i < 5; i++)
    		po.boxesByLane.add(new ArrayList<>());
    	
    	po.laneCursor = 0;
    	po.currentLane = -1;
    	po.currentLaneNode = null;
        
        if (poSim == null)
        	return;
        
        Node dockNode = main.INBOUND_DOCK_NODES[po.dockIdx];

        for (Map.Entry<String,Integer> e : poSim.orderedUnitsBySkuId.entrySet()) {
            String skuId = e.getKey();
            int unitsTotal = Math.max(0, e.getValue());
            int upb = Math.max(1, main.unitsPerBoxBySkuId.getOrDefault(skuId, 1));
            int boxes = (int)Math.ceil(unitsTotal / (double)upb);

            Integer pid = main.productIdBySkuId.get(skuId);
            double wt = main.weightBySkuId.getOrDefault(skuId, 0.0);
            PRODUCT_TYPE pt = PRODUCT_TYPE.fromSkuId(skuId);
            int laneIdx = main.inboundLaneIdxByType.get(pt);
            
            if (laneIdx < 0) laneIdx = 0;
    	    if (laneIdx > 4) laneIdx = 4;

            for (int i = 0; i < boxes; i++) {
                int remaining = unitsTotal - i * upb;
                int boxUnits = Math.min(upb, Math.max(0, remaining));
                if (boxUnits <= 0)
                	continue;
                
                MotherBox mb = new MotherBox(pt, pid, skuId, boxUnits, wt);

                Resource resMb = main.add_motherBoxes();
                resMb.category = RESOURCE_TYPE.MOTHERBOX;
                resMb.setMotherBox(mb);

                resMb.poSimId = poSim.simId;
                resMb.id = poSim.vendorId;
                resMb.inboundLaneIdx = laneIdx;
                resMb.inboundQcLaneIdx = laneIdx;

                // physically at dock
                resMb.jumpTo(dockNode);
                // resMb.setMBVisibility(true);

                // reduce on-order now that it’s delivered
                main.rmOnOrderUnitsBySkuId.merge(skuId, -boxUnits, Integer::sum);
                if (main.rmOnOrderUnitsBySkuId.getOrDefault(skuId, 0) < 0) {
                    main.rmOnOrderUnitsBySkuId.put(skuId, 0);
                }
                po.unloadedBoxes.add(resMb);
                po.boxesByLane.get(laneIdx).add(resMb);
            }
        }
    }
    
    public void finishDropAtLane(ProcurementOrder po) {
        if (po == null)
        	return;

        int lane = po.currentLane;
        PointNode laneNode = po.currentLaneNode;
        ArrayList<Resource> list = po.boxesByLane.get(lane);

        double baseX = laneNode.getX();
        double baseY = laneNode.getY();

        int i = 0;
        for (Resource mb : list) {
            // detach from forklift
            mb.isCarried = false;
            mb.carriedBy = null;

            // drop near lane node
            mb.setXY(baseX + 0.3*(i % 6), baseY + 0.3*(i / 6));
            i++;
            
            // Inject into MB processing flow (NEW ENTER BLOCK)
            main.mbIn.take(mb);
        }

        list.clear();                 // lane completed
        po.laneCursor = lane + 1;     // move to next lane search
        po.currentLane = -1;
        po.currentLaneNode = null;
    }
    
    public void loadAllAtOnce(ProcurementOrder po) {
    	// get the seized inbound worker (forklift) from this PO
    	Resource fork = null;
    	for (Agent u : po.resourceUnits()) {          // list of seized units is on the agent
    	    Resource r = (Resource) u;
    	    if (r.category == RESOURCE_TYPE.INBOUND_WORKER) {
    	        fork = r;
    	        break;
    	    }
    	}
    	if (fork == null)
    		return;

    	// “load” all boxes onto the forklift visually
    	int k = 0;
    	for (Resource mb : po.unloadedBoxes) {
    	    mb.isCarried = true;
    	    mb.carriedBy = fork;

    	    // stack offsets so they don’t overlap (adjust spacing to your liking)
    	    mb.carryDx = 0.35 * (k % 4);
    	    mb.carryDy = 0.35 * (k / 4);
    	    k++;
    	}
    }

    // Inbound QC pass/fail handlers
    public void onInboundBoxStored(Resource mb) {
        if (mb == null || mb.poSimId <= 0)
    		return;

        PurchaseOrderSim po = main.poBySimId.get(mb.poSimId);
        if (po == null)
    		return;

        int upb = mb.getMotherBox().getUnitsPerBox();
        String skuId = mb.getMotherBox().getSkuId();
        po.goodUnitsBySkuId.merge(skuId, upb, Integer::sum);

        this.tryPostPoReceiptToOdooIfComplete(po);
    }

    public void onInboundBoxRejected(Resource mb) {
        if (mb == null || mb.poSimId <= 0)
    		return;

        PurchaseOrderSim po = main.poBySimId.get(mb.poSimId);
        if (po == null)
    		return;

        int upb = mb.getMotherBox().getUnitsPerBox();
        String skuId = mb.getMotherBox().getSkuId();
        po.badUnitsBySkuId.merge(skuId, upb, Integer::sum);

        this.tryPostPoReceiptToOdooIfComplete(po);
    }

    // When PO is fully processed (good+bad reached ordered), validate receipt in Odoo once
    private void tryPostPoReceiptToOdooIfComplete(PurchaseOrderSim po) {
        if (po == null || po.receiptPostedToOdoo)
    		return;
        
        if (po.orderedUnitsBySkuId == null || po.goodUnitsBySkuId == null || po.badUnitsBySkuId == null)
            return;
        
        

        for (Map.Entry<String,Integer> e : po.orderedUnitsBySkuId.entrySet()) {
            String skuId = e.getKey();
            int ordered = e.getValue();
            int good = po.goodUnitsBySkuId.getOrDefault(skuId, 0);
            int bad  = po.badUnitsBySkuId.getOrDefault(skuId, 0);

            if (good + bad < ordered)
    			return; // still processing boxes
        }
        
        if (po.completedAt <= 0) {
    	  po.completedAt = main.time();
    	  double lt = Math.max(0, po.completedAt - po.createdAt);

    	  main.kpiPoCount++;
    	  main.kpiPoLeadSum += lt;
    	  main.kpiPoLeadMin = Math.min(main.kpiPoLeadMin, lt);
    	  main.kpiPoLeadMax = Math.max(main.kpiPoLeadMax, lt);
    	}

        // All lines processed
        if (main.m_odooSession != null) {
        	po.receiptPostedToOdoo = OdooPurchaseGateway.receiveIncomingForPo(main, po);
        }
    }
    
    // ======================================================
    // Lane assignment (EnumMap-based)
    // ======================================================
    public PointNode inboundLaneNode(Resource mb) {
        // NO side-effects in expressions — assume lane idx already assigned
        int idx = (mb != null) ? mb.inboundLaneIdx : 0;
        idx = Math.max(0, Math.min(idx, main.INBOUND_LANE_NODES.length - 1));
        return main.INBOUND_LANE_NODES[idx];
    }

    public PointNode inboundQcNode(Resource mb) {
        int idx = (mb != null) ? mb.inboundLaneIdx : 0;
        idx = Math.max(0, Math.min(idx, main.INBOUND_QC_NODES.length - 1));
        return main.INBOUND_QC_NODES[idx];
    }

    // ======================================================
    // Placement helpers (for visuals)
    // ======================================================
    /* private void placeInParkingArea(Resource mb) {
        if (mb == null || main.parkingArea == null)
        	return;
        double x = main.uniform(main.parkingArea.getX(), main.parkingArea.getX() + main.parkingArea.getWidth());
        double y = main.uniform(main.parkingArea.getY(), main.parkingArea.getY() + main.parkingArea.getHeight());
        mb.setXY(x, y);
    } */

    public void placeNearNodeWithJitter(Resource mb, PointNode n) {
        if (mb == null || n == null)
        	return;
        mb.setXY(n.getX() + main.uniform(-2, 2), n.getY() + main.uniform(-2, 2));
    }

    public void placeInQcStagingArea(Resource mb) {
        if (mb == null || main.qcStagingArea == null)
        	return;
        
        // put the box inside qcStagingArea visually
        double x = main.uniform(main.qcStagingArea.getX(), main.qcStagingArea.getX() + main.qcStagingArea.getWidth());
        double y = main.uniform(main.qcStagingArea.getY(), main.qcStagingArea.getY() + main.qcStagingArea.getHeight());
        mb.setXY(x, y);
        mb.jumpTo(x, y);
    }
    
    public void placeInParkingArea(ProcurementOrder po) {
        if (po == null || main.parkingArea == null)
        	return;
        
        // Move truck to a parking/wait node (define one)
        if (!po.movedToPark) {
        	double x = main.parkingArea.getX() + main.uniform(0, main.parkingArea.getWidth());
        	double y = main.parkingArea.getY() + main.uniform(0, main.parkingArea.getHeight());
        	po.truck.moveTo(x, y);
        	po.movedToPark = true;
        }
    }
    
    // ======================================================
    // Dock availability + “park if busy” (realistic)
    // ======================================================    
    private int tryReserveDock() {
  	  for (int i = 0; i < main.inboundDockBusy.length; i++) {
  	    if (!main.inboundDockBusy[i]) {
  	    	main.inboundDockBusy[i] = true;  // RESERVE here immediately (atomic)
  	      return i;
  	    }
  	  }
  	  return -1;
  	}

  	public void releaseDock(int idx) {
  	  if (idx >= 0 && idx < main.inboundDockBusy.length)
  		  main.inboundDockBusy[idx] = false;
  	}
  	
  	public boolean dockReservedForPo(ProcurementOrder po) {
		if (po.dockReserved)
			return true; // already reserved earlier

		int idx = this.tryReserveDock();
		if (idx >= 0) {
		  po.dockIdx = idx;
		  po.poSim.assignedDockIdx = idx;
		  po.dockReserved = true;	
		  return true;
		}
		return false;
	}
    
    // ======================================================
    // QC decision + routing
    // ======================================================
    public void setQcResult(Resource mb) {
        if (mb == null)
        	return;

        // Example: % reject differs by SKU type
        double pFail;
        switch (mb.getMotherBox().getSkuType()) {
            case DISPLAY:   pFail = 0.01; break;
            case MICROCHIP: pFail = 0.03; break;
            case BATTERY:   pFail = 0.04; break;
            case CASE:      pFail = 0.01; break;
            case STRAP:     pFail = 0.01; break;
            default:        pFail = 0.02;
        }
        
        mb.inboundQcPassed = (main.uniform(0, 1) > pFail);
    }

    public boolean routeQcPassFail(Resource mb) {
        return mb != null && mb.inboundQcPassed;
    }
    
	public boolean isTruckMoving(ProcurementOrder job) {
		return job.truck != null && job.truck.isMoving();
	}

	public int unloadTimePerPO(ProcurementOrder po) {
		return (po.poSim != null ? po.poSim.expectedBoxes : 1) * po.unloadTimePerBox;
	}
    
	public int offloadTimePerPO(ProcurementOrder po) {
		if (po == null) 
			return 10;
		
		return po.boxesByLane.get(po.currentLane).size() * po.offloadTimePerBox;
	}	
    
    
    public void debugCreatePO(String skuId, int units, double etaSeconds) {
        if (skuId == null || skuId.isEmpty() || units <= 0) {
            Logger.warn("debugCreatePO invalid args");
            return;
        }

        Resource vendor = this.policy.chooseVendorForSkuId(skuId);
        if (vendor == null) {
            Logger.warn("debugCreatePO: No vendor for skuId=", skuId);
            return;
        }

        // Round to boxes + MOQ exactly like real procurement
        int needUnits = units;
        int orderUnits = this.policy.applyBoxAndMoqRounding(vendor, skuId, needUnits);

        LinkedHashMap<String,Integer> lines = new LinkedHashMap<>();
        lines.put(skuId, orderUnits);

        // Create PO using your normal method
        createPurchaseOrderSimAndScheduleInbound(vendor, lines);

        // Override ETA to be soon (for testing)
        PurchaseOrderSim po = main.poBySimId.get(nextPoSimId - 1); // last created
        if (po != null) {
            po.etaSec = main.time() + Math.max(0.01, etaSeconds);

            // Re-arm arrival event (since ETA changed)
            // If inboundEtaQ is a PriorityQueue, you should remove+add to refresh order
            main.inboundEtaQ.remove(po);
            main.inboundEtaQ.add(po);

            armInboundArrivalEvent();

            Logger.info("DEBUG PO(sim) ", po.simId, " sku=", skuId, " orderUnits=", orderUnits,
                        " etaSeconds=", etaSeconds, " vendor=", po.vendorName);
        }
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1767741231118</Id>
			<Name><![CDATA[BootstrapService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * BootstrapService
 */	
public class BootstrapService {

	private final Main main;
    private final InitService init;
    private final MasterDataService masterData;
    private final SlottingInitService slottingInit;
    private final InventorySeedService inventorySeed;
    private final ProcurementPolicyService procurementPolicy;

    public BootstrapService(
            Main main,
            InitService init,
            MasterDataService masterData,
            SlottingInitService slottingState,
            InventorySeedService inventorySeed,
            ProcurementPolicyService procurementPolicy
    ) {
        this.main = main;
        this.init = init;
        this.masterData = masterData;
        this.slottingInit = slottingState;
        this.inventorySeed = inventorySeed;
        this.procurementPolicy = procurementPolicy;
    }
    
    public void bootstrapModel() {
    	this.configureLogging();
    	this.bootstrap();
    }

    private void configureLogging() {
    	Logger.enableSimDayFileLogging("logs", "smartwatch",
    			main.getEngine().getStartDate(),
    			() -> main.time()
    	);
    	
    	Logger.setFileFlushEveryLines(1000);

    	// Level + color + sink
    	Logger.setLogLevel(Configuration.logLevel);
    	Logger.setColorMode(Configuration.colorMode);
    	Logger.setSink(Configuration.useStdoutInsteadOfAnyLogic ? Logger.Sink.STDOUT : Logger.Sink.ANYLOGIC);
    	
    	// Choose console output separately (recommended: true for debugging, false for 6-month runs)
    	Logger.setConsoleEnabled(Configuration.enableConsoleLogs);
    }

    /** Recommended new bootstrap orchestration (replace Main.bootstrapModel body with this call). */
    private void bootstrap() {
        Logger.info("=== Model bootstrap starting ===");

        init.initLayoutAndWorkers();
        masterData.initializeDatabaseAndMasters();
        
        slottingInit.initSlotMaps();
        slottingInit.initRmSlots();
        // slottingInit.debugRmVariantLayout(PRODUCT_TYPE.CASE);
        // slottingInit.debugRmVariantLayout(PRODUCT_TYPE.STRAP);
        slottingInit.initFgSlots();

        inventorySeed.loadInitialInventory();
        // inventorySeed.debugInitialInvTargets();
        procurementPolicy.initDefaults();
        
        init.initInventoryKpis();

        Logger.info("=== Model bootstrap done ===");
        Logger.log(null);
    }
    
    public void operationalScheduler() {
    	if (Configuration.enableAutoEvents) {

    	    // main dispatch loop (keeps the factory “alive”)
    	    main.event.restart(0.1);

    	    // procurement review loop
    	    main.procurementPlannerEvent.restart(60); // give bootstrap 1 minute

    	    // outbound shipping loops
    	    main.outboundTruckDispatcher.restart(120);
    	    main.outboundTruckPoller.restart(0.2);

    	    // holds recalculation (only if you actually rely on Hold condition release)
    	    main.recalculateHoldCalculations.restart(0.5);

    	    // (optional) diagnostics
    	    main.checkOverfillSku.restart(3600);

    	    // If you want periodic Odoo master refresh, start it once
    	    main.odooMasterSync.restart(900);
    	}
    }
}]]></Text>
		</JavaClass>
