			<AdditionalClassCode><![CDATA[// -------------------------------------------------------------
// Core handles / sessions (Odoo, DB, time, global services)
// -------------------------------------------------------------
public transient OdooUtils.OdooSession m_odooSession;
public transient Connection m_dbConn;

public transient MainService services; // if you have a services aggregator

// ------------------------------------------------------
// Vendors, Distributorrs & Workcenters
// ------------------------------------------------------
public LinkedHashMap<Integer, Resource> vendorsById 			= new LinkedHashMap<>();
public LinkedHashMap<Integer, Resource> distributorsById 		= new LinkedHashMap<>();
public Map<STAGE, Integer> workCentersByCode					= new HashMap<>();

// -------------------------------------------------------------
// Master data / catalog mappings (read-only after init)
// -------------------------------------------------------------
// ---- Purchasable products
public Map<String, Integer> productIdBySkuId					= new HashMap<>();
public Map<String, String>  skuRawTypeBySkuId					= new HashMap<>();
public Map<PRODUCT_TYPE, List<String>> skuIdsBySkuType			= new EnumMap<>(PRODUCT_TYPE.class);
public Map<String, Double> rmCostPriceBySkuId					= new HashMap<>();
public Map<String, Double>  weightBySkuId						= new HashMap<>();
public Map<String, Integer> unitsPerBoxBySkuId					= new HashMap<>();

// live inventory snapshots
public Map<String, Double> liveOnHandBySkuId					= new HashMap<>();

// ---- Saleable Products
public Map<String, Integer> saleableProductIdBySkuId			= new HashMap<>();
public Map<String, Integer> saleableProductTmplIdBySkuId		= new HashMap<>();
public Map<String, Integer> saleableProductUnitsPerBoxBySkuId	= new HashMap<>();
// public Map<FG_SKU, Double> saleableProductCostBySkuId			= new HashMap<>();
public Map<String, Double> fgSalesPriceBySkuId					= new HashMap<>();
public Map<String, Double> fgCostPriceBySkuId					= new HashMap<>(); // optional

// -------------------------------------------------------------
// Layout / nodes / seats / select outputs (static references)
// -------------------------------------------------------------
// ---- RM layout
public PointNode[] RM_RACK_STARTS;
public PointNode[] RM_RACK_ENDS;
public PointNode[] RM_PICKER_SEATS;
public PointNode[] RM_STOWER_SEATS;
public PointNode[] RM_STOWER_CORRIDOR_NODES;

public int[] rmEndLoad;   // how many pickers are committed to each RM end point

// ---- Inbound layout
public PointNode[] INBOUND_DOCK_NODES;
public PointNode[] INBOUND_LANE_NODES;
public PointNode[] INBOUND_QC_NODES;
public PointNode[] INBOUND_WORKER_SEATS;
public PointNode QC_STAGING_E_NODE;

public EnumMap<PRODUCT_TYPE, Integer> inboundLaneIdxByType 		= new EnumMap<>(PRODUCT_TYPE.class);
public boolean[] inboundDockBusy;
public List<SelectOutputOut<ProcurementOrder>> DOCK_OUTS;

// ---- FG layout
public PointNode[] FG_RACK_STARTS;
public PointNode[] FG_RACK_ENDS;
public PointNode[] FG_PICKER_SEATS;
public PointNode[] FG_STOWER_SEATS;
public PointNode[] FG_STOWER_CORRIDOR_NODES;
public PointNode FG_STAGING_E_NODE;

// ---- Packing / outbound layout
public PointNode[] PACK_STATION_NODES;
public PointNode CO_PACK_STAGING_E_NODE;
public PointNode[] OUTBOUND_WORKER_SEATS;
public PointNode[] OUTBOUND_DOCK_NODES;

// ---- Vendor / conveyor
public PointNode[] VENDOR_ENTRIES;
public ConveyorPath[] CONVEYOR_IN;

// ---- Manufacturing routing (SelectOutputOut)
public List<SelectOutputOut<WipUnit>> ASSEMBLY_OUTS;
public List<SelectOutputOut<WipUnit>> SOFTWARE_OUTS; 
public List<SelectOutputOut<WipUnit>> PACKAGE_OUTS;
public List<SelectOutputOut<WipUnit>> BATCH_OUTS;

// ---- Multi-Station transition
public final int[] inTransitAsm = new int[ManufacturingConfigService.nAssembly];
public final int[] inTransitSw = new int[ManufacturingConfigService.nSoftwareIntegration];
public final int[] inTransitPs = new int[ManufacturingConfigService.nPackaging];

// -------------------------------------------------------------
// Storage / slotting state (shared warehouse state)
// -------------------------------------------------------------
public EnumMap<PRODUCT_TYPE, List<RmSlot>> rmSlotsBySku;
public EnumMap<FG_SKU, List<FgSlot>>       fgSlotsBySku;

// slot availability / empty-slot queues
public ArrayDeque<RmSlot> pendingEmptyRmSlots = new ArrayDeque<>();
public HashSet<RmSlot> pendingEmptyRmSlotsSet = new HashSet<>();

public ArrayDeque<FgSlot> pendingEmptyFgSlots = new ArrayDeque<>();
public HashSet<FgSlot> pendingEmptyFgSlotsSet = new HashSet<>();

// -------------------------------------------------------------
// Inbound flow state (RM receiving / QC / stowing)
// -------------------------------------------------------------
public LinkedList<Resource> waitingRmBoxes			= new LinkedList<>();
public PriorityQueue<PurchaseOrderSim> inboundEtaQ	= new PriorityQueue<>(Comparator.comparingDouble(p -> p.etaSec));
public LinkedList<MrpOrder> waitingMrpOrders		= new LinkedList<>();

// -------------------------------------------------------------
// Outbound flow state (orders / picking / staging / shipping)
// -------------------------------------------------------------
// customer order lifecycle lists
public LinkedList<CustomerOrder> pendingCustomerOrders	= new LinkedList<>();
public LinkedList<CustomerOrder> pickingCustomerOrders	= new LinkedList<>();
public LinkedList<CustomerOrder> shippedCustomerOrders	= new LinkedList<>();
public LinkedList<CustomerOrder> stagedCustomerOrders	= new LinkedList<>();

public LinkedList<CustomerOrder> pendingPackingOrders	= new LinkedList<>();
public LinkedList<CustomerOrder> coStagingQueue			= new LinkedList<>();

// outbound docks
public OutboundDockState[] outboundDocks = new OutboundDockState[Constants.OUTBOUND_DOCK_STATIONS];
public LinkedList<CustomerOrder>[] waitingForDock;

// packing stations
public CustomerOrderPackStation[] coPackStations = new CustomerOrderPackStation[Constants.CO_PACK_STATIONS];

// -------------------------------------------------------------
// Tray forming / WIP grouping (variant forming buffers)
// -------------------------------------------------------------
public LinkedList<Resource> waitingFgTrays = new LinkedList<>();

public List<WipUnit> metForming;
public List<WipUnit> fwForming;
public List<WipUnit> fbForming;

// -------------------------------------------------------------
// Procurement policy parameters + runtime tracking
// -------------------------------------------------------------
// policy parameters (computed / configured)
public Map<String, Integer> ropUnitsBySkuId							= new HashMap<>();
public Map<String, Integer> orderUpToUnitsBySkuId					= new HashMap<>();
public Map<String, Double> reviewPeriodHoursBySkuId					= new HashMap<>();
public Map<String, Integer> jitSafetyUnitsBySkuId					= new HashMap<>();

// Defaults keyed by ProductType (easy “same policy for all CASE variants”)
public Map<PRODUCT_TYPE, Integer> ropUnitsDefaultBySkuType			= new EnumMap<>(PRODUCT_TYPE.class);
public Map<PRODUCT_TYPE, Integer> orderUpToUnitsDefaultBySkuType	= new EnumMap<>(PRODUCT_TYPE.class);
public Map<PRODUCT_TYPE, Double> reviewPeriodHoursDefaultBySkuType	= new EnumMap<>(PRODUCT_TYPE.class);
public Map<PRODUCT_TYPE, Integer> jitSafetyUnitsDefaultBySkuType	= new EnumMap<>(PRODUCT_TYPE.class);

// runtime tracking
public Map<String, Integer> rmOnOrderUnitsBySkuId					= new HashMap<>();
public Map<String, Double> nextReviewDueSecBySkuId					= new HashMap<>();

// link sim PO -> Odoo PO
public Map<Integer, PurchaseOrderSim> poBySimId						= new HashMap<>();

// -------------------------------------------------------------
// Demand statistics / lead-time stats (Welford trackers)
// -------------------------------------------------------------
public Map<String, Integer> rmConsumedTodayBySkuId					= new HashMap<>();

public Map<String, Double> rmDailyMeanBySkuId						= new HashMap<>();
public Map<String, Double> rmDailyM2BySkuId							= new HashMap<>(); // Welford M2 accumulator
public Map<String, Double> rmDailyVarBySkuId						= new HashMap<>();
public Map<String, Integer> rmDaysObservedBySkuId					= new HashMap<>();

public double lastStatsDay = 0;

public Map<String, LeadTimeStats> leadTimeStatsDaysForSkuId			= new HashMap<>();

/** ************************************************** **/
// Runtime state
private double odooCurrentPeriod = Constants.HEARTBEAT_BASE_SEC;

// ERP / stock locations
public int stockLocationId = -1;

// Inbound Qc Operator
int qcOpCounter = 0;
/** ************************************************** **/

// ================= KPI STORAGE (Main) =================
// Service level
public long kpiDemandUnitsTotal = 0;
public long kpiDemandUnitsShipped = 0;
public long kpiDemandUnitsCancelled = 0;

// Procurement lead time (seconds)
public long kpiPoCount = 0;
public double kpiPoLeadSum = 0;
public double kpiPoLeadMin = Double.POSITIVE_INFINITY;
public double kpiPoLeadMax = 0;
public long kpiPoCreatedCount = 0;

// Unit throughput (seconds) and MO cycle time (seconds)
public long kpiUnitDoneCount = 0;
public double kpiUnitThroughputSum = 0;

public long kpiMoDoneCount = 0;
public double kpiMoCycleSum = 0;

// Scrap counters
public long kpiScrapQC1Max = 0;
public long kpiScrapQC2Max = 0;
public long kpiScrapOther = 0;

// Scrap per variant
public EnumMap<FG_SKU, Long> kpiScrapByVariant = new EnumMap<>(FG_SKU.class);
public EnumMap<FG_SKU, Long> kpiGoodByVariant  = new EnumMap<>(FG_SKU.class);

// Step times (processing times) per stage
public EnumMap<STAGE, Long>   kpiStepCount = new EnumMap<>(STAGE.class);
public EnumMap<STAGE, Double> kpiStepSum   = new EnumMap<>(STAGE.class);

public long kpiCoShippedCount = 0;
public double kpiCoLeadSum = 0;
public double kpiCoLeadMin = Double.POSITIVE_INFINITY;
public double kpiCoLeadMax = 0;

public DataSet kpiServiceLevel = new DataSet(Constants.KPI_DATASET_CAPACITY); // "ServiceLevel"
public DataSet kpiThroughputTime = new DataSet(Constants.KPI_DATASET_CAPACITY); // "ThroughputTime"
public DataSet kpiScrapRate = new DataSet(Constants.KPI_DATASET_CAPACITY); // "ScrapRate"
public DataSet kpiScrapCost = new DataSet(Constants.KPI_DATASET_CAPACITY);  // ("ScrapCost");
public DataSet kpiProductCost = new DataSet(Constants.KPI_DATASET_CAPACITY);  // ("ProductCost");

public DataSet kpiAsmOpsUtilization = new DataSet(Constants.KPI_DATASET_CAPACITY); // "AsmOpsUtilization"
public DataSet kpiSwOpsUtilization = new DataSet(Constants.KPI_DATASET_CAPACITY); // "SwOpsUtilization"
public DataSet kpiQcOpsUtilization = new DataSet(Constants.KPI_DATASET_CAPACITY); // "QcOpsUtilization"
public DataSet kpiReworkOpsUtilization = new DataSet(Constants.KPI_DATASET_CAPACITY); // "ReworkOpsUtilization"
public DataSet kpiPackOpsUtilization = new DataSet(Constants.KPI_DATASET_CAPACITY); // "PackOpsUtilization"
public DataSet kpiSortOpsUtilization = new DataSet(Constants.KPI_DATASET_CAPACITY); // "SortOpsUtilization"
public DataSet kpiIbQcOpsUtilization = new DataSet(Constants.KPI_DATASET_CAPACITY); // "IbQcOpsUtilization"
public DataSet kpiIbWorkerOpsUtilization = new DataSet(Constants.KPI_DATASET_CAPACITY); // "IbWorkerOpsUtilization"

public DataSet kpiRmPickerUtilization = new DataSet(Constants.KPI_DATASET_CAPACITY);
public DataSet kpiFgPickerUtilization = new DataSet(Constants.KPI_DATASET_CAPACITY);
public DataSet kpiRmStowerUtilization = new DataSet(Constants.KPI_DATASET_CAPACITY);
public DataSet kpiFgStowerUtilization = new DataSet(Constants.KPI_DATASET_CAPACITY);

public DataSet kpiOutboundWorkerUtilization = new DataSet(Constants.KPI_DATASET_CAPACITY);
public DataSet kpiOutboundDockUtilization = new DataSet(Constants.KPI_DATASET_CAPACITY);   // optional but very useful

public DataSet kpiPoLeadAvg = new DataSet(Constants.KPI_DATASET_CAPACITY);
public DataSet kpiMoCycleAvg = new DataSet(Constants.KPI_DATASET_CAPACITY);
public DataSet kpiCoLeadAvg = new DataSet(Constants.KPI_DATASET_CAPACITY);

// Add backlog/queue KPIs
public DataSet kpiMoBacklog = new DataSet(Constants.KPI_DATASET_CAPACITY);        // waitingMrpOrders
public DataSet kpiCoBacklog = new DataSet(Constants.KPI_DATASET_CAPACITY);        // pendingCustomerOrders

public DataSet kpiPackingBacklog = new DataSet(Constants.KPI_DATASET_CAPACITY);   // pendingPackingOrders


// =============================================================
// Inventory-policy KPI storage (NEW)
// =============================================================

// RM inventory time-series (TOTAL + shared-only)
public DataSet kpiRmOnHandTotal  = new DataSet(Constants.KPI_DATASET_CAPACITY);
public DataSet kpiRmInvPosTotal  = new DataSet(Constants.KPI_DATASET_CAPACITY);
public DataSet kpiRmOnHandShared = new DataSet(Constants.KPI_DATASET_CAPACITY);
public DataSet kpiRmInvPosShared = new DataSet(Constants.KPI_DATASET_CAPACITY);

public DataSet kpiRmInventoryValue = new DataSet(Constants.KPI_DATASET_CAPACITY);

// Stockout tracking (per RM sku_id string)
public Map<String, Boolean> rmInStockout = new HashMap<>();
public Map<String, Double>  rmStockoutStartTimeSec = new HashMap<>();
public Map<String, Long>    kpiRmStockoutEvents = new HashMap<>();
public Map<String, Double>  kpiRmStockoutTimeDays = new HashMap<>();

// PO ordering behaviour
public double kpiPoUnitsOrderedTotal = 0.0;
public Map<String, Double> kpiPoUnitsOrderedBySkuId = new HashMap<>();
public DataSet kpiPoAvgOrderSizeUnits = new DataSet(Constants.KPI_DATASET_CAPACITY);

public DataSet kpiPoCreatedCountDs = new DataSet(Constants.KPI_DATASET_CAPACITY);
public DataSet kpiPoCompletedCount = new DataSet(Constants.KPI_DATASET_CAPACITY);

// Cost time-series (cumulative)
public DataSet kpiHoldingCost  = new DataSet(Constants.KPI_DATASET_CAPACITY);
public DataSet kpiOrderingCost = new DataSet(Constants.KPI_DATASET_CAPACITY);
public DataSet kpiTotalCost    = new DataSet(Constants.KPI_DATASET_CAPACITY);

public double totalHoldingCost  = 0.0;
public double totalOrderingCost = 0.0;
]]></AdditionalClassCode>
