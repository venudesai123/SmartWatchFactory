							<Value Class="CodeValue">
								<Code><![CDATA[ProcurementOrder po = (ProcurementOrder) agent;

// Move truck to exit
if (po.truck != null) {
    po.truck.moveTo(this.inboundTruckExitNode);
    po.movedToExit = true;
}

// Release dock reservation
if (po.dockIdx >= 0) {
    this.services.inboundPoFlow.releaseDock(po.dockIdx);
}
]]></Code>
