				<Event>
					<Id>1768342983183</Id>
					<Name><![CDATA[odooHeartbeat]]></Name>
					<X>840</X><Y>-2370</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="userControls">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[uniform(2, 10);]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_SECOND]]></Unit>
						</Rate>
						<Id>1753899529599</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1764576000000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[if(!Configuration.enableAutoEvents) 
	return;

if (m_odooSession != null && stockLocationId > 0) {
	try {
		if (this.stockLocationId > 0) {
			Set<String> skus = new LinkedHashSet<>(this.productIdBySkuId.keySet()); // all known SKUs
	        Map<String, Double> fresh = OdooLiveService.fetchOnHandBySkuIds(this, skus, this.stockLocationId, "ODOO Hearbeat");
	        
	        // Update your “live” cache
	        this.liveOnHandBySkuId.clear();
	        this.liveOnHandBySkuId.putAll(fresh);
	        
	        this.odooCurrentPeriod = Constants.HEARTBEAT_BASE_SEC; // success → reset backoff
	        
	        // (Optional) if you use dynamic slot proportionality, recompute quotas here
	    	// and mark which slots are claimable or plan replenishment, etc.
		}
	
	} catch (Exception ex) {
	    Logger.warn("odooHeartbeat: ", ex);
	    this.odooCurrentPeriod = Math.min(
	    								Constants.HEARTBEAT_MAX_SEC,
	    								Math.max(Constants.HEARTBEAT_BASE_SEC, this.odooCurrentPeriod * Constants.HEARTBEAT_BACKOFF_MULT));
	}
} else {
	this.odooCurrentPeriod = Math.min(
									Constants.HEARTBEAT_MAX_SEC,
									Math.max(Constants.HEARTBEAT_BASE_SEC, this.odooCurrentPeriod * Constants.HEARTBEAT_BACKOFF_MULT));
}

// reschedule
this.odooHeartbeat.restart(this.odooCurrentPeriod);
]]></Action>
				</Event>
				<Event>
					<Id>1768342983193</Id>
					<Name><![CDATA[odooMasterSync]]></Name>
					<X>840</X><Y>-2340</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="userControls">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[900]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_SECOND]]></Unit>
						</Rate>
						<Id>1753899529598</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1764576000000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[try {
    if (m_odooSession != null) {
    	int wc = OdooSyncService.updateWorkCenters(this);
        int v = OdooSyncService.updateVendors(this);
        int p = OdooSyncService.updateProducts(this);
        int m = OdooSyncService.updateProductVendorMapping(this);
        Logger.info("Master sync-> work centers:", wc, " vendors:", v, " products:", p, " mappings:", m);
        
        this.services.masterData.initializeMasters();
		
		// best-effort lock cleanup (e.g., check up to 50 MOs per run)
        try {
            OdooMrpGateway.sweepMoLocks(this, 50);
        } catch (Exception ignore) { /* keep sync resilient */ }	
    }
} catch (Exception ex) {
    Logger.warn("odooMasterSync failed", ex);
}

this.odooMasterSync.restart(900.0); // every 15 minutes, say
]]></Action>
				</Event>
				<Event>
					<Id>1768342983201</Id>
					<Name><![CDATA[coPackingPoller]]></Name>
					<X>840</X><Y>-2310</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_SECOND]]></Unit>
						</Rate>
						<Id>1753899529597</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1764576000000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[true]]></Condition>
					</Properties>
					<Action><![CDATA[double now = time();
for (CustomerOrderPackStation ps : this.coPackStations) {
    if (ps.current != null && ps.finishTime >= 0 && now >= ps.finishTime) {
        CustomerOrder co = ps.current;
        ps.current = null;
        ps.finishTime = -1;

        this.services.coFlow.onPackingFinished(ps, co);
    }
}
]]></Action>
				</Event>
