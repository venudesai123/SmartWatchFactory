		<JavaClass>
			<Id>1767740101224</Id>
			<Name><![CDATA[InventorySeedService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * InventorySeedService
 */

public class InventorySeedService {

	private final Main main;
    private final SlottingService slotting;

    public InventorySeedService(Main main, SlottingService slotting) {
        this.main = main;
        this.slotting = slotting;
    }

    public void loadInitialInventory() {
        Logger.info("ServiceInventorySeed.loadInitialInventory: start");

        for (Map.Entry<String, Double> e : main.liveOnHandBySkuId.entrySet()) {

            final String skuId = e.getKey();
            final double unitsAvailable = e.getValue();

            final Integer pid = main.productIdBySkuId.get(skuId);
            final Integer upb = main.unitsPerBoxBySkuId.get(skuId);
            final double wt   = main.weightBySkuId.getOrDefault(skuId, 0.0);

            if (pid == null || upb == null || upb <= 0) {
                Logger.warn("loadInitialInventory: missing product/upb for ", skuId, " pid=", pid, " upb=", upb);
                continue;
            }

            final int targetBoxes = (int) Math.floor(unitsAvailable / upb);
            final int leftoverUnits = (int) (unitsAvailable - ((double) targetBoxes * upb));

            final int existingBoxes = (int) main.motherBoxes.stream()
                    .filter(mb -> skuId.equals(mb.getMotherBox().getSkuId()))
                    .count();

            final int delta = targetBoxes - existingBoxes;

            Logger.trace("SeedCheck: ", skuId,
                    ", units= ", unitsAvailable,
                    ", upb= ", upb,
                    ", targetBoxes= ", targetBoxes,
                    ", existing= ", existingBoxes,
                    ", delta= ", delta,
                    ", leftoverUnits=", leftoverUnits
            );

            if (delta <= 0) {
                if (leftoverUnits > 0)
                    Logger.debug("loadInitialInventory: ", skuId, " has ", leftoverUnits, " leftover units (<1 box).");
                continue;
            }

            final PRODUCT_TYPE skuType = PRODUCT_TYPE.fromSkuId(skuId);
            if (skuType == null) {
                Logger.warn("Unknown ProductType for ", skuId);
                continue;
            }

            for (int i = 0; i < delta; i++) {
                Resource resMb = main.add_motherBoxes();
                resMb.category = RESOURCE_TYPE.MOTHERBOX;
                resMb.setMotherBox(new MotherBox(skuType, pid, skuId, upb, wt));

                RmSlot slot = slotting.chooseRmSlotForUnits(skuId, upb);
                if (slot == null) {
                    Logger.warn("INIT: no RM slot available for sku=", skuId, " units=", upb);
                    continue;
                }

                slot.incomingBoxes += 1;
                slot.incomingUnits += upb;

                resMb.hasRackTarget = true;
                resMb.rackTargetRow   = slot.row;
                resMb.rackTargetCell  = slot.cell;
                resMb.rackTargetLevel = slot.level;

                resMb.rackTargetCloseToFront = true;
                resMb.rackTargetLeftAisle    = (slot.row == 0);

                main.initialInv.take(resMb);
            }

            if (leftoverUnits > 0)
                Logger.debug("loadInitialInventory: ", skuId, " leftover units after boxing = ", leftoverUnits);
        }

        Logger.info("ServiceInventorySeed.loadInitialInventory: done");
    }
    
    /* public Map<String, Double> fetchFabricatedStockBySkuId() {
    	Map<String, Double> seedBoxes = new LinkedHashMap<>();
    	seedBoxes.put("DISP001", 10000.0);
    	seedBoxes.put("MC001",   10000.0);
    	seedBoxes.put("BA001",   10000.0);
    	seedBoxes.put("CA001-MET", 6000.0);
    	seedBoxes.put("CA001-FW",  4500.0);
    	seedBoxes.put("CA001-FB",  4500.0);
    	seedBoxes.put("ST001-MET", 6000.0);
    	seedBoxes.put("ST001-FW",  4500.0);
    	seedBoxes.put("ST001-FB",  4500.0); 

    	return seedBoxes;
    } */
    
    public void debugInitialInvTargets() {
        Map<String, Integer> counts = new LinkedHashMap<>();

        for (Resource mb : main.motherBoxes) {
            if (mb == null || mb.getMotherBox() == null) continue;

            PRODUCT_TYPE pt = mb.getMotherBox().getSkuType();
            String key = pt + " [" + mb.rackTargetRow + "," + mb.rackTargetCell + "," + mb.rackTargetLevel + "]";

            counts.put(key, counts.getOrDefault(key, 0) + 1);
        }

        for (Map.Entry<String,Integer> e : counts.entrySet()) {
            if (e.getValue() > 1) {
                Logger.warn("INIT TARGET DUPLICATE: ", e.getKey(), " x", e.getValue());
            }
        }    	
    }
}]]></Text>
