		<JavaClass>
			<Id>1754924794137</Id>
			<Name><![CDATA[DatabaseUtils]]></Name>
			<Folder>1771290631309</Folder>
			<Text><![CDATA[/**
 * DatabaseUtils
 */	
import java.nio.file.Files;
import java.nio.file.Paths;
import java.nio.charset.StandardCharsets;
import java.sql.Connection;

public class DatabaseUtils {
	
	/**
     * Returns the AnyLogic embedded database connection.
     * Only works if your model has an embedded DB, so first have an database.
     */
    public static Connection getEmbeddedConnection(Main mainAgent) {
        try {
            Connection conn = mainAgent.getDatabaseConnection();
            Logger.info("Fetched Embedded Database Connection.");
            return conn;
        } catch (Exception e) {
        	Logger.error("Error fetching embedded database connection. Exception: ", e.getMessage());
            return null;
        }
    }
    
    public static boolean executeSqlScriptFromFile(Main mainAgent, String fileName) {
        try {
            // Load file contents
            String script = new String(Files.readAllBytes(Paths.get(fileName)), StandardCharsets.UTF_8);
            script = script.replace("\r\n", "\n"); // normalize newlines

            // Remove block comments
            script = script.replaceAll("(?m)^\\s*(/\\*{2,}.*?\\*{2,}/|/\\*.*?\\*/|/\\*.*|\\*/)\\s*$", "");

            // Split by semicolon + newline
            String[] statements = script.split("(?<=;)[ \\t]*[\\r\\n]+");

            // Ensure we have a DB connection
            if (mainAgent.m_dbConn == null) {
                mainAgent.m_dbConn = getEmbeddedConnection(mainAgent);
            }

            // Execute statements
            boolean allOk = true;
            for (String raw : statements) {
                String stmt = raw.trim();
                if (stmt.isEmpty() || stmt.startsWith("--") || stmt.startsWith("/*") || stmt.startsWith("/")) {
                    continue;
                }
                try {
                	Logger.info("Executing: ", stmt);
                    mainAgent.m_dbConn.createStatement().executeUpdate(stmt);
                } catch (Exception ex) {
                	Logger.error("Failed to execute:\n" + stmt, ex.getMessage());
                    allOk = false; // At least one statement failed
                }
            }

            if (allOk) {
            	Logger.info("SQL script executed successfully.");
            } else {
            	Logger.warn("SQL script executed with errors. Check log for details.");
            }

            return allOk;

        } catch (Exception e) {
        	Logger.error("Error executing SQL script: ", e.getMessage());
            return false;
        }
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1754926164490</Id>
			<Name><![CDATA[OdooUtils]]></Name>
			<Folder>1772891791304</Folder>
			<Text><![CDATA[/**
 * OdooUtils
 */	
import java.net.URL;
import java.util.Arrays;
import java.util.ArrayList;
import java.util.Collections;
import java.util.List;
import java.util.HashMap;
import java.util.Locale;
import java.util.Map;
import java.util.Date;
import java.text.SimpleDateFormat;
import java.text.ParseException;

import org.apache.xmlrpc.client.XmlRpcClient;
import org.apache.xmlrpc.client.XmlRpcClientConfigImpl;

public final class OdooUtils {
	
	// ----------  ----------
    public static class OdooSession {

    	public final int uid;
        public final XmlRpcClient client;    

        public OdooSession(int uid, XmlRpcClient client) {
            this.uid = uid;
            this.client = client;
        }
    }
	
	public static String BASE_URL = Configuration.odooBaseUrl; // 127.0.0.1, 192.168.0.114, 10.168.54.1
	public static final String AUTH_SERVICE = "common";
	public static final String DATA_ACCESS_SERVICE = "object";
	
	public static String DATABASE_NAME = Configuration.odooDatabaseName;
	public static String SERVER_USERNAME = Configuration.odooServerUserName;
	public static String SERVER_PASSWORD = Configuration.odooServerPassword;
	
	/**
     * Wrapper for execute_kw.
     * Example:
     *   Object res = executeKw(session, Constants.DATABASE_NAME, Constants.PASSWORD,
     *                          "res.partner", "search_read",
     *                          Arrays.asList(Arrays.asList(Arrays.asList("is_company","=",true))),
     *                          Map.of("fields", Arrays.asList("name","email"), "limit", 5));
     */
    public static Object executeKw(
            OdooSession session,
            String db,
            String password,
            String model,
            String method,
            Object args,                 // typically a List<Object>
            Map<String, Object> kwargs   // may be null
    ) throws Exception {
        if (session == null || session.client == null) {
            throw new IllegalStateException("OdooSession/client is null. Did you call connectAndPrepare()?");
        }
        Object[] payload = new Object[] {
            db,
            session.uid,
            password,
            model,
            method,
            args,
            (kwargs == null ? new HashMap<String, Object>() : kwargs)
        };
        return session.client.execute("execute_kw", payload);
    }
	
	private static OdooSession connectAndPrepare(String baseUrl, String db, String username, String password) {
        try {
            // --- Authenticate (common) ---
            XmlRpcClientConfigImpl authCfg = new XmlRpcClientConfigImpl();
            authCfg.setServerURL(new URL(ensureSlash(baseUrl) + AUTH_SERVICE));
            authCfg.setConnectionTimeout(10000);
            authCfg.setReplyTimeout(15000);

            XmlRpcClient authClient = new XmlRpcClient();
            authClient.setConfig(authCfg);

            Object uidObj = authClient.execute(
                "authenticate",
                Arrays.asList(db, username, password, new HashMap<String, Object>())
            );

            if (uidObj instanceof Boolean && !(Boolean) uidObj) {
            	Logger.warn("Odoo login failed: check DB/username/password.");
                return null;
            }
            if (!(uidObj instanceof Integer)) {
            	Logger.warn("Unexpected auth response type: " + uidObj);
                return null;
            }
            int uid = (Integer) uidObj;
            Logger.info("Odoo login OK. UID=" + uid);

            // --- Prepare /object client ---
            XmlRpcClientConfigImpl objCfg = new XmlRpcClientConfigImpl();
            objCfg.setServerURL(new URL(ensureSlash(baseUrl) + DATA_ACCESS_SERVICE));
            objCfg.setConnectionTimeout(10000);
            objCfg.setReplyTimeout(15000);

            XmlRpcClient objectClient = new XmlRpcClient();
            objectClient.setConfig(objCfg);

            Logger.info("XML-RPC client for /object is ready.");
            return new OdooSession(uid, objectClient);

        } catch (Exception e) {
        	Logger.error("connectAndPrepare failed: ", e.getMessage());
            return null;
        }
    }
	
	/** Convenience overload that uses your Constants. */
    public static OdooSession connectAndPrepare() {
        return connectAndPrepare(BASE_URL, DATABASE_NAME, SERVER_USERNAME, SERVER_PASSWORD);
    }
    
    // ---------- Adapters --------------
    // @SuppressWarnings("unchecked")
    public static List<Map<String, Object>> asListOfMaps(Object res) {
        if (res == null) return Collections.emptyList();

        if (res instanceof Object[]) {
            Object[] arr = (Object[]) res;
            List<Map<String, Object>> out = new ArrayList<>(arr.length);
            for (Object o : arr) {
                out.add((Map<String, Object>) o);  // each element is a struct/map
            }
            return out;
        }
        if (res instanceof List) {
        	List<?> list = (List<?>) res;
            List<Map<String, Object>> out = new ArrayList<>();
            for (Object o : list) if (o instanceof Map) out.add((Map<String, Object>) o);
            return out;
        }
        // Unexpected type
        return Collections.emptyList();
    }
    
    public static Map<String, Object> asMap(Object res) {
        if (res instanceof Map) return (Map<String, Object>) res;

        // If Odoo read() returned a list, take the first row
        if (res instanceof List) {
            List<?> list = (List<?>) res;
            if (!list.isEmpty() && list.get(0) instanceof Map)
                return (Map<String, Object>) list.get(0);
        }
        if (res instanceof Object[]) {
            Object[] arr = (Object[]) res;
            if (arr.length > 0 && arr[0] instanceof Map)
                return (Map<String, Object>) arr[0];
        }
        return null;
    }
    
    // @SuppressWarnings("unchecked")
    public static List<Integer> asListOfInts(Object val) {
        List<Integer> out = new ArrayList<>();
        if (val == null) return out;
        
        if (val instanceof List) {
            for (Object o : (List<?>) val) {
                Integer v = safeCastToInteger(o);
                if (v != null) out.add(v);
            }
            return out;
        }
        if (val instanceof Object[]) {
            for (Object o : (Object[]) val) {
                Integer v = safeCastToInteger(o);
                if (v != null) out.add(v);
            }
            return out;
        }
        if (val instanceof int[]) {
            for (int v : (int[]) val) out.add(v);
            return out;
        }
        if (val instanceof Integer) {
            out.add((Integer) val);
            return out;
        }
        // unknown shape → empty list
        return out;
    }
    
    // ---------- Additional helpers ----------
    public static int m2oId(Object m2o) {
        if (m2o == null) return 0;

        if (m2o instanceof Object[]) {
            Object[] arr = (Object[]) m2o;
            return arr.length > 0 ? safeCastToInteger(arr[0]) : 0;
        }

        if (m2o instanceof List) {
            List<?> list = (List<?>) m2o;
            return list.size() > 0 ? safeCastToInteger(list.get(0)) : 0;
        }

        // sometimes it’s already an Integer/Long
        return safeCastToInteger(m2o);
    }

    public static String m2oName(Object m2o) {
        if (m2o == null) return null;

        if (m2o instanceof Object[]) {
            Object[] arr = (Object[]) m2o;
            return arr.length > 1 ? safeCastToString(arr[1]) : null;
        }

        if (m2o instanceof List) {
            List<?> list = (List<?>) m2o;
            return list.size() > 1 ? safeCastToString(list.get(1)) : null;
        }

        return safeCastToString(m2o);
    }
    
    // ---------- Safe cast helpers ----------
    public static String safeCastToString(Object val) {
        if (val == null || val instanceof Boolean) {
            return "";
        }
        return val.toString();
    }
    
    public static double safeCastToDouble(Object val) {
        if (val == null || val instanceof Boolean) {
            return 0.0;
        }
        if (val instanceof Number) {
            return ((Number) val).doubleValue();
        }
        try {
            return Double.parseDouble(val.toString());
        } catch (NumberFormatException e) {
            return 0.0;
        }
    }

    public static int safeCastToInteger(Object val) {
        if (val == null || val instanceof Boolean) {
            return -1;
        }
        if (val instanceof Number) {
            return ((Number) val).intValue();
        }
        try {
            return Integer.parseInt(val.toString());
        } catch (NumberFormatException e) {
            return -1;
        }
    }
    
    public static boolean safeCastToBoolean(Object val) {
        if (val instanceof Boolean) {
            return (Boolean) val;
        }
        if (val instanceof Number) {
            return ((Number) val).intValue() != 0;
        }
        if (val instanceof String) {
        	String s = ((String) val).trim().toLowerCase(Locale.ROOT);
        	return s.equals("true") || s.equals("1") || s.equals("yes") || s.equals("y") || s.equals("on");
        }
        return false;
    }
    
    /**
     * Safe: returns java.util.Date or null.
     * Handles:
     *  - Date instance (returned as-is)
     *  - String dates common in Odoo: "yyyy-MM-dd", "yyyy-MM-dd HH:mm:ss",
     *    ISO-like "yyyy-MM-dd'T'HH:mm:ss" with optional ".SSS"
     *  - Numeric epoch (heuristic: seconds or milliseconds)
     */    
    public static Date safeCastToDate(Object val) {
        if (val == null || val instanceof Boolean) return null;

        if (val instanceof Date) return (Date) val;

        if (val instanceof Number) {
            long n = ((Number) val).longValue();
            // If it looks like seconds, convert to ms
            if (n > 0 && n < 1_000_000_000_000L) n *= 1000L;
            return new Date(n);
        }

        if (val instanceof String) {
            return tryParseDateString(((String) val).trim());
        }

        // last resort: toString()
        try {
            return tryParseDateString(val.toString().trim());
        } catch (Exception ignore) {
            return null;
        }
    }

    // ---------- date parsing helpers ----------

    private static Date tryParseDateString(String s) {
        if (s == null || s.isEmpty()) return null;

        String[] patterns = {
            "yyyy-MM-dd HH:mm:ss",
            "yyyy-MM-dd'T'HH:mm:ss",
            "yyyy-MM-dd'T'HH:mm:ss.SSS",
            "yyyy-MM-dd"
        };

        for (String p : patterns) {
            Date d = parseWithPattern(s, p);
            if (d != null) return d;
        }
        return null;
    }

    private static Date parseWithPattern(String text, String pattern) {
        try {
            SimpleDateFormat fmt = new SimpleDateFormat(pattern, Locale.ROOT);
            fmt.setLenient(false);
            return fmt.parse(text);
        } catch (ParseException e) {
            return null;
        }
    }
    
    
    // ---------- Ensures base URL ends with a single slash ----------
    private static String ensureSlash(String url) {
        return url.endsWith("/") ? url : url + "/";
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1755141629044</Id>
			<Name><![CDATA[OdooSyncService]]></Name>
			<Folder>1771290566546</Folder>
			<Text><![CDATA[/**
 * OdooSyncService
 */	
import java.sql.*;
import java.util.*;

public final class OdooSyncService {
	
	// ---------- Public entry points ----------
	public static int updateWorkCenters(Main main) {
	    if (!ensureSessionAndDb(main)) 
	        return 0;

	    final String SQL =
	            "MERGE INTO work_centers wc " +
	            "USING (VALUES (?, ?, ?, ?, ?)) s(wc_id, wc_name, wc_code, capacity, active) " +
	            "ON (wc.wc_id = s.wc_id) " +
	            "WHEN MATCHED THEN UPDATE SET " +
	            "  wc_name = s.wc_name, " +
	            "  wc_code = s.wc_code, " +
	            "  capacity = s.capacity, " +
	            "  active = s.active " +
	            "WHEN NOT MATCHED THEN INSERT (wc_id, wc_name, wc_code, capacity, active) " +
	            "  VALUES (s.wc_id, s.wc_name, s.wc_code, s.capacity, s.active)";

	    final int pageSize = 200;
	    int offset = 0, total = 0;

	    boolean prevAuto = setTx(main.m_dbConn, false);

	    try (PreparedStatement ps = main.m_dbConn.prepareStatement(SQL)) {
	        while (true) {
	            List<Map<String,Object>> page = fetchPage(
	                main.m_odooSession,
	                "mrp.workcenter",
	                "search_read",
	                Arrays.asList(),  // Add any filters here if needed
	                Arrays.asList("id", "name", "code", "default_capacity", "active"),
	                pageSize, offset
	            );

	            if (page.isEmpty())
	                break;

	            for (Map<String,Object> wc : page) {
	                ps.setInt(1, OdooUtils.safeCastToInteger(wc.get("id")));
	                ps.setString(2, OdooUtils.safeCastToString(wc.get("name")));
	                ps.setString(3, OdooUtils.safeCastToString(wc.get("code")));
	                ps.setInt(4, OdooUtils.safeCastToInteger(wc.get("default_capacity")));
	                ps.setBoolean(5, Boolean.TRUE.equals(wc.get("active")));
	                ps.addBatch();
	            }

	            total += ps.executeBatch().length;

	            if (page.size() < pageSize)
	                break;
	            offset += pageSize;
	        }

	        main.m_dbConn.commit();
	    } catch (Exception e) {
	        rollbackQuiet(main.m_dbConn);
	        Logger.error("updateWorkCenters: ", e.getMessage());
	        total = 0;
	    } finally {
	        restoreAuto(main.m_dbConn, prevAuto);
	    }
	    return total;
	}
	
	public static int updateDistributors(Main main) {

	    if (!ensureSessionAndDb(main))
	        return 0;

	    final String SQL =
	        "MERGE INTO distributors d " +
	        "USING (VALUES (?, ?, ?, ?, ?, ?, ?, ?)) s(" +
	        "  partner_id, distributor_sim_name, customer_name, " +
	        "  customer_address, customer_pincode, customer_city, " +
	        "  customer_country, active" +
	        ") " +
	        "ON (d.partner_id = s.partner_id) " +
	        "WHEN MATCHED THEN UPDATE SET " +
	        "  distributor_sim_name = s.distributor_sim_name, " +
	        "  customer_name        = s.customer_name, " +
	        "  customer_address     = s.customer_address, " +
	        "  customer_pincode     = s.customer_pincode, " +
	        "  customer_city        = s.customer_city, " +
	        "  customer_country     = s.customer_country, " +
	        "  active               = s.active " +
	        "WHEN NOT MATCHED THEN INSERT (" +
	        "  partner_id, distributor_sim_name, customer_name, " +
	        "  customer_address, customer_pincode, customer_city, " +
	        "  customer_country, active" +
	        ") VALUES (" +
	        "  s.partner_id, s.distributor_sim_name, s.customer_name, " +
	        "  s.customer_address, s.customer_pincode, s.customer_city, " +
	        "  s.customer_country, s.active" +
	        ")";

	    final int pageSize = 200;
	    int offset = 0, total = 0;

	    boolean prevAuto = setTx(main.m_dbConn, false);

	    try (PreparedStatement ps = main.m_dbConn.prepareStatement(SQL)) {
	        while (true) {
	            // --- Fetch active customers from Odoo ---
	            List<Map<String,Object>> page = fetchPage(
	                main.m_odooSession,
	                "res.partner",
	                "search_read",
	                Arrays.asList(
	                    Arrays.asList("active", "=", true),
	                    Arrays.asList("customer_rank", ">", 0)
	                    // If you have a specific "Distributor" tag/category,
	                    // add it here as an extra domain filter.
	                ),
	                Arrays.asList("id", "name", "street", "street2",
	                              "zip", "city", "country_id", "active"),
	                pageSize,
	                offset
	            );

	            if (page.isEmpty())
	                break;

	            for (Map<String, Object> c : page) {
	                int    partnerId = OdooUtils.safeCastToInteger(c.get("id"));
	                String simName   = "Dist_" + partnerId; // or build a nicer code if you want
	                String name      = OdooUtils.safeCastToString(c.get("name"));
	                String addr      = joinSpace(
	                        OdooUtils.safeCastToString(c.get("street")),
	                        OdooUtils.safeCastToString(c.get("street2"))
	                );
	                String zip       = OdooUtils.safeCastToString(c.get("zip"));
	                String city      = OdooUtils.safeCastToString(c.get("city"));
	                String country   = OdooUtils.m2oName(c.get("country_id"));
	                boolean active   = Boolean.TRUE.equals(c.get("active"));

	                ps.setInt(1, partnerId);
	                ps.setString(2, simName);
	                ps.setString(3, name);
	                ps.setString(4, addr);
	                ps.setString(5, zip);
	                ps.setString(6, city);
	                ps.setString(7, country);
	                ps.setBoolean(8, active);
	                ps.addBatch();
	            }

	            total += ps.executeBatch().length;

	            if (page.size() < pageSize)
	                break;
	            offset += pageSize;
	        }

	        main.m_dbConn.commit();
	    } catch (Exception e) {
	        rollbackQuiet(main.m_dbConn);
	        Logger.error("updateDistributors: ", e.getMessage());
	        total = 0;
	    } finally {
	        restoreAuto(main.m_dbConn, prevAuto);
	    }
	    return total;
	}

    /** Upsert vendors. Returns count of rows affected. */
    public static int updateVendors(Main main) {
    	
        if (!ensureSessionAndDb(main))
        	return 0;
        
        final String SQL =
        		"MERGE INTO vendors v " +
		        "USING (VALUES (?, ?, ?, ?, ?, ?, ?, ?)) s(vendor_id, vendor_sim_name, vendor_name, vendor_address, vendor_pincode, vendor_city, vendor_country, active) " +
		        "ON (v.vendor_id = s.vendor_id) " +
		        "WHEN MATCHED THEN UPDATE SET " +
		        "  vendor_sim_name = s.vendor_sim_name, " +
		        "  vendor_name     = s.vendor_name, " +
		        "  vendor_address  = s.vendor_address, " +
		        "  vendor_pincode  = s.vendor_pincode, " +
		        "  vendor_city     = s.vendor_city, " +
		        "  vendor_country  = s.vendor_country, " +
		        "  active          = s.active " +
		        "WHEN NOT MATCHED THEN INSERT (vendor_id, vendor_sim_name, vendor_name, vendor_address, vendor_pincode, vendor_city, vendor_country, active) " +
		        "  VALUES (s.vendor_id, s.vendor_sim_name, s.vendor_name, s.vendor_address, s.vendor_pincode, s.vendor_city, s.vendor_country, s.active)";
        
        final int pageSize = 200;
        int offset = 0, total = 0;

        boolean prevAuto = setTx(main.m_dbConn, false);
        
        try (PreparedStatement ps = main.m_dbConn.prepareStatement(SQL)) {
            while (true) {
                List<Map<String,Object>> page = fetchPage(
                    main.m_odooSession,
                    "res.partner", "search_read",
                    Arrays.asList(
                        Arrays.asList("supplier_rank", ">", 0)
                    ),
                    Arrays.asList("id","name","street","street2","zip","city","country_id", "active"),
                    pageSize, offset
                );
                
                if (page.isEmpty())
                	break;

                for (Map<String,Object> v : page) {
                    int vendorId = OdooUtils.safeCastToInteger(v.get("id"));
                    String vendorSim = "Vendor_" + vendorId;
                    String name   = OdooUtils.safeCastToString(v.get("name"));
                    String addr   = joinSpace(
                        OdooUtils.safeCastToString(v.get("street")),
                        OdooUtils.safeCastToString(v.get("street2"))
                    );
                    String zip    = OdooUtils.safeCastToString(v.get("zip"));
                    String city   = OdooUtils.safeCastToString(v.get("city"));
                    String country= OdooUtils.m2oName(v.get("country_id"));
                    boolean active   = Boolean.TRUE.equals(v.get("active"));

                    ps.setInt(1, vendorId);
                    ps.setString(2, vendorSim);
                    ps.setString(3, name);
                    ps.setString(4, addr);
                    ps.setString(5, zip);
                    ps.setString(6, city);
                    ps.setString(7, country);
                    ps.setBoolean(8, active);
                    ps.addBatch();
                }
                total += ps.executeBatch().length;

                if (page.size() < pageSize)
                	break;
                offset += pageSize;
            }
            main.m_dbConn.commit();
        } catch (Exception e) {
            rollbackQuiet(main.m_dbConn);
            Logger.error("updateVendors: ", e.getMessage());
            total = 0;
        } finally {
            restoreAuto(main.m_dbConn, prevAuto);
        }
        return total;
    }

    /** Upsert products. Returns count of rows affected. */
    public static int updateProducts(Main main) {
    	
        if (!ensureSessionAndDb(main))
        	return 0;
        
        final String SQL =
        		"MERGE INTO products p " +
        		"USING (VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)) s(product_id, sku_id, sku_name, product_tmpl_id, units_per_box, unit_weight, cost_price, sales_price, active, purchase_ok, sale_ok) " +
        		"ON (p.product_id = s.product_id) " +
        		"WHEN MATCHED THEN UPDATE SET " +
        		"  sku_id			= s.sku_id, " +
        		"  sku_name			= s.sku_name, " +
        		"  product_tmpl_id	= s.product_tmpl_id, " +
        		"  units_per_box	= s.units_per_box, " +
        		"  unit_weight		= s.unit_weight, " +
        		"  cost_price		= s.cost_price, " +
        		"  sales_price		= s.sales_price, " +
        		"  active			= s.active, " + 
        		"  purchase_ok		= s.purchase_ok, " + 
        		"  sale_ok			= s.sale_ok " +
        		"WHEN NOT MATCHED THEN INSERT (product_id, sku_id, sku_name, product_tmpl_id, units_per_box, unit_weight, cost_price, sales_price, active, purchase_ok, sale_ok) " +
        		"  VALUES (s.product_id, s.sku_id, s.sku_name, s.product_tmpl_id, s.units_per_box, s.unit_weight, s.cost_price, s.sales_price, s.active, s.purchase_ok, s.sale_ok)";
        
        final int pageSize = 200;
        int offset = 0, total = 0;

        boolean prevAuto = setTx(main.m_dbConn, false);
        
        try (PreparedStatement ps = main.m_dbConn.prepareStatement(SQL)) {
            while (true) {
                List<Map<String,Object>> page = fetchPage(
                    main.m_odooSession,
                    "product.product", "search_read",
                    Arrays.asList(
                        Arrays.asList("active","=",true),
                        Arrays.asList("type","=","product"),
                        "|", Arrays.asList("purchase_ok","=",true), Arrays.asList("sale_ok","=",true)
                    ),
                    Arrays.asList("id","name","default_code","weight","uom_id", "uom_po_id", 
                    			"product_tmpl_id", "standard_price", "list_price", 
                    			"active", "purchase_ok", "sale_ok"),
                    pageSize, offset
                );
                
                if (page.isEmpty())
                	break;

                // Collect UoM ids for this page
                Set<Integer> tmplIds  = new HashSet<>();
                Set<Integer> uomIds   = new HashSet<>();
                Set<Integer> uomPoIds = new HashSet<>();
                for (Map<String,Object> p : page) {
                	int tId   = OdooUtils.m2oId(p.get("product_tmpl_id"));
                    int uId   = OdooUtils.m2oId(p.get("uom_id"));
                    int upoId = OdooUtils.m2oId(p.get("uom_po_id"));
                    if (tId  > 0) tmplIds.add(tId);
                    if (uId  > 0) uomIds.add(uId);
                    if (upoId> 0) uomPoIds.add(upoId);
                }
                
                // Read product template for fallbacks
                Map<Integer,Integer> tmplUomById   = new HashMap<>();
                Map<Integer,Integer> tmplUomPoById = new HashMap<>();
                Map<Integer,String>  tmplCodeById  = new HashMap<>();
                if (!tmplIds.isEmpty()) {
                    Map<String,Object> kwT = new HashMap<>();
                    kwT.put("fields", Arrays.asList("id","default_code","uom_id","uom_po_id"));
                    Object tmplRes = OdooUtils.executeKw(
                        main.m_odooSession,
                        OdooUtils.DATABASE_NAME,
                        OdooUtils.SERVER_PASSWORD,
                        "product.template",
                        "read",
                        Arrays.asList(new ArrayList<>(tmplIds)),
                        kwT
                    );
                    List<Map<String,Object>> tmplRows = OdooUtils.asListOfMaps(tmplRes);
                    for (Map<String,Object> t : tmplRows) {
                        int id      = OdooUtils.safeCastToInteger(t.get("id"));
                        tmplCodeById.put(id, OdooUtils.safeCastToString(t.get("default_code")));
                        int tu      = OdooUtils.m2oId(t.get("uom_id"));
                        int tpo     = OdooUtils.m2oId(t.get("uom_po_id"));
                        if (tu  > 0) { tmplUomById.put(id, tu);  uomIds.add(tu); }
                        if (tpo > 0) { tmplUomPoById.put(id, tpo); uomPoIds.add(tpo); }
                    }
                }
                
                // Read UoM factor_inv for both stock & purchase UoMs
                Set<Integer> allUomIds = new HashSet<>();
                allUomIds.addAll(uomIds);
                allUomIds.addAll(uomPoIds);
                Map<Integer,Double> factorInvByUom = fetchUomFactors(main, allUomIds);

                for (Map<String,Object> p : page) {
                    int id        = OdooUtils.safeCastToInteger(p.get("id"));
                    String skuId  = OdooUtils.safeCastToString(p.get("default_code"));
                    String name   = OdooUtils.safeCastToString(p.get("name"));
                    double weight = OdooUtils.safeCastToDouble(p.get("weight"));
                    double cost_price   = OdooUtils.safeCastToDouble(p.get("standard_price"));
                    double sales_price   = OdooUtils.safeCastToDouble(p.get("list_price"));
                    
                    int tmplId    = OdooUtils.m2oId(p.get("product_tmpl_id"));
                    if (skuId == null || skuId.isEmpty()) {
                        String tCode = tmplCodeById.getOrDefault(tmplId, "");
                        // simple fallback to keep SKUs unique & stable
                        skuId = (tCode != null && !tCode.isEmpty() ? tCode : "PRD") + "-" + id;
                    }
                    
                    // Prefer purchase UoM, fallback to stock UoM (variant first, then template)
                    int uomPoId = OdooUtils.m2oId(p.get("uom_po_id"));
                    if (uomPoId <= 0) uomPoId = tmplUomPoById.getOrDefault(tmplId, -1);

                    int uomId = OdooUtils.m2oId(p.get("uom_id"));
                    if (uomId <= 0) uomId = tmplUomById.getOrDefault(tmplId, -1);
                    
                    double unitsD = 1.0;
                    if (uomPoId > 0) {
                        unitsD = Math.max(1.0, factorInvByUom.getOrDefault(uomPoId, 1.0));
                    } else if (uomId > 0) {
                        unitsD = Math.max(1.0, factorInvByUom.getOrDefault(uomId, 1.0));
                    }
                    int unitsPerBox = (int)Math.round(unitsD);
                    
                    boolean active = OdooUtils.safeCastToBoolean(p.get("active"));
                    boolean purchase_ok = OdooUtils.safeCastToBoolean(p.get("purchase_ok"));
                    boolean sale_ok = OdooUtils.safeCastToBoolean(p.get("sale_ok"));

                    ps.setInt(1, id);
                    ps.setString(2, skuId);
                    ps.setString(3, name);
                    ps.setInt(4, tmplId);
                    ps.setInt(5, unitsPerBox);
                    ps.setDouble(6, weight);
                    ps.setDouble(7, cost_price);
                    ps.setDouble(8, sales_price);
                    ps.setBoolean(9, active);
                    ps.setBoolean(10, purchase_ok);
                    ps.setBoolean(11, sale_ok);
                    ps.addBatch();
                }
                total += ps.executeBatch().length;

                if (page.size() < pageSize) 
                	break;
                offset += pageSize;
            }
            main.m_dbConn.commit();
        } catch (Exception e) {
            rollbackQuiet(main.m_dbConn);
            Logger.error("updateProducts: ", e.getMessage());
            total = 0;
        } finally {
            restoreAuto(main.m_dbConn, prevAuto);
        }
        return total;
    }

    /** Upsert product-vendor mapping. Returns count of rows affected. */    
    public static int updateProductVendorMapping(Main main) {
    	
        if (!ensureSessionAndDb(main)) return 0;

        final String SQL =
            "MERGE INTO product_vendor_map m " +
            "USING (VALUES (?, ?, ?, ?, ?, ?)) s(vendor_id, vendor_name, product_id, product_sku_id, min_qty, delay) " +
            "ON (m.product_id = s.product_id AND m.vendor_id = s.vendor_id) " +
            "WHEN MATCHED THEN UPDATE SET " +
            "  vendor_name    = s.vendor_name, " +
            "  product_sku_id = s.product_sku_id, " +
            "  min_qty        = s.min_qty, " +
            "  delay          = s.delay " +
            "WHEN NOT MATCHED THEN INSERT (vendor_id, vendor_name, product_id, product_sku_id, min_qty, delay) " +
            "  VALUES (s.vendor_id, s.vendor_name, s.product_id, s.product_sku_id, s.min_qty, s.delay)";

        final int pageSize = 200;
        int offset = 0, total = 0;

        // cache template->variants to avoid repeated RPC calls on the same template
        final Map<Integer, List<Variant>> templateVariantsCache = new HashMap<>();

        boolean prevAuto = setTx(main.m_dbConn, false);

        try (PreparedStatement ps = main.m_dbConn.prepareStatement(SQL)) {
            while (true) {
                // Keep template filters; we want both variant- and template-level supplierinfo
                List<Map<String,Object>> page = fetchPage(
                    main.m_odooSession,
                    "product.supplierinfo", "search_read",
                    Arrays.asList(
                        Arrays.asList("partner_id","!=",false),
                        Arrays.asList("product_tmpl_id","!=",false),
                        Arrays.asList("product_tmpl_id.active","=",true),
                        Arrays.asList("product_tmpl_id.purchase_ok","=",true)
                    ),
                    Arrays.asList("partner_id","product_id","product_tmpl_id","min_qty","delay"),
                    pageSize, offset
                );

                if (page.isEmpty()) break;

                for (Map<String,Object> si : page) {
                    int vendorId    = OdooUtils.m2oId(si.get("partner_id"));
                    String vendor   = OdooUtils.m2oName(si.get("partner_id"));

                    // If supplierinfo is variant-specific, product_id > 0; otherwise 0 and tmplId > 0
                    int variantId   = OdooUtils.m2oId(si.get("product_id"));
                    int tmplId      = OdooUtils.m2oId(si.get("product_tmpl_id"));

                    // Optional denormalized copy; for variant-specific we can take the M2O display name.
                    String productSkuFromSi = OdooUtils.m2oName(si.get("product_id")); // may be blank/null for template rows

                    double minQty = Math.max(1.0, OdooUtils.safeCastToDouble(si.get("min_qty")));
                    int delay     = Math.max(0,   OdooUtils.safeCastToInteger(si.get("delay")));

                    if (vendorId <= 0) continue;

                    if (variantId > 0) {
                        // Variant-specific supplierinfo => one row
                        bindAndAdd(ps, vendorId, vendor, variantId, productSkuFromSi, minQty, delay);
                    } else if (tmplId > 0) {
                        // Template-level supplierinfo => fan out to ALL variants of that template
                        List<Variant> variants = getVariantsForTemplate(main, tmplId, templateVariantsCache);
                        for (Variant v : variants) {
                            // Prefer the variant's default_code; fall back to its display name.
                            String sku = (v.defaultCode != null && !v.defaultCode.isEmpty())
                                       ? v.defaultCode
                                       : v.displayName;
                            bindAndAdd(ps, vendorId, vendor, v.id, sku, minQty, delay);
                        }
                    }
                }

                total += ps.executeBatch().length;
                ps.clearBatch();

                if (page.size() < pageSize) break;
                offset += pageSize;
            }
            main.m_dbConn.commit();
        } catch (Exception e) {
            rollbackQuiet(main.m_dbConn);
            Logger.error("updateProductVendorMapping: ", e.getMessage());
            total = 0;
        } finally {
            restoreAuto(main.m_dbConn, prevAuto);
        }
        return total;
    }

    // ---------- Private helpers (reusable for future syncs) ----------

    private static boolean ensureSessionAndDb(Main main) {
        if (main.m_odooSession == null || main.m_odooSession.client == null) {
        	Logger.error("Odoo session not ready."); return false;
        }
        if (main.m_dbConn == null) {
            main.m_dbConn = DatabaseUtils.getEmbeddedConnection(main);
            if (main.m_dbConn == null) { 
            	Logger.error("No embedded DB."); 
            	return false;
            }
        }
        return true;
    }

    /** Generic pager for execute_kw search_read. */
    private static List<Map<String,Object>> fetchPage(
    		OdooUtils.OdooSession session,
            String model, 
            String method,
            List<Object> domain,
            List<String> fields,
            int limit, int offset
    ) throws Exception {
        Map<String,Object> kwargs = new HashMap<>();
        kwargs.put("fields", fields);
        if (limit > 0)  
        	kwargs.put("limit", limit);
        if (offset > 0) 
        	kwargs.put("offset", offset);

        Object res = OdooUtils.executeKw(
            session,
            OdooUtils.DATABASE_NAME,
            OdooUtils.SERVER_PASSWORD,
            model,
            method,
            Arrays.asList(domain),
            kwargs
        );
        
        List<Map<String,Object>> list = OdooUtils.asListOfMaps(res);
        return list == null ? Collections.<Map<String, Object>>emptyList() : list;
    }
    
    private static void bindAndAdd(PreparedStatement ps,
            int vendorId, String vendorName,
            int productId, String productSku,
            double minQty, int delay) throws SQLException {
		ps.setInt(1, vendorId);
		ps.setString(2, vendorName);
		ps.setInt(3, productId);
		ps.setString(4, productSku);
		ps.setDouble(5, minQty);
		ps.setInt(6, delay);
		ps.addBatch();
    }

    /** Batch read UoM factor_inv → units/box. */
    private static Map<Integer,Double> fetchUomFactors(Main main, Set<Integer> uomIds) {
    	
        Map<Integer,Double> map = new HashMap<>();
        
        Map<String, Object> kwargs = new HashMap<>();
        kwargs.put("fields", Arrays.asList("id", "factor_inv"));
        
        if (uomIds == null || uomIds.isEmpty())
        	return map;
        
        try {
            List<Integer> ids = new ArrayList<>(uomIds);
            Object res = OdooUtils.executeKw(
                main.m_odooSession,
                OdooUtils.DATABASE_NAME,
                OdooUtils.SERVER_PASSWORD,
                "uom.uom", "read",
                Arrays.asList(ids),
                kwargs
            );
            
            List<Map<String,Object>> rows = OdooUtils.asListOfMaps(res);
            if (rows != null) {
                for (Map<String,Object> r : rows) {
                    int id = OdooUtils.safeCastToInteger(r.get("id"));
                    double units = Math.max(1, OdooUtils.safeCastToDouble(r.get("factor_inv")));
                    if (id > 0) 
                    	map.put(id, units);
                }
            }
        } catch (Exception e) {
        	Logger.error("fetchUomFactors: ", e.getMessage());
        }
        return map;
    }
    
    /** Cache-aware lookup of all variant IDs (and basic fields) for a template. */
    private static List<Variant> getVariantsForTemplate(Main main, int tmplId, Map<Integer, List<Variant>> cache) {
    	List<Variant> cached = cache.get(tmplId);
    	
    	if (cached != null)
    		return cached;
    	
    	List<Variant> variants = new ArrayList<>();
    	try {
    		List<Map<String,Object>> rows = fetchPage(
    				main.m_odooSession,
    				"product.product", "search_read",
    				Arrays.asList(Arrays.asList("product_tmpl_id","=", tmplId)),
    				Arrays.asList("id","display_name","default_code"),
    				-1, 0 // see item #2 about limit handling
    				);
    		
    		for (Map<String,Object> r : rows) {
    			Variant v = new Variant();
    			v.id          = OdooUtils.safeCastToInteger(r.get("id"));
    			v.displayName = Objects.toString(r.get("display_name"), null);
    			v.defaultCode = Objects.toString(r.get("default_code"), null);
    			
    			if (v.id > 0) 
    				variants.add(v);
    		}
    	} catch (Exception e) {
    		Logger.error("getVariantsForTemplate: ", e.getMessage());
    	}
    	cache.put(tmplId, variants);
    	return variants;
    }
    
    private static String joinSpace(String a, String b) {
        return (a + " " + b).trim().replaceAll("\\s+"," ");
    }

    private static boolean setTx(Connection c, boolean auto) {
        try { 
        	boolean prev = c.getAutoCommit(); 
        	c.setAutoCommit(auto); 
        	return prev;
        }
        catch (Exception e) { 
        	return true;
        }
    }
    
    private static void restoreAuto(Connection c, boolean prev) {
        try { 
        	c.setAutoCommit(prev); 
        } catch (Exception ignore) {}
    }
    
    private static void rollbackQuiet(Connection c) {
        try { 
        	c.rollback();
        } catch (Exception ignore) {}
    }
    
    private static final class Variant {
        int id;
        String displayName;
        String defaultCode;
    }
}
