						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[ProcurementOrder po = (ProcurementOrder) agent;
PurchaseOrderSim poSim = po.poSim;

if (poSim == null) {
  Logger.warn("PO job has null poSim");
  return;
}

// Create truck once
if (!po.truckCreated) {
  // Create your truck resource the same way you already do
  Resource t = this.add_resources(); // or add_trucks() if you have a truck population
  t.category = RESOURCE_TYPE.TRUCK;   // adapt to your enum
  po.truck = t;
  poSim.inboundTruck = t;

  // Place at vendor start node (choose how you store this)
  if (po.vendorNode != null)
  	t.jumpTo(po.vendorNode);
  else
  	t.jumpTo(this.inboundTruckEntryNode); // fallback if you have one

  po.truckCreated = true;
}

// Send truck to entry node
if (!po.movedToEntry) {
  po.truck.moveTo(this.inboundTruckEntryNode); // your “entry/wait node”
  po.movedToEntry = true;
}
]]></Code>
							</Value>
