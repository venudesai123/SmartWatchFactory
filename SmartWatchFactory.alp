						<Action><![CDATA[if (currentCustomerOrder != null) {
    CustomerOrder co = currentCustomerOrder;
    int st = co.packStationIndex;

    // Place the order visually at that station
    PointNode station = main.PACK_STATION_NODES[st];
    co.setXY(station.getX(), station.getY());

    // Now tell Main that the order has arrived at its pack station
    main.services.coFlow.onPickedOrderArrivedAtPackStation(co);

    // The picker is done with this order, so clear it
    currentCustomerOrder = null;
}]]></Action>
