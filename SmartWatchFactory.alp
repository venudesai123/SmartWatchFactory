						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[Resource mbRes = (Resource) agent;

MotherBoxAssignment task = mbRes.rmStowTask;
if (task != null) {
    task.rollbackIncomingReservation("RM terminated");
    mbRes.rmStowTask = null;
} else {
    // fallback (should rarely happen)
    MotherBox mb = mbRes.getMotherBox();
    if (mb != null) {
        RmSlot slot = services.slotting.getRmSlot(
            mb.getSkuType(),
            mbRes.rackTargetRow,
            mbRes.rackTargetLevel,
            mbRes.rackTargetCell,
            0
        );
        if (slot != null) {
        	int units = mb.totalUnits();
		    if (slot.incomingBoxes <= 0) {
		        Logger.warn("RM incoming underflow rollback sku=" + mb.getSkuType()
		            + " incoming=" + slot.incomingBoxes + " rollback=" + units);
		    }
        
        	slot.rollbackIncomingBox(mb.totalUnits(), "RM terminated (no task)");
        }
    }
}

// Cleanup + requeue
mbRes.hasRackTarget = false;
mbRes.itemAssigned = false;

if (!mbRes.itemQueued) {
    mbRes.itemQueued = true;
    waitingRmBoxes.addLast(mbRes);
}

this.services.whDispatch.tryDispatchRmStowing();
]]></Code>
