						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[if (coStagingQueue.isEmpty())
    return;
    
// Try to allocate trucks at each dock
for (int d = 0; d < Constants.OUTBOUND_DOCK_STATIONS; d++) {
    OutboundDockState ds = outboundDocks[d];

    // If no truck here and we still have orders waiting in staging → create one
    if (ds.truck == null && !coStagingQueue.isEmpty()) {
        this.services.outbound.spawnOutboundTruckAtDock(d);
        this.services.outbound.fillTruckFromStaging(d);
    }
}

// After assigning orders to docks, try to start workers
this.services.outbound.tryDispatchOutboundWorkers();
]]></Action>
				</Event>
				<Event>
					<Id>1768342983218</Id>
					<Name><![CDATA[outboundTruckPoller]]></Name>
					<X>840</X><Y>-2250</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_SECOND]]></Unit>
						</Rate>
						<Id>1753899529595</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1764576000000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0.05]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[0.05]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[for (CustomerOrder co : customerOrders) {   // use your CO population name
    if (co == null) continue;
    if (co.carriedBy != null) {
        co.setXY(co.carriedBy.getX(), co.carriedBy.getY());
    }
}

for (int i = 0; i < Constants.OUTBOUND_DOCK_STATIONS; i++) {
    OutboundDockState ds = outboundDocks[i];
    if (ds == null || ds.truck == null)
    	continue;

    Resource t = ds.truck;

    // truck arrived at dock
    if (!ds.truckAtDock && !ds.truckLeaving && !t.isMoving()) {
        double dist = Math.hypot(t.getX() - ds.node.getX(), t.getY() - ds.node.getY());
        if (dist <= 0.5) { // tolerance
            ds.truckAtDock = true;
            this.services.outbound.tryDispatchOutboundWorkers(); // now allow workers to load
        }
    }

    // truck finished leaving -> delete truck + remove/hide COs
    if (ds.truckLeaving && !t.isMoving()) {
        double distExit = (outboundTruckENode == null) ? 0
                : Math.hypot(t.getX() - outboundTruckENode.getX(),
                             t.getY() - outboundTruckENode.getY());

        if (outboundTruckENode == null || distExit <= 0.5) {

            // COs “arrived” at exit with truck -> now remove from animation
            for (CustomerOrder co : ds.loadedOrders) {
                if (co == null)
                	continue;
                co.carriedBy = null;

                // (visually): move off-scene but keep object for KPIs
                co.setXY(-10000, -10000);
            }
            ds.loadedOrders.clear();

            // remove truck
            t.deleteSelf();
            ds.truck = null;

            ds.truckAtDock = false;
            ds.truckLeaving = false;
            ds.assignedBoxes = 0;
            ds.ordersAssigned = 0;
            ds.ordersLoaded = 0;

            this.services.outbound.tryStartTruckIfNeeded();
        }
    }
}
]]></Action>
				</Event>
				<Event>
					<Id>1768342983227</Id>
					<Name><![CDATA[procurementPlannerEvent]]></Name>
					<X>840</X><Y>-2100</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[3600]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_SECOND]]></Unit>
						</Rate>
						<Id>1753899529594</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1764576000000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[10]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[triangular(5.5, 6, 6.5)]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[if (!Configuration.enableAutoEvents)
	return;

Collection<String> procurementSkuIds = this.services.procurementPolicy.getProcurementSkuIds();

if (procurementSkuIds == null || procurementSkuIds.isEmpty()) {
	Logger.warn("[Planner] No procurement SKUs found.");
	return;
}

Map<String,Integer> availSnap = this.services.procurementPolicy.snapshotRmAvailableUnitsBySkuId();
Logger.trace("[Planner] availSnap.size=" + availSnap.size());

Map<Resource, LinkedHashMap<String,Integer>> poLinesByVendor = new LinkedHashMap<>(); // vendor -> (skuId -> orderUnits)

for (String skuId : procurementSkuIds) {
    if (skuId == null || skuId.isEmpty() || PRODUCT_TYPE.fromSkuId(skuId) == null) continue;
    
    int pos = this.services.procurementPolicy.inventoryPositionUnits(skuId, availSnap);
    
    Logger.trace("SKU " + skuId
			   + " avail=" + availSnap.getOrDefault(skuId, 0)
			   + " onOrder=" + rmOnOrderUnitsBySkuId.getOrDefault(skuId, 0)
			   + " pos=" + pos);
    
    int needUnits = 0;

    switch (Configuration.inventoryPolicy) {
        case ROP: {
        	int rop = this.services.procurementPolicy.ropUnits(skuId);
            int upto = this.services.procurementPolicy.orderUpToUnits(skuId);
            
            Logger.trace("  [ROP] rop=" + rop + " upto=" + upto);
            
            if (pos < rop)
            	needUnits = Math.max(0, upto - pos);
		}
        break;

        case PR: {
		    double rpHours = this.services.procurementPolicy.reviewPeriodHours(skuId);
			double rpSec = rpHours * 3600.0; // Review period length in seconds
		    if (rpSec <= 0) 
		    	rpSec = 24 * 3600; // safety fallback
			
        	double due = this.nextReviewDueSecBySkuId.getOrDefault(skuId, time() + rpSec);
			// double due = this.nextReviewDueSecBySkuId.computeIfAbsent(skuId, k -> time() + rpSec);
			
		    if (time() >= due) {
		        int upto = this.services.procurementPolicy.orderUpToUnits(skuId);
		        needUnits = Math.max(0, upto - pos);
		        
		        Logger.trace("[PR-REVIEW] sku=" + skuId
			                + " pos=" + pos
			                + " upto(S)=" + upto
			                + " need=" + needUnits
			                + " rpHours=" + rpHours
			                + " dueBeforeAdvance=" + due
			                + " t=" + time());
				
		        // advance due in a non-drifting way
		        while (due <= time()) due += rpSec;
		        this.nextReviewDueSecBySkuId.put(skuId, due);
		        
		        Logger.trace("[PR-NEXT] sku=" + skuId + " nextDue=" + due);
		    }
		}
        break;

        case JIT: {
        	int openNeed = this.services.procurementPolicy.computeJitNeedUnits(skuId);
		    int safety = this.services.procurementPolicy.jitSafetyUnitsDynamic(skuId);
		
		    int target = openNeed + safety;
		    needUnits  = Math.max(0, target - pos);
		
		    Logger.trace("  [JIT] openNeed=" + openNeed
		               + " safety=" + safety
		               + " target=" + target
		               + " pos=" + pos
		               + " need=" + needUnits);
		}
        break;
    }
    
    if (needUnits <= 0) continue;
	
	// Pick a vendor for this SKU (fastest lead time, active, has mapping)
	Resource vendor = this.services.procurementPolicy.chooseVendorForSkuId(skuId);
	if (vendor == null) {
	    Logger.warn("No vendor found for ", skuId, " cannot procure.");
	    continue;
	}
	
	int orderUnits = this.services.procurementPolicy.applyBoxAndMoqRounding(vendor, skuId, needUnits);
		
	poLinesByVendor
		.computeIfAbsent(vendor, v -> new LinkedHashMap<>())
	    .merge(skuId, orderUnits, Integer::sum);
	    
	Logger.trace("  -> ORDER " + orderUnits + " units"
			   + " (after rounding) from " + vendor.displayName
			   + " for sku=" + skuId);
}

if (poLinesByVendor.isEmpty()) {
	Logger.trace("[Planner] No PO created this cycle.");
	return;
}

// Create one PO per vendor (real-world behavior)
for (Map.Entry<Resource, LinkedHashMap<String,Integer>> e : poLinesByVendor.entrySet()) {
    Resource vendor = e.getKey();
    LinkedHashMap<String,Integer> lines = e.getValue();
    
    if (lines == null || lines.isEmpty()) continue;
    
    this.services.inboundPoFlow.createPurchaseOrderSimAndScheduleInbound(vendor, lines);
    
    Logger.trace("[Planner] PO created for " + vendor.displayName + " with " + lines.size() + " lines.");
}
]]></Action>
				</Event>
