			<Events>
				<Event>
					<Id>1765141763590</Id>
					<Name><![CDATA[customerOrderGenerator]]></Name>
					<X>20</X><Y>30</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_SECOND]]></Unit>
						</Rate>
						<Id>1753899529397</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1764576000000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[triangular(10, 20, 45)]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[if(!Configuration.enableAutoEvents) {
	return;
}
			
if (category != RESOURCE_TYPE.DISTRIBUTOR || !active) {
    return; // safety
}

// Choose SKU for this distributor (simple random for now)
FG_SKU[] allFg = FG_SKU.values();
int maxVariants = Math.min(3, allFg.length);
int variantCount = uniform_discr(1, maxVariants);

// Choose distinct variants
LinkedHashSet<FG_SKU> chosen = new LinkedHashSet<>();

while (chosen.size() < variantCount) {
    int idx = uniform_discr(0, allFg.length - 1);
    chosen.add(allFg[idx]);
}

// ---- Spike behaviour ----
boolean isSpike = uniform(0,1) < Constants.spikeOrderProbability;

// Build lines map: FG_SKU -> qty
LinkedHashMap<FG_SKU, Integer> linesBySku = new LinkedHashMap<>();

for (FG_SKU sku : chosen) {
    int boxes = sampleCOBoxes();
    if (isSpike) {
        double factor = uniform(Constants.spikeQtyFactorMin,
                                Constants.spikeQtyFactorMax);
        boxes = (int) Math.round(boxes * factor);
    }
    if (boxes <= 0)
    	boxes = 1;
    linesBySku.put(sku, boxes);
}

// Create multi-line CustomerOrder and push to Odoo
CustomerOrder co = main.services.coFlow.createCustomerOrderFromDistributor(this, linesBySku, true);
if (co != null) {
    Logger.info("Distributor ", this,
                " created CO ", co,
                " (variants=", linesBySku.size(),
                ", spike=", isSpike, ")");
}

// ---- Schedule next order time: weekly base + jitter + possible extra spike order ----
double meanH = Constants.meanInterOrderTimeHours;

// jitter between 50% and 150% of mean – weeks are not identical
double jitterFactor = triangular(0.5, 1.0, 1.5);
double nextH = meanH * jitterFactor;

// Sometimes schedule an extra order in the same week
if (uniform(0,1) < Constants.spikeExtraOrderProb)
	nextH *= Constants.spikeExtraIntervalFactor; // e.g. 0.3 => extra order much sooner
			
if (nextH <= 0)
	nextH = meanH;

// Time units in the model are seconds -> convert hours to seconds
customerOrderGenerator.restart(nextH * 3600);
]]></Action>
				</Event>
				<Event>
					<Id>1765634051671</Id>
					<Name><![CDATA[outboundArrivalPoller]]></Name>
					<X>260</X><Y>30</Y>
