				<Event>
					<Id>1768342983275</Id>
					<Name><![CDATA[checkOverfillSku]]></Name>
					<X>840</X><Y>-1930</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_SECOND]]></Unit>
						</Rate>
						<Id>1753899529591</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1764576000000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[3600]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[// RM: unit-based + box-position checks
for (PRODUCT_TYPE pt : PRODUCT_TYPE.values()) {
    List<RmSlot> list = rmSlotsBySku.get(pt);
    if (list == null) continue;

    for (RmSlot s : list) {
        if (s == null) continue;

        int occUnits = s.units + s.reservedUnits + s.incomingUnits;
        if (occUnits > Constants.RM_MAX_UNITS_PER_SLOT) {
            Logger.error("RM OVERFILL-UNITS sku=" + s.skuId +
                " row=" + s.row + " cell=" + s.cell + " L=" + s.level +
                " occUnits=" + occUnits);
        }

        // Optional: box-position check (needs unitsPerBox)
        Integer upb = unitsPerBoxBySkuId.get(s.skuId);
        if (upb != null && upb > 0) {
            int maxBoxes = s.maxBoxesForCell(upb);
            int occBoxes = s.boxes.size() + s.incomingBoxes;
            if (occBoxes > maxBoxes) {
                Logger.error("RM OVERFILL-BOXES sku=" + s.skuId +
                    " row=" + s.row + " cell=" + s.cell + " L=" + s.level +
                    " occBoxes=" + occBoxes + " maxBoxes=" + maxBoxes);
            }
        }
    }
}

// FG: unit-based + tray-position checks
for (FG_SKU fg : FG_SKU.values()) {
    List<FgSlot> list = fgSlotsBySku.get(fg);
    if (list == null) continue;

    for (FgSlot s : list) {
        if (s == null) continue;

        int occUnits = s.units + s.reservedUnits + s.incomingUnits;
        if (occUnits > Constants.FG_MAX_UNITS_PER_SLOT) {
            Logger.error("FG OVERFILL-UNITS sku=" + s.skuId +
                " row=" + s.row + " cell=" + s.cell + " L=" + s.level +
                " occUnits=" + occUnits);
        }

        int occTrays = s.trays.size() + s.incomingTrays;
        int maxTrays = s.maxTraysForCell();
        if (occTrays > maxTrays) {
            Logger.error("FG OVERFILL-TRAYS sku=" + s.skuId +
                " row=" + s.row + " cell=" + s.cell + " L=" + s.level +
                " occTrays=" + occTrays + " maxTrays=" + maxTrays);
        }
    }
}
]]></Action>
				</Event>
				<Event>
					<Id>1768342983283</Id>
					<Name><![CDATA[mrpOrderGeneratorEvent]]></Name>
					<X>840</X><Y>-2170</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_SECOND]]></Unit>
						</Rate>
						<Id>1753899529590</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1764576000000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[300]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[3600]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[if(!Configuration.enableAutoEvents) return;

// If capped by WIP control, check again later (don’t spin fast)
if (!this.services.mfgConfig.isMoRequired()) {
	this.mrpOrderGeneratorEvent.restart(30*60); // in seconds
	return;
}

if (this.m_odooSession == null) {
	this.mrpOrderGeneratorEvent.restart(60); // Try again in 60 seconds (or stop if you want)
	return;
}

// Pick which variant to produce next
VARIANT v = this.services.mfgConfig.pickVariantByRemaining();
if (v == null) return;

// MO qty
int qty = uniform_discr(ManufacturingConfigService.moMinQty, ManufacturingConfigService.moMaxQty);

// Create MO
this.services.moFlow.createMrpOrder(qty, v, FG_SKU.valueOf(v.name()));

// Update counters
this.services.mfgConfig.updateMoMadeCounter(v, qty);

// Schedule next release
// If qty=6, next after ~6*taktSec (so total daily output stays correct)
double baseInterval = this.services.mfgConfig.getTaktSec() * qty;

// Add jitter ±20%
double jitter = 0.20 * baseInterval;
double dt = Math.max(10, baseInterval + uniform(-jitter, +jitter));

this.mrpOrderGeneratorEvent.restart(dt);
]]></Action>
				</Event>
				<Event>
					<Id>1768342983292</Id>
					<Name><![CDATA[dailyMOPlannerEvent]]></Name>
