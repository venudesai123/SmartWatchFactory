		<JavaClass>
			<Id>1766265994752</Id>
			<Name><![CDATA[CatalogService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * CatalogService
 * 
 * skeleton to help split Main's Additional class code into services.
 * Purpose: SKU master helpers (units/box, etc.) using product master maps loaded in Main.
 */	
public class CatalogService {
	private final Main main;

    public CatalogService(Main main) {
        this.main = main;
    }
    
    public int lookupUnitsPerBoxForSku(String skuId) {
        Integer v = main.saleableProductUnitsPerBoxBySkuId.get(skuId);
        if (v == null || v <= 0)
        	return 10;
        return v;
    }
}]]></Text>
