						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[ProcurementOrder po = (ProcurementOrder) agent;

po.currentLane = -1;
for (int i = po.laneCursor; i < 5; i++) {
    if (!po.boxesByLane.get(i).isEmpty()) {
        po.currentLane = i;
        po.currentLaneNode = INBOUND_LANE_NODES[i]; // (isn1..isn5) in Main
        break;
