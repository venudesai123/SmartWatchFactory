					<Name><![CDATA[cancel_all_picker]]></Name>
					<ExcludeFromBuild>true</ExcludeFromBuild>
					<X>400</X><Y>-40</Y>
					<Label><X>0</X><Y>-10</Y></Label>
					<PublicFlag>true</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>false</ShowLabel>
					<DrawMode>SHAPE_DRAW_2D3D</DrawMode>
					<BasicProperties Width="130" Height="30">
                        <EmbeddedIcon>false</EmbeddedIcon>	
						<TextColor>-16777216</TextColor>
						<Enabled>true</Enabled>
						<ActionCode><![CDATA[int n = 0;
for (Picker p : rmPickers) {
	if (!p.isIdle()) {
		p.cancelJob("manual cancel (all)");
		n++;
	}
}
Logger.info("Cancelled ", n, " active pickers.");
]]></ActionCode>
					</BasicProperties>
					<ExtendedProperties>
						<Font Name="Dialog" Size="11" Style="0"/>
						<LabelText><![CDATA[cancel_all_picker]]></LabelText>
					</ExtendedProperties>
				</Control>
