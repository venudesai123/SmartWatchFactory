							<Name><![CDATA[onEnter]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[ProcurementOrder po = (ProcurementOrder)agent;

if (po.truck == null) {
	Logger.warn("moveToDock: job.truck is null for poSimId=" + (po.poSim != null ? po.poSim.simId : -1));
	return;
}
if (po.dockIdx < 0) {
	Logger.warn("moveToDock: dockIdx < 0 for poSimId=" + (po.poSim != null ? po.poSim.simId : -1));
	return;
}

po.truck.moveTo(this.INBOUND_DOCK_NODES[po.dockIdx]);
]]></Code>
