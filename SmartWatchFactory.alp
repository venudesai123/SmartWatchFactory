					<Properties Width="196.11650485436894" Height="30">
						<ExitAction><![CDATA[PointNode deliveredAt = this.deliveryEnd; // snapshot FIRST

// RELEASE endpoint reservation (RM delivery finished)
if (deliveryEndIdx >= 0 && main.rmEndLoad != null) {
    main.rmEndLoad[deliveryEndIdx] = Math.max(0, main.rmEndLoad[deliveryEndIdx] - 1);
}
this.deliveryEndIdx = -1;
this.deliveryEnd = null;   // optional

// Snapshot references BEFORE clearing
MrpOrder moRef = this.currentOrder;
List<PickStop> planRef = new ArrayList<>(this.stops);

if (moRef != null) {
    moRef.markDelivered(deliveredAt);           // record delivery time on MO
    main.services.moFlow.onPickerDropOff(moRef, planRef);            // club parts + spawn WIP(s)
    
    // If more demand exists (e.g., scrap happened while we were picking), requeue now
    if (moRef.hasPendingDemand()) {
        moRef.markRequeued();
        if (!main.waitingMrpOrders.contains(moRef))
            main.waitingMrpOrders.add(moRef);
    }
} else {  // If it's an FG plan, currentOrder will be null (expected)
    boolean isFgJob = !planRef.isEmpty() && this.jobKind == JOB_KIND.FG;
    if (!isFgJob) {
        Logger.warn("DropOff Exit: no MO and not FG; nothing to deliver.");
    }
}

this.carryingUnits = 0;
this.updateCarryState();

// Clear job so picker is free for the next assignment
this.currentPlan = null;
this.currentOrder = null;
this.stopIdx = 0;
this.totalOrderQuantity = 0;
this.stops.clear();        // <-- don't reassign stops
this.hasJob = false;       // <-- crucial
this.hasDroppedOff = true;
]]></ExitAction>
