						<ActionCode><![CDATA[StringBuilder errors = new StringBuilder();
this.uiHasError = false;

// ---------------- VALIDATION ----------------
if (this.isBlank(this.uiTimeZone)) {
    errors.append("❌ TimeZone cannot be empty (example: UTC).\n");
    this.uiHasError = true;
}

if (this.isBlank(this.uiInventoryPolicyName)) {
    errors.append("❌ Please select an inventory policy.\n");
    this.uiHasError = true;
}

if (this.isBlank(this.uiOdooDbName)) {
    errors.append("❌ Odoo DB Name cannot be empty.\n");
    this.uiHasError = true;
}

if (this.isBlank(this.uiOdooHostUrl)) {
    errors.append("❌ Odoo Host URL cannot be empty (example: http://localhost:8069).\n");
    this.uiHasError = true;
}

if (!this.isBlank(this.uiOdooHostUrl) &&
	!this.uiOdooHostUrl.trim().startsWith("http://") && 
	!this.uiOdooHostUrl.trim().startsWith("https://")) {
    errors.append("❌ Host URL must start with http:// or https://\n");
    this.uiHasError = true;
}

if (this.isBlank(this.uiOdooServerUsername)) {
    errors.append("❌ Odoo Server UserName cannot be empty.\n");
    this.uiHasError = true;
}

if (this.isBlank(this.uiOdooServerPassword)) {
    errors.append("❌ Odoo Server Password cannot be empty.\n");
    this.uiHasError = true;
}

// ---------------- POLICY PARSE ----------------
INVENTORY_POLICY inventoryPolicy = null;

if (!this.isBlank(this.uiInventoryPolicyName)) {
    try {
        inventoryPolicy = INVENTORY_POLICY.parse(this.uiInventoryPolicyName.trim());
    } catch (Exception e) {
        errors.append("❌ Invalid policy value: " + this.uiInventoryPolicyName + "\n");
        this.uiHasError = true;
    }
}

// ---------------- STOP IF ERRORS ----------------
if (this.uiHasError) {
    this.uiStatus = errors.toString();
    return;
}

// ---------------- APPLY CONFIG ----------------
this.uiConfigSaved	= Configuration.applyNewConfiguration(
						this.uiEnableAutoEvents,
						this.uiTimeZone.trim(),
						inventoryPolicy,
						this.uiOdooDbName.trim(),
						this.uiOdooHostUrl.trim(),
						this.uiOdooServerUsername.trim(),
						this.uiOdooServerPassword.trim()
					);
this.uiStatus = "✅ Saved. You can now start / run simulation.";


// ---------------- PRINT CONFIG SUMMARY ----------------
traceln("================== SIMULATION CONFIG ===================");
traceln("Auto Events: " + Configuration.enableAutoEvents);
traceln("TimeZone: " + Configuration.timeZone);
traceln("Policy: " + Configuration.inventoryPolicy.policyName());
traceln("Odoo Base URL: " + Configuration.odooBaseUrl);
traceln("Odoo Database Name: " + Configuration.odooDatabaseName);
traceln("Odoo Server UserName: " + Configuration.odooServerUserName);
traceln("Odoo Server Password: " + Configuration.odooServerPassword);
traceln("=========================================================");
traceln();
traceln("================= SIMULATION DATE TIME ==================");
traceln("Experiment start date: " + getEngine().getStartDate());
traceln("Sim time: " + time());
traceln("Odoo time: " +
    DateTimeUtil.convertSimulationTimeToDate(
        getEngine().getStartDate(),
        time(),
        false
    )
);
traceln("=========================================================");
]]></ActionCode>
