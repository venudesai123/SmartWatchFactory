			<Text><![CDATA[/**
 * DateTimeUtil
 */	
import java.util.Date;
import java.text.SimpleDateFormat;
import java.util.TimeZone;

public class DateTimeUtil {
	
	// Odoo expects UTC "yyyy-MM-dd HH:mm:ss"
    private static final SimpleDateFormat ODOO_FORMAT = new SimpleDateFormat("yyyy-MM-dd HH:mm:ss");
    
    static {
        ODOO_FORMAT.setTimeZone(TimeZone.getTimeZone(Configuration.timeZone));
    }
    
    /**
     * Converts simulation time (seconds OR hours) into Odoo UTC datetime string.
     *
     * @param engineStartDate  main.getEngine().getStartDate()
     * @param simTime          simulation time value
     * @param isTimeInHours    true if simTime is in hours, false if already in seconds
     */
    public static String convertSimulationTimeToDate(
            Date engineStartDate,
            double simTime,
            boolean isTimeInHours
    ) {

        long simTimeInSeconds = isTimeInHours
                ? Math.round(simTime * 3600.0)
                : Math.round(simTime);

        long realWorldMillis =
                engineStartDate.getTime() + (simTimeInSeconds * 1000L);

        Date date = new Date(realWorldMillis);

        synchronized (ODOO_FORMAT) {
            return ODOO_FORMAT.format(date);
        }
    }
}



