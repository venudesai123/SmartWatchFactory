		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1771291072954</Id>
			<Name><![CDATA[PRODUCT_TYPE]]></Name>
			<Folder>1771290735356</Folder>
			<Text><![CDATA[/**
 * PRODUCT_TYPE
 */	
public enum PRODUCT_TYPE {
	
	DISPLAY("Display"),
    MICROCHIP("Microchip"),
    BATTERY("Battery"),
    CASE("Case"),
    STRAP("Strap");

    private final String label;
    
    private static final Map<String, PRODUCT_TYPE> BY_LABEL;
    static {
    	Map<String, PRODUCT_TYPE> m = new HashMap<>();
    	for(PRODUCT_TYPE pt : values()) {
    		m.put(pt.label.toLowerCase(Locale.ROOT), pt);
    	}
    	BY_LABEL = Collections.unmodifiableMap(m);
    }

    PRODUCT_TYPE(String label) { this.label = label; }

    public String getLabel() { return label; }
    public static PRODUCT_TYPE fromSkuId(String skuId) {
	    if (skuId == null)
	    	return null;

	    String s = skuId.trim().toUpperCase(Locale.ROOT);
	    
	    if (s.startsWith("DISP")) return DISPLAY;
	    if (s.startsWith("MC"))   return MICROCHIP;
	    if (s.startsWith("BA"))   return BATTERY;
	    if (s.startsWith("CA"))   return CASE;
	    if (s.startsWith("ST"))   return STRAP;

	    return null;
	}
    
    public boolean isSharedComponent() {
        switch (this) {
            case DISPLAY:
            case MICROCHIP:
            case BATTERY:
                return true;
            default:
                return false;
        }
    }
    
    public static PRODUCT_TYPE parse(String s) {
		if (s == null)
			Logger.error("SKU NAME is null and cannot be parsed.", new IllegalArgumentException("null"));
		
		String k = s.trim();
		PRODUCT_TYPE byLabel = BY_LABEL.get(k.toLowerCase(Locale.ROOT));
		if (byLabel != null)
			return byLabel;
		
		return valueOf(k.toUpperCase(Locale.ROOT)); // also accepts "DISPLAY"
	}
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1771291173981</Id>
			<Name><![CDATA[FG_SKU]]></Name>
			<Folder>1771290735356</Folder>
			<Text><![CDATA[/**
 * FG_SKU
 */	
public enum FG_SKU {
	MET("SW001-MET", 10, 20), // 30, 80
	FW("SW001-FW", 10, 20),
	FB("SW001-FB", 10, 20);
	
	private final String skuId;
	private final int rop;	// reorder points per variant
	private final int upto; // order-up-to per variant
	
	FG_SKU(String sku, int rop, int upto) { 
		this.skuId = sku;
		this.rop = rop;
		this.upto = upto;
	}
	
	public String skuId() { return this.skuId; }
	public int rop() { return this.rop; }
	public int upto() { return this.upto; }
	
	public static FG_SKU getBySkuId(String skuId) {
	    for (FG_SKU sku : FG_SKU.values()) {
	        if (sku.skuId().equals(skuId)) {
	            return sku;
	        }
	    }
	    return null; // or throw an exception if you prefer
	}
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1771381410378</Id>
			<Name><![CDATA[Configuration]]></Name>
			<Folder>1771290631309</Folder>
			<Text><![CDATA[	/**
	 * Configuration
	 */	
	public class Configuration {
	
		public static boolean enableAutoEvents = false;
		public static String timeZone = "UTC";
		public static INVENTORY_POLICY inventoryPolicy = INVENTORY_POLICY.ROP;
		public static String odooDatabaseName = "smartwatch_db";
		public static String odooBaseUrl = "http://localhost:8069/xmlrpc/2/";
		public static String odooServerUserName = "admin";
		public static String odooServerPassword= "admin";
		
		// types come from your Logger class
		public static boolean enableConsoleLogs 		 = !enableAutoEvents;
		public static Logger.LogLevel logLevel			 = Logger.LogLevel.TRACE;
		public static Logger.ColorMode colorMode		 = Logger.ColorMode.EMOJI;   // good for IDE console
		public static boolean useStdoutInsteadOfAnyLogic = true;        // set true for CLI runs
		
		public static boolean configSaved = false;
		
		public static boolean applyNewConfiguration(boolean _enableAutoEvents, String _timeZone, INVENTORY_POLICY _inventoryPolicy,
				String _odooDbName, String _odooHostUrl, String _odooServerUserName, String _odooServerPassword) {
			enableAutoEvents = _enableAutoEvents;
			timeZone = _timeZone;
			inventoryPolicy = _inventoryPolicy;
			odooDatabaseName = _odooDbName;
			odooBaseUrl = normalizeXmlRpcBaseUrl(_odooHostUrl);
			odooServerUserName = _odooServerUserName;
			odooServerPassword = _odooServerPassword;
			
			configSaved = true;
			
			return configSaved;
		}
		
		
		private static String normalizeXmlRpcBaseUrl(String input) {
		    if (input == null)
		    	return null;

		    String s = input.trim();
		    if (s.isEmpty())
		    	return s;

		    // remove trailing slashes
		    while (s.endsWith("/")) s = s.substring(0, s.length() - 1);

		    // if user pasted xmlrpc path, remove it (we’ll append cleanly)
		    String lower = s.toLowerCase();
		    int idx = lower.indexOf("/xmlrpc/2");
		    if (idx >= 0) s = s.substring(0, idx);

		    return s + "/xmlrpc/2/";
		}
	}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1771381670816</Id>
			<Name><![CDATA[INVENTORY_POLICY]]></Name>
			<Folder>1771290735356</Folder>
			<Text><![CDATA[/**
 * INVENTORY_POLICY
 */	
public enum INVENTORY_POLICY {

	ROP("Re-order Point"),
	PR("Periodic Review"),
	JIT("Just-In-Time");
	
	private final String policyName;
	
	private static final Map<String, INVENTORY_POLICY> BY_LABEL;
    static {
    	Map<String, INVENTORY_POLICY> m = new HashMap<>();
    	for(INVENTORY_POLICY pt : values()) {
    		m.put(pt.policyName.toLowerCase(Locale.ROOT), pt);
    	}
    	BY_LABEL = Collections.unmodifiableMap(m);
    }
	
	INVENTORY_POLICY(String name) { 
		this.policyName = name;
	}
	
	public String policyName() { return this.policyName; }
	
	public static INVENTORY_POLICY parse(String name)
	{
		if (name == null)
			Logger.error("POLICY NAME is null and cannot be parsed.", new IllegalArgumentException("null"));
		
		String k = name.trim();
		INVENTORY_POLICY byLabel = BY_LABEL.get(k.toLowerCase(Locale.ROOT));
		if (byLabel != null)
			return byLabel;
		
		return valueOf(k.toUpperCase(Locale.ROOT));
	}
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1771648445646</Id>
			<Name><![CDATA[CustomerOrderAtpForecastService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * CustomerOrderAtpForecastService
 *
 * Exact ATP "next completion" forecaster driven by simulation events.
 *
 * It records FG completions as they occur (packaged/ready-to-ship),
 * then can answer: "when will the Nth future unit of SKU X be completed?"
 */

public class CustomerOrderAtpForecastService {

	private final Main main;

	// SKU -> completion times (simulation seconds), appended in time order
	private final Map<String, ArrayDeque<Double>> completionsBySku = new HashMap<>();

    public CustomerOrderAtpForecastService(Main main) {
        this.main = main;
    }

    /** Call when one FG unit is completed and becomes available for shipping. */
    public void onFgCompleted(String fgSkuId, double completedAt) {
        if (fgSkuId == null || fgSkuId.isBlank())
        	return;
        this.completionsBySku.computeIfAbsent(fgSkuId, k -> new ArrayDeque<>()).addLast(completedAt);
        this.cleanupPast(fgSkuId, main.time());
    }

    /** Remove completion events earlier than now (optional). */
    private void cleanupPast(String fgSkuId, double now) {
        ArrayDeque<Double> q = completionsBySku.get(fgSkuId);
        if (q == null)
        	return;
        
        while (!q.isEmpty() && q.peekFirst() < now)
        	q.pollFirst();
    }

    /**
     * Returns the time of the Nth future completion (1-based).
     * Example: additionalUnitsNeeded=3 => time when the 3rd future unit completes.
     * Returns -1 if not enough future completions are known yet.
     */
    public double forecastNthCompletion(String fgSkuId, int additionalUnitsNeeded) {
        if (additionalUnitsNeeded <= 0)
        	return main.time();
        
        ArrayDeque<Double> q = completionsBySku.get(fgSkuId);
        if (q == null || q.size() < additionalUnitsNeeded)
        	return -1;

        int i = 0;
        for (Double t : q) {
            i++;
            if (i == additionalUnitsNeeded)
            	return t;
        }
        return -1;
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
