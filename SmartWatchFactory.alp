		<JavaClass>
			<Id>1771288462274</Id>
			<Name><![CDATA[MainService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * MainService
 * 
 * Aggregates all services used by Main.
 */	
public class MainService {

	// =========================================================
    // Setup / Bootstrap
    // =========================================================
    public final ManufacturingConfigService mfgConfig;
	public final BootstrapService bootstrap;
	public final MasterDataService masterData;
    private final InitService layoutInit;
    private final SlottingInitService slottingInit;

    // =========================================================
    // Core domain services
    // =========================================================
    public final LayoutService layout;
    public final CatalogService catalog;
    public final RoutingService routing;
    public final SlottingService slotting;

    // =========================================================
    // Warehouse
    // =========================================================
    public final InventorySeedService inventorySeed;
    private final StowingAssignmentsService stowAssignment;
    public final ReservationsService reservation;
    public final PickPlanningService pickPlanning;
    public final CustomerOrderAtpForecastService atpForecast;
    public final DiagnosticsService stockDiag;
    public final WarehouseDispatchService whDispatch;

    // =========================================================
    // Business flows
    // =========================================================
    public final ManufacturingFlowService moFlow;
    public final CustomerOrderFlowService coFlow;
    public final OutboundFlowService outbound;

    // =========================================================
    // Procurement split (new target)
    // =========================================================
    public final ProcurementPolicyService procurementPolicy;
    public final InboundProcurementFlowService inboundPoFlow;
    
    // =========================================================
    // KPI Service
    // =========================================================
    public final KpiService kpis;

    public MainService(Main main) {
    	
    	// --- Core / domain ---
        this.layout = new LayoutService(main);
        this.slotting = new SlottingService(main);
        this.catalog = new CatalogService(main);
        this.routing = new RoutingService(main);

        // --- Warehouse legacy ---
        this.stowAssignment = new StowingAssignmentsService(main);
        this.reservation = new ReservationsService(main);
        this.pickPlanning = new PickPlanningService(main, this.reservation);
        this.atpForecast = new CustomerOrderAtpForecastService(main);
        this.stockDiag = new DiagnosticsService(main);
        this.whDispatch = new WarehouseDispatchService(main, this.pickPlanning, this.stowAssignment);

        // --- Seed service ---
        this.inventorySeed = new InventorySeedService(main, this.slotting);

        // --- Flows ---
        this.moFlow = new ManufacturingFlowService(main);
        this.coFlow = new CustomerOrderFlowService(main);
        this.outbound = new OutboundFlowService(main);

        // --- Procurement new split ---
        this.procurementPolicy = new ProcurementPolicyService(main);
        this.inboundPoFlow = new InboundProcurementFlowService(main, this.procurementPolicy);
    	
    	// --- Bootstrap wrappers (so Main gets thinner) ---
        this.mfgConfig = new ManufacturingConfigService(main);
        this.masterData = new MasterDataService(main);
        this.layoutInit = new InitService(main);
        this.slottingInit = new SlottingInitService(main, this.slotting);
        this.bootstrap  = new BootstrapService(
                main,
                this.layoutInit,
                this.masterData,
                this.slottingInit,
                this.inventorySeed,
                this.procurementPolicy
        );
        
        // --- KPIs wrappers (so Main gets thinner) ---
        this.kpis = new KpiService(main);
    }
}]]></Text>
		</JavaClass>
