	<JavaClasses>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1754858531314</Id>
			<Name><![CDATA[RmSlot]]></Name>
			<Folder>1771726185934</Folder>
			<Text><![CDATA[/**
 * RmSlot (recommended final)
 *
 * Semantics:
 * - units			= available units in boxes already stored here
 * - reservedUnits	= units reserved for picking (still physically in boxes)
 * - incomingUnits	= units reserved for inbound stowing (boxes in-flight to this slot)
 *
 * - incomingBoxes	= number of inbound boxes in-flight to this slot
 * - boxes			= motherbox Resources currently stored in this slot
 */
import java.util.*;

public class RmSlot {

    public PRODUCT_TYPE skuType;   // DISPLAY, MICROCHIP, ...
    public String skuId;          // claimed SKU for this cell (null/empty if unclaimed)

    public int rackIdx;
    public int row, cell, level, deep;

    public final Deque<Resource> boxes = new ArrayDeque<>();

    public int units = 0;
    public int reservedUnits = 0;

    public int incomingUnits = 0;       // incoming UNITS (sum of upb for in-flight boxes)
    public int incomingBoxes = 0;		// incoming BOX COUNT
    
    public RackSystem rackSystem = null; 
    public boolean emptyRemovalInFlight = false;

    public RmSlot(RackSystem rs, PRODUCT_TYPE skuType, String skuId, int rackIdx,
                  int row, int cell, int level, int deep) {
    	this.rackSystem = rs;
        this.skuType = skuType;
        this.skuId = skuId;
        this.rackIdx = rackIdx;
        this.row = row;
        this.cell = cell;
        this.level = level;
        this.deep = deep;
        recalc();
    }

    // --------------------------
    // Capacity
    // --------------------------
    public int occupiedUnits() {
        return Math.max(0, units) + Math.max(0, reservedUnits) + Math.max(0, incomingUnits);
    }

    public int freeUnitCapacity() {
        return Math.max(0, Constants.RM_MAX_UNITS_PER_SLOT - occupiedUnits());
    }

    /** Max number of boxes this cell can hold (based on units per box). */
    public int maxBoxesForCell(int unitsPerBox) {
        if (unitsPerBox <= 0) return 0;
        return Math.max(1, Constants.RM_MAX_UNITS_PER_SLOT / unitsPerBox);
    }

    /** Free box positions left for a box with given UPB. */
    public int freeBoxesFor(int unitsPerBox) {
        return maxBoxesForCell(unitsPerBox) - (boxes.size() + incomingBoxes);
    }

    // --------------------------
    // Incoming reservation helpers (stowing)
    // --------------------------
    public void reserveIncomingBox(int unitsPerBox) {
        incomingBoxes += 1;
        incomingUnits += Math.max(0, unitsPerBox);
    }

    public void rollbackIncomingBox(int unitsPerBox, String reason) {
        if (incomingBoxes <= 0) {
            Logger.warn("RM incomingBoxes underflow rollback sku=", skuId, " reason=", reason);
        }
        incomingBoxes = Math.max(0, incomingBoxes - 1);

        int dec = Math.max(0, unitsPerBox);
        if (incomingUnits < dec) {
            Logger.warn("RM incoming(units) underflow rollback sku=", skuId,
                    " incoming=", incomingUnits, " dec=", dec, " reason=", reason);
        }
        incomingUnits = Math.max(0, incomingUnits - dec);
    }

    // --------------------------
    // Optional legacy slot-level reserve API (ONLY if you still use it somewhere)
    // If you are reserving from MotherBoxes, these are unused but safe to keep.
    // --------------------------
    public int reserve(int want) {
        if (want <= 0) return 0;
        int take = Math.min(want, units);
        units -= take;
        reservedUnits += take;
        return take;
    }

    public void consume(int q) {
        if (q <= 0) return;
        reservedUnits = Math.max(0, reservedUnits - q);
    }

    public void release(int q) {
        if (q <= 0) return;
        int giveBack = Math.min(reservedUnits, q);
        reservedUnits -= giveBack;
        units += giveBack;
    }

    // --------------------------
    // Recalc from actual MotherBoxes
    // --------------------------
    public void recalc() {
        int u = 0, r = 0;

        for (Resource mbRes : boxes) {
            MotherBox mb = mbRes.getMotherBox();
            if (mb == null) continue;
            u += mb.availableUnits();
            r += mb.reservedUnits();
        }

        this.units = u;
        this.reservedUnits = r;
    }

    @Override
    public String toString() {
        return "RM[rack=" + rackIdx +
                " row=" + row + " cell=" + cell + " L=" + level + " D=" + deep +
                " sku=" + skuId +
                " units=" + units + " reserved=" + reservedUnits +
                " inU=" + incomingUnits + " inB=" + incomingBoxes +
                " boxes=" + boxes.size() + "]";
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1754858786829</Id>
			<Name><![CDATA[PickStop]]></Name>
			<Folder>1771726185934</Folder>
			<Text><![CDATA[/**
 * PickStop
 */

public class PickStop {
	
	public int moId = -1;
	
	public String skuId;
	public PRODUCT_TYPE skuType;
	public FG_SKU fgSku;
	

	public int rackIdx;
	public int row;
	public int cell;
	public int level;
	public int deep;
	
	public int unitsToPick;
	
	public transient RmSlot slotRef;
	public FgSlot fgSlotRef;
	
	public List<Integer> fgIds = new ArrayList<>();
	
	public List<RmPickAlloc> rmAllocs = new ArrayList<>();
	public List<FgPickAlloc> fgAllocs = new ArrayList<>();
	
    public PickStop() {}
    
    public PickStop(String skuId, PRODUCT_TYPE skuType, int rackIdx, int row, int cell, int level, int deep, int units) {
        this.skuId = skuId;
        this.skuType = skuType;
        
        this.rackIdx = rackIdx;
        this.row = row;
        this.cell = cell;
        this.level = level;
        this.deep = deep;
        
        this.unitsToPick = units;
    }
}]]></Text>
		</JavaClass>
