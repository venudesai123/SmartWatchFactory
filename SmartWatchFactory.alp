			<Text><![CDATA[/**
 * VARIANT
 */	
public enum VARIANT { 
	
	MET(Color.DARK_GRAY, "Metallic"), 	// metallic - 0xCFD8DC
	FW(Color.MAGENTA, "Fiber white"), 	// fiber white - 0x43A047
	FB(Color.GREEN, "Fiber black"); 	// fiber black - 0xF4511E
	
	private final Color color;
	private final String label;
	
	VARIANT(Color color, String label) { 
		this.color = color;
		this.label = label;
	}
	
    public Color color() { return color; }
    public String label() { return label; }
}]]></Text>
