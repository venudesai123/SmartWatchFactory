/* ====================== For Vendors ===================== */
/* ======================================================== */

// supplier capabilities (initialize like you do in AnyLogic vars)
public List<Integer> suppliedProducts = new ArrayList<>();
public Map<Integer, Double> minQtyByProduct = new HashMap<>();
public Map<Integer, Double> delayDaysByProduct = new HashMap<>();
public List<String> suppliedSkus = new ArrayList<>();
public Map<String, Integer> productIdBySku = new HashMap<>();

public void setVendor(int vendorId,
                      String simName,
                      String name,
                      String address,
                      String pincode,
                      String city,
                      String country) {
    
    this.id = vendorId;
    this.simName = simName;
    this.name = name;
    this.address = address;
    this.pincode = pincode;
    this.city = city;
    this.country = country;
}

public void initVendorStartPoint() {
    if (main == null || main.VENDOR_ENTRIES == null || main.VENDOR_ENTRIES.length == 0) {
        Logger.debug("Vendor ", id, " postponing start point; entries not ready.");
        return;
    }
    int idx = Math.floorMod(this.id, main.VENDOR_ENTRIES.length);
    PointNode pn = main.VENDOR_ENTRIES[idx];
    
    if (pn != null)
    	jumpTo(pn);
}

/* ======================================================== */
/* ================== For Outbound Workers ================ */
/* ======================================================== */
private PointNode seatNode;
public CustomerOrder currentCo = null;
public int currentDockIndex = -1;
private String nextOutboundArrivalMsg = null;

public boolean reachedStaging = false;
public boolean outboundWorkerBusy = false;

public void initWorker(PointNode seat) {
	this.seatNode = seat;
}

public void armOutboundArrivalOrFireNow(String msg, double tx, double ty) {
    double dx = getX() - tx;
    double dy = getY() - ty;

    if (Math.hypot(dx, dy) <= 0.01) {
        // Already there → immediately tell statechart
        statechartOutbound.fireEvent(msg);
        return;
    }

    nextOutboundArrivalMsg = msg;
    moveTo(tx, ty);
    outboundArrivalPoller.restart();
}

public void armOutboundArrivalOrFireNow(String msg, PointNode pn) {
    double dx = getX() - pn.getX();
    double dy = getY() - pn.getY();

    if (Math.hypot(dx, dy) <= 0.01) {
        // Already there → immediately tell statechart
        statechartOutbound.fireEvent(msg);
        return;
    }

    nextOutboundArrivalMsg = msg;
    moveTo(pn);
    outboundArrivalPoller.restart();
}

public void goOutboundSeatAndWait(String msg) {
	armOutboundArrivalOrFireNow(msg, seatNode);
}

public double getLoadingTime() {
	int boxes = currentCo.getTotalBoxes();
	double perBox = Constants.TRUCK_LOAD_PER_BOX_IN_SECS;  // e.g. 3 seconds per box
	return Math.max(1, boxes) * perBox;
}

public void assignOutboundJob(CustomerOrder co, int dockIdx) {
    if (co == null)
    	return;
    if (currentCo!= null) {
        Logger.warn("OutboundWorker ", getIndex(), " already has a job.");
        return;
    }

    this.currentCo = co;
    this.currentDockIndex = dockIdx;
    this.outboundWorkerBusy = true;

    statechartOutbound.fireEvent("NEW_OUTBOUND_JOB");
}

/* ======================================================== */

public void applyTruckTheme() {
	Color[] duo = Constants.TWO_COLOR_PALETTE_TRUCK[Math.floorMod(getId(), Constants.TWO_COLOR_PALETTE_TRUCK.length)];
	
	truckIcon.setColor("Material__2__Surf", duo[0]);
	truckIcon.setColor("Material__1__Surf", duo[1]);
	truckIcon.setColor("Material__3__Surf", Color.BLACK);
}

@Override
public String toString() {
	String idLabel, loc, namePart, locPart;
	
	switch(category) {
		case DISTRIBUTOR:
		case VENDOR:
		    idLabel = (simName != null && !simName.isEmpty())
		             ? simName
		             : (category.name() + "_" + id);
		
		    loc = (city == null || city.isEmpty())
		        ? (country == null ? "" : country)
		        : (city + (country == null || country.isEmpty() ? "" : ", " + country));
		
		    namePart = (name == null ? "" : name);
		    locPart = (loc.isEmpty() ? "" : " (" + loc + ")");
		
		    return idLabel + " — " + namePart + locPart;
		default:
			return super.toString();
	}
}
]]></AdditionalClassCode>
			<StartupCode><![CDATA[if (category == RESOURCE_TYPE.DISTRIBUTOR) {
    double meanH = Constants.meanInterOrderTimeHours;
    double firstDelayH = exponential(meanH); // or triangular, up to you

    if (firstDelayH <= 0) 
    	firstDelayH = meanH;
    	
    customerOrderGenerator.restart(firstDelayH * 3600);  // if your base unit is seconds
}
]]></StartupCode>
