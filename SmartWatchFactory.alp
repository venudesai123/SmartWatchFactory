			<Folder>1771290735356</Folder>
			<Text><![CDATA[/**
 * RESOURCE_TYPE
 */	
public enum RESOURCE_TYPE {

	MOTHERBOX,
	TRAY,
	VENDOR,
	DISTRIBUTOR,
	TRUCK,
	
	INBOUND_WORKER,
	INBOUND_QC_WORKER,
	OUTBOUND_WORKER,
	
	ASM_OP,
	SW_OP,
	QC_OP,
	REWORK_OP,
	PACK_OP,
	SORT_OP	
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1771732900698</Id>
			<Name><![CDATA[SlottingInitService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * SlottingInitService
 */	
import java.util.*;

public class SlottingInitService {
	
	private final Main main;
	private final SlottingService slotting;
	
	public SlottingInitService(Main main, SlottingService slotting) {
        this.main = main;
        this.slotting = slotting;
    }

	public void initSlotMaps() {
        main.rmSlotsBySku = new EnumMap<>(PRODUCT_TYPE.class);
        for (PRODUCT_TYPE t : PRODUCT_TYPE.values()) {
        	main.rmSlotsBySku.put(t, new ArrayList<>());
        }
        
        main.fgSlotsBySku = new EnumMap<>(FG_SKU.class);
        for (FG_SKU s : FG_SKU.values()) {
        	main.fgSlotsBySku.put(s, new ArrayList<>());
        }
    }
	
	public void initRmSlots() {
    	for (PRODUCT_TYPE pt : PRODUCT_TYPE.values()) {
    		RackSystem rs = this.slotting.selectRmRackSystem(pt);
    		List<RmSlot> slots = main.rmSlotsBySku.get(pt);
    	    slots.clear();

    	    // build the full grid for this rack (2 rows × 25 cells × 10 levels × 1 deep = 500) ---
    	    for (int row = 0; row < Constants.RM_RACK_ROWS; row++) {
    	        for (int level = 0; level < Constants.RM_RACK_LEVELS; level++) {
    	            for (int cell = 0; cell < Constants.RM_RACK_CELLS; cell++) {
    	                for (int deep = 0; deep < Constants.RM_RACK_DEEP; deep++) {
    	                    // start empty; skuId == null means "free slot" that can be claimed on first inbound box
    	                    RmSlot s = new RmSlot(rs, pt, null, pt.ordinal(), row, cell, level, deep);
    	                    slots.add(s);
    	                }
    	            }
    	        }
    	    }

    	    // get variants for THIS rack (if any) ---
    	    List<String> variants = this.orderedVariantsFor(pt, main.skuIdsBySkuType.get(pt));
    	    if (variants == null || variants.isEmpty() || variants.size() == 1) {
    	        // Single-variant (e.g., Display/Microchip/Battery): keep all slots free (skuId=null)
    	        continue;
    	    }
    	    
    	    boolean liveReady = (main.m_odooSession != null && main.stockLocationId > 0);
    		if (liveReady) {
    			Set<String> skus = new LinkedHashSet<>(main.skuRawTypeBySkuId.keySet());
    		    main.liveOnHandBySkuId = OdooLiveService.fetchOnHandBySkuIds(main, skus, main.stockLocationId, "ServiceSlotting.initRmSlot");
    		}
    	    
    	    // fair proportional allocation with largest-remainder rounding
    	    int totalSlots = slots.size(); // rows * levels * cells * deep
    	    Map<String, Integer> quotas = this.computeProportionalQuotas(variants, main.liveOnHandBySkuId, totalSlots);

    	    // --- Allocate variant capacity by CELL-BANDS per ROW (keeps all 3 variants present in each row) ---
    		int flexCellsPerRow = Constants.RM_FLEX_CELLS_PER_ROW; 
    		int claimCellsPerRow = Math.max(0, Constants.RM_RACK_CELLS - flexCellsPerRow);
    		
    		// quotas are computed in "cells per row" (NOT total rack slots)
    		Map<String, Integer> cellQuotas = this.computeProportionalQuotas(variants, main.liveOnHandBySkuId, claimCellsPerRow);
    		
    		// Ensure each variant gets at least 1 cell per row (only if possible)
    		if (claimCellsPerRow >= variants.size()) {
    		    for (String v : variants) {
    		        cellQuotas.put(v, Math.max(1, cellQuotas.getOrDefault(v, 0)));
    		    }
    		
    		    // normalize back down to claimCellsPerRow if mins pushed us over
    		    int total = 0;
    		    for (String v : variants) total += cellQuotas.getOrDefault(v, 0);
    		
    		    while (total > claimCellsPerRow) {
    		        String best = null;
    		        for (String v : variants) {
    		            int qv = cellQuotas.getOrDefault(v, 0);
    		            if (qv <= 1) continue; // don't reduce below 1
    		            if (best == null || qv > cellQuotas.get(best)) best = v;
    		        }
    		        if (best == null) break;
    		        cellQuotas.put(best, cellQuotas.get(best) - 1);
    		        total--;
    		    }
    		}
    		
    		// Build contiguous cell ranges per variant: [startCell..endCell]
    		Map<String, int[]> ranges = new LinkedHashMap<>();
    		int cellCursor = 0;
    		for (String skuId : variants) {
    		    int w = Math.max(0, cellQuotas.getOrDefault(skuId, 0));
    		    int start = cellCursor;
    		    int end = cellCursor + w - 1;
    		    ranges.put(skuId, new int[] { start, end });
    		    cellCursor += w;
    		}
    		
    		// Claim ALL levels/deep slots inside those cell bands for EACH row
    		for (int row = 0; row < Constants.RM_RACK_ROWS; row++) {
    		    for (String skuId : variants) {
    		        int[] r = ranges.get(skuId);
    		        if (r == null || r[1] < r[0]) continue;
    		
    		        int startCell = r[0];
    		        int endCell = r[1];
    		
    		        for (RmSlot s : slots) {
    		            if (s.row != row) continue;
    		            if (s.cell < startCell || s.cell > endCell) continue;
    		
    		            if (s.skuId == null) {
    		                s.skuId = skuId;   // claim this slot for this variant
    		                s.skuType = pt;
    		            }
    		        }
    		    }
    		}
    		// remaining cells (flexCellsPerRow) stay skuId == null (flex capacity)
    	}
    }
    
    private Map<String,Integer> computeProportionalQuotas(List<String> variants, Map<String, Double> stock, int totalSlots) {
    	Map<String,Integer> q = new LinkedHashMap<>();
    	if (totalSlots <= 0 || variants == null || variants.isEmpty())
    		return q;

    	double sum = 0;
    	for (String v : variants) 
    		sum += Math.max(0, stock.getOrDefault(v, 0.0));

    	if (sum <= 0) {
    	    // no stock info → even split
    	    int base = totalSlots / variants.size();
    	    int rem  = totalSlots - base * variants.size();
    	    for (int i = 0; i < variants.size(); i++) {
    	        q.put(variants.get(i), base + (i < rem ? 1 : 0));
    	    }
    	    return q;
    	}

    	// floor part + collect remainders
    	double[] exact = new double[variants.size()];
    	double[] rem   = new double[variants.size()];
    	int allocated  = 0;
    	for (int i = 0; i < variants.size(); i++) {
    	    String v = variants.get(i);
    	    exact[i] = (double) Math.max(0, stock.getOrDefault(v, 0.0)) * totalSlots / (double) sum;
    	    int floor = (int) Math.floor(exact[i]);
    	    rem[i] = exact[i] - floor;
    	    q.put(v, floor);
    	    allocated += floor;
    	}

    	// distribute leftovers to largest remainders
    	int leftover = totalSlots - allocated;
    	while (leftover-- > 0) {
    	    int bestIdx = 0;
    	    double bestRem = -1;
    	    for (int i = 0; i < rem.length; i++) {
    	        if (rem[i] > bestRem) { bestRem = rem[i]; bestIdx = i; }
    	    }
    	    String v = variants.get(bestIdx);
    	    q.put(v, q.get(v) + 1);
    	    rem[bestIdx] = -1; // so it won't be picked again
    	}
    	return q;
    }
    
    public void initFgSlots() {
    	for (FG_SKU fg : FG_SKU.values()) {
    		RackSystem rs = this.slotting.selectFgRackSystem(fg);
    		
    	    List<FgSlot> slots = main.fgSlotsBySku.get(fg);
    	    slots.clear();

    	    for (int row = 0; row < Constants.FG_RACK_ROWS; row++) {
    	        for (int level = 0; level < Constants.FG_RACK_LEVELS; level++) {
    	            for (int cell = 0; cell < Constants.FG_RACK_CELLS; cell++) {
    	                for (int deep = 0; deep < Constants.FG_RACK_DEEP; deep++) {
    	                    // start empty
    	                    FgSlot s = new FgSlot(
    	                    	rs,
    	                        fg,
    	                        null,    // skuId: will be set on first use
    	                        row, cell, level, deep
    	                    );
    	                    slots.add(s);
    	                }
    	            }
    	        }
    	    }
    	}
    }
    
    private List<String> orderedVariantsFor(PRODUCT_TYPE pt, List<String> variants) {
        if (variants == null) return Collections.emptyList();

        if (pt == PRODUCT_TYPE.CASE) {
            return Arrays.asList(
                CASE_SKU.MET.skuId(),
                CASE_SKU.FW.skuId(),
                CASE_SKU.FB.skuId()
            );
        }
        if (pt == PRODUCT_TYPE.STRAP) {
            return Arrays.asList(
                STRAP_SKU.MET.skuId(),
                STRAP_SKU.FW.skuId(),
                STRAP_SKU.FB.skuId()
            );
        }
        return variants; // no ordering needed for single-variant types
    }
    
    public void debugRmVariantLayout(PRODUCT_TYPE pt) {
    	List<RmSlot> slots = main.rmSlotsBySku.get(pt);
	        if (slots == null || slots.isEmpty()) {
	            Logger.info("debugRmVariantLayout: no slots for pt=", pt);
	        return;
	    }
	
	    Logger.info("=== RM Variant Layout for ", pt, " ===");
	
	    for (int row = 0; row < Constants.RM_RACK_ROWS; row++) {
	
	        Map<String, Integer> cellsBySku = new LinkedHashMap<>();
	        int freeCells = 0;
	        int mixedCells = 0;
	
	        for (int cell = 0; cell < Constants.RM_RACK_CELLS; cell++) {
	
	            // collect distinct skuIds across all levels/deep for this cell
	            HashSet<String> skus = new HashSet<>();
	            for (RmSlot s : slots) {
	                if (s.row == row && s.cell == cell) {
	                    if (s.skuId != null && !s.skuId.isEmpty()) skus.add(s.skuId);
	                }
	            }
	
	            if (skus.isEmpty()) {
	                freeCells++;
	            } else if (skus.size() == 1) {
	                String sku = skus.iterator().next();
	                cellsBySku.put(sku, cellsBySku.getOrDefault(sku, 0) + 1);
	            } else {
	                mixedCells++;
	                Logger.warn("Row ", row, " cell ", cell, " has mixed SKUs: ", skus);
	            }
	        }
	
	        Logger.info("Row ", row, " -> per-sku cells: ", cellsBySku, " | freeCells=", freeCells, " | mixedCells=", mixedCells);
	    }
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1771783631749</Id>
			<Name><![CDATA[Logger]]></Name>
			<Folder>1771290631309</Folder>
			<Text><![CDATA[/**
 * Logger
 *
 * Purpose
 * - Lightweight logger for AnyLogic + standalone runs.
 * - Supports console logging (AnyLogic traceln / stdout) and file logging for long experiments.
 *
 * Features
 * - Same public API as before: error/warn/info/debug/trace, log level filtering, sink, and color mode.
 * - Per-run log folder created at startup:
 *     <baseDir>/<REAL_RUN_START_yyyy-MM-dd_HH-mm-ss>/
 * - Log files are rotated by SIMULATION calendar day (not real day):
 *     <prefix>-YYYY-MM-DD.log
 *   where the simulation date is computed as:
 *     simDate = engineStartDate + main.time() seconds
 * - Log prefix includes BOTH timestamps for easier analysis:
 *     [REAL <wall-clock> | SIM <sim-calendar> UTC (t=<simSeconds>s)] [LEVEL] message
 * - Performance-friendly buffering:
 *     - INFO/DEBUG/TRACE flushed every N lines (configurable)
 *     - WARN/ERROR flushed immediately (so crash causes are likely preserved)
 * - Graceful shutdown support:
 *     - shutdown() closes and flushes the current file
 *     - a JVM shutdown hook calls shutdown() on normal termination
 *
 * Typical usage (Main -> On startup)
 *   Logger.enableSimDayFileLogging(
 *       "logs",
 *       "smartwatch",
 *       main.getEngine().getStartDate(),
 *       () -> main.time()          // simulation time in seconds
 *   );
 *   Logger.setConsoleEnabled(false);   // recommended for 6-month runs (avoid UI console overhead)
 *   Logger.setFileFlushEveryLines(1000);
 *   Logger.setLogLevel(Logger.LogLevel.INFO); // or WARN for faster runs
 *
 * Typical usage (Experiment -> On stop / Main -> On destroy)
 *   Logger.shutdown();
 *
 * Notes
 * - Configuration.timeZone is used for simulation timestamps and sim-day rotation (recommended: "UTC").
 * - In a hard crash (power loss / kill -9), buffered INFO/DEBUG lines not yet flushed may be lost.
 *   WARN/ERROR lines are flushed immediately to minimize loss of critical diagnostics.
 */

import java.time.ZonedDateTime;
import java.time.format.DateTimeFormatter;

import java.io.PrintWriter;
import java.io.StringWriter;
import java.io.BufferedWriter;

import java.nio.charset.StandardCharsets;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.nio.file.Files;
import java.nio.file.StandardOpenOption;

import java.text.SimpleDateFormat;

import java.util.Date;
import java.util.TimeZone;

import java.util.function.DoubleSupplier;

public class Logger {

    public enum LogLevel { ERROR, WARN, INFO, DEBUG, TRACE }
    public enum ColorMode { NONE, ANSI, EMOJI }
    public enum Sink { ANYLOGIC, STDOUT }

    // ANSI codes
    private static final String RESET  = "\u001B[0m";
    private static final String RED    = "\u001B[31m";
    private static final String YELLOW = "\u001B[33m";
    private static final String BLUE   = "\u001B[34m";
    private static final String CYAN   = "\u001B[36m";
    private static final String GRAY   = "\u001B[90m";

    // REAL (wall-clock) time for prefix
    private static final DateTimeFormatter REAL_TS_FMT = DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm:ss.SSS xxx");

    // REAL run-start folder name formatter (safe for Windows/Linux)
    private static final DateTimeFormatter RUN_DIR_FMT = DateTimeFormatter.ofPattern("yyyy-MM-dd_HH-mm-ss");

    // SIM (simulation calendar) time for prefix + rolling
    private static final SimpleDateFormat SIM_TS_FMT  = new SimpleDateFormat("yyyy-MM-dd HH:mm:ss.SSS");
    private static final SimpleDateFormat SIM_DAY_FMT = new SimpleDateFormat("yyyy-MM-dd");

    // Config
    private static volatile LogLevel currentLevel = LogLevel.INFO;
    private static volatile ColorMode colorMode   = autoColorMode();
    private static volatile Sink sink             = Sink.ANYLOGIC;

    // ---------------- FILE LOGGING (SIM-DAY ROLLING) ----------------
    private static volatile boolean fileEnabled = false;
    private static volatile boolean consoleEnabled = true;

    // Base logs dir (e.g., "logs") and the per-run directory actually used
    private static volatile Path baseLogDir = Paths.get("logs"); // NEW: base directory
    private static volatile Path runLogDir  = null;              // NEW: logs/<runStart>/
    private static volatile String filePrefix = "sim";

    // Simulation clock inputs
    private static volatile Date engineStartDateRef = null;
    private static volatile DoubleSupplier simTimeSecondsSupplier = null;

    private static final Object fileLock = new Object();
    private static BufferedWriter fileOut = null;

    private static String openSimDay = null;
    private static int fileLineCount = 0;
    private static volatile int flushEveryLines = 500;

    static {
        // Set SIM formatters timezone from your Configuration.timeZone if available, else UTC
        try {
            String tz = (Configuration.timeZone == null || Configuration.timeZone.trim().isEmpty())
                    ? "UTC"
                    : Configuration.timeZone.trim();
            TimeZone zone = TimeZone.getTimeZone(tz);
            SIM_TS_FMT.setTimeZone(zone);
            SIM_DAY_FMT.setTimeZone(zone);
        } catch (Throwable ignore) {
            TimeZone utc = TimeZone.getTimeZone("UTC");
            SIM_TS_FMT.setTimeZone(utc);
            SIM_DAY_FMT.setTimeZone(utc);
        }

        // Shutdown hook
        try {
            Runtime.getRuntime().addShutdownHook(new Thread(Logger::shutdown));
        } catch (Throwable ignore) { }
    }

    /**
     * Enable SIMULATION-DAY rolling file output.
     * Creates per-run folder under base directory:
     *   <base>/<REAL_RUN_START_yyyy-MM-dd_HH-mm-ss>/<prefix>-YYYY-MM-DD.log
     */
    public static void enableSimDayFileLogging(String directory,
                                               String prefix,
                                               Date engineStartDate,
                                               DoubleSupplier simTimeSeconds) {
        if (directory != null && !directory.trim().isEmpty())
            baseLogDir = Paths.get(directory.trim());

        if (prefix != null && !prefix.trim().isEmpty())
            filePrefix = prefix.trim();

        engineStartDateRef = engineStartDate;
        simTimeSecondsSupplier = simTimeSeconds;

        // NEW: create run-specific directory once
        String runFolder = ZonedDateTime.now().format(RUN_DIR_FMT);
        runLogDir = baseLogDir.resolve(runFolder);

        fileEnabled = true;

        synchronized (fileLock) {
            // Create directories eagerly
            try {
                Files.createDirectories(runLogDir);
            } catch (Throwable t) {
                // If we cannot create run dir, disable file logging but keep console alive
                fileEnabled = false;
                runLogDir = null;
                System.err.println("Logger: cannot create run log directory: " + t.getMessage());
                return;
            }

            // Try open immediately
            ensureFileOpenForCurrentSimDay();
        }
    }

    /** Where the current run logs are being written (may be null if file logging disabled). */
    public static String getRunLogDir() {
        Path p = runLogDir;
        return (p == null) ? null : p.toString();
    }

    public static void disableFileLogging() {
        fileEnabled = false;
        synchronized (fileLock) {
            closeFileNoThrow();
        }
    }

    public static void setConsoleEnabled(boolean on) {
        consoleEnabled = on;
    }

    public static void setFileFlushEveryLines(int n) {
        if (n < 1) n = 1;
        flushEveryLines = n;
    }

    public static void shutdown() {
        synchronized (fileLock) {
            closeFileNoThrow();
        }
    }
    // ---------------------------------------------------------------

    // ---------- public API ----------
    public static LogLevel getLogLevel() { return currentLevel; }
    public static void setLogLevel(LogLevel level) { if (level != null) currentLevel = level; }
    public static void setColorMode(ColorMode mode) { if (mode != null) colorMode = mode; }
    public static void setSink(Sink s) { if (s != null) sink = s; }

    public static void log(LogLevel level, Object... args) {
        if (level == null) { write(joinArgs(args), null); return; }
        if (!shouldLog(level)) return;
        write(prefix(level) + joinArgs(args), level);
    }

    public static void error(Object... a){ log(LogLevel.ERROR, a); }
    public static void warn (Object... a){ log(LogLevel.WARN , a); }
    public static void info (Object... a){ log(LogLevel.INFO , a); }
    public static void debug(Object... a){ log(LogLevel.DEBUG, a); }
    public static void trace(Object... a){ log(LogLevel.TRACE, a); }

    public static void error(String msg, Throwable t) { logThrowable(LogLevel.ERROR, msg, t); }
    public static void warn (String msg, Throwable t) { logThrowable(LogLevel.WARN , msg, t); }
    public static void debug(String msg, Throwable t) { logThrowable(LogLevel.DEBUG, msg, t); }

    // ---------- internals ----------
    private static boolean shouldLog(LogLevel msgLevel) {
        return msgLevel.ordinal() <= currentLevel.ordinal();
    }

    private static String prefix(LogLevel level) {
        String realTs = ZonedDateTime.now().format(REAL_TS_FMT);

        String simPart = "SIM n/a";
        Date start = engineStartDateRef;
        DoubleSupplier sup = simTimeSecondsSupplier;

        if (start != null && sup != null) {
            try {
                double simSeconds = sup.getAsDouble();
                long simMillis = (long) Math.round(simSeconds * 1000.0);
                Date simNow = new Date(start.getTime() + simMillis);

                String simTs;
                synchronized (SIM_TS_FMT) {
                    simTs = SIM_TS_FMT.format(simNow);
                }

                String tzTag;
                try {
                    tzTag = (Configuration.timeZone == null || Configuration.timeZone.trim().isEmpty())
                            ? "UTC"
                            : Configuration.timeZone.trim();
                } catch (Throwable ignore) {
                    tzTag = "UTC";
                }

                simPart = "SIM " + simTs + " " + tzTag + String.format(" (t=%.3fs)", simSeconds);
            } catch (Throwable ignore) {
                simPart = "SIM n/a";
            }
        }

        String tag = "[" + level.name() + "]";
        String base = "[REAL " + realTs + " | " + simPart + "] ";

        switch (colorMode) {
            case NONE:
                return base + tag + " ";
            case EMOJI:
                String icon =
                        (level==LogLevel.ERROR) ? "❌" :
                        (level==LogLevel.WARN ) ? "⚠️" :
                        (level==LogLevel.INFO ) ? "ℹ️" :
                        (level==LogLevel.DEBUG) ? "🐞" : "🔍";
                return base + icon + " " + tag + " ";
            case ANSI:
            default:
                String color =
                        (level==LogLevel.ERROR) ? RED :
                        (level==LogLevel.WARN ) ? YELLOW :
                        (level==LogLevel.INFO ) ? BLUE :
                        (level==LogLevel.DEBUG) ? CYAN : GRAY;
                return base + color + tag + RESET + " ";
        }
    }

    private static void write(String line, LogLevel level) {
        if (line == null)
        	line = "";

        if (fileEnabled) {
            writeToSimDayFile(line, level);
        }

        if (!consoleEnabled)
        	return;

        boolean inAnyLogic;
        try { 
        	Class.forName("com.anylogic.engine.Utilities");
        	inAnyLogic = true;
        } catch (Throwable t) { 
        	inAnyLogic = false;
        }

        if (inAnyLogic && sink == Sink.ANYLOGIC) {
            try {
                com.anylogic.engine.Utilities.traceln(stripAnsi(line));
                return;
            } catch (Throwable ignore) { }
        }

        boolean isErr = (level == LogLevel.ERROR || level == LogLevel.WARN);
        if (colorMode == ColorMode.ANSI) {
            if (isErr) System.err.println(line);
            else       System.out.println(line);
        } else {
            String clean = stripAnsi(line);
            if (isErr) System.err.println(clean);
            else       System.out.println(clean);
        }
    }

    // ---------------- FILE LOGGING internals ----------------
    private static void writeToSimDayFile(String line, LogLevel level) {
        synchronized (fileLock) {
            if (!ensureFileOpenForCurrentSimDay()) return;

            try {
                fileOut.write(stripAnsi(line));
                fileOut.newLine();

                fileLineCount++;

                boolean critical = (level == LogLevel.ERROR || level == LogLevel.WARN);
                if (critical || (fileLineCount % flushEveryLines == 0)) {
                    fileOut.flush();
                }
            } catch (Throwable t) {
                fileEnabled = false;
                closeFileNoThrow();
                System.err.println("Logger: file logging disabled due to error: " + t.getMessage());
            }
        }
    }

    private static boolean ensureFileOpenForCurrentSimDay() {
        if (!fileEnabled) return false;
        if (engineStartDateRef == null || simTimeSecondsSupplier == null) return false;
        if (runLogDir == null) return false;

        double simSeconds;
        try { simSeconds = simTimeSecondsSupplier.getAsDouble(); }
        catch (Throwable t) { return false; }

        long simMillis = (long) Math.round(simSeconds * 1000.0);
        Date simNow = new Date(engineStartDateRef.getTime() + simMillis);

        String simDay;
        synchronized (SIM_DAY_FMT) {
            simDay = SIM_DAY_FMT.format(simNow);
        }

        if (fileOut != null && simDay.equals(openSimDay)) return true;

        closeFileNoThrow();

        try {
            Files.createDirectories(runLogDir);

            Path filePath = runLogDir.resolve(filePrefix + "-" + simDay + ".log");

            fileOut = Files.newBufferedWriter(
                    filePath,
                    StandardCharsets.UTF_8,
                    StandardOpenOption.CREATE,
                    StandardOpenOption.WRITE,
                    StandardOpenOption.APPEND
            );

            openSimDay = simDay;
            fileLineCount = 0;

            fileOut.write("----- RUN DIR: " + runLogDir.toString() + " -----");
            fileOut.newLine();
            fileOut.write("----- NEW SIM DAY: " + openSimDay + " -----");
            fileOut.newLine();
            fileOut.flush();

            return true;

        } catch (Throwable t) {
            System.err.println("Logger: cannot open log file in " + runLogDir + " : " + t.getMessage());
            fileOut = null;
            openSimDay = null;
            return false;
        }
    }

    private static void closeFileNoThrow() {
        try {
            if (fileOut != null) {
                fileOut.flush();
                fileOut.close();
            }
        } catch (Throwable ignore) {
        } finally {
            fileOut = null;
            openSimDay = null;
            fileLineCount = 0;
        }
    }
    // -------------------------------------------------------

    private static String joinArgs(Object... args) {
        if (args == null || args.length == 0) return "";
        StringBuilder sb = new StringBuilder();
        for (Object a : args) sb.append(a == null ? "null" : a.toString()).append(' ');
        return sb.toString().trim();
    }

    private static String stripAnsi(String s) {
        if (s == null) return null;
        return s.replaceAll("\\u001B\\[[;\\d]*m", "");
    }

    private static void logThrowable(LogLevel lvl, String msg, Throwable t) {
        if (!shouldLog(lvl)) return;

        StringBuilder sb = new StringBuilder();
        if (msg != null && !msg.isEmpty()) sb.append(msg).append('\n');
        if (t != null) sb.append(stackTrace(t));

        write(prefix(lvl) + sb, lvl);
    }

    private static String stackTrace(Throwable t) {
        StringWriter sw = new StringWriter(512);
        t.printStackTrace(new PrintWriter(sw));
        return sw.toString();
    }

    private static ColorMode autoColorMode() {
        boolean inAnyLogic;
        try { 
        	Class.forName("com.anylogic.engine.Utilities");
        	inAnyLogic = true;
        } catch (Throwable t) { 
        	inAnyLogic = false;
        }

        if (inAnyLogic)
        	return ColorMode.EMOJI;
        
        return (System.console() != null) ? ColorMode.ANSI : ColorMode.NONE;
    }
}]]></Text>
