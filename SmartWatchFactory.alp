						<Parameter>
							<Name><![CDATA[onExit]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[Resource mbRes = (Resource) agent;
MotherBox mb = mbRes.getMotherBox();
if (mb == null) return;

mbRes.itemAssigned = false;

PRODUCT_TYPE pt = (mb.getSkuType() != null) ? 
					mb.getSkuType() : 
					PRODUCT_TYPE.fromSkuId(mb.getSkuId());
RmSlot slot = this.services.slotting.getRmSlot(
    pt,
    mbRes.rackTargetRow,
    mbRes.rackTargetLevel,
    mbRes.rackTargetCell,
    0 // if later needs to model deep positions, add a rackTargetDeep variable
);

if (slot == null) {
    Logger.error("RM RackStore: cannot find logical slot for sku=", mb.getSkuId());
    return;
}

boolean ok = this.services.slotting.placeMotherBoxIntoRmSlot(mbRes, slot);
if (!ok) {
    Logger.error("RM RackStore: logical placement failed sku=", mb.getSkuId());
	return;
}

mbRes.hasRackTarget = false;
mbRes.rmStowTask = null;
this.services.inboundPoFlow.onInboundBoxStored(mbRes);
]]></Code>
							</Value>
