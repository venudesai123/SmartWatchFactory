		<JavaClass>
			<Id>1754891094219</Id>
			<Name><![CDATA[Constants]]></Name>
			<Folder>1771290631309</Folder>
			<Text><![CDATA[/**
 * Constants
 */	
import java.awt.Color;
import java.util.Calendar;
import java.util.Date;

public final class Constants {	
		
	// Default values
	public static final String DEFAULT_WAREHOUSE_CODE	= "WH";
	public static final double HEARTBEAT_BASE_SEC		= 5.0;
	public static final double HEARTBEAT_MAX_SEC		= 60.0;
	public static final double HEARTBEAT_BACKOFF_MULT 	= 2.0;
	public static final int READ_GROUP_BATCH			= 100;
	
	public static final int CO_PACK_STATIONS = 3;
	public static final int OUTBOUND_DOCK_STATIONS = 3;
	public static final double TRUCK_LOAD_PER_BOX_IN_SECS = 3.0;
	public static final int TRUCK_BOX_CAPACITY = 200;
	
	// Pallet rack default values for RM
	public static final int RM_RACK_ROWS			= 2;  // two racks, one aisle (left/right)
	public static final int RM_RACK_CELLS			= 25; // columns along the rack
	public static final int RM_RACK_LEVELS			= 10; // 0..9
	public static final int RM_RACK_DEEP			= 1;  // single deep
	public static final int RM_MAX_UNITS_PER_SLOT	= 150;
	
	public static final int RM_MIN_BOX_PER_TRIP = 3;
	public static final int RM_MAX_BOX_PER_TRIP = 10;
	
	public static final int RM_FLEX_CELLS_PER_ROW = 2; // keep 1–2 cells per row unclaimed for flexibility
	public static final boolean RM_USE_DYNAMIC_VARIANT_BANDS = true;
	
	// Pallet rack default values for FG
	public static final int FG_RACK_ROWS			= 2;  // two racks, one aisle (left/right)
	public static final int FG_RACK_CELLS			= 8;  // columns along the rack
	public static final int FG_RACK_LEVELS			= 10; // 0..9
	public static final int FG_RACK_DEEP			= 1;  // single deep
	public static final int FG_MAX_UNITS_PER_SLOT	= 100;  // FG_MAX_UNITS_PER_SLOT/TRAY_SIZE trays
	
	public static final int FG_MIN_TRAYS_PER_TRIP 	= 3;
	public static final int FG_MAX_TRAYS_PER_TRIP 	= 10;
	
	public static final int TRAY_SIZE = Configuration.enableAutoEvents ? 10 : 1;
	
	public static final double WARM_UP_DAYS = 7.0;
	
	public static final double STOW_MAX_WAIT = 20*60; // in seconds
	
	// For Distributors (customer orders)

	// Typical time between orders per distributor (in hours).
	// We default to weekly demand with randomness around it.
	public static final double meanInterOrderTimeHours = 7 * 24; // 1 week

	// Base per-line quantity (before spikes)
	public static final int minOrderQty = 50;
	public static final int maxOrderQty = 200;

	// ---- Spike behaviour ----
	// Fraction of orders that will be "big" (quantity spike)
	public static final double spikeOrderProbability    = 0.20;
	// Multiplier range applied to the base qty in spike orders
	public static final double spikeQtyFactorMin        = 1.5;
	public static final double spikeQtyFactorMax        = 3.0;

	// Chance that we schedule an extra order soon after a normal one.
	public static final double spikeExtraOrderProb      = 0.10;
	// Factor to shrink the interval (e.g. 0.3 => extra order ~ 30% of normal interval)
	public static final double spikeExtraIntervalFactor = 0.30;
	
	// For Procurement
	// Service levels / tuning
	// public static final double inboundQcPassRate = 0.01;
	
	public static final int SIM_HORIZON_DAYS = 181;
	public static final double KPI_SAMPLE_HOURS = 6.0;
	
	public static final int KPI_DATASET_CAPACITY;
	static {
	    double horizonDays = SIM_HORIZON_DAYS;     // e.g., 180
	    double samplesPerDay = 24.0 / Constants.KPI_SAMPLE_HOURS; // e.g., 4 for 6 hours
	    KPI_DATASET_CAPACITY = (int) Math.ceil(horizonDays * samplesPerDay) + 200; // safety buffer
	}
	
	public static final double holdingRatePerDay = 0.0005;
	public static final double orderingCostPerPO = 30.0;

	
	public static final Color[][] TWO_COLOR_PALETTE_TRUCK = {
			{ new Color(0x1976D2), new Color(0x9E9E9E) }, // Blue, Gray
		    { new Color(0x1B9E77), new Color(0x666666) }, // Teal, Dark gray
		    { new Color(0xD32F2F), new Color(0x424242) }, // Red, Dark gray
		    { new Color(0xF57C00), new Color(0x37474F) }, // Orange, Blue-gray
		    { new Color(0x7B1FA2), new Color(0xBDBDBD) }, // Purple, Light gray
		    { new Color(0x00796B), new Color(0x263238) }, // Teal dark, Charcoal
		    { new Color(0x388E3C), new Color(0x212121) }, // Green, Near black
		    { new Color(0x455A64), new Color(0xCFD8DC) }  // Blue-gray, Light blue-gray
		    // add more rows if you like
		};
	
	public static final Color[][] TWO_COLOR_PALETTE_BOX = {
			{ new Color(0x1976D2), new Color(0x90A4AE) }, // blue / gray
		    { new Color(0x00897B), new Color(0x263238) }, // teal / charcoal
		    { new Color(0xFB8C00), new Color(0x37474F) }, // orange / blue-gray
		    { new Color(0x7E57C2), new Color(0xBDBDBD) }, // purple / light gray
		    { new Color(0x43A047), new Color(0x424242) }, // green / dark gray
		    { new Color(0xE53935), new Color(0x6D4C41) }, // red / warm gray
		    { new Color(0x3949AB), new Color(0xCFD8DC) }, // indigo / silver
		    { new Color(0x00ACC1), new Color(0x1A237E) }, // cyan / navy
		    { new Color(0xFFC107), new Color(0x5D4037) }  // amber / brown
		};
}]]></Text>
