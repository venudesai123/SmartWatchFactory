				<StatechartElement Class="State" ParentState="ROOT_NODE">
					<Id>1764793575439</Id>
					<Name><![CDATA[Idle]]></Name>
					<X>140.421</X><Y>90</Y>
					<Label><X>35</X><Y>15</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="142.05811190597854" Height="30">
						<EntryAction><![CDATA[// Nothing special; assume stower is already at seatNode
this.kpiMarkBusyEnd();
this.jobPhase = JobPhase.NONE;
this.currentItem = null;
this.fgTargetSlot = null;
this.rmTargetSlot = null;
this.rackIdx = -1;
]]></EntryAction>
						<ExitAction><![CDATA[this.kpiMarkBusyStart();
]]></ExitAction>
						<FillColor/>
					</Properties>
				</StatechartElement>
				<StatechartElement Class="State" ParentState="ROOT_NODE">
					<Id>1764793600507</Id>
					<Name><![CDATA[GoStaging]]></Name>
					<X>140.421</X><Y>170</Y>
					<Label><X>15</X><Y>15</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="142.05811190597854" Height="30">
						<EntryAction><![CDATA[// Logger.info("FROM SEAT -> SEAT CORRIDOR");
this.cancelPendingArrival();

PointNode entry = (jobKind == JOB_KIND.RM) ? 
						main.QC_STAGING_E_NODE : 
						main.FG_STAGING_E_NODE;

if (this.reachedSeatCorridor) {
	this.armArrivalOrFireNow("ARRIVED_STAGING_ENTRY", entry);
} else {
	this.armArrivalOrFireNow("ARRIVED_SEAT_CORRIDOR", this.seatCorridorNode);
}
]]></EntryAction>
						<FillColor/>
					</Properties>
				</StatechartElement>
				<StatechartElement Class="State" ParentState="ROOT_NODE">
					<Id>1764793686591</Id>
					<Name><![CDATA[PickItem]]></Name>
					<X>140</X><Y>350</Y>
					<Label><X>20</X><Y>15</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="142.05811190597854" Height="30">
						<EntryAction><![CDATA[this.pickupTime = triangular(1, 2, 4);

Logger.info("Stower " + getId() + " entered Pick, pickupTime=" + pickupTime);
]]></EntryAction>
						<FillColor/>
					</Properties>
				</StatechartElement>
				<StatechartElement Class="State" ParentState="ROOT_NODE">
					<Id>1764793725624</Id>
					<Name><![CDATA[GoToSlot]]></Name>
					<X>140</X><Y>580</Y>
					<Label><X>15</X><Y>15</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="142.05811190597854" Height="30">
						<EntryAction><![CDATA[int cell = jobKind == JOB_KIND.RM ? this.rmTargetSlot.cell : this.fgTargetSlot.cell;
int row = jobKind == JOB_KIND.RM ? this.rmTargetSlot.row : this.fgTargetSlot.row;

Logger.info("Stower " + getId() + " entering GoToSlot for cell=" + cell + ", row=" + row);

cancelPendingArrival();

Point p = null;
if (jobKind == JOB_KIND.RM) {
    p = main.services.layout.rmRackCellPoint(this.rackIdx, cell, row);
}
if (jobKind == JOB_KIND.FG) {
	p = main.services.layout.fgRackCellPoint(this.rackIdx, cell, row);
}

if (p != null)
	armArrivalOrFireNow("ARRIVED_SLOT", p.getX(), p.getY());
]]></EntryAction>
						<FillColor/>
					</Properties>
				</StatechartElement>
				<StatechartElement Class="State" ParentState="ROOT_NODE">
					<Id>1764793784533</Id>
					<Name><![CDATA[PlaceItem]]></Name>
					<X>140</X><Y>660</Y>
					<Label><X>15</X><Y>15</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="142.05811190597854" Height="30">
						<EntryAction><![CDATA[Logger.info("PlaceTray Entry action");

this.placeTime = triangular(2, 4, 6);

if (jobKind == JOB_KIND.RM) {
	Resource mb = (Resource) currentItem;
    if (mb == null || this.rmTargetSlot == null) return;

    // Stop following the stower
    mb.isCarried = false;
    mb.carriedBy = null;
    carriedItems.remove(mb);
    
    // Drop exactly where the stower stands
	mb.setXY(getX(), getY());
	
	// set rack target (RackStore reads these)
	mb.hasRackTarget = true;
	mb.rackTargetRow = this.rmTargetSlot.row;
	mb.rackTargetCell = this.rmTargetSlot.cell;
	mb.rackTargetLevel = this.rmTargetSlot.level;
	
	// These two help the “ahead of stower” effect a lot
	mb.rackTargetCloseToFront = true;
	mb.rackTargetLeftAisle = (this.rmTargetSlot.row == 0); // if your rack uses leftAisle

    // Release from Wait so it flows into rackStoreMB (you already have waitRmStaging.out -> rackStoreMB.in)
    main.waitRmStaging.free(mb);
}

if (jobKind == JOB_KIND.FG) {
	Resource tray = (Resource) currentItem;
	if (tray == null || this.fgTargetSlot == null) return;
	
	// Stop following stower
    tray.isCarried = false;
    tray.carriedBy = null;
    carriedItems.remove(tray);
    
    // Drop at stower position
    tray.setXY(getX(), getY());

    // set rack target (RackStore reads these)
    tray.hasRackTarget = true;
    tray.rackTargetRow = this.fgTargetSlot.row;
    tray.rackTargetCell = this.fgTargetSlot.cell;
    tray.rackTargetLevel = this.fgTargetSlot.level;
    
    tray.rackTargetCloseToFront = true;
    tray.rackTargetLeftAisle = (this.fgTargetSlot.row == 0);

    // release from wait to flow into soFgIn -> rackStoreFgX
    main.waitFgStaging.free(tray);
}
]]></EntryAction>
						<FillColor/>
					</Properties>
				</StatechartElement>
				<StatechartElement Class="State" ParentState="ROOT_NODE">
					<Id>1764793827474</Id>
					<Name><![CDATA[ReturnSeat]]></Name>
					<X>140</X><Y>740</Y>
					<Label><X>10</X><Y>15</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="142.05811190597854" Height="30">
						<EntryAction><![CDATA[this.cancelPendingArrival();
this.goSeatAndWait("ARRIVED_SEAT");
]]></EntryAction>
						<ExitAction><![CDATA[// Clear job
this.currentItem = null;
this.fgTargetSlot  = null;
this.rmTargetSlot = null;
this.rackIdx     = -1;
this.reachedSeatCorridor = false;

this.carriedItems.clear();
this.rmJobItems.clear();
this.fgJobItems.clear();
this.jobPhase = JobPhase.NONE;
this.collectIndex = -1;
this.stowIndex = -1;

// Ask Main to dispatch next tray
main.services.whDispatch.tryDispatchRmStowing();
main.services.whDispatch.tryDispatchFgStowing();
]]></ExitAction>
						<FillColor/>
					</Properties>
				</StatechartElement>
				<StatechartElement Class="State" ParentState="ROOT_NODE">
					<Id>1764920638627</Id>
					<Name><![CDATA[GoItemPoint]]></Name>
					<X>140</X><Y>260</Y>
					<Label><X>25</X><Y>15</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="140" Height="30">
						<EntryAction><![CDATA[Logger.info("GoItemPoint Entry action");
cancelPendingArrival();

if (currentItem != null) {
    double tx = currentItem.getX();
    double ty = currentItem.getY();
    this.armArrivalOrFireNow("ARRIVED_ITEM_POINT", tx, ty);
} else {
	// Safety: no tray? just go back
    this.goSeatAndWait("ARRIVED_SEAT");
    return;
    // statechartStow.fireEvent("ARRIVED_ITEM_POINT");
}
]]></EntryAction>
						<FillColor/>
					</Properties>
				</StatechartElement>
				<StatechartElement Class="State" ParentState="ROOT_NODE">
					<Id>1764920830974</Id>
					<Name><![CDATA[GoRackStart]]></Name>
					<X>140</X><Y>500</Y>
					<Label><X>25</X><Y>15</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="140" Height="30">
						<EntryAction><![CDATA[Logger.info("Stower " + getId() + " entering GoRackStart, rackIdx=" + rackIdx);
this.cancelPendingArrival();

PointNode entryNode =
    (jobKind == JOB_KIND.RM)
    ? main.RM_RACK_STARTS[this.rackIdx]
    : main.FG_RACK_STARTS[this.rackIdx];
    
if (entryNode == null) {
    Logger.error("GoRackStart: entryNode is NULL for rackIdx=", rackIdx, " jobKind=", jobKind);
    // safest fallback: go back to seat instead of crashing
    this.goSeatAndWait("ARRIVED_SEAT");
    return;
}

this.armArrivalOrFireNow("ARRIVED_RACK_START", entryNode);
]]></EntryAction>
						<FillColor/>
					</Properties>
				</StatechartElement>
