		<JavaClass>
			<Id>1757258598216</Id>
			<Name><![CDATA[OdooMrpGateway]]></Name>
			<Folder>1771290666693</Folder>
			<Text><![CDATA[/**
 * OdooMrpGateway
 */
import java.util.*;
import java.util.concurrent.*;
import java.util.function.*;

public final class OdooMrpGateway {
    
    // ---------- Public API ----------
    /** Create MOs in Odoo for an Order (per variant), set IDs on the Order and init allocation ledgers. */
    public static void createMOsForOrder(Main main, MrpOrder o) {
        try {
			if (main == null || main.m_odooSession == null)
				return;

			if (o.getTotalQuantity() <= 0)
				return;

			Integer fgPid = main.saleableProductIdBySkuId.get(o.getFgSkuVariant().skuId());
			if (fgPid == null || fgPid <= 0)
				throw new IllegalStateException("FG SKU not found: " + o.getFgSkuVariant().skuId());

			int bomId = ensureBomFor(main, o.getFgSkuVariant().skuId());
			
			String moPlannedStart = DateTimeUtil.convertSimulationTimeToDate(
			    main.getEngine().getStartDate(),
			    o.moCreateAt,
			    false
			);
			
			Map<String,Object> vals = new HashMap<>();
			vals.put("product_id", fgPid);
			vals.put("product_qty", o.getTotalQuantity());
			vals.put("bom_id", bomId);
			vals.put("location_src_id", main.stockLocationId);
			vals.put("location_dest_id", main.stockLocationId);
			vals.put("date_planned_start", moPlannedStart);
			
			// Create the Manufacturing Order (MO)
			Object moIdObj = OdooUtils.executeKw(
				main.m_odooSession, 
				OdooUtils.DATABASE_NAME, 
				OdooUtils.SERVER_PASSWORD,
				"mrp.production", 
				"create",
				Arrays.asList(vals), 
				null
			);
			int moId = OdooUtils.safeCastToInteger(moIdObj);
			
			// Retrieve the fg_ids of the created MO
			Map<Integer, Integer> fgIdsBySerialId = fetchSerialToFgMap(main, moId);
            o.setIds(moId, fgIdsBySerialId);

            Logger.info("Created MO Id: ", moId, " Sku: ", o.getFgSkuVariant().skuId());
			
			// Confirm and assign the MO
			OdooUtils.executeKw(
				main.m_odooSession, 
				OdooUtils.DATABASE_NAME, 
				OdooUtils.SERVER_PASSWORD,
				"mrp.production",
				"action_confirm", 
				Arrays.asList(Arrays.asList(moId)), 
				null); 

			OdooUtils.executeKw(
				main.m_odooSession,
				OdooUtils.DATABASE_NAME,
				OdooUtils.SERVER_PASSWORD,
				"mrp.production",
				"action_assign",
				Arrays.asList(Arrays.asList(moId)),
				null);
			
			
        } catch (Exception e) {
            Logger.warn("createMOsForOrder failed", e);
        }
    }
	
	/** At picker drop-off: increment Odoo raw consumption (qty_done) against the right MO raw moves. */
	public static void consumeRawFromPlanWithLock(Main main, MrpOrder order, List<PickStop> plan) {
		int moId = order.getMoId();
		
		synchronized (moLock(moId)) {
			try {
				// Perform raw material consumption logic for each moId
				consumeRawMaterials(main, moId, plan);

				// After processing, release the lock if the MO is terminal
				releaseMoLockIfTerminal(main, (int) moId);
			} catch (Exception ex) {
				Logger.error("Error occurred while processing MO " + moId, ex);
				releaseMoLockIfTerminal(main, (int) moId);
				throw ex;  // Optionally re-throw the exception to propagate it
			}
		}
	}
	
	public static void sendSimStartToOdoo(Main main, WipUnit wu, Integer wcId) {
		try {
			if (wcId == null) {
				wcId = wu.workcenterId;
			}
			
			String dateStart = DateTimeUtil.convertSimulationTimeToDate(
			        main.getEngine().getStartDate(),
			        wu.getStartTime(),
			        false
			);
			
			List<Object> args = Arrays.asList(
	            Collections.emptyList(),  // [] → self (we don't use it, _fetch_workorders finds by keys)
	            wu.moId,
	            wu.fgId,
	            wcId,
	            dateStart
	        );

			OdooUtils.executeKw(
			    main.m_odooSession,
			    OdooUtils.DATABASE_NAME,
			    OdooUtils.SERVER_PASSWORD,
			    "mrp.workorder",
			    "action_sim_start",
			    args,
			    null
			);
		} catch (Exception e) {
			Logger.error("Failed to start work order for MO: " + wu.moId + " FG_ID: " + wu.fgId + " WC_ID: " + wu.workcenterId, e);
		}
	}
	
	public static void sendSimFinishToOdoo(Main main, WipUnit wu, Integer wcId, boolean initialCall) {
		try {
			if (wcId == null) {
				wcId = wu.workcenterId;
			}

			Date engineStart = main.getEngine().getStartDate();

	        String dateStart = DateTimeUtil.convertSimulationTimeToDate(
	            engineStart,
	            wu.getStartTime(),
	            false
	        );

	        String dateFinished = DateTimeUtil.convertSimulationTimeToDate(
	            engineStart,
	            wu.getEndTime(),
	            false
	        );
			
			List<Object> args = Arrays.asList(
	            Collections.emptyList(),
	            wu.moId,
	            wu.fgId,
	            wcId,
	            dateStart,
	            dateFinished,
	            Boolean.valueOf(initialCall)  // will arrive as Python bool
	        );
			
			OdooUtils.executeKw(
			    main.m_odooSession,
			    OdooUtils.DATABASE_NAME,
			    OdooUtils.SERVER_PASSWORD,
			    "mrp.workorder",
			    "action_sim_finish",
			    args,
			    null
			);
		} catch (Exception e) {
			Logger.error("Failed to finish work order for MO: " + wu.moId + " FG_ID: " + wu.fgId + " WC_ID: " + wu.workcenterId, e);
		}
	}
	
	public static void sendSimSkipToOdoo(Main main, WipUnit wu, Integer wcId, double simTime) {
		try {
			if (wcId == null) {
				wcId = wu.workcenterId;
			}
			
			String date = DateTimeUtil.convertSimulationTimeToDate(
	            main.getEngine().getStartDate(),
	            simTime,
	            false
	        );
			
			List<Object> args = Arrays.asList(
	            Collections.emptyList(),
	            wu.moId,
	            wu.fgId,
	            wcId,
	            date
	        );
			
			OdooUtils.executeKw(
			    main.m_odooSession,
			    OdooUtils.DATABASE_NAME,
			    OdooUtils.SERVER_PASSWORD,
			    "mrp.workorder",
			    "action_sim_skip",
			    args,
			    null
			);
		} catch (Exception e) {
			Logger.error("Failed to skip work order for MO: " + wu.moId + " FG_ID: " + wu.fgId + " WC_ID: " + wu.workcenterId, e);
		}
	}
	
	public static void sendSimScrapToOdoo(Main main, WipUnit wu, double simTime) {
		try {
			String date = DateTimeUtil.convertSimulationTimeToDate(
	            main.getEngine().getStartDate(),
	            simTime,
	            false
	        );
			
			List<Object> args = Arrays.asList(
	            Collections.emptyList(),
	            wu.moId,
	            wu.fgId,
	            wu.workcenterId,
	            date,
	            wu.getScrapReason().toString()
	        );
			
			OdooUtils.executeKw(
			    main.m_odooSession,
			    OdooUtils.DATABASE_NAME,
			    OdooUtils.SERVER_PASSWORD,
			    "mrp.workorder",
			    "action_sim_scrap_fg",
			    args,
			    null
			);
		} catch (Exception e) {
			Logger.error("Failed to scrap work orders.", e);
		}
	}
	
	public static void moveFgToStaging(Main main, List<Integer> fgIds) {
		try {
			List<Object> args = Arrays.asList(
	            new ArrayList<Object>(fgIds)   // this becomes "self" recordset ids
	        );

		    OdooUtils.executeKw(
		        main.m_odooSession,
		        OdooUtils.DATABASE_NAME,
		        OdooUtils.SERVER_PASSWORD,
		        "mrp.production.fg",
		        "action_sim_move_to_staging",
		        args,
		        null
		    );
		} catch (Exception e) {
			Logger.error("Failed to move the fg to production staging area.", e);
		}
	}
	
	public static void storeFgInWarehouse(Main main, List<Integer> fgIds) {
	    try {
	        if (main == null || main.m_odooSession == null)
	        	return;
	        
	        if (fgIds == null || fgIds.isEmpty())
	        	return;

	        // Only update your addon FG status flags
	        OdooUtils.executeKw(
	            main.m_odooSession,
	            OdooUtils.DATABASE_NAME,
	            OdooUtils.SERVER_PASSWORD,
	            "mrp.production.fg",
	            "action_sim_store",
	            Arrays.asList(new ArrayList<Object>(fgIds)),
	            null
	        );

	    } catch (Exception e) {
	        Logger.error("Failed to store the fgs in warehouse.", e);
	    }
	}
	
	public static boolean markFgsShippedByIds(Main main, List<Integer> fgIds, int soId, int pickingId, double simTime) {
	    try {
	        if (main == null || main.m_odooSession == null)
	        	return false;
	        
	        if (fgIds == null || fgIds.isEmpty()) {
	            Logger.warn("markFgsShippedByIds: fgIds empty");
	            return false;
	        }

	        String date = DateTimeUtil.convertSimulationTimeToDate(
                main.getEngine().getStartDate(),
                simTime,
                false
            );

	        List<Object> args = Arrays.asList(
	            new ArrayList<Object>(fgIds),
	            (soId > 0 ? soId : Boolean.FALSE),
	            (pickingId > 0 ? pickingId : Boolean.FALSE),
	            date,
	            "Shipped via simulation"
	        );

	        OdooUtils.executeKw(
	            main.m_odooSession,
	            OdooUtils.DATABASE_NAME,
	            OdooUtils.SERVER_PASSWORD,
	            "mrp.production.fg",
	            "action_sim_ship",
	            args,
	            null
	        );

	        return true;

	    } catch (Exception e) {
	        Logger.error("markFgsShippedByIds failed", e);
	        return false;
	    }
	}
	
	public static Map<Integer, Integer> fetchSerialToFgMap(Main main, Integer moId) {
		Map<Integer, Integer> serialToFgId = new HashMap<>();
		try {
			// Domain: [("parent_id", "=", moId)]
		    List<Object> domain = Arrays.asList(
		        Arrays.asList("parent_id", "=", moId)
		    );

		    Map<String, Object> kwargs = new HashMap<>();
		    kwargs.put("fields", Arrays.asList("id", "serialId"));
		    kwargs.put("order", "serialId asc");

		    Object raw = OdooUtils.executeKw(
		        main.m_odooSession,
		        OdooUtils.DATABASE_NAME,
		        OdooUtils.SERVER_PASSWORD,
		        "mrp.production.fg",
		        "search_read",
		        Arrays.asList(domain),
		        kwargs
		    );

		    List<Map<String, Object>> records = OdooUtils.asListOfMaps(raw);

		    for (Map<String, Object> rec : records) {
		        Integer fgId     = OdooUtils.safeCastToInteger(rec.get("id"));
		        Integer serialId = OdooUtils.safeCastToInteger(rec.get("serialId"));
		        if (serialId != -1 && fgId != -1) {
		            serialToFgId.put(serialId, fgId);
		        }
		    }
		} catch (Exception e) {
			Logger.error("Failed to fetch fgIds and serialId maps.", e);
		}

	    return serialToFgId;
	}
	
	public static void markFgsShippedForCustomerOrder(Main main, CustomerOrder co) {
	    if (main == null || main.m_odooSession == null || co == null || co.lines == null) return;

	    try {
	    	String date = DateTimeUtil.convertSimulationTimeToDate(
                main.getEngine().getStartDate(),
                main.time(),
                false
            );

	        for (CustomerOrderLine line : co.lines) {
	            if (line == null || line.qty <= 0) continue;

	            String skuId = (line.skuId != null && !line.skuId.isEmpty())
	                ? line.skuId
	                : (line.sku != null ? line.sku.skuId() : null);

	            if (skuId == null)
	            	continue;

	            Integer productId = main.saleableProductIdBySkuId.get(skuId);
	            if (productId == null || productId <= 0)
	            	continue;

	            // Pick ANY stowed + not shipped FG rows (because your sim doesn’t track exact FG IDs per CO yet)
	            List<Integer> fgIds = findStowedUnshippedFgs(main, productId, line.qty);

	            if (!fgIds.isEmpty()) {
	                Map<String, Object> vals = new HashMap<>();
	                vals.put("is_shipped", true);
	                vals.put("is_stowed", false);
	                vals.put("is_in_staging", false);
	                vals.put("sale_order_id", (co.saleOrderId > 0 ? co.saleOrderId : false));
	                vals.put("picking_id", (co.pickingId > 0 ? co.pickingId : false));
	                vals.put("date_shipped", date);

	                OdooUtils.executeKw(
	                    main.m_odooSession,
	                    OdooUtils.DATABASE_NAME,
	                    OdooUtils.SERVER_PASSWORD,
	                    "mrp.production.fg",
	                    "write",
	                    Arrays.asList(fgIds, vals),
	                    null
	                );
	            }
	        }

	    } catch (Exception e) {
	        Logger.error("markFgsShippedForCustomerOrder failed for " + co, e);
	    }
	}

	private static List<Integer> findStowedUnshippedFgs(Main main, int productId, int limit) throws Exception {
	    List<Object> domain = Arrays.asList(
	        Arrays.asList("product_id", "=", productId),
	        Arrays.asList("is_stowed", "=", true),
	        Arrays.asList("is_shipped", "=", false)
	    );

	    Map<String, Object> kw = new HashMap<>();
	    kw.put("limit", limit);

	    Object idsObj = OdooUtils.executeKw(
	        main.m_odooSession,
	        OdooUtils.DATABASE_NAME,
	        OdooUtils.SERVER_PASSWORD,
	        "mrp.production.fg",
	        "search",
	        Arrays.asList(domain),
	        kw
	    );

	    return OdooUtils.asListOfInts(idsObj);
	}
	
	// ---------- Private helpers (moved/adapted from your OdooMrpService) ----------
	/** Ensure a BOM exists for a finished SKU, using BOM_BY_FG. */
    private static int ensureBomFor(Main main, String fgSku) throws Exception {
        Integer tmplId = main.saleableProductTmplIdBySkuId.get(fgSku);
        if (tmplId == null || tmplId <= 0)
            Logger.error("FG SKU not found in saleableProductTmplIdBySkuId: " + fgSku);

        Map<String,Object> kwSearch = new HashMap<>();
        kwSearch.put("limit", 1);

        Object bomIds = OdooUtils.executeKw(
            main.m_odooSession,
            OdooUtils.DATABASE_NAME,
            OdooUtils.SERVER_PASSWORD,
            "mrp.bom",
            "search",
            Arrays.asList(Arrays.asList(
                Arrays.asList("product_tmpl_id","=", tmplId),
                Arrays.asList("product_id","=", Boolean.FALSE)
            )),
            kwSearch
        );

        Object[] bomArr = (bomIds instanceof Object[]) ? (Object[]) bomIds : new Object[0];
        if (bomArr.length > 0)
            return OdooUtils.safeCastToInteger(bomArr[0]);

        // Create template-level BoM (shared by all variants)
        Map<String,Object> bomVals = new HashMap<>();
        bomVals.put("product_tmpl_id", tmplId);
        bomVals.put("product_id", Boolean.FALSE);   // very important: template-level BoM

        Object bomIdObj = OdooUtils.executeKw(
            main.m_odooSession,
            OdooUtils.DATABASE_NAME,
            OdooUtils.SERVER_PASSWORD,
            "mrp.bom",
            "create",
            Arrays.asList(bomVals),
            null
        );
        int bomId = OdooUtils.safeCastToInteger(bomIdObj);

        // do NOT auto-create lines here, because you designed the BoM once in Odoo with attributes, etc.
        return bomId;
    }
	
	private static void consumeRawMaterials(Main main, int moId, List<PickStop> plan) {
		if (main == null || plan == null || plan.isEmpty()) {
			return;
		}
		
		Map<Integer, Double> byProduct = new LinkedHashMap<>();
		for (PickStop ps : plan) {
			if (ps == null || ps.moId != moId)
				continue;
			Integer pid = main.productIdBySkuId.get(ps.skuId);
			
			if (pid == null || pid <= 0)
				continue;
			
			byProduct.merge(pid, (double) ps.unitsToPick, Double::sum);
		}
		
		try {
			ensureReadyForConsumption(main, (int) moId);

			// Fetch raw moves for this MO
			Map<String, Object> kwRead = new HashMap<>();
			kwRead.put("fields", Arrays.asList("id", "product_id", "product_uom", "move_line_ids", "state"));

			Object res = OdooUtils.executeKw(
				main.m_odooSession,
				OdooUtils.DATABASE_NAME,
				OdooUtils.SERVER_PASSWORD,
				"stock.move",
				"search_read",
				Arrays.asList(Arrays.asList(Arrays.asList("raw_material_production_id", "=", moId))),
				kwRead
			);

			List<Map<String, Object>> rawMoves = OdooUtils.asListOfMaps(res);
			Map<Integer, Map<String, Object>> byPid = new HashMap<>();
			for (Map<String, Object> mv : rawMoves) {
				byPid.put(OdooUtils.m2oId(mv.get("product_id")), mv);
			}

			// Update the stock moves for each product in the MO
			for (Map.Entry<Integer, Double> comp : byProduct.entrySet()) {
				int compPid = comp.getKey();
				double picked = comp.getValue();
				Map<String, Object> mv = byPid.get(compPid);
				if (mv == null) {
					Logger.warn("RAW: MO ", moId, " pid=", compPid, " has no raw move; skip.");
					continue;
				}

				boolean changed = addQtyOnExistingRawLines(main, mv, picked);
				if (!changed) {
					Logger.warn("RAW: MO ", moId, " pid=", compPid, " no headroom / not editable.");
				}
			}
		} catch (Exception ex) {
			Logger.warn("consumeRawFromPlan failed for MO " + moId, ex);
			releaseMoLockIfTerminal(main, (int) moId);
		}
	}
	
	/** Confirm/plan/assign MO and ensure first WO is started. */
    private static void ensureReadyForConsumption(Main main, int moId) {
        try { 
			OdooUtils.executeKw(
				main.m_odooSession,
				OdooUtils.DATABASE_NAME,
				OdooUtils.SERVER_PASSWORD,
				"mrp.production",
				"action_confirm",
				Arrays.asList(Arrays.asList(moId)),
				null
			); 
		} catch (Exception ignore) {}
		
        try { 
			OdooUtils.executeKw(
				main.m_odooSession, 
				OdooUtils.DATABASE_NAME, 
				OdooUtils.SERVER_PASSWORD,
				"mrp.production", 
				"button_plan",
				Arrays.asList(Arrays.asList(moId)),
				null
			);
		} catch (Exception ignore) {}
		
        try {
			OdooUtils.executeKw(
				main.m_odooSession,
				OdooUtils.DATABASE_NAME,
				OdooUtils.SERVER_PASSWORD,
				"mrp.production",
				"action_assign",
				Arrays.asList(Arrays.asList(moId)),
				null);
		} catch (Exception ignore) {}
        
        try {
		    Map<String,Object> kw = new HashMap<>();
		    kw.put("fields", Arrays.asList("id","state"));
		    Object res = OdooUtils.executeKw(
				main.m_odooSession,
				OdooUtils.DATABASE_NAME, 
				OdooUtils.SERVER_PASSWORD,
				"mrp.workorder",
				"search_read",
				Arrays.asList(Arrays.asList(Arrays.asList("production_id","=", moId))),
				kw
			);
		    
		    for (Map<String,Object> wo : OdooUtils.asListOfMaps(res)) {
	            String st = OdooUtils.safeCastToString(wo.get("state"));
	            int woId  = OdooUtils.safeCastToInteger(wo.get("id"));
	            if (!"progress".equals(st) && !"done".equals(st) && !"cancel".equals(st)) {
	            	Map<String, Object> kwargs = new HashMap<>();
	            	Map<String, Object> ctx = new HashMap<>();
	            	ctx.put("sim_mode", true);
	            	kwargs.put("context", ctx);
	            	
	            	OdooUtils.executeKw(
						main.m_odooSession,
						OdooUtils.DATABASE_NAME,
						OdooUtils.SERVER_PASSWORD,
						"mrp.workorder",
						"button_start", 
						Arrays.asList(Arrays.asList(woId)),
						kwargs
					);
	            }
	        }
        } catch (Exception ignore) {}
    }
	
	// --- RAW move write with fallback to move.quantity_done ---//
	private static boolean addQtyOnExistingRawLines(Main main, Map<String, Object> move, double delta) throws Exception {
		if (delta <= 0.0)
			return false;

		final int moveId = OdooUtils.safeCastToInteger(move.get("id"));
		final String reservedField = smlReservedField(main); // "reserved_uom_qty", "reserved_qty", or ""
		List<Integer> mlIds = OdooUtils.asListOfInts(move.get("move_line_ids"));

		if (mlIds == null || mlIds.isEmpty()) {
			boolean ok = addQtyOnMoveQuantityDoneFallback(main, moveId, delta);
			if (!ok) Logger.debug("RAW fallback failed for move ", moveId, " (no lines).");
			return ok;
		}

		List<String> fields = new ArrayList<>(Arrays.asList("id", "qty_done", "state"));
		if (!reservedField.isEmpty())
			fields.add(reservedField);
		
		Map<String, Object> kw = new HashMap<>();
		kw.put("fields", fields);

		Object rd = OdooUtils.executeKw(
			main.m_odooSession,
			OdooUtils.DATABASE_NAME,
			OdooUtils.SERVER_PASSWORD,
			"stock.move.line",
			"read",
			Arrays.asList(mlIds),
			kw
		);
		List<Map<String, Object>> rows = OdooUtils.asListOfMaps(rd);

		rows.sort((a, b) -> {
			double aDone = OdooUtils.safeCastToDouble(a.get("qty_done"));
			double bDone = OdooUtils.safeCastToDouble(b.get("qty_done"));
			double aRes = reservedField.isEmpty() ? Double.POSITIVE_INFINITY : OdooUtils.safeCastToDouble(a.get(reservedField));
			double bRes = reservedField.isEmpty() ? Double.POSITIVE_INFINITY : OdooUtils.safeCastToDouble(b.get(reservedField));
			return -Double.compare(aRes - aDone, bRes - bDone);
		});

		double left = delta;
		boolean changed = false;

		for (Map<String, Object> r : rows) {
			if (left <= 1e-12)
				break;
			
			if ("done".equals(OdooUtils.safeCastToString(r.get("state"))))
				continue;

			double done = OdooUtils.safeCastToDouble(r.get("qty_done"));
			double resv = reservedField.isEmpty() ? Double.POSITIVE_INFINITY : OdooUtils.safeCastToDouble(r.get(reservedField));
			double room = resv - done;
			if (room <= 1e-12)
				continue;

			double addNow = Math.min(left, room);
			int lineId = OdooUtils.safeCastToInteger(r.get("id"));

			Map<String, Object> w = new HashMap<>();
			w.put("qty_done", done + addNow);
			
			Object ok = OdooUtils.executeKw(
				main.m_odooSession,
				OdooUtils.DATABASE_NAME,
				OdooUtils.SERVER_PASSWORD,
				"stock.move.line",
				"write",
				Arrays.asList(Arrays.asList(lineId), w),
				null
			);
			if (Boolean.TRUE.equals(ok)) {
				left -= addNow;
				changed = true;
			}
		}

		if (left > 1e-12) {
			boolean ok = addQtyOnMoveQuantityDoneFallback(main, moveId, left);
			if (ok)
				changed = true;
			else
				Logger.debug("RAW remainder fallback failed for move ", moveId, " (left=", left, ").");
		}
		return changed;
	}
    
    private static boolean addQtyOnMoveQuantityDoneFallback(Main main, int moveId, double delta) throws Exception {
        if (delta <= 0) return false;

        Map<String,Object> kw = new HashMap<>();
        kw.put("fields", Arrays.asList("id","product_uom_qty","quantity_done","state"));
        Object rd = OdooUtils.executeKw(
            main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
            "stock.move", "read",
            Arrays.asList(Arrays.asList(moveId)), kw
        );
        List<Map<String,Object>> rows = OdooUtils.asListOfMaps(rd);
        if (rows.isEmpty()) return false;

        Map<String,Object> mv = rows.get(0);
        String st = OdooUtils.safeCastToString(mv.get("state"));
        if ("done".equals(st) || "cancel".equals(st)) return false;

        double req   = OdooUtils.safeCastToDouble(mv.get("product_uom_qty"));
        double done  = OdooUtils.safeCastToDouble(mv.get("quantity_done"));
        double room  = req - done;
        if (room <= 1e-12) return false;

        double addNow = Math.min(delta, room);

        Map<String,Object> w = new HashMap<>();
        w.put("quantity_done", done + addNow);
        Object ok = OdooUtils.executeKw(
            main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
            "stock.move", "write",
            Arrays.asList(Arrays.asList(moveId), w), null
        );
        return Boolean.TRUE.equals(ok);
    }
	
	private static volatile String SML_RESERVED_FIELD= null; // "reserved_uom_qty", "reserved_qty", or ""
    private static String smlReservedField(Main main) {
        if (SML_RESERVED_FIELD != null) return SML_RESERVED_FIELD;
        try {
            Map<String,Object> kw = new HashMap<>();
            kw.put("attributes", Arrays.asList("string"));
            Object res = OdooUtils.executeKw(
                main.m_odooSession, OdooUtils.DATABASE_NAME, OdooUtils.SERVER_PASSWORD,
                "stock.move.line", "fields_get",
                Arrays.asList(Arrays.asList("reserved_uom_qty","reserved_qty")), kw
            );
            Map<String,Object> fields = OdooUtils.asMap(res);
            if (fields.containsKey("reserved_uom_qty"))      SML_RESERVED_FIELD = "reserved_uom_qty";   // v16+
            else if (fields.containsKey("reserved_qty"))     SML_RESERVED_FIELD = "reserved_qty";
            else                                             SML_RESERVED_FIELD = "";
        } catch (Exception ignore) {
            SML_RESERVED_FIELD = "";
        }
        return SML_RESERVED_FIELD;
    }

	// ---------- Locking helpers ----------
	// Concurrent HashMap to store locks for Manufacturing Orders (MO)
	private static final ConcurrentHashMap<Long, Object> MO_LOCKS = new ConcurrentHashMap<>();

	// Create or retrieve a lock object for a specific MO ID
	private static Object moLock(long moId) {
		return MO_LOCKS.computeIfAbsent(moId, k -> new Object());
	}

	// Remove the lock immediately (no state check)
	/* private static void releaseMoLock(int moId) {
		MO_LOCKS.remove((long) moId);
	} */

	// Remove the lock only if the MO is already terminal (done/cancel)
	private static void releaseMoLockIfTerminal(Main main, int moId) {
		try {
			if (isMoDone(main, moId)) {
				MO_LOCKS.remove((long) moId);
				Logger.debug("Released MO lock for terminal MO " + moId);
			}
		} catch (Exception ignore) {
			// best-effort; no need to escalate
			Logger.debug("Failed to check terminal state for MO " + moId);
		}
	}

	// Best-effort periodic cleanup: check up to maxToCheck MOs and drop locks for terminal ones
	public static void sweepMoLocks(Main main, int maxToCheck) {
		try {
			List<Long> keys = new ArrayList<>(MO_LOCKS.keySet());
			if (maxToCheck > 0 && keys.size() > maxToCheck) {
				keys = keys.subList(0, maxToCheck);
			}
			int removed = 0, checked = 0;
			for (Long k : keys) {
				checked++;
				int moId = k.intValue();
				try {
					if (isMoDone(main, moId)) {
						MO_LOCKS.remove(k);
						removed++;
					}
				} catch (Exception ignore) {
					Logger.debug("Failed to check terminal state for MO " + moId);
				}
			}
			if (removed > 0) {
				Logger.debug("sweepMoLocks: checked=" + checked + " removed=" + removed + " remaining=" + MO_LOCKS.size());
			} else {
				Logger.debug("sweepMoLocks: no locks removed, remaining=" + MO_LOCKS.size());
			}
		} catch (Exception e) {
			Logger.warn("sweepMoLocks failed", e);
		}
	}
	
	private static boolean isMoDone(Main main, int moId) throws Exception {
        Map<String,Object> kw = new HashMap<>();
        kw.put("fields", Arrays.asList("state"));
        
		Object rd = OdooUtils.executeKw(
            main.m_odooSession,
			OdooUtils.DATABASE_NAME,
			OdooUtils.SERVER_PASSWORD,
            "mrp.production",
			"read",
            Arrays.asList(Arrays.asList(moId)), kw
        );
        List<Map<String,Object>> rows = OdooUtils.asListOfMaps(rd);
        
		if (rows.isEmpty())
			return false;
        
		String st = OdooUtils.safeCastToString(rows.get(0).get("state"));
		
        return "done".equals(st) || "cancel".equals(st);
	}
}
]]></Text>
		</JavaClass>
