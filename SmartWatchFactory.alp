						<EntryAction><![CDATA[if (this.currentOrder != null) {
    this.currentOrder.markPicking();
}
if (this.currentCustomerOrder != null) {
    this.currentCustomerOrder.markPicking();
}

if (this.stopIdx >= this.stops.size() ) {
	this.statechartMO.fireEvent("ARRIVED_DELIVERY");
} else {
	PickStop ps = this.stops.get(this.stopIdx);
	String label = (this.jobKind == JOB_KIND.FG) ? String.valueOf(ps.fgSku) : String.valueOf(ps.skuType);
	Logger.info("Stop " + stopIdx + ": " + label + " r" + ps.rackIdx + " c" + ps.cell + " L" + ps.level + " take " + ps.unitsToPick);
	this.goToEntryForStopAndWait(ps, "ARRIVED_ENTRY_FOR_STOP");
}
]]></EntryAction>
