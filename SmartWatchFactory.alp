			<Text><![CDATA[/**
 * FgPickAlloc
 */	
public class FgPickAlloc {
    public Resource trayRes;
    public ArrayList<Integer> ids = new ArrayList<>();
    
    public FgPickAlloc(Resource trayRes, List<Integer> ids) {
        this.trayRes = trayRes;
        if (ids != null) this.ids.addAll(ids);
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1767306943174</Id>
			<Name><![CDATA[RmPickAlloc]]></Name>
			<Folder>1771726185934</Folder>
			<Text><![CDATA[/**
 * RmPickAlloc
 */	
public class RmPickAlloc {
    public Resource mbRes;
    public int qty;
    
    public RmPickAlloc(Resource mbRes, int qty) { 
    	this.mbRes = mbRes; 
    	this.qty = qty;
    }
}]]></Text>
