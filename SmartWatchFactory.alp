		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1767737211858</Id>
			<Name><![CDATA[InitService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * InitService
 */

public class InitService {

	private final Main main;

    public InitService(Main main) {
        this.main = main;
    }
    
    public void initLayoutAndWorkers() {
    	// ===================== RM LAYOUT =====================
    	main.RM_RACK_STARTS = new PointNode[] { main.startNodeDisplay, main.startNodeMicrochip, main.startNodeBattery, main.startNodeCase, main.startNodeStrap };
    	main.RM_RACK_ENDS = new PointNode[] { main.endNodeDisplay, main.endNodeMicrochip, main.endNodeBattery, main.endNodeCase, main.endNodeStrap };
    	main.RM_PICKER_SEATS = new PointNode[] { main.rmpn1, main.rmpn2, main.rmpn3, main.rmpn4, main.rmpn5, main.rmpn6 };
    	main.RM_STOWER_SEATS = new PointNode[] { main.rmStower1, main.rmStower2, main.rmStower3, main.rmStower4, main.rmStower5, main.rmStower6 };
    	main.RM_STOWER_CORRIDOR_NODES = new PointNode[] { main.rmCn1, main.rmCn2, main.rmCn3 };
    	
    	main.rmEndLoad = new int[ main.RM_RACK_ENDS.length ];
    	
    	// ===================== INBOUND =====================
    	main.INBOUND_DOCK_NODES = new PointNode[] { main.idn1, main.idn2, main.idn3 };
    	main.INBOUND_LANE_NODES = new PointNode[] { main.isn1, main.isn2, main.isn3, main.isn4, main.isn5 };
    	main.INBOUND_QC_NODES = new PointNode[] { main.iQcNode1, main.iQcNode2, main.iQcNode3, main.iQcNode4, main.iQcNode5 };

    	main.INBOUND_WORKER_SEATS = new PointNode[] { main.inboundWorker1, main.inboundWorker2, main.inboundWorker3, main.inboundWorker4 };
    	// this.INBOUND_STAGING_E_NODE = main.inboundStagingENode;
    	main.QC_STAGING_E_NODE = main.qcSAENode;
    	
    	// inbound lane index mapping (you used values() order)
    	int ptIdx = 0;
    	main.inboundLaneIdxByType.clear();
    	for(PRODUCT_TYPE pt: PRODUCT_TYPE.values()) {
    		main.inboundLaneIdxByType.put(pt, ptIdx);
    		ptIdx++;
    	}

    	main.inboundDockBusy = new boolean[main.INBOUND_DOCK_NODES.length];
    	main.DOCK_OUTS = Arrays.asList(main.soOutDock1, main.soOutDock2, main.soOutDock3);
    	
    	// ===================== FG LAYOUT =====================
    	main.FG_RACK_STARTS = new PointNode[] { main.startNodeFgMet, main.startNodeFgFw, main.startNodeFgFb };
    	main.FG_RACK_ENDS = new PointNode[] { main.endNodeFgMet, main.endNodeFgFw, main.endNodeFgFb };
    	main.FG_PICKER_SEATS = new PointNode[] { main.fgpn1, main.fgpn2, main.fgpn3, main.fgpn4, main.fgpn5, main.fgpn6 };
    	main.FG_STOWER_SEATS = new PointNode[] { main.ssn1, main.ssn2, main.ssn3, main.ssn4, main.ssn5, main.ssn6 };
    	main.FG_STOWER_CORRIDOR_NODES = new PointNode[] { main.cn1, main.cn2, main.cn3 };
    	main.FG_STAGING_E_NODE = main.fgStagingENode;
    	
    	// ===================== PACKING / OUTBOUND =====================
    	main.PACK_STATION_NODES = new PointNode[] { main.packStation1, main.packStation2, main.packStation3 };
    	main.CO_PACK_STAGING_E_NODE = main.coPackedStagingNode;
    	
    	// Your coPackStations[] lives on Main -> initialize it here
    	for (int i = 0; i < Constants.CO_PACK_STATIONS; i++) {
    		main.coPackStations[i] = new CustomerOrderPackStation(i, main.PACK_STATION_NODES[i]);
    	}

    	main.OUTBOUND_WORKER_SEATS = new PointNode[] { main.outboundWorker1, main.outboundWorker2 };
    	main.OUTBOUND_DOCK_NODES = new PointNode[] { main.odn1, main.odn2, main.odn3 };
    	
    	// outbound dock state init (these arrays live in Main in your model)
    	main.waitingForDock = new LinkedList[Constants.OUTBOUND_DOCK_STATIONS];
    	for (int i = 0; i < Constants.OUTBOUND_DOCK_STATIONS; i++) {
    		OutboundDockState ds = new OutboundDockState();
    	    ds.index = i;
    	    ds.node  = main.OUTBOUND_DOCK_NODES[i];
    	    ds.truck = null;
    	    main.outboundDocks[i] = ds;
    	        
    	    main.waitingForDock[i] = new LinkedList<CustomerOrder>();
    	}

    	// ===================== VENDORS / CONVEYOR =====================
    	main.VENDOR_ENTRIES = new PointNode[] { main.vendor1, main.vendor2, main.vendor3 };
    	main.CONVEYOR_IN = new ConveyorPath[] { main.cvIn1, main.cvIn2, main.cvIn3, main.cvIn4, main.cvIn5 };
    	
    	// ===================== SELECTOUTPUT OUTS =====================
    	main.ASSEMBLY_OUTS = Arrays.asList(main.soAsmOut1, main.soAsmOut2, main.soAsmOut3, main.soAsmOut4);
    	main.SOFTWARE_OUTS = Arrays.asList(main.soSwOut1, main.soSwOut2, main.soSwOut3);
    	main.PACKAGE_OUTS = Arrays.asList(main.soPackOut1, main.soPackOut2);
    	main.BATCH_OUTS = Arrays.asList(main.soMetBatOut, main.soFwBatOut, main.soFbBatOut);
    	
    	// ===================== TRAY FORMING LISTS =====================
    	main.metForming = new ArrayList<>(Constants.TRAY_SIZE);
    	main.fwForming  = new ArrayList<>(Constants.TRAY_SIZE);
    	main.fbForming  = new ArrayList<>(Constants.TRAY_SIZE);
    	
    	// ===================== CREATE WORKERS =====================
    	for(PointNode seat: main.RM_PICKER_SEATS) {
    		Picker pk = main.add_rmPickers();
    		pk.setSeat(seat);
    		pk.setXY(seat.getX(), seat.getY());
    	}

    	int seatIdx = 0;
    	for(PointNode seat: main.RM_STOWER_SEATS) {
    		Stower s = main.add_rmStowers();
    	    s.initStower(seat, main.RM_STOWER_CORRIDOR_NODES[seatIdx / 2]); 
    	    s.setXY(seat.getX(), seat.getY());
    	    seatIdx++;
    	}

    	for(PointNode seat: main.FG_PICKER_SEATS) {
    		Picker pk = main.add_fgPickers();
    		pk.setSeat(seat);
    		pk.setXY(seat.getX(), seat.getY());
    	}

    	seatIdx = 0;
    	for(PointNode seat : main.FG_STOWER_SEATS) {
    		Stower s = main.add_fgStowers();
    	    s.initStower(seat, main.FG_STOWER_CORRIDOR_NODES[seatIdx / 2]); 
    	    s.setXY(seat.getX(), seat.getY());
    	    seatIdx++;
    	}

    	for(PointNode seat: main.OUTBOUND_WORKER_SEATS) {
    		Resource ow = main.add_operators();
    		ow.category = RESOURCE_TYPE.OUTBOUND_WORKER;
    		ow.initWorker(seat);
    		ow.setXY(seat.getX(), seat.getY());
    	}

    	/* for(PointNode seat: main.INBOUND_WORKER_SEATS) {
    		Resource iw = main.add_operators();
    		iw.category = RESOURCE_TYPE.INBOUND_WORKER;
    		iw.initWorker(seat);
    		iw.setXY(seat.getX(), seat.getY());
    	} */
    	
    	// ================= KPI STORAGE (Main) =================    	
    	for (FG_SKU v : FG_SKU.values()) {
    		main.kpiScrapByVariant.put(v, 0L);
    		main.kpiGoodByVariant.put(v, 0L);
    	}
    	
    	for (STAGE s : STAGE.values()) {
    		main.kpiStepCount.put(s, 0L);
    		main.kpiStepSum.put(s, 0.0);
    	}
    }
	
	public void initInventoryKpis() {
	    if (main.rmInStockout == null) 
	    	main.rmInStockout = new HashMap<>();
	    
	    if (main.rmStockoutStartTimeSec == null) 
	    	main.rmStockoutStartTimeSec = new HashMap<>();
	    
	    if (main.kpiRmStockoutEvents == null) 
	    	main.kpiRmStockoutEvents = new HashMap<>();
	    
	    if (main.kpiRmStockoutTimeDays == null) 
	    	main.kpiRmStockoutTimeDays = new HashMap<>();
	    
	    if (main.kpiPoUnitsOrderedBySkuId == null) 
	    	main.kpiPoUnitsOrderedBySkuId = new HashMap<>();
	}
}]]></Text>
		</JavaClass>
