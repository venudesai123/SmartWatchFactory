			<Name><![CDATA[LayoutService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * LayoutService
 * 
 * skeleton to help split Main's Additional class code into services.
 * Purpose: Geometry + indexing helpers (rack cell points, slot indexing, FG rack index helper).
 */	
public class LayoutService {
	private final Main main;
	
	public LayoutService(Main main) {
        this.main = main;
    }
	
	public Point rmRackCellPoint(int rackIdx, int cell, int row) {
		int offset = 32; // to determine correct lenth of rack pallets calculated using exact location x-cordinate value
		PointNode A = main.RM_RACK_STARTS[rackIdx], B = main.RM_RACK_ENDS[rackIdx];
		double t = (cell + 0.5) / Constants.RM_RACK_CELLS; // center of the bay
		double x = A.getX() + t * (B.getX() - A.getX() - 2*offset) + offset;
	  	double y = A.getY() + t * (B.getY() - A.getY());
	  	
		double lateral = 2.0;             // small visual nudge
	    double ax = B.getX() - A.getX();
	    double ay = B.getY() - A.getY();
	    double len = Math.hypot(ax, ay);
	    if (len > 1e-6) {
	        // perpendicular to aisle; row=0 go one side, row=1 other side
	        double nx = -ay/len, ny = ax/len;
	        x += (row == 0 ? -lateral : lateral) * nx;
	        y += (row == 0 ? -lateral : lateral) * ny;
	    }
	    
	  	return new Point(x, y);
    }

    public Point fgRackCellPoint(int rackIdx, int cell, int row) {
    	int offset = 32; // to determine correct lenth of rack pallets calculated using exact location x-cordinate value
    	PointNode A = main.FG_RACK_STARTS[rackIdx], B = main.FG_RACK_ENDS[rackIdx];
    	double t = (cell + 0.5) / Constants.FG_RACK_CELLS; // center of the bay
    	
    	double x = A.getX() + t * (B.getX() - A.getX() - 2*offset) + offset;
      	double y = A.getY() + t * (B.getY() - A.getY());
      	
    	double lateral = 2.0;             // small visual nudge
        double ax = B.getX() - A.getX();
        double ay = B.getY() - A.getY();
        double len = Math.hypot(ax, ay);
        if (len > 1e-6) {
            // perpendicular to aisle; row=0 go one side, row=1 other side
            double nx = -ay/len, ny = ax/len;
            x += (row == 0 ? -lateral : lateral) * nx;
            y += (row == 0 ? -lateral : lateral) * ny;
        }
        
      	return new Point(x, y);
    }
    
    // Picking time multiplier by level (tune as needed)
    public double levelFactor(int level) {
    	return 1.0 + 0.1 * level; // +10% per vertical level
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1766265356018</Id>
			<Name><![CDATA[SlottingService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * SlottingService
 * 
 * skeleton to help split Main's Additional class code into services.
 * Purpose: RM/FG slot maps + slotting/storing logic (boxes -> RM slots, trays -> FG slots). Owns rmSlotsBySku & fgSlotsBySku.
 */

public class SlottingService {
	private final Main main;

    public SlottingService(Main main) {
        this.main = main;
    }
    
    /** Compute list index for (level, cell) given the way you populated slots: level outer, then cell. */
    private int rmSlotIndex(int row, int level, int cell, int deep) {
    	return (((row * Constants.RM_RACK_LEVELS + level) * Constants.RM_RACK_CELLS + cell) * Constants.RM_RACK_DEEP + deep);
    }
    
    /** Get a slot by SKU, cell, level. Returns null if out of bounds. */
    public RmSlot getRmSlot(PRODUCT_TYPE sku, int row, int level, int cell, int deep) {
    	List<RmSlot> list = main.rmSlotsBySku.get(sku);
    	
    	if (list == null)
    		return null;
    	
    	if (row   < 0 || row   >= Constants.RM_RACK_ROWS)  return null;
    	if (level < 0 || level >= Constants.RM_RACK_LEVELS)return null;
    	if (cell  < 0 || cell  >= Constants.RM_RACK_CELLS) return null;
    	if (deep  < 0 || deep  >= Constants.RM_RACK_DEEP)  return null;
    	
    	int idx = rmSlotIndex(row, level, cell, deep);
    	
    	return (idx >= 0 && idx < list.size()) ? list.get(idx) : null;
    }
    
    public RmSlot chooseRmSlotForUnits(String skuId, int unitsPerBox) {
    	PRODUCT_TYPE t = PRODUCT_TYPE.fromSkuId(skuId);
        if (t == null) return null;

        List<RmSlot> list = main.rmSlotsBySku.get(t);
        if (list == null) return null;

        // (optional) sectioning for CASE/STRAP variants:
        // int[] range = variantCellRange(skuId, t);

        for (RmSlot s : list) {
            if (skuId.equals(s.skuId) && s.freeBoxesFor(unitsPerBox) > 0)
            	return s;
        }
        for (RmSlot s : list) {
            if ((s.skuId == null || s.skuId.isEmpty()) && s.freeBoxesFor(unitsPerBox) > 0) {
                // Claim the entire CELL across all levels (prevents mixing variants in flex cells)
                this.claimRmCellAllLevels(t, s.row, s.cell, skuId);
                return s;
            }
        }
        return null;
    }
    
    public boolean placeMotherBoxIntoRmSlot(Resource mbRes, RmSlot slot) {
        MotherBox mb = mbRes.getMotherBox();
        if (mb == null) return false;

        String skuId = mb.getSkuId();
        int upb = mb.getUnitsPerBox();

        // Claim slot SKU on first use
        if (slot.skuId == null || slot.skuId.isEmpty()) slot.skuId = skuId;
        if (!skuId.equals(slot.skuId)) return false;

        // Commit reservation: BOX COUNT
        if (slot.incomingBoxes <= 0) Logger.warn("RM commit without incomingBoxes reservation sku=", skuId);
        slot.incomingBoxes = Math.max(0, slot.incomingBoxes - 1);

        // Commit reservation: UNITS
        if (slot.incomingUnits < upb) Logger.warn("RM commit without incoming(units) reservation sku=", skuId,
                                             " incoming=", slot.incomingUnits, " upb=", upb);
        slot.incomingUnits = Math.max(0, slot.incomingUnits - upb);

        slot.boxes.addFirst(mbRes);
        mbRes.getMotherBox().setInRmSlot(true);
        slot.recalc();
        return true;
    }
    
    public void claimRmCellAllLevels(PRODUCT_TYPE rackType, int row, int cell, String skuId) {
        if (rackType == null || skuId == null) return;

        List<RmSlot> list = main.rmSlotsBySku.get(rackType);
        if (list == null) return;

        for (RmSlot s : list) {
            if (s.row == row && s.cell == cell) {
                if (s.skuId == null || s.skuId.isEmpty()) {
                    s.skuId = skuId;
                    s.skuType = rackType;
                }
            }
        }
    }
    
    public RackSystem selectRmRackSystem(PRODUCT_TYPE pt) {
    	if (pt == null)
    		return main.rackSystemDisplay;

    	switch(pt) {
    		case DISPLAY:
    			return main.rackSystemDisplay;
    		case MICROCHIP:
    			return main.rackSystemMicrochip;
    		case BATTERY:
    			return main.rackSystemBattery;
    		case CASE:
    			return main.rackSystemCase;
    		case STRAP:
    			return main.rackSystemStrap;
    		default:
    			return main.rackSystemDisplay;
    	}
    }
    
    public RackSystem selectFgRackSystem(FG_SKU fgSku) {
    	if (fgSku == null)
    		return main.rackSystemFgMet;

    	switch(fgSku) {
    		case MET:
    			return main.rackSystemFgMet;
    		case FW:
    			return main.rackSystemFgFw;
    		case FB:
    			return main.rackSystemFgFb;
    		default:
    			return main.rackSystemFgMet;
    	}
    }
    
    public FgSlot chooseSlotForTray(FG_SKU fgSku, int trayUnits) {
        List<FgSlot> list = main.fgSlotsBySku.get(fgSku);
        if (list == null) return null;

        for (FgSlot s : list) {
            if (s.freeTrayCapacity() > 0) return s;
        }
        return null;
    }
    
    public boolean placeTrayIntoFgSlot(Resource trayRes, FgSlot slot) {
        Tray tray = trayRes.getTray();
        if (tray == null)
        	return false;

        String skuId = tray.getFgSkuVariant().skuId();  // or however you standardize it
        int trayUnits = tray.totalUnits();

        // Claim/check skuId (optional but recommended)
        if (slot.skuId == null || slot.skuId.isEmpty()) {
            slot.skuId = skuId;
        } else if (!skuId.equals(slot.skuId)) {
            Logger.error("FG slot sku mismatch slot=", slot.skuId, " tray=", skuId,
                         " row=", slot.row, " cell=", slot.cell, " level=", slot.level);
            return false;
        }

        // Commit reservation: TRAY COUNT
        if (slot.incomingTrays <= 0) 
        	Logger.warn("FG commit without incomingTrays reservation sku=", skuId);
        slot.incomingTrays = Math.max(0, slot.incomingTrays - 1);

        // Commit reservation: UNITS
        if (slot.incomingUnits < trayUnits) 
        	Logger.warn("FG commit without incoming(units) reservation sku=", skuId,
        			" incoming=", slot.incomingUnits, " trayUnits=", trayUnits);
        slot.incomingUnits = Math.max(0, slot.incomingUnits - trayUnits);

        slot.trays.addFirst(trayRes);
        slot.recalc();
        
        return true;
    }
    
    public FgSlot getFgSlot(FG_SKU sku, int row, int cell, int level) {
        List<FgSlot> list = main.fgSlotsBySku.get(sku);
        if (list == null) return null;
        for (FgSlot s : list) {
            if (s.row == row && s.cell == cell && s.level == level) return s;
        }
        return null;
    }
}
]]></Text>
		</JavaClass>
