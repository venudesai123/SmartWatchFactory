		<!--   =========   Active Object Class   ========  -->
		<ActiveObjectClass>
			<Id>1754496151103</Id>
			<Name><![CDATA[Picker]]></Name>
			<AdditionalClassCode><![CDATA[// ---------- Job data (copied from Order when assigned) ----------
private MrpOrder currentOrder = null;
private CustomerOrder currentCustomerOrder = null;

private JOB_KIND jobKind = null;
private int lastRackIdx = -1;

private List<PickStop> currentPlan = null;
private boolean hasDroppedOff = false;  // set true only after successful drop-off
private int totalOrderQuantity = 0;

private int deliveryEndIdx = -1;
private PointNode deliveryEnd;     // single drop-off node

private boolean hasJob = false;

// ---------- Seat in pickingArea (supports PointNode or Attractor) ----------
private double seatX, seatY;

// ---------- Timing knobs ----------
private double pickTimePerUnit = 1.0; // seconds per unit (tune)
private double dropOffTime = 2.0;     // seconds to unload (tune)

// --- Plan ---
private final List<PickStop> stops = new ArrayList<>();
private int stopIdx = 0;

// --- Timing / movement ---
private double baseSpeed;            // set in Picker -> On startup: baseSpeed = speed;

// --- Poller message (you already have arrivalPoller event with Timeout/User control/0.05s) ---
private String nextArrivalMsg = null;

// ---- Arrival helpers ----
private static final double EPS = 1e-3;

private int carryingUnits = 0;

public double busyTime = 0;
private double lastBusyStart = -1;

// ---------- Helpers ----------
public double getSeatX() { return this.seatX; }
public double getSeatY() { return this.seatY; }

public void setSeat(PointNode seat) {
	if (seat == null) {
		Logger.error("setSeat received NULL PointNode");
		return;
	}
	this.seatX = seat.getX();
	this.seatY = seat.getY();
}

public boolean isIdleForDispatch() { 
	// return !hasJob;
	return statechartMO.isStateActive(Idle) && !hasJob && !isMoving();
}
public boolean isIdle() { return statechartMO.isStateActive(Idle); }

// private PointNode startOf(int idx){ return main.RM_RACK_STARTS[idx]; }
private PointNode endOf(int idx){   return main.RM_RACK_ENDS[idx];   }

// Assign a ready-made plan from Main
public void assignWithRmPlan(MrpOrder order, List<PickStop> plan) {
	if (this.hasJob) {
        Logger.warn("assignWithPlan called on non-idle picker " + getIndex() +
                    " – requeueing order " + order.getIndex());

        if (!main.waitingMrpOrders.contains(order)) {
            main.waitingMrpOrders.add(order);
        }
        return;
    }
    
    this.jobKind = JOB_KIND.RM;
    
    this.hasJob = true; 
	
	this.currentOrder = order;
	this.currentPlan = plan;
	this.hasDroppedOff = false;
	order.markAssigned();
	
	this.totalOrderQuantity = order.getTotalQuantity();
	
	this.stops.clear();
	
	if (plan != null && !plan.isEmpty()) {
        this.stops.addAll(plan);  // Ensure stops list is populated correctly
    } else {
        Logger.error("Assigned plan is empty or null!");
        this.currentOrder       = null;
        this.currentPlan        = null;
        this.totalOrderQuantity = 0;
        return;  // Ensure the picker won't proceed if there's no plan
    }
    
	this.stopIdx = 0;
	this.deliveryEnd = null;
	
	Logger.info("Picker ", this.getIndex(), " assigned ", this.stops.size(), " stops. Plan:");
	
	for (int i = 0; i < this.stops.size(); i++) {
		PickStop ps = this.stops.get(i);
        String slotId = (ps.slotRef == null) ? "null" : Integer.toHexString(System.identityHashCode(ps.slotRef));
        int reservedNow = (ps.slotRef == null) ? -1 : ps.slotRef.reservedUnits;
        Logger.info(
            String.format("  #%02d skuId=%s type=%s r=%d c=%d L=%d qty=%d reserved=%d slotRef=%s",
                          i, ps.skuId, ps.skuType, ps.rackIdx, ps.cell, ps.level,
                          ps.unitsToPick, reservedNow, slotId)
        );
	}	
	
	this.statechartMO.fireEvent("NEW_JOB");
}

public void assignWithFgPlan(CustomerOrder co, List<PickStop> plan) {
    if (this.hasJob) {
        Logger.warn("assignCustomerOrderWithPlan on non-idle picker ", getIndex());
        if (!get_Main().pendingCustomerOrders.contains(co)) {
            get_Main().pendingCustomerOrders.add(co);
        }
        return;
    }
    
    this.jobKind = JOB_KIND.FG;
	
    this.hasJob = true;
    this.currentCustomerOrder = co;
    this.currentOrder = null;   // clear MRP context if you use that
    this.stops.clear();
    this.stops.addAll(plan);

    // Kick the statechart similar to how you start MRP picking
    this.statechartMO.fireEvent("NEW_JOB");
}

// Abort the job BEFORE drop-off
public void abortCurrentJob(String reason) {
	Logger.warn("Picker " + getIndex() + " aborting: " + reason);
	
	// RELEASE endpoint reservation (job aborted)
	if (deliveryEndIdx >= 0 && main.rmEndLoad != null) {
	    main.rmEndLoad[deliveryEndIdx] = Math.max(0, main.rmEndLoad[deliveryEndIdx] - 1);
	}
	deliveryEndIdx = -1;
	deliveryEnd = null;
	
	// Only release/restore if we have NOT dropped off yet
	if (this.currentPlan != null && this.currentOrder != null && !this.hasDroppedOff) {
		main.services.reservation.releasePlanReservations(this.currentPlan, 0); // free rack reservations
		this.currentOrder.restoreClubbedQuantities(currentPlan); // return SKU needs to the order’s per-MO ledger
	}
	
	// Requeue the order so it can be dispatched again
	if (this.currentOrder != null) {
		this.currentOrder.markRequeued();
		
    	if (!main.waitingMrpOrders.contains(this.currentOrder))
    		main.waitingMrpOrders.add(currentOrder);
	}
	
	// Clear picker job state and go idle
	this.currentPlan  = null;
	this.currentOrder = null;
	this.hasDroppedOff = false;
	
	// Let Main try to assign the next waiting order
	main.services.whDispatch.tryDispatchRmPicking();
}

/** Drop any pending arrival message before arming a new leg. */
private void cancelPendingArrival() {
    if (this.nextArrivalMsg != null && !isMoving()) {
        Logger.debug("cancelPendingArrival: dropping '" + this.nextArrivalMsg + "'");
        this.nextArrivalMsg = null;
    }
}

/** Arm arrival message for a target (tx,ty), or fire immediately if we're already there. */
private void armArrivalOrFireNow(String msg, double tx, double ty) {
    this.cancelPendingArrival();
    
    Logger.debug("Current position: (" + getX() + ", " + getY() + "), Target position: (" + tx + ", " + ty + ")");
    if (hypot(getX() - tx, getY() - ty) <= EPS) {
        // We're already at the target → deliver the message synchronously
        this.statechartMO.fireEvent(msg);
        return;
    }
    this.nextArrivalMsg = msg;
	moveTo(tx, ty);
    this.arrivalPoller.restart();
}

/** Overload for PointNode. */
private void armArrivalOrFireNow(String msg, PointNode pn) {
    this.cancelPendingArrival();
    // this.currentStartNode = pn;
    double tx = pn.getX();
    double ty = pn.getY();    
    Logger.debug("Current position: (" + getX() + ", " + getY() + "), Target position: (" + tx + ", " + ty + ")");
    if (hypot(getX() - tx, getY() - ty) <= EPS) {
        // We're already at the target → deliver the message synchronously
        this.statechartMO.fireEvent(msg);
        return;
    }
    this.nextArrivalMsg = msg;
    moveTo(pn);
    this.arrivalPoller.restart();
}

private PointNode entryFor(PickStop ps, double fromX, double fromY) {
    PointNode s, e;

    if (this.jobKind == JOB_KIND.FG) { // FG pallet racks
        s = main.FG_RACK_STARTS[ps.rackIdx];
        e = main.FG_RACK_ENDS[ps.rackIdx];
    } else { // Default: RM racks
        s = main.RM_RACK_STARTS[ps.rackIdx];
        e = main.RM_RACK_ENDS[ps.rackIdx];
    }

    double ds = hypot(fromX - s.getX(), fromY - s.getY());
    double de = hypot(fromX - e.getX(), fromY - e.getY());

    return ds <= de ? s : e;
}

private void goToEntryForStopAndWait(PickStop ps, String msg) {
	PointNode nextStop = this.entryFor(ps, getX(), getY());
	if (lastRackIdx == ps.rackIdx) {
	    goToStopAndWait(ps, "ARRIVED_ENTRY_FOR_STOP");
	    return;
	}
	
	if (nextStop != null) {
		this.armArrivalOrFireNow(msg, nextStop);
	} else {
        // Fallback – should not happen with the new entryFor, 
        // but prevents the picker from getting stuck silently
        Logger.warn("entryFor returned null for stopIdx=" + stopIdx 
                    + ", rackIdx=" + ps.rackIdx + ". Falling back to goToStopAndWait.");
        this.goToStopAndWait(ps, msg);
    }
}

// Move to a slot’s front point and wait for arrival (poller will fire message)
private void goToStopAndWait(PickStop ps, String msg) {
    Point p;

    if (this.jobKind == JOB_KIND.FG) { // Front-of-bay point for FG pallets
        p = main.services.layout.fgRackCellPoint(ps.rackIdx, ps.cell, ps.row);
    } else { // Front-of-bay point for RM pallets
        p = main.services.layout.rmRackCellPoint(ps.rackIdx, ps.cell, ps.row);
    }

    this.armArrivalOrFireNow(msg, p.x, p.y);
}

private void goSeatAndWait(String msg) {
	this.armArrivalOrFireNow(msg, this.seatX, this.seatY);
}

// Choose nearest & least-crowded delivery endNode from a point (x,y).
/* private PointNode chooseDeliveryEndWeighted(double x, double y){
	double CROWD_PENALTY = 5.0; // "meters" added per picker there; tune to your layout
	PointNode best = this.endOf(0);
	double bestScore = 1e18;
	
	for (int i = 0; i < main.RM_RACK_ENDS.length; i++) {
		PointNode cand = endOf(i);
		double d = hypot(x - cand.getX(), y - cand.getY());
		int crowd = 0;
		for (Picker p : main.rmPickers){
			if (p == this) continue;
			if (p.deliveryEnd == cand && !p.isIdle()) crowd++;
		}
		double score = d + CROWD_PENALTY * crowd;
		if (score < bestScore) { bestScore = score; best = cand; }
	}
	return best;
} */

private PointNode chooseDeliveryEndSmart(double x, double y){
    final double LOAD_PENALTY_METERS = 8.0; // tune: how much “1 extra picker” should hurt

    PointNode best = this.endOf(0);
    int bestIdx = 0;
    double bestScore = 1e18;

    for (int i = 0; i < main.RM_RACK_ENDS.length; i++) {
        PointNode cand = main.RM_RACK_ENDS[i];
        double d = hypot(x - cand.getX(), y - cand.getY());

        int load = (main.rmEndLoad == null ? 0 : main.rmEndLoad[i]);

        double score = d + LOAD_PENALTY_METERS * load;

        if (score < bestScore) {
            bestScore = score;
            best = cand;
            bestIdx = i;
        }
    }

    // commit reservation (so others see it as busy immediately)
    if (main.rmEndLoad != null)
    	main.rmEndLoad[bestIdx]++;
    	
    this.deliveryEndIdx = bestIdx;

    return best;
}

public void cancelJob(String reason) {
	Logger.warn("Cancelling job for picker ", getIndex(), ": ", reason);
	// Stop any pending arrival message so we don't auto-fire after cancel
	this.nextArrivalMsg = null;
	
	// RELEASE endpoint reservation
    if (deliveryEndIdx >= 0 && main.rmEndLoad != null) {
        main.rmEndLoad[deliveryEndIdx] = Math.max(0, main.rmEndLoad[deliveryEndIdx] - 1);
    }
    deliveryEndIdx = -1;
    deliveryEnd = null;
	
	// Snapshot references BEFORE we clear local state
    MrpOrder moRef = this.currentOrder;
    List<PickStop> planRef = new ArrayList<>(this.stops);
	
	// Return all reserved units to available
	main.services.reservation.releasePlanReservations(this.stops, 0);
	
	// Restore clubbed component counts back to the order's MO ledger
    if (moRef != null) {
        moRef.restoreClubbedQuantities(planRef);
        moRef.markRequeued();
        main.waitingMrpOrders.addFirst(moRef);
    }
	
	// Reset local state
	this.stops.clear();
	this.stopIdx = 0;
	this.totalOrderQuantity = 0;
	this.currentOrder = null;
	this.currentPlan = null;
    this.hasDroppedOff = false;
    this.hasJob = false; 
	
	// Return to seat
	this.goSeatAndWait("ARRIVED_SEAT");
	
	// Optionally ping dispatcher
	main.services.whDispatch.tryDispatchRmPicking();
}

// Base time per unit; you already have pickTimePerUnit
// Optional randomness per order-line:
private double timePerUnit(double time) {
	return triangular(0.8, 1.0, 1.3) * time; // slightly variable
}

// Pick time = per-unit time * units * level factor
private double holdTimeFor(PickStop ps) {
	return this.timePerUnit(this.pickTimePerUnit) * ps.unitsToPick * main.services.layout.levelFactor(ps.level);
}

public double getDropOffHoldSeconds() {
	return this.totalOrderQuantity * this.timePerUnit(this.dropOffTime);
}

private void updateCarryState() {
    boolean loaded = (carryingUnits > 0);

    // slight speed penalty when loaded (optional)
    this.baseSpeed = loaded ? (0.9 * baseSpeed) : baseSpeed;

    // If you create a small icon/shape named carryIcon:
    this.carryIcon.setVisible(loaded);
}

public void kpiMarkBusyStart() {
	if (lastBusyStart < 0)
		lastBusyStart = time();
}

public void kpiMarkBusyEnd() {
	if (lastBusyStart >= 0) {
		busyTime += (time() - lastBusyStart);
		lastBusyStart = -1;
	}
}

public double utilization() {
	double t = time();
	if (t <= 0) return 0;
	double bt = busyTime + ((lastBusyStart>=0) ? (t-lastBusyStart) : 0);
	return bt / t;
}
]]></AdditionalClassCode>
