		<ActiveObjectClass>
			<Id>1765130711169</Id>
			<Name><![CDATA[CustomerOrder]]></Name>
			<AdditionalClassCode><![CDATA[// Link back to who ordered
public Resource distributor;   // which distributor placed this order

public int packStationIndex = -1;

// Odoo link fields (we'll use these later)
public int saleOrderId		= -1;      // sale.order id in Odoo
public int pickingId		= -1;      // outgoing stock.picking id
public String orderName		= "";     // Odoo SO name or local label
public String externalRef	= "";   // optional (customer ref)

public Resource carriedBy = null;
public double carryDx = 0;
public double carryDy = -6;  

/** All lines (variants) in this order. */
public List<CustomerOrderLine> lines = new ArrayList<>();

// Exact FG IDs reserved/picked for this order (serial-accurate shipping)
public List<Integer> pickedFgIds = new ArrayList<>();

// Store the FG plan so Main can commit/release reservations safely
public List<PickStop> fgPickPlan = new ArrayList<>();

// Timing / KPI fields (SIM seconds; ModelTimeUnit = Second)
public double createdAt;
public double assignedAt;
public double pickingStartedAt;
public double pickedAt;
public double packingStartedAt;
public double packedAt;
public double stagedAt;
public double dockedAt;
public double loadedAt;
public double shippedAt;

// Overall order status – outbound lifecycle
public enum Status {
    QUEUED,          // created, waiting for picker assignment
    ASSIGNED_PICK,   // picker reserved, not yet physically picking
    PICKING,         // picker is walking the FG racks
    PICKED,          // all units for this order picked
    PACKING,         // in packing / boxing
    PACKED,
    STAGED,          // packed and in outbound staging
    DOCKED,
    LOADED,          // loaded into truck
    SHIPPED,         // truck left factory
    CANCELLED        // logically cancelled
}

private Status status = Status.QUEUED;

public enum LocationStage {
    PICKING,
    PACK_STATION,
    PACK_STAGED,
    PACK_STAGING,
    DOCKED,
    LOADED,
    SHIPPED
}

private LocationStage locationStage = LocationStage.PICKING;

public int outboundDockIndex = -1;

// ===================== ATP / Planning timestamps (SIM seconds) =====================
// These are PLANNED times (promise/schedule) computed at order creation.
// Your existing fields like pickedAt/shippedAt are ACTUAL event times.

public double atpComputedAt = 0;

// Earliest time the complete order is expected to be available (either from stock or from production)
public double atpReadyAt = 0;

// Warehouse plan times (what we intend)
public double atpPickScheduledAt = 0;
public double atpPackScheduledAt = 0;
public double atpShipScheduledAt = 0;

// Customer promise date/time (delivery promise)
public double atpPromisedDeliveryAt = 0;

// ATP diagnostics
public boolean atpHardReserved = false;   // true if we reserved FG IDs immediately from stock
public int atpUnitsFromStock = 0;
public int atpUnitsFromFuture = 0;

// Optional: store a text reason/debug
public String atpNote = "";

public boolean odooScheduledDateWritten = false;
// ----------------- End ATP / Planning timestamps (SIM seconds) -----------------

/** Initialise a multi-line order for a distributor. */
public void initMultiLine(Resource distributor, List<CustomerOrderLine> newLines) {
    this.distributor = distributor;

    if (this.lines == null) {
        this.lines = new ArrayList<>();
    } else {
        this.lines.clear();
    }

    if (newLines != null) {
        this.lines.addAll(newLines);
    }

    this.createdAt = time();
    this.status = Status.QUEUED;    
    main.kpiDemandUnitsTotal += this.getTotalUnits();
}

// ------------ Initializer for single-line orders ------------
public void initSingleLine(Resource dist, FG_SKU sku, int boxes) {
    ArrayList<CustomerOrderLine> tmp = new ArrayList<>();

    int safeBoxes = Math.max(0, boxes);
    if (sku != null && safeBoxes > 0) {
        String skuId = sku.skuId();
        int unitsPerBox = get_Main().services.catalog.lookupUnitsPerBoxForSku(skuId);

        tmp.add(new CustomerOrderLine(sku, skuId, safeBoxes, unitsPerBox));
    }

    initMultiLine(distributor, tmp);
}

/** Total quantity over all lines (variants) in this order. */
public int getTotalUnits() {
	int total = 0;
    if (lines != null && !lines.isEmpty()) {
        for (CustomerOrderLine l : lines) {
            if (l != null) {
                total += Math.max(0, l.qty);
            }
        }
    }
    return total;
}

public int getTotalBoxes() {
    int total = 0;
    if (lines != null) {
        for (CustomerOrderLine l : lines) {
            if (l != null) {
                total += Math.max(0, l.boxes);
            }
        }
    }
    return total;
}

// ------------ Status helpers ------------
public Status getStatus() {
    return status;
}

public LocationStage getLocationStage() {
    return locationStage;
}

public void markQueued() {
    this.status = Status.QUEUED;
    this.createdAt = time();
}

public void markAssignedForPicking() {
    this.status = Status.ASSIGNED_PICK;
    this.assignedAt = time();
}

public void markPicking() {
    this.status = Status.PICKING;
    this.locationStage = LocationStage.PICKING;
    this.pickingStartedAt = time();
}

public void markPicked() {
    this.status = Status.PICKED;
    this.pickedAt = time();
}

public void markPacking() {
    this.status = Status.PACKING;
    this.locationStage = LocationStage.PACK_STATION;
    this.packingStartedAt = time();
}

public void markPacked() {
    this.status = Status.PACKED;
    this.locationStage = LocationStage.PACK_STATION;
    this.packedAt = time();
}

public void markStaged() {
    this.status = Status.STAGED;
    this.locationStage = LocationStage.PACK_STAGED;
    this.stagedAt = time();
}

public void markDocked() {
    this.status = Status.DOCKED;
    this.locationStage = LocationStage.DOCKED;
    this.dockedAt = time();
}

public void markLoaded() {
    this.status = Status.LOADED;
    this.locationStage = LocationStage.LOADED;
    this.loadedAt = time();
}

public void markShipped() {
    this.status = Status.SHIPPED;
    this.locationStage = LocationStage.SHIPPED;
    this.shippedAt = time();
    
    double lt = shippedAt - createdAt;
	main.kpiCoShippedCount++;
	main.kpiCoLeadSum += lt;
	main.kpiCoLeadMin = Math.min(main.kpiCoLeadMin, lt);
	main.kpiCoLeadMax = Math.max(main.kpiCoLeadMax, lt);
    main.kpiDemandUnitsShipped += this.getTotalUnits();
}

public void markCancelled() {
    this.status = Status.CANCELLED;
    main.kpiDemandUnitsCancelled += this.getTotalUnits();
}

public boolean isComplete() {
    return this.status == Status.SHIPPED || this.status == Status.CANCELLED;
}

public void clearFgPickData() {
    pickedFgIds.clear();
    fgPickPlan.clear();
}

// ------------ Pretty label for logs / UI ------------
@Override
public String toString() {
    String name = (orderName != null && !orderName.isEmpty())
            ? orderName
            : ("CO#" + getId());

    int lineCount = (lines == null ? 0 : lines.size());
    int totalQty  = getTotalUnits();

    String skuLabel;
    if (lineCount == 0) {
        skuLabel = "?";
    } else if (lineCount == 1) {
        CustomerOrderLine l = lines.get(0);
        skuLabel = (l.sku == null ? "?" : l.sku.skuId());
    } else {
        CustomerOrderLine first = lines.get(0);
        String firstSku = (first.sku == null ? "?" : first.sku.skuId());
        skuLabel = firstSku + " +" + (lineCount - 1) + " more";
    }

    return name + " [lines=" + lineCount
            + ", sku=" + skuLabel
            + ", totalQty=" + totalQty
            + ", status=" + status + "]";
}
