					<Properties Source="1764793686591" Target="1764920638627" Trigger="timeout">
						<Action><![CDATA[// We just finished picking the tray at current tray position
if (currentItem != null && !carriedItems.contains(currentItem)) {
    carriedItems.add(currentItem);
    currentItem.setXY(getX(), getY());
}

// we just picked the tray at collectIndex
collectIndex++;

// switch to next item in staging
if (jobKind == JOB_KIND.RM) {
    MotherBoxAssignment next = rmJobItems.get(collectIndex);
    this.currentItem  = next.mbRes;
    this.rmTargetSlot = next.targetSlot;
    this.rackIdx      = next.rackIdx;
} else {
    TrayAssignment next = fgJobItems.get(collectIndex);
    this.currentItem = next.trayRes;
    this.fgTargetSlot = next.targetSlot;
    this.rackIdx      = next.rackIdx;
}
]]></Action>
