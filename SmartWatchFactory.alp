				<StatechartElement Class="Transition" ParentState="ROOT_NODE">
					<Id>1764920807284</Id>
					<Name><![CDATA[transition7]]></Name>
					<X>200</X><Y>380</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>false</ShowLabel>
					<Points>
						<Point><X>0</X><Y>0</Y></Point>
						<Point><X>0</X><Y>120</Y></Point>
					</Points>
					<IconOffset>20.0</IconOffset>
					<Properties Source="1764793686591" Target="1764920830974" Trigger="timeout">
						<Action><![CDATA[// We just finished picking the tray at current tray position
if (currentItem != null && !carriedItems.contains(currentItem)) {
    carriedItems.add(currentItem);
    if (jobKind == JOB_KIND.RM) {
	    currentItem.isCarried = true;
	    currentItem.carriedBy = this;
	
	    int k = carriedItems.size() - 1;
	    currentItem.carryDx = 0.35 * (k % 4);
	    currentItem.carryDy = 0.35 * (k / 4);
	}
	else {
		currentItem.setXY(getX(), getY());
	}
}

// We just finished picking the last tray in the collecting phase
collectIndex++;  // now should equal xxJobItems.size()

jobPhase = JobPhase.STOWING;
stowIndex = 0;

if (jobKind == JOB_KIND.RM) {	
    // optional: sort RM by rack to reduce walking
    rmJobItems.sort(
		Comparator.comparingInt((MotherBoxAssignment a) -> a.rackIdx)
		            .thenComparingInt(a -> a.targetSlot.row)
		            .thenComparingInt(a -> a.targetSlot.cell)
	);
	
	MotherBoxAssignment first = rmJobItems.get(0);
	this.currentItem  = first.mbRes;
	this.rmTargetSlot = first.targetSlot;
	this.rackIdx      = first.rackIdx;
	
	this.fgTargetSlot = null;
} else {
	// Phase 2: STOWING  -------------------------------------------
	// Sort trays by variant so racks are visited in variant order
	Collections.sort(
	    fgJobItems,
	    new Comparator<TrayAssignment>() {
	        @Override
	        public int compare(TrayAssignment a, TrayAssignment b) {
	            FG_SKU sa = a.trayPayload.getFgSkuVariant();
	            FG_SKU sb = b.trayPayload.getFgSkuVariant();
	            return sa.compareTo(sb); // MET, then FW, then FB
	        }
	    }
	);
	
    // Initialize first tray for stowing
	TrayAssignment firstStore = fgJobItems.get(stowIndex);
	this.currentItem  = firstStore.trayRes;
	this.fgTargetSlot = firstStore.targetSlot;
	this.rackIdx	  = firstStore.rackIdx;
	
	this.rmTargetSlot = null;
}
]]></Action>
