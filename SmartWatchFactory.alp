			<Name><![CDATA[OdooLiveService]]></Name>
			<Folder>1771290566546</Folder>
			<Text><![CDATA[/**
 * OdooLiveService
 */	

public final class OdooLiveService {
	
	public static int resolveCompanyId(Main main) {
    	try {
	    	Map<String, Object> kwUser = new HashMap<>();
	    	kwUser.put("fields", Arrays.asList("company_id"));
	    	Object userResult = OdooUtils.executeKw(
	    	    main.m_odooSession,
	    	    OdooUtils.DATABASE_NAME,
	    	    OdooUtils.SERVER_PASSWORD,
	    	    "res.users",
	    	    "read",
	    	    Arrays.asList(main.m_odooSession.uid),  // Get current user
	    	    kwUser
	    	);
	    	
	    	List<Map<String, Object>> userRows = OdooUtils.asListOfMaps(userResult);
	    	int companyId = -1;
	    	
	    	if (!userRows.isEmpty()) {
	    	    companyId = OdooUtils.m2oId(userRows.get(0).get("company_id"));
	    	}
	    	
	    	return companyId;
    	} catch (Exception e) {
		    Logger.error("fetchCompanyId: ", e);
		    return -1;
		}
    }
	
	public static int resolveStockLocationId(Main main, String warehouseCode) { // needs main.m_odooSession
		try {
			// search stock.warehouse by code
		    Map<String,Object> kwSearchWh = new HashMap<String,Object>();
		    kwSearchWh.put("limit", 1);
			
		    // Get the warehouse
		    Object whIds = OdooUtils.executeKw(
		    	main.m_odooSession, 
		        OdooUtils.DATABASE_NAME, 
		        OdooUtils.SERVER_PASSWORD,
		        "stock.warehouse", 
		        "search",
		        Arrays.asList(Arrays.asList(
		        		Arrays.asList("code","=", warehouseCode)
		        )),
		        kwSearchWh
		    );
		    Object[] whArr = (whIds instanceof Object[]) ? (Object[]) whIds : new Object[0];
		    int whId = (whArr.length > 0) ? ((Number) whArr[0]).intValue() : -1;
		    
		    if (whId <= 0) {
		        Logger.warn("resolveStockLocationId: no warehouse found for code=", warehouseCode);
		        return -1;
		    }
		    
		    // Read lot_stock_id (main internal location), plus view_location_id and company_id
		    Map<String,Object> kwReadWh = new HashMap<String,Object>();
		    kwReadWh.put("fields", Arrays.asList("lot_stock_id", "view_location_id", "company_id"));
		    
		    // Read its view_location_id (root internal location)
		    Object whRead = OdooUtils.executeKw(
		    	main.m_odooSession,
		        OdooUtils.DATABASE_NAME,
		        OdooUtils.SERVER_PASSWORD,
		        "stock.warehouse", 
		        "read",
		        Arrays.asList(Collections.singletonList(whId)),
		        kwReadWh
		    );
		    List<Map<String,Object>> whRows = OdooUtils.asListOfMaps(whRead);
		    if (whRows == null || whRows.isEmpty())
		    	return -1;
		    
		    Map<String,Object> wh = whRows.get(0);
		    
		    // Prefer lot_stock_id (language-agnostic)
		    int lotStockId = OdooUtils.m2oId(wh.get("lot_stock_id"));
		    if (lotStockId > 0)
		        return lotStockId;
		    
		    // Fallback: find any internal location under the warehouse root
		    int rootLocId = OdooUtils.m2oId(wh.get("view_location_id"));
	        int companyId = OdooUtils.m2oId(wh.get("company_id")); // Optional: restrict by company for multi-company setups
	        
	        if (rootLocId <= 0)
		        return -1; // no good fallback available
	        
	        if (lotStockId <= 0 && rootLocId > 0) {
	            Logger.warn("Warehouse WH=", warehouseCode, " has no lot_stock_id; searching internal 'Stock' under root ", rootLocId);
	        }
		    
		    // find the internal "Stock" child location under that root
		    Map<String,Object> kwSearchLoc = new HashMap<String,Object>();
		    kwSearchLoc.put("limit", 1);
		    
		    List<Object> domain = new ArrayList<>();
	        domain.add(Arrays.asList("usage","=","internal"));
	        domain.add(Arrays.asList("location_id","child_of", rootLocId));
	        domain.add(Arrays.asList("name","ilike","Stock")); // or "complete_name"
	        if (companyId > 0)
	        	domain.add(Arrays.asList("company_id","=", companyId));

		    // Find its “Stock” child location (internal use)
		    Object locIds = OdooUtils.executeKw(
		    	main.m_odooSession,
		        OdooUtils.DATABASE_NAME,
		        OdooUtils.SERVER_PASSWORD,
		        "stock.location",
		        "search",
		        Arrays.asList(domain),
		        kwSearchLoc
		    );
		    
		    Object[] locArr = (locIds instanceof Object[]) ? (Object[]) locIds : new Object[0];
		    return (locArr.length > 0) ? ((Number) locArr[0]).intValue() : -1;
		} catch (Exception e) {
		    Logger.error("resolveStockLocationId: ", e);
		    return -1;
		}
	}
	
    public static Map<String,Double> fetchOnHandBySkuIds(Main main, Collection<String> skuIds, int locationId, String texts) {
    	// Logger.warn("Called from: ", texts);
    	Map<String, Double> out = new LinkedHashMap<String, Double>();
    	if (main.m_odooSession == null || skuIds == null || skuIds.isEmpty() || locationId <= 0) 
    		return out;

    	List<Integer> productIds = new ArrayList<Integer>();
    	for (String sku : skuIds) {
    	    Integer pid = main.productIdBySkuId.get(sku);
    	    if (pid != null && pid > 0) {
    	        productIds.add(pid);
    	    }
    	}

    	if (productIds.isEmpty()) {
    	    for (String sku : skuIds)
    	    	out.put(sku, 0.0);
    	    return out;
    	}

    	try {
    	    Map<String,Object> kwargs = new HashMap<String,Object>();
    	    kwargs.put("fields",  Arrays.asList("product_id", "quantity:sum", "reserved_quantity:sum"));
    	    kwargs.put("groupby", Arrays.asList("product_id"));
    	    kwargs.put("lazy",    Boolean.FALSE);

    	    Object res = OdooUtils.executeKw(
    	        main.m_odooSession,
    	        OdooUtils.DATABASE_NAME, 
    	        OdooUtils.SERVER_PASSWORD,
    	        "stock.quant",
    	        "read_group",
    	        Arrays.asList(Arrays.asList(
    	            Arrays.asList("location_id", "child_of", locationId),
    	            Arrays.asList("product_id", "in", productIds)
    	        )),
    	        kwargs
    	    );
    	    
    	    Map<Integer, Double> qtyByPid = new HashMap<Integer, Double>();
    	    List<Map<String,Object>> rows = OdooUtils.asListOfMaps(res);
    	    if (rows != null) {
    	        for (Map<String,Object> r : rows) {
    	            int pid = OdooUtils.m2oId(r.get("product_id"));
    	            double qty = OdooUtils.safeCastToDouble(r.get("quantity"));
    	            double resv = OdooUtils.safeCastToDouble(r.get("reserved_quantity"));
    	            double available = qty - resv;  // use 'qty' if you want raw on-hand
    	            qtyByPid.put(pid, available);
    	        }
    	    }
    	    
    	    for (String sku : skuIds) {
    	        Integer pid = main.productIdBySkuId.get(sku);
    	        double q = (pid != null) ? (qtyByPid.containsKey(pid) ? qtyByPid.get(pid) : 0.0) : 0.0;
    	        out.put(sku, q);
    	    }
    	} catch (Exception e) {
    		for (String sku : skuIds)
	    	if (!out.containsKey(sku))
	    		out.put(sku, 0.0);
    	    Logger.error("fetchOnHandBySkuIds - " + texts + " ", e);
    	}

    	return out;
    } 
}]]></Text>
		</JavaClass>
