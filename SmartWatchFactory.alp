						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[WipUnit wu = (WipUnit) agent;

// You can expose these getters on WipUnit if they’re private
boolean passed 	= wu.getLastQc2Passed();
int tries 		= wu.getQc2Attempts();

// Optional flag set at decision time (see below)
boolean flaggedToScrap = wu.isFlaggedToScrap();

// Business rule: only units that PASSED QC2 and have attempts <= max may queue for Pack
if (!passed || tries > ManufacturingConfigService.qcMaxAttempts || flaggedToScrap) {
    Logger.warn("Intercepted invalid unit before Pack: serial=" + wu.serialId +
                " passed=" + passed + " tries=" + tries + " flaggedToScrap=" + flaggedToScrap);
    sinkScrap.onEnter(wu);
    return;
}
]]></Code>
							</Value>
