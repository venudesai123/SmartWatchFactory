		<ActiveObjectClass>
			<Id>1764793326678</Id>
			<Name><![CDATA[Stower]]></Name>
			<AdditionalClassCode><![CDATA[// Job data
private final List<TrayAssignment> fgJobItems = new ArrayList<>();

// 2-phase job: first pick all in staging, then stow them
private enum JobPhase { NONE, COLLECTING, STOWING }

private JobPhase jobPhase = JobPhase.NONE;

// indices
private int collectIndex = -1;  // which tray we are currently picking in staging
private int stowIndex    = -1;  // which tray we are currently stowing to racks
// ************************************************** //

private Resource currentItem = null;     // the tray Resource we are carrying

private PointNode seatNode;
private PointNode seatCorridorNode;
private FgSlot fgTargetSlot = null;
private int rackIdx = -1;

private double pickupTime;
private double placeTime;

private boolean reachedSeatCorridor = false;

private List<Resource> carriedItems = new ArrayList<>();

private double baseSpeed;
private String nextArrivalMsg = null;

private JOB_KIND jobKind = null;

public double busyTime = 0;
private double lastBusyStart = -1;

private final List<MotherBoxAssignment> rmJobItems = new ArrayList<>();
private RmSlot rmTargetSlot = null;

public void initStower( PointNode seat, PointNode corridorNode) {
	this.seatNode = seat;
	this.seatCorridorNode = corridorNode;
}

private int jobCount() {
    return (jobKind == JOB_KIND.FG) ? fgJobItems.size() : rmJobItems.size();
}

private void cancelPendingArrival() {
    this.nextArrivalMsg = null;
    arrivalPoller.reset();
}

private void armArrivalOrFireNow(String msg, double tx, double ty) {
    this.nextArrivalMsg = msg;
    moveTo(tx, ty);
    this.arrivalPoller.restart();
}

private void armArrivalOrFireNow(String msg, PointNode pn) {
    this.nextArrivalMsg = msg;
    moveTo(pn);
    this.arrivalPoller.restart();
}

private void goSeatAndWait(String msg) {
    armArrivalOrFireNow(msg, this.seatNode);
}

public boolean isIdle() {
    return jobPhase == JobPhase.NONE && statechartStow.isStateActive(Idle);
}

// Backwards-compatible wrapper for single-tray jobs (if ever needed)
public void assignTray(Resource tray, FgSlot slot) {
    Tray payload = tray != null ? tray.getTray() : null;
    int rIdx = -1;
    if (payload != null) {
        rIdx = payload.getFgSkuVariant().ordinal(); // main.fgRackIndex(payload.getFgSku());
    }
    List<TrayAssignment> one = new ArrayList<>();
    one.add(new TrayAssignment(tray, payload, slot, rIdx));
    assignFgJob(one);
}

// New multi-tray job assignment
public void assignFgJob(List<TrayAssignment> tasks) {
	// clear RM job data
    rmJobItems.clear();
    rmTargetSlot = null;

    // set FG job data
    fgJobItems.clear();
    carriedItems.clear(); 
    fgTargetSlot = null;

    jobKind = JOB_KIND.FG;
    
    if (tasks != null) {
        fgJobItems.addAll(tasks);
    }

    if (fgJobItems.isEmpty()) {
        // nothing to do
        jobPhase = JobPhase.NONE;
        collectIndex = -1;
        stowIndex = -1;
        currentItem = null;
        fgTargetSlot  = null;
        rackIdx     = -1;
        return;
    }

    // Phase 1: collecting in staging
    jobPhase = JobPhase.COLLECTING;
    collectIndex = 0;
    stowIndex = -1;

    TrayAssignment first = fgJobItems.get(0);
    this.currentItem  = first.trayRes;
    this.fgTargetSlot   = first.targetSlot;   // used later in stowing
    this.rackIdx      = first.rackIdx;      // used later in stowing
	
    this.reachedSeatCorridor = false;

    // kick the statechart
    statechartStow.fireEvent("NEW_JOB");
}

public void assignRmJob(List<MotherBoxAssignment> tasks) {
    // clear FG job data
    fgJobItems.clear();
    fgTargetSlot = null;

    // set RM job data
    rmJobItems.clear();
    carriedItems.clear();
    rmTargetSlot = null;

    jobKind = JOB_KIND.RM;

    if (tasks != null) { rmJobItems.addAll(tasks); }
    rmJobItems.removeIf(t -> t == null || t.mbRes == null || t.targetSlot == null);

    if (rmJobItems.isEmpty()) {
        jobPhase = JobPhase.NONE;
        return;
    }

    jobPhase = JobPhase.COLLECTING;
    collectIndex = 0;
    stowIndex = -1;

    MotherBoxAssignment first = rmJobItems.get(0);
    this.currentItem  = first.mbRes;
    this.rmTargetSlot = first.targetSlot;
    this.rackIdx      = first.rackIdx;

    this.reachedSeatCorridor = false;
    statechartStow.fireEvent("NEW_JOB");
}

public void kpiMarkBusyStart() {
	if (lastBusyStart < 0)
		lastBusyStart = time();
}

public void kpiMarkBusyEnd() {
	if (lastBusyStart >= 0) {
		busyTime += (time() - lastBusyStart);
		lastBusyStart = -1;
	}
}

public double utilization() {
	double t = time();
	if (t <= 0) return 0;
	double bt = busyTime + ((lastBusyStart>=0) ? (t-lastBusyStart) : 0);
	return bt / t;
}
