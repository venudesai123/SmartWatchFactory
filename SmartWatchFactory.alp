		<JavaClass>
			<Id>1757633276650</Id>
			<Name><![CDATA[Tray]]></Name>
			<Folder>1771726185934</Folder>
			<Text><![CDATA[/**
 * Tray (aligned)
 *
 * availableFgIds	= ids available for picking
 * reservedFgIds	= ids reserved for pick plans
 */
import java.util.*;

public class Tray {
    private final VARIANT variant;
    private final List<WipUnit> units; // original WIP objects (optional to keep)
    private final ArrayList<Integer> availableFgIds = new ArrayList<>();
    private final ArrayList<Integer> reservedFgIds  = new ArrayList<>();

    public Tray(VARIANT variant, List<WipUnit> units) {
        this.variant = variant;
        this.units = (units == null) ? new ArrayList<>() : new ArrayList<>(units);

        for (WipUnit wu : this.units) {
            if (wu == null) continue;
            availableFgIds.add(wu.fgId);
        }
    }

    public VARIANT getVariant() { return variant; }

    public FG_SKU getFgSkuVariant() {
        return FG_SKU.valueOf(variant.name());
    }

    /** Total FG units physically represented by this tray (available + reserved). */
    public int totalUnits() { return availableFgIds.size() + reservedFgIds.size(); }

    /** Available units in this tray (not reserved). */
    public int availableUnits() { return availableFgIds.size(); }

    /** Reserved units in this tray. */
    public int reservedUnits() { return reservedFgIds.size(); }

    /** Backward compatibility (but avoid using this for capacity). */
    // public int getUnitCount() { return totalUnits(); }

    public List<Integer> reserveIds(int want) {
        int take = Math.min(Math.max(0, want), availableFgIds.size());
        ArrayList<Integer> out = new ArrayList<>(take);

        for (int i = 0; i < take; i++) {
            // pop from end
            out.add(availableFgIds.remove(availableFgIds.size() - 1));
        }
        reservedFgIds.addAll(out);
        return out;
    }

    public void releaseIds(List<Integer> ids) {
        if (ids == null || ids.isEmpty()) return;

        // move ids from reserved -> available
        reservedFgIds.removeAll(ids);
        availableFgIds.addAll(ids);
    }

    public void commitIds(List<Integer> ids) {
        if (ids == null || ids.isEmpty()) return;

        // remove from reserved permanently (shipped / consumed)
        reservedFgIds.removeAll(ids);
    }

    public boolean isEmpty() {
        return totalUnits() == 0;
    }
    
    public List<Integer> getFgIds() {
        ArrayList<Integer> out = new ArrayList<>(availableFgIds.size() + reservedFgIds.size());
        out.addAll(availableFgIds);
        out.addAll(reservedFgIds);
        return out;
    }
}]]></Text>
		</JavaClass>
