public enum STAGE {
	
    KIT(0x9E9E9E),
    ASM(0x42A5F5),
    SI(0x26A69A),
    QC1(0x7E57C2),
    RW1(0xFF7043),
    QC2(0xAB47BC),
    RW2(0xFF7043),
    PK(0x66BB6A),
    SCRAP(0xEF5350),
    DONE(0x2E7D32);

    private final Color color;
