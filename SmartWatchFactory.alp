		<JavaClass>
			<Id>1767745158314</Id>
			<Name><![CDATA[WarehouseDispatchService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * WarehouseDispatchService
 * 
 * skeleton to help split Main's Additional class code into services.
 * Purpose: Shared warehouse operations used by both MO and CO flows: worker selection, pick plan building, reservations, dispatch loops, stock logging.
 */	
import com.anylogic.libraries.processmodeling.RackSystem;
import com.anylogic.engine.markup.PalletRackApproachDirection;

public class WarehouseDispatchService {

	private final Main main;
	private final StowingAssignmentsService srvStowAssignment;
	private final PickPlanningService srvPickPlan;

    public WarehouseDispatchService(Main main, PickPlanningService srvPickPlan, StowingAssignmentsService srvStowAssignment) {
        this.main = main;
        this.srvPickPlan = srvPickPlan;
        this.srvStowAssignment = srvStowAssignment;
    }
    
    private Picker findIdlePicker() {
    	for (Picker p : main.rmPickers) {
    		if (p.isIdleForDispatch()) {
    			return p;
    		}
    	}
    	return null;
    }

    public Picker findIdleFgPicker() {
        for (Picker p : main.fgPickers) {
            if (p.isIdleForDispatch()) {
                return p;
            }
        }
        return null;
    }
    
    private Stower findIdleRmStower() {
        for (Stower s : main.rmStowers) {
            if (s != null && s.isIdle())
            	return s;
        }
        return null;
    }

    private Stower findIdleFgStower() {
        for (Stower s : main.fgStowers) {
            if (s != null && s.isIdle())
            	return s;
        }
        return null;
    }

    public Resource findIdleOutboundWorker() {
        for (Resource r : main.operators) {
            if (r.category == RESOURCE_TYPE.OUTBOUND_WORKER && !r.outboundWorkerBusy)
            	return r;
        }
        return null;
    }
    
    // ======================================================
    // Dispatch loops (entry points to call from events)
    // ======================================================
    public void tryDispatchRmPicking() {

        // Bounded pass: only look at the items that were waiting at the time we entered.
        // Anything we re-queue goes to the end and will be tried on the NEXT call.
        int passCount = main.waitingMrpOrders.size();

        for (int i = 0; i < passCount; i++) {

            // Need an idle picker first
            Picker picker = this.findIdlePicker();
            if (picker == null)
                return;

            MrpOrder order = main.waitingMrpOrders.poll(); // FIFO
            if (order == null)
                continue;

            if (!order.hasPendingDemand()) {
                Logger.info("Skipping order ", order.getIndex(), " — no pending demand.");
                continue;
            }

            // if this MO already has a picker assigned/picking, don't assign another.
            if (order.isPickInFlight()) {
            	main.waitingMrpOrders.addLast(order); // keep it, but try later
                continue;
            }

            List<PickStop> plan = this.srvPickPlan.buildRmPickPlan(order);

            // Optional but strongly recommended: don't dispatch a zero-stop job
            if (plan == null || plan.isEmpty()) {
                Logger.warn("No pick plan possible now for order ", order.getIndex(), " — requeueing.");
                main.waitingMrpOrders.addLast(order);
                continue;
            }

            this.srvPickPlan.assertPlanMatchesOrder(order, plan);
            
            picker.assignWithRmPlan(order, plan);
            Logger.info("Assigned order to picker id= " + picker.getIndex());
        }
    }
    
    public void tryDispatchFgPicking() {
        int passCount = main.pendingCustomerOrders.size();

        for (int i = 0; i < passCount; i++) {
            Picker picker = main.services.whDispatch.findIdleFgPicker();
            if (picker == null) return;

            CustomerOrder co = main.pendingCustomerOrders.pollFirst();
            if (co == null) continue;

            // List<PickStop> plan = main.services.pickPlanning.buildFgPickPlan(co);
            List<PickStop> plan;

			// If ATP already built a plan (hard reserved), reuse it.
			// Otherwise build one now (for orders that were soft ATP and later became feasible).
			if (co.fgPickPlan != null && !co.fgPickPlan.isEmpty()) {
				plan = new ArrayList<>(co.fgPickPlan);
			} else {
				plan = main.services.pickPlanning.buildFgPickPlan(co);
			}
            
            if (plan == null || plan.isEmpty()) {
                Logger.warn("No FG plan for customer order ", co, " ; requeueing.");
                main.pendingCustomerOrders.addLast(co);
                return; // stop spinning
            }

            co.markAssignedForPicking();
            main.pickingCustomerOrders.add(co);
            
            if (co.packStationIndex < 0 || co.packStationIndex >= Constants.CO_PACK_STATIONS) {
                main.services.routing.assignPackStationForCO(co);
            }
            
            picker.assignWithFgPlan(co, plan);
        }
    }
    
    public void tryDispatchRmStowing() {

        if (main.waitingRmBoxes == null || main.waitingRmBoxes.isEmpty())
            return;

        Stower st = this.findIdleRmStower();
        if (st == null)
            return;

        // Clean queue
        main.waitingRmBoxes.removeIf(r -> r == null || r.itemAssigned);
        if (main.waitingRmBoxes.isEmpty())
            return;
        
        // TEMP DEBUG: detect duplicate resources in waiting queue
        int unique = new java.util.HashSet<>(main.waitingRmBoxes).size();
        if (unique != main.waitingRmBoxes.size()) {
            Logger.warn("DUPLICATES in waitingRmBoxes! size=" + main.waitingRmBoxes.size() +
                        " unique=" + unique);
        }

        int q = main.waitingRmBoxes.size();
        int minNow = Constants.RM_MIN_BOX_PER_TRIP;

        double oldestAge = 0;
        for (Resource r : main.waitingRmBoxes) {
            if (r != null && r.itemQueued && r.queuedAt >= 0) {
                oldestAge = Math.max(oldestAge, main.time() - r.queuedAt);
            }
        }

        if (q < minNow && oldestAge >= Constants.STOW_MAX_WAIT) {
            minNow = 1;
        }

        if (q < minNow)
            return;

        // MAX-first
        int want = Math.min(Constants.RM_MAX_BOX_PER_TRIP, q);

        ArrayList<Resource> batch = new ArrayList<>(want);

        while (batch.size() < want && !main.waitingRmBoxes.isEmpty()) {
            Resource mbRes = main.waitingRmBoxes.pollFirst();
            if (mbRes == null)
            	continue;

            if (!mbRes.itemQueued || mbRes.itemAssigned)
            	continue;

            mbRes.itemQueued = false;
            mbRes.itemAssigned = true;

            batch.add(mbRes);
        }

        // If we couldn't reserve enough, requeue what we reserved
        if (batch.size() < minNow) {
            this.requeueRmReserved(batch, "batch < minNow");
            return;
        }

        // Builder will requeue notAssigned internally
        List<MotherBoxAssignment> tasks = this.srvStowAssignment.buildMotherBoxAssignments(batch);

        if (tasks == null || tasks.isEmpty()) {
        	// Builder already requeued notAssigned (and set their itemAssigned=false)
            // Requeue only those still reserved (itemAssigned=true)
            ArrayList<Resource> stillReserved = new ArrayList<>();
            for (Resource r : batch) {
                if (r != null && r.itemAssigned)
                	stillReserved.add(r);
            }
            this.requeueRmReserved(stillReserved, "builder returned empty");
            return;
        }
        
        HashSet<Resource> assignedToTask = new HashSet<>();
        // Mark only actually-assigned ones as "consumed" (clear queuedAt)
        for (MotherBoxAssignment a : tasks) {
            if (a != null && a.mbRes != null) {
                a.mbRes.rmStowTask = a;   // redundant but safe
                a.mbRes.queuedAt = -1;
                assignedToTask.add(a.mbRes);
            }
        }

        // Anything still reserved but not in tasks must be requeued
        ArrayList<Resource> leftovers = new ArrayList<>();
        for (Resource r : batch) {
            if (r != null && r.itemAssigned && !assignedToTask.contains(r))
            	leftovers.add(r);
        }
        if (!leftovers.isEmpty()) {
            this.requeueRmReserved(leftovers, "leftovers after task build");
        }

        st.assignRmJob(tasks);
    }
    
    private void requeueRmReserved(List<Resource> list, String reason) {
        if (list == null || list.isEmpty())
        	return;

        for (Resource r : list) {
            if (r == null)
            	continue;

            // rollback incoming reservation if it exists
            if (r.rmStowTask != null) {
                r.rmStowTask.rollbackIncomingReservation(reason);
                r.rmStowTask = null;
            }

            r.itemAssigned = false;
            if (!r.itemQueued) 
            	r.itemQueued = true;

            if (r.queuedAt < 0)
            	r.queuedAt = main.time();

            main.waitingRmBoxes.addLast(r);
        }
    }
    
    public void tryDispatchFgStowing() {

        if (main.waitingFgTrays == null || main.waitingFgTrays.isEmpty())
            return;

        Stower st = this.findIdleFgStower();
        if (st == null)
            return;

        main.waitingFgTrays.removeIf(r -> r == null || r.itemAssigned);
        if (main.waitingFgTrays.isEmpty())
            return;
        
        int unique = new HashSet<>(main.waitingFgTrays).size();
        if (unique != main.waitingFgTrays.size()) {
            Logger.warn("DUPLICATES in waitingFgTrays! size=" + main.waitingFgTrays.size() +
                        " unique=" + unique);
        }

        int q = main.waitingFgTrays.size();
        int minNow = Constants.FG_MIN_TRAYS_PER_TRIP;

        double oldestAge = 0;
        for (Resource r : main.waitingFgTrays) {
            if (r != null && r.itemQueued && r.queuedAt >= 0) {
                oldestAge = Math.max(oldestAge, main.time() - r.queuedAt);
            }
        }

        if (q < minNow && oldestAge >= Constants.STOW_MAX_WAIT) {
            minNow = 1;
        }

        if (q < minNow)
            return;

        // MAX-first
        int want = Math.min(Constants.FG_MAX_TRAYS_PER_TRIP, q);

        ArrayList<Resource> batch = new ArrayList<>(want);

        while (batch.size() < want && !main.waitingFgTrays.isEmpty()) {
            Resource trayRes = main.waitingFgTrays.pollFirst();
            if (trayRes == null)
            	continue;

            if (!trayRes.itemQueued || trayRes.itemAssigned)
            	continue;

            trayRes.itemQueued = false;
            trayRes.itemAssigned = true;

            batch.add(trayRes);
        }

        if (batch.size() < minNow) {
            this.requeueFgReserved(batch, "batch < minNow");
            return;
        }

        List<TrayAssignment> tasks = this.srvStowAssignment.buildTrayAssignments(batch);

        if (tasks == null || tasks.isEmpty()) {
        	// Builder already requeued notAssigned (and set their itemAssigned=false)
            // Requeue ONLY those still reserved (itemAssigned==true)
            ArrayList<Resource> stillReserved = new ArrayList<>();
            for (Resource r : batch) {
                if (r != null && r.itemAssigned)
                	stillReserved.add(r);
            }
            this.requeueFgReserved(stillReserved, "builder returned empty");
            return;
        }
        
        HashSet<Resource> assignedToTask = new HashSet<>();
        for (TrayAssignment a : tasks) {
            if (a != null && a.trayRes != null) {
                a.trayRes.fgStowTask = a;  // redundant but safe
                a.trayRes.queuedAt = -1;
                assignedToTask.add(a.trayRes);
            }
        }
        
        ArrayList<Resource> leftovers = new ArrayList<>();
        for (Resource r : batch) {
            if (r != null && r.itemAssigned && !assignedToTask.contains(r))
            	leftovers.add(r);
        }
        if (!leftovers.isEmpty()) {
            this.requeueFgReserved(leftovers, "leftovers after task build");
        }

        st.assignFgJob(tasks);
    }
    
    private void requeueFgReserved(List<Resource> list, String reason) {
        if (list == null || list.isEmpty())
        	return;

        for (Resource r : list) {
            if (r == null)
            	continue;

            if (r.fgStowTask != null) {
                r.fgStowTask.rollbackIncomingReservation(reason);
                r.fgStowTask = null;
            }

            r.itemAssigned = false;
            if (!r.itemQueued) 
            	r.itemQueued = true;

            if (r.queuedAt < 0)
            	r.queuedAt = main.time();

            main.waitingFgTrays.addLast(r);
        }
    }
    
    public void tryDispatchPackedCO() {
        // Bridge from the old queue to the per-station queues
        while (!main.pendingPackingOrders.isEmpty()) {
            CustomerOrder co = main.pendingPackingOrders.pollFirst();
            if (co == null)
            	continue;

            // Make sure it has a station assigned
            int st = co.packStationIndex;
            if (st < 0 || st >= Constants.CO_PACK_STATIONS) {
                st = main.services.routing.assignPackStationForCO(co);
            }

            // Pretend it has just arrived at that packing station
            main.services.coFlow.onPickedOrderArrivedAtPackStation(co);
        }
    }
    
    public void tryDispatchEmptyRmFromSlot(RmSlot slot) {
        if (slot == null) return;
        if (slot.emptyRemovalInFlight) return;

        // pick correct rack system by skuType
        RackSystem rack = slot.rackSystem;

        // PHYSICAL front is deepPosition=0
        Resource front = (Resource) rack.get(slot.row, slot.cell, slot.level, 0);
        if (front == null) return;

        if (!front.isEmpty) return;

        slot.emptyRemovalInFlight = true;
        main.rmEmptyIn.take(front);     // this goes to rackPickEmptyRm
    }
    
    public void onEmptyRmBoxRemoved(Resource mbRes) {
        if (mbRes == null) return;
        MotherBox mb = mbRes.getMotherBox();
        if (mb == null) return;

        PRODUCT_TYPE pt = mb.getSkuType();
        if (pt == null) return;

        // IMPORTANT: getRmSlot signature is (pt, row, level, cell, deep)
        RmSlot slot = main.services.slotting.getRmSlot(
            pt,
            mbRes.rackTargetRow,
            mbRes.rackTargetLevel,
            mbRes.rackTargetCell,
            0
        );
        if (slot == null) return;

        boolean removed = slot.boxes.remove(mbRes);
        if (!removed) {
            Logger.warn("onEmptyRmBoxRemoved - box not found in slot.boxes for sku=", mbRes.getMotherBox().getSkuId());
        }
        
        mbRes.getMotherBox().setInRmSlot(false);
        slot.recalc();

        slot.emptyRemovalInFlight = false;

        // only clear sku when physically removed and truly empty
        if (slot.boxes.isEmpty() && slot.incomingBoxes == 0) slot.skuId = null;

        this.enqueueEmptyRmSlot(slot);
    }
    
    private void enqueueEmptyRmSlot(RmSlot slot) {
	    if (slot == null) return;
	    
	    // Only enqueue once until processed
	    if (main.pendingEmptyRmSlotsSet.add(slot))
	    	main.pendingEmptyRmSlots.addLast(slot);
	    
	    // Ensure event runs next micro-step
	    main.dispatchEmptyRm.restart(0);
	}
    
    public void tryDispatchEmptyFgFromSlot(FgSlot slot) {
    	
        if (slot == null) return;
        if (slot.emptyRemovalInFlight) return;

        // decide by SKU (quick approach)
        RackSystem rack = slot.rackSystem;

        // PHYSICAL front tray = deepPosition 0
        Resource front = (Resource) rack.get(slot.row, slot.cell, slot.level, 0);
        if (front == null) return;
        if (!front.isEmpty) return;
        
        /* Logger.warn("Dispatch empty PHYSICAL front tray ", front,
        	    " ident=", System.identityHashCode(front),
        	    " from slot ", slot
        	); */

        slot.emptyRemovalInFlight = true;
        main.fgEmptyIn.take(front);
    }

    // Called when RackPick successfully removed the tray and it's about to be destroyed
    public void onEmptyFgTrayRemoved(Resource trayRes) {
        if (trayRes == null) return;

        Tray tray = trayRes.getTray();
        if (tray == null) return;

        FG_SKU sku = tray.getFgSkuVariant();

        FgSlot slot = main.services.slotting.getFgSlot(
            sku,
            trayRes.rackTargetRow,
            trayRes.rackTargetCell,
            trayRes.rackTargetLevel
        );

        if (slot == null) return;
        
        /* Logger.warn("Removed empty tray ", trayRes,
        	    " ident=", System.identityHashCode(trayRes),
        	    " from slot ", slot,
        	    " remaining=", slot.trays.size()
        	); */

        // Remove by identity (NOT by order)
        boolean removed = slot.trays.remove(trayRes);
        if (!removed) {
            Logger.warn("onEmptyRmBoxRemoved - box not found in slot.boxes for sku=", trayRes.getMotherBox().getSkuId());
        }
        slot.recalc();

        // unlock and try again
        slot.emptyRemovalInFlight = false;
        this.enqueueEmptyFgSlot(slot);
    }
    
    private void enqueueEmptyFgSlot(FgSlot slot) {
	    if (slot == null) return;

	    // Only enqueue once until processed
	    if (main.pendingEmptyFgSlotsSet.add(slot)) {
	        main.pendingEmptyFgSlots.addLast(slot);
	    }

	    // Ensure event runs next micro-step
	    main.dispatchEmptyFg.restart(0);
	}
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1767745451018</Id>
			<Name><![CDATA[PickPlanningService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * PickPlanningService
 */

public class PickPlanningService {

	private final Main main;
	private final ReservationsService srvReservation;

    public PickPlanningService(Main main, ReservationsService srvReservation) {
        this.main = main;
        this.srvReservation = srvReservation;
    }
    
    public List<PickStop> buildRmPickPlan(MrpOrder order) {

        if (order == null) {
            Logger.warn("buildRmPickPlan: order is null");
            return Collections.emptyList();
        }

        // If true: only dispatch when ALL RM lines can be fully reserved in one plan.
        // This prevents "same order gets assigned again" due to partial plans.
        final boolean ALL_OR_NOTHING = true;

        // What still needs to be picked (ledger)
        LinkedHashMap<String, Integer> rem = order.getRemainingInMo();
        LinkedHashMap<String, Integer> needTotals = new LinkedHashMap<>();

        if (rem != null) {
            for (Map.Entry<String, Integer> e : rem.entrySet()) {
                Integer q = e.getValue();
                if (q != null && q > 0) {
                    needTotals.put(e.getKey(), q);
                }
            }
        }

        // Fallback: if ledger is empty (should be rare), use the full order lines
        if (needTotals.isEmpty()) {
            Map<String, Integer> lines = order.getLinesBySkuId();
            if (lines != null) needTotals.putAll(lines);
        }

        List<PickStop> plan = new ArrayList<>();

        // Helper: rollback everything reserved so far
        Runnable rollbackAll = () -> {
        	// release MB reservations
            for (PickStop ps : plan) {
                if (ps == null) continue;
                if (ps.rmAllocs != null) {
                    for (RmPickAlloc a : ps.rmAllocs) {
                        if (a == null || a.qty <= 0 || a.mbRes == null) continue;
                        MotherBox mb = a.mbRes.getMotherBox();
                        if (mb != null) mb.releaseUnits(a.qty);
                    }
                }
                if (ps.slotRef != null) ps.slotRef.recalc();
            }
            // restore MO ledger decrements
            order.restoreClubbedQuantities(plan);
        };

        // Build plan SKU by SKU
        for (Map.Entry<String, Integer> line : needTotals.entrySet()) {

            String skuId = line.getKey();
            int qtyRemaining = line.getValue() != null ? line.getValue() : 0;
            if (qtyRemaining <= 0) continue;

            PRODUCT_TYPE skuType = PRODUCT_TYPE.fromSkuId(skuId);
            if (skuType == null) {
                Logger.error("buildRmPickPlan: unknown skuType for skuId=", skuId);
                if (ALL_OR_NOTHING) {
                	rollbackAll.run();
                	return Collections.emptyList();
                }
                continue;
            }

            List<RmSlot> slots = main.rmSlotsBySku.get(skuType);
            if (slots == null) {
                Logger.error("buildRmPickPlan: no rack slots list for skuId=", skuId, " skuType=", skuType);
                if (ALL_OR_NOTHING) { 
                	rollbackAll.run();
                	return Collections.emptyList();
                }
                continue;
            }

            // Walk slots of that rack type
            for (RmSlot s : slots) {
                if (qtyRemaining <= 0) break;
                if (!skuId.equals(s.skuId)) continue;
                
                PickStop ps = new PickStop(
                		skuId, skuType, 
                		s.rackIdx, s.row, s.cell, s.level, s.deep, 0
                );
                ps.moId = order.getMoId();
                ps.slotRef = s;
                
                for (Resource mbRes : s.boxes) {
                	if (qtyRemaining <= 0) break;
                    MotherBox mb = mbRes.getMotherBox();
                    if (mb == null) continue;

                    int took = mb.reserveUnits(qtyRemaining);
                    if (took <= 0) continue;

                    ps.rmAllocs.add(new RmPickAlloc(mbRes, took));
                    ps.unitsToPick += took;
                    qtyRemaining -= took;

                    if (rem != null) {
                        int cur = Math.max(0, rem.getOrDefault(skuId, 0));
                        rem.put(skuId, Math.max(0, cur - took));
                    }
                }
                
                if (ps.unitsToPick > 0) {
                    plan.add(ps);
                    s.recalc();
                }
            }

            if (qtyRemaining > 0) {
                Logger.warn("buildRmPickPlan: Insufficient stock for ", skuId, " (short ", qtyRemaining, ")");

                if (ALL_OR_NOTHING) {
                    // Undo everything reserved & undo ledger decrements
                    rollbackAll.run();
                    return Collections.emptyList();
                }
            }
        }

        // Nice pick path ordering
        plan.sort(
            Comparator
                .comparingInt((PickStop p) -> p.rackIdx)
                .thenComparingInt(p -> p.row)
                .thenComparingInt(p -> p.cell)
                .thenComparingInt(p -> p.level)
        );

        return plan;
    }
    
    public List<PickStop> buildFgPickPlan(CustomerOrder co) {
        List<PickStop> plan = new ArrayList<>();
    	
    	if (co == null || co.lines == null || co.lines.isEmpty()) {
            return plan;    // no lines = nothing to pick
        }
        
    	// Reset any previous FG pick data (IMPORTANT: release reservations first)
    	if (co.fgPickPlan != null && !co.fgPickPlan.isEmpty()) {
    	    // release reserved IDs back to trays/racks
    	    srvReservation.releasePlanReservations(co.fgPickPlan, 0);
    	}
    	co.clearFgPickData();
    	
        for (CustomerOrderLine line : co.lines) {
        	if (line == null || line.sku == null || line.qty <= 0)
                continue;
        
            FG_SKU sku = line.sku;
            String skuId = sku.skuId();
            int remaining = line.qty;
    		
    		List<FgSlot> base = main.fgSlotsBySku.get(sku);
            if (base == null || base.isEmpty()) {
                Logger.warn("No FG slots configured for ", sku);
                srvReservation.rollbackFgReservations(plan, co);
                return Collections.emptyList();
            }
    		
    		// Work on a copy so we don’t reorder your master slot list
            List<FgSlot> slots = new ArrayList<>(base);
            if (slots == null || slots.isEmpty())
                continue;

            // Strategy: fullest first
            slots.sort((a, b) -> Integer.compare(b.units, a.units));

            for (FgSlot s : slots) {
                if (remaining <= 0)
    				break;
    				
                if (s.units <= 0)
    				continue;
    				
    			if (s.skuId == null || !skuId.equals(s.skuId))
    				continue;
    				
    			int want = Math.min(s.units, remaining);
    			ArrayList<FgPickAlloc> allocs = new ArrayList<>();
    			List<Integer> ids = s.reserveIdsFromTrays(want, allocs);
                if (ids.isEmpty())
                	continue;

                PickStop ps = new PickStop();
                ps.fgSku = sku;
                ps.skuId = skuId;
                
                ps.rackIdx = s.skuType.ordinal();
                ps.row = s.row;
                ps.cell = s.cell;
                ps.level = s.level;
                ps.deep = s.deep;
                
                ps.unitsToPick = ids.size();
                ps.fgSlotRef = s;
                
                ps.fgAllocs.addAll(allocs);
                ps.fgIds.addAll(ids);

                plan.add(ps);
                
                // Attach exact IDs to order (this is what you will ship in Odoo!)
                co.pickedFgIds.addAll(ids);
                
                remaining -= ids.size();
            }

            if (remaining > 0) {
            	Logger.warn("Not enough FG stock for ", sku,
            				" need remaining=", remaining,
            				" for ", co);
                srvReservation.rollbackFgReservations(plan, co);
                return Collections.emptyList();
            }
        }
    	
    	// Store plan on the order so Main can commit/release later
        co.fgPickPlan.addAll(plan);
        return plan;
    }
    
    public void assertPlanMatchesOrder(MrpOrder o, List<PickStop> plan) {
        if (o == null)
        	return;

        Map<String,Integer> planned = new LinkedHashMap<>();
        for (PickStop ps : plan) {
            planned.merge(ps.skuId, ps.unitsToPick, Integer::sum);
        }

        // Baseline: full order lines (target quantities)
        Map<String,Integer> wantMap = o.getLinesBySkuId();
        for (Map.Entry<String,Integer> e : wantMap.entrySet()) {
            String sku  = e.getKey();
            int    want = e.getValue();
            int    got  = planned.getOrDefault(sku, 0);

            if (got > want) {
                Logger.warn("Plan over-picks for ", sku, " want=", want, " got=", got);
            }
        }

        // Optional: log current remainingInMo for debugging
        LinkedHashMap<String,Integer> rem = o.getRemainingInMo();
        if (rem != null) {
            Logger.info("Remaining ledger after plan for order ", o.getIndex(), " : ", rem);
        }
    }
    
    // Read-only: how many FG units are currently available for a given FG_SKU
    public int countAvailableFgUnits(FG_SKU sku) {
        if (sku == null)
        	return 0;

        List<FgSlot> base = main.fgSlotsBySku.get(sku);
        if (base == null || base.isEmpty())
        	return 0;

        String skuId = sku.skuId();
        int sum = 0;

        for (FgSlot s : base) {
            if (s == null)
            	continue;
            
            if (s.units <= 0)
            	continue;
            
            if (s.skuId == null)
            	continue;
            
            if (!skuId.equals(s.skuId))
            	continue;

            sum += s.units;
        }
        return sum;
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1767745855915</Id>
			<Name><![CDATA[StowingAssignmentsService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * StowingAssignmentsService
 */

public class StowingAssignmentsService {

	private final Main main;

    public StowingAssignmentsService(Main main) {
        this.main = main;
    }
    
    public List<MotherBoxAssignment> buildMotherBoxAssignments(List<Resource> batch) {
        List<MotherBoxAssignment> res = new ArrayList<>();
        List<Resource> notAssigned = new ArrayList<>();

        for (Resource mbRes : batch) {
            if (mbRes == null) continue;

            String skuId = mbRes.getMotherBox().getSkuId();
            int units = mbRes.getMotherBox().getUnitsPerBox();
            if (units <= 0 || units > Constants.RM_MAX_UNITS_PER_SLOT) {
                Logger.error("Invalid unitsPerBox for " + skuId + ": " + units + " -> requeue");
                notAssigned.add(mbRes);
                continue;
            }

            RmSlot slot = main.services.slotting.chooseRmSlotForUnits(skuId, units);
            if (slot == null) {
                notAssigned.add(mbRes);
                continue;
            }
            
            if (slot.skuId == null || slot.skuId.isEmpty()) {
            	PRODUCT_TYPE pt = PRODUCT_TYPE.fromSkuId(skuId);
                main.services.slotting.claimRmCellAllLevels(pt, slot.row, slot.cell, skuId);
            }

            PRODUCT_TYPE pt = (mbRes.getMotherBox().getSkuType() != null) ? 
            		mbRes.getMotherBox().getSkuType() : 
            			PRODUCT_TYPE.fromSkuId(skuId);
            int rackIdx = (pt != null) ? pt.ordinal() : 0;
            
            MotherBoxAssignment task = new MotherBoxAssignment(mbRes, slot, rackIdx);
            if (!task.isValid()) { notAssigned.add(mbRes); continue; }
            
            task.markIncomingReserved();
            mbRes.rmStowTask = task;
            res.add(task);
        }

        // Requeue ones without slot
        if (!notAssigned.isEmpty()) {
        	for (Resource r : notAssigned) {
                r.itemAssigned = false;
                if (!r.itemQueued)
                	r.itemQueued = true;
            }        	
            main.waitingRmBoxes.addAll(notAssigned);
        }

        return res;
    }
    
    public List<TrayAssignment> buildTrayAssignments(List<Resource> batch) {
        List<TrayAssignment> res = new ArrayList<>();
        List<Resource> notAssigned = new ArrayList<>();

        for (Resource trayRes : batch) {
            Tray tray = trayRes.getTray();
            if (tray == null) {
            	notAssigned.add(trayRes);
                Logger.warn("Tray Resource without payload, skipping.");
                continue;
            }

            FG_SKU fgSkuVariant = tray.getFgSkuVariant();
            int units = tray.totalUnits();
            
            if (units <= 0 || units > Constants.FG_MAX_UNITS_PER_SLOT) {
                Logger.error("Invalid tray unitCount=" + units + " for " + fgSkuVariant);
                notAssigned.add(trayRes);
                continue;
            }

            FgSlot slot = main.services.slotting.chooseSlotForTray(fgSkuVariant, units);
            if (slot == null) {
                // No suitable slot right now, keep tray in waiting list
                notAssigned.add(trayRes);
                continue;
            }
            
            if (slot.freeTrayCapacity() <= 0  || slot.freeUnitCapacity() < units) { //  slot.freeCapacity() <= units
                notAssigned.add(trayRes);
                continue;
            }
            
            int rackIdx = fgSkuVariant.ordinal();
            TrayAssignment task = new TrayAssignment(trayRes, tray, slot, rackIdx);
            if (!task.isValid()) {
            	notAssigned.add(trayRes);
                Logger.error("Invalid tray assignment: ", task);
                continue;
            }
            
            // Reserve BOTH counters consistently
            task.markIncomingReserved();
            trayRes.fgStowTask = task;
            
            res.add(task);
        }

        // Return unassigned trays to the waiting queue (at the tail)
        if (!notAssigned.isEmpty()) {
        	for (Resource r : notAssigned) {
                r.itemAssigned = false;
                if (!r.itemQueued)
                	r.itemQueued = true;
            }
            main.waitingFgTrays.addAll(notAssigned);
        }

        return res;
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1767746038648</Id>
			<Name><![CDATA[DiagnosticsService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * DiagnosticsService
 */

public class DiagnosticsService {

	private final Main main;

    public DiagnosticsService(Main main) {
        this.main = main;
    }
    
    public void logRmStock() {
    	for (PRODUCT_TYPE pt : PRODUCT_TYPE.values()) {
    		int avail = 0, resv = 0;
    		List<RmSlot> list = main.rmSlotsBySku.get(pt);
    		if (list != null) {
    			for (RmSlot s : list) {
    				avail += s.units;
    				resv += s.reservedUnits;
    			}
    		}
    		Logger.info(String.format("Stock %-10s = %4d avail %4d reserved %4d total", pt.getLabel(), avail, resv, (avail + resv)));
    	}
    }

    public void logFgStock() {
        int met = 0, fw = 0, fb = 0;

        for (Resource r : main.trays) {  // your 'trays' population
            if (r.category == RESOURCE_TYPE.TRAY) {
                Tray t = r.getTray();
                if (t == null)
                	continue;

                VARIANT v = t.getVariant();
                if (v == null)
                	continue;

                switch (v) {
                    case MET: met++; break;
                    case FW:  fw++;  break;
                    case FB:  fb++;  break;
                }
            }
        }

        Logger.info("FG rack -> MET: ", met, " FW: ", fw, " FB: ", fb);
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1767822328383</Id>
			<Name><![CDATA[ReservationsService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * ReservationsService
 */	
public class ReservationsService {

	// private final Main main;

    public ReservationsService(Main main) {
        // this.main = main;
    }
    
    public void releasePlanReservations(List<PickStop> plan, int fromIdx) {
        if (plan == null) return;

        for (int i = Math.max(0, fromIdx); i < plan.size(); i++) {
            PickStop ps = plan.get(i);
            if (ps == null) continue;

            // ---------------- RM (MotherBox-based) ----------------
            if (ps.rmAllocs != null && !ps.rmAllocs.isEmpty()) {
                for (RmPickAlloc a : ps.rmAllocs) {
                    if (a == null || a.qty <= 0 || a.mbRes == null) continue;
                    MotherBox mb = a.mbRes.getMotherBox();
                    if (mb != null) mb.releaseUnits(a.qty);
                }
                if (ps.slotRef != null) ps.slotRef.recalc();
                ps.rmAllocs.clear();
            } else if (ps.slotRef != null && ps.unitsToPick > 0) { // fallback only (old slot-level style)
                ps.slotRef.release(ps.unitsToPick);
                ps.slotRef.recalc();
                
                if (ps.rmAllocs != null) ps.rmAllocs.clear();
            }

            // ---------------- FG (Tray ID reservations) ----------------
            if (ps.fgAllocs != null && !ps.fgAllocs.isEmpty()) {
                for (FgPickAlloc a : ps.fgAllocs) {
                    if (a == null || a.trayRes == null || a.ids == null || a.ids.isEmpty()) continue;
                    Tray t = a.trayRes.getTray();
                    if (t != null) t.releaseIds(a.ids);
                }
                if (ps.fgSlotRef != null) ps.fgSlotRef.recalc();
                ps.fgAllocs.clear();
            }
            if (ps.fgIds != null) ps.fgIds.clear();
        }
    }
    
    public void rollbackFgReservations(List<PickStop> plan, CustomerOrder co) {
        releasePlanReservations(plan, 0);
        if (co != null) co.clearFgPickData();
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1768055710611</Id>
			<Name><![CDATA[ManufacturingConfigService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * ManufacturingConfigService
 */
import java.util.*;

public class ManufacturingConfigService {
	
	private Main main;
	
	private double workHoursPerDay = 24.0;
	private double utilization = 0.0;
	private double taktSec = 0.0;
	private int dailyTarget = 0;
	private Map<VARIANT, Integer> dailyTargetByVariant = new EnumMap<>(VARIANT.class);
	private Map<VARIANT, Integer> dailyMadeByVariant = new EnumMap<>(VARIANT.class);
	
	// Mean Time in seconds
	private final double tAssembly = 480.0;
	private final double tSoftwareIntegration = 360.0;
	private final double tQcSoftware = 120.0;
	private final double tReworkSoftware = 480.0;
	private final double tQcCosmetic = 120.0;
	private final double tReworkCosmetic = 420.0;
	private final double tPackaging = 240.0;
	
	private final double MIX_MET = 0.40; // MET 40%
	private final double MIX_FW  = 0.30; // FW 30%
	// private final double MIX_FB  = 0.30; // FB 30%
	
	// Defect Rates
	public static final int qcMaxAttempts = 2;		 // allow 2 attempts (first + one retry), tune as needed
	public static final double passAttemptS1 = 0.93; // 0.92
	public static final double passAttemptS2 = 0.96; // 0.95
	
	public static final double passAttemptC1 = 0.96;
	public static final double passAttemptC2 = 0.97;
	
	// Station counts
	public static final int nAssembly = 4;
	public static final int nSoftwareIntegration = 3;
	public static final int nQcSoftware = 1;
	public static final int nReworkSoftware = 1;
	public static final int nQcCosmetic = 1;
	public static final int nReworkCosmetic = 1;
	public static final int nPackaging = 2;
	
	public static final int moMinQty = 5;
	public static final int moMaxQty = 6;
	
	public static final int maxWaitingMos = 10;
	
	public ManufacturingConfigService(Main main) {
		this.main = main;
		
		// Prevent null values before first planToday()
	    for (VARIANT v : VARIANT.values()) {
	        this.dailyTargetByVariant.put(v, 0);
	        this.dailyMadeByVariant.put(v, 0);
	    }
	}
	
	public double getStationTime(STAGE s) {
		double time = 0.0;
		
		if (!Configuration.enableAutoEvents) {
			switch(s) {
				case ASM: { time = main.triangular(20, 30, 45); }	break;
				case SI: { time = main.triangular(3, 5, 8); } break;
				case QC1: { time = main.triangular( 2, 4, 6 ); } break;
				case RW1: { time = main.triangular( 3, 5, 7 ); } break;
				case QC2: { time = main.triangular( 3, 5, 7 ); } break;
				case RW2: { time = main.triangular( 3, 5, 7 ); } break;
				case PK: { time = main.triangular( 2, 3, 5 ); } break;
				default: { time = main.triangular(20, 30, 45); } break;
			}
			return time;
		}
		
		switch(s) {
			case ASM: { time = this.tAssembly; }	break;
			case SI: { time = this.tSoftwareIntegration; } break;
			case QC1: { time = this.tQcSoftware; } break;
			case RW1: { time = this.tReworkSoftware; } break;
			case QC2: { time = this.tQcCosmetic; } break;
			case RW2: { time = this.tReworkCosmetic; } break;
			case PK: { time = this.tPackaging; } break;
			default: { time = this.tAssembly; } break;
		}
		
		double diff = (time / 10) * 2;		
		return main.triangular(time - diff, time, time + diff) * this.rampFactor();
	}
	
	public void planToday(double workHoursPerDay, double utilization) {

	    // Reset counters
	    for (VARIANT v : VARIANT.values()) {
	    	this.dailyTargetByVariant.put(v, 0);
	    	this.dailyMadeByVariant.put(v, 0);
	    }

	    // Compute total target + takt from your service
	    this.computeCapacityAndSetTakt(workHoursPerDay, utilization);

	    Logger.info("DAILY PLAN: total=", this.dailyTarget,
	            " MET=", this.dailyTargetByVariant.get(VARIANT.MET), 
	            " FW=", this.dailyTargetByVariant.get(VARIANT.FW), 
	            " FB=", this.dailyTargetByVariant.get(VARIANT.FB),
	            " traySize=", Math.max(1, Constants.TRAY_SIZE),
	            " taktSec=", this.taktSec);
	}
	
	private void computeCapacityAndSetTakt(double workHoursPerDay, double utilization) {
	    
		this.workHoursPerDay = workHoursPerDay;
	    this.utilization = Math.max(0.1, Math.min(1.0, utilization));

	    double secPerHour = 3600.0;
	    
	    // --- Software QC (max 2 attempts) ---
	    double fSw1 = Math.max(0.0, Math.min(0.999, (1.0 - this.passAttemptS1)));
	    double fSw2 = Math.max(0.0, Math.min(0.999, (1.0 - this.passAttemptS2)));
	    double ySw  = 1.0 - (fSw1 * fSw2);     // survive software QC
	    
	    // Expected loads per STARTED unit at QC1/RW1 (max 2 attempts)
	    // QC1 visits: always once, plus retry only if attempt1 failed
	    double qc1VisitsPerStarted = 1.0 + fSw1;
	    // RW1 happens only if attempt1 failed
	    double rw1PerStarted = fSw1;

	    // ---------- QC2 (Cosmetic): max 2 attempts ----------
	    double fC1 = Math.max(0.0, Math.min(0.999, (1.0 - this.passAttemptC1)));
	    double fC2 = Math.max(0.0, Math.min(0.999, (1.0 - this.passAttemptC2)));
	    double yCos = 1.0 - (fC1 * fC2);

	    // At cosmetic stage, flow rate is only those that passed software QC.
	    // QC2 visits per unit entering cosmetic stage:
	    double qc2VisitsPerInCos = 1.0 + fC1;
	    double rw2PerInCos = fC1;

	    // Total yield through both QCs
	    double yTotal = ySw * yCos;
	    
	    // ---------- Raw capacities ----------
	    // These are "units/hour" for assembly/SI/packing and "visits/hour" for QC stations.
	    double capAsmUnits     = this.nAssembly * secPerHour / Math.max(1e-9, this.tAssembly);
	    double capSIUnits      = this.nSoftwareIntegration * secPerHour / Math.max(1e-9, this.tSoftwareIntegration);

	    double capQc1Visits    = this.nQcSoftware * secPerHour / Math.max(1e-9, this.tQcSoftware);
	    double capRw1Units     = this.nReworkSoftware * secPerHour / Math.max(1e-9, this.tReworkSoftware);

	    double capQc2Visits    = this.nQcCosmetic * secPerHour / Math.max(1e-9, this.tQcCosmetic);
	    double capRw2Units     = this.nReworkCosmetic * secPerHour / Math.max(1e-9, this.tReworkCosmetic);

	    double capPackUnits    = this.nPackaging * secPerHour / Math.max(1e-9, this.tPackaging);
	    
	    // Let X = FINISHED good units/hour at the end of Packing.
	    // Started units/hour S = X / yTotal

	    // ---------- Convert station constraints into FINISHED units/hour ----------
	    // Assembly & SI process STARTED units:
	    double xAsm  = capAsmUnits * yTotal;
	    double xSI   = capSIUnits  * yTotal;

	    // QC1 sees started units as visits: visits/hour = S * qc1VisitsPerStarted
	    // => X <= capQc1Visits * yTotal / qc1VisitsPerStarted
	    double xQc1  = capQc1Visits * yTotal / Math.max(1e-9, qc1VisitsPerStarted);

	    // RW1 sees started units at rate: S * rw1PerStarted
	    // => X <= capRw1Units * yTotal / rw1PerStarted
	    double xRw1  = (rw1PerStarted <= 1e-12) ? 1e12 : (capRw1Units * yTotal / rw1PerStarted);

	    // Cosmetic stage input rate = S * ySw = X / yCos  (since X = S*ySw*yCos)
	    // QC2 visits/hour = (X / yCos) * qc2VisitsPerInCos
	    // => X <= capQc2Visits * yCos / qc2VisitsPerInCos
	    double xQc2  = capQc2Visits * yCos / Math.max(1e-9, qc2VisitsPerInCos);

	    // RW2 units/hour = (X / yCos) * rw2PerInCos
	    // => X <= capRw2Units * yCos / rw2PerInCos
	    double xRw2  = (rw2PerInCos <= 1e-12) ? 1e12 : (capRw2Units * yCos / rw2PerInCos);

	    // Packing is on finished flow directly
	    double xPack = capPackUnits;

	    // ---------- Bottleneck selection ----------
	    double thrPerHour = xAsm;
	    String bottleneck = "Assembly";

	    if (xSI   < thrPerHour) { thrPerHour = xSI;   bottleneck = "SoftwareIntegration"; }
	    if (xQc1  < thrPerHour) { thrPerHour = xQc1;  bottleneck = "QC1_Software"; }
	    if (xRw1  < thrPerHour) { thrPerHour = xRw1;  bottleneck = "RW1_Software"; }
	    if (xQc2  < thrPerHour) { thrPerHour = xQc2;  bottleneck = "QC2_Cosmetic"; }
	    if (xRw2  < thrPerHour) { thrPerHour = xRw2;  bottleneck = "RW2_Cosmetic"; }
	    if (xPack < thrPerHour) { thrPerHour = xPack; bottleneck = "Packing"; }

	    // ---------- Daily target + takt ----------
	    this.dailyTarget = (int) Math.floor(thrPerHour * this.workHoursPerDay * this.utilization);
	    this.dailyTarget = Math.max(1, this.dailyTarget);

	    double availableSec = this.workHoursPerDay * 3600.0;
	    this.taktSec = availableSec / this.dailyTarget;
	    
	    // split daily target
	    this.splitDailyTargetByVariant();

	    Logger.info("CAPACITY(max2): bottleneck=", bottleneck,
	            " thrPerHour=", thrPerHour,
	            " targetPerDay=", this.dailyTarget,
	            " taktSec=", taktSec,
	            " yields: ySw=", ySw, " yCos=", yCos, " yTotal=", yTotal,
	            " capsFG[h]= asm=", xAsm,
	            " si=", xSI,
	            " qc1=", xQc1,
	            " rw1=", xRw1,
	            " qc2=", xQc2,
	            " rw2=", xRw2,
	            " pack=", xPack);
	}
	
	private void splitDailyTargetByVariant() {
	    
	    int targetMET = (int) Math.round(this.dailyTarget * this.MIX_MET);
	    int targetFW = (int) Math.round(this.dailyTarget * this.MIX_FW);
	    int targetFB = this.dailyTarget - targetMET - targetFW;
	    
	    this.dailyTargetByVariant.put(VARIANT.MET, targetMET);
	    this.dailyTargetByVariant.put(VARIANT.FW, targetFW);
	    this.dailyTargetByVariant.put(VARIANT.FB, targetFB);
	}
	
	public double getTaktSec() {
	    return this.taktSec;
	}
	
	public int getDailyTarget() {
		return this.dailyTarget;
	}
	
	public int getDailyTarget(VARIANT v) {
	    Integer x = this.dailyTargetByVariant.get(v);
	    return (x == null) ? 0 : x;
	}

	public Map<VARIANT, Integer> getDailyTargetByVariantCopy() {
	    return new EnumMap<>(this.dailyTargetByVariant);
	}
	
	public VARIANT pickVariantByRemaining() {

	    int rMET = Math.max(0, this.getDailyTarget(VARIANT.MET) - this.dailyMadeByVariant.get(VARIANT.MET));
	    int rFW  = Math.max(0, this.getDailyTarget(VARIANT.FW)  - this.dailyMadeByVariant.get(VARIANT.FW));
	    int rFB  = Math.max(0, this.getDailyTarget(VARIANT.FB)  - this.dailyMadeByVariant.get(VARIANT.FB));

	    int sum = rMET + rFW + rFB;
	    if (sum <= 0) return null;

	    int pick = main.uniform_discr(1, sum);
	    if (pick <= rMET) return VARIANT.MET;
	    pick -= rMET;
	    if (pick <= rFW) return VARIANT.FW;
	    return VARIANT.FB;
	}
	
	public boolean isMoRequired() {
		// Release-control / WIP cap (prevents MO spam)
		if (main.waitingMrpOrders != null && main.waitingMrpOrders.size() >= maxWaitingMos) {
			return false;
		}
		
	    // Normal "plan remaining" logic
	    int madeMET = this.dailyMadeByVariant.getOrDefault(VARIANT.MET, 0);
	    int madeFW  = this.dailyMadeByVariant.getOrDefault(VARIANT.FW, 0);
	    int madeFB  = this.dailyMadeByVariant.getOrDefault(VARIANT.FB, 0);

	    return !(madeMET >= this.getDailyTarget(VARIANT.MET) &&
	             madeFW  >= this.getDailyTarget(VARIANT.FW)  &&
	             madeFB  >= this.getDailyTarget(VARIANT.FB));
	}
	
	public void updateMoMadeCounter(VARIANT v, int qty) {
		int oldQty = this.dailyMadeByVariant.get(v);
		this.dailyMadeByVariant.merge(v, qty, Integer::sum);
	}
	

    
    private double rampFactor() {
    	if (!main.services.procurementPolicy.inWarmupTime())
    		return 1.0;
	  
	  // Example: 1.5 on day 0 -> 1.0 by day 7
	  double t = main.time() / (Constants.WARM_UP_DAYS * main.day());
	  return 1.5 - 0.5 * min(1.0, t);
	}
	
	/* public enum QcOutcome { PASS, REWORK, SCRAP }

	public QcOutcome evalQc1(int attemptsSoFar) {
	    int attempt = attemptsSoFar + 1;
	    double passProb = (attempt == 1) ? passAttemptS1 : passAttemptS2;

	    boolean pass = main.uniform(0, 1) < passProb;
	    if (pass) return QcOutcome.PASS;
	    if (attempt >= qcMaxAttempts) return QcOutcome.SCRAP;
	    return QcOutcome.REWORK;
	}

	public QcOutcome evalQc2(int attemptsSoFar) {
	    int attempt = attemptsSoFar + 1;
	    double passProb = (attempt == 1) ? passAttemptC1 : passAttemptC2;

	    boolean pass = main.uniform(0, 1) < passProb;
	    if (pass) return QcOutcome.PASS;
	    if (attempt >= qcMaxAttempts) return QcOutcome.SCRAP;
	    return QcOutcome.REWORK;
	} */
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1768522306876</Id>
			<Name><![CDATA[KpiService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * KpiService
 */
import com.anylogic.engine.analysis.*;

import java.util.Map;
import java.util.HashMap;
import java.util.ArrayList; // if you need elsewhere
import java.io.File;
import java.io.FileWriter;
import java.io.PrintWriter;

public class KpiService {

    private final Main main;

    public KpiService(Main main) {
        this.main = main;
    }

    public boolean kpiEnabled() {
        return main != null && main.time() >= Constants.WARM_UP_DAYS * main.day();
    }

    // -------------------- Core KPIs --------------------

    public void updateKpiServiceLevel() {
        double serviceLevel = (main.kpiDemandUnitsTotal == 0)
                ? 0
                : 100.0 * main.kpiDemandUnitsShipped / main.kpiDemandUnitsTotal;
        main.kpiServiceLevel.add(main.time(), serviceLevel);
    }

    public void recordThroughputTime() {
        double throughputTime = (main.kpiUnitDoneCount == 0)
                ? 0
                : main.kpiUnitThroughputSum / main.kpiUnitDoneCount;
        main.kpiThroughputTime.add(main.time(), throughputTime);
    }

    public void updateScrapRate() {
        long totalScrapUnits = main.kpiScrapQC1Max + main.kpiScrapQC2Max + main.kpiScrapOther;

        if (main.kpiUnitDoneCount == 0) {
            main.kpiScrapRate.add(main.time(), 0);
        } else {
            double scrapRate = (totalScrapUnits / (double) main.kpiUnitDoneCount) * 100.0;
            main.kpiScrapRate.add(main.time(), scrapRate);
        }
    }

    public void updateScrapCost() {
        double scrapCost = 0.0;

        for (FG_SKU fgSku : FG_SKU.values()) {
            long scrapUnits = main.kpiScrapByVariant.getOrDefault(fgSku, 0L);
            double unitCost = main.fgCostPriceBySkuId.getOrDefault(fgSku.skuId(), 0.0);
            scrapCost += scrapUnits * unitCost;
        }

        main.kpiScrapCost.add(main.time(), scrapCost);
    }

    public void updateRmInventoryValue() {
        double value = computeRmInventoryValueNow();
        main.kpiRmInventoryValue.add(main.time(), value);
    }

    public void recordOrderLeadTimes() {
        double t = main.time();

        double poAvg = (main.kpiPoCount == 0) ? 0 : (main.kpiPoLeadSum / main.kpiPoCount);
        main.kpiPoLeadAvg.add(t, poAvg);

        double moAvg = (main.kpiMoDoneCount == 0) ? 0 : (main.kpiMoCycleSum / main.kpiMoDoneCount);
        main.kpiMoCycleAvg.add(t, moAvg);

        double coAvg = (main.kpiCoShippedCount == 0) ? 0 : (main.kpiCoLeadSum / main.kpiCoShippedCount);
        main.kpiCoLeadAvg.add(t, coAvg);
    }

    public void recordBackLog() {
        double t = main.time();
        main.kpiMoBacklog.add(t, main.waitingMrpOrders.size());
        main.kpiCoBacklog.add(t, main.pendingCustomerOrders.size());
        main.kpiPackingBacklog.add(t, main.pendingPackingOrders.size());
    }

    public void recordWorkerUtilization() {
        double t = main.time();

        main.kpiAsmOpsUtilization.add(t, 100.0 * main.asmOps.utilization());
        main.kpiSwOpsUtilization.add(t, 100.0 * main.swOps.utilization());
        main.kpiQcOpsUtilization.add(t, 100.0 * main.qcOps.utilization());
        main.kpiReworkOpsUtilization.add(t, 100.0 * main.reworkOps.utilization());
        main.kpiPackOpsUtilization.add(t, 100.0 * main.packOps.utilization());
        main.kpiSortOpsUtilization.add(t, 100.0 * main.sortOps.utilization());
        main.kpiIbQcOpsUtilization.add(t, 100.0 * main.ibQcOps.utilization());
        main.kpiIbWorkerOpsUtilization.add(t, 100.0 * main.ibWorkerOps.utilization());

        main.kpiRmPickerUtilization.add(t, 100.0 * this.avgRmPickerUtil());
        main.kpiFgPickerUtilization.add(t, 100.0 * this.avgFgPickerUtil());
        main.kpiRmStowerUtilization.add(t, 100.0 * this.avgRmStowerUtil());
        main.kpiFgStowerUtilization.add(t, 100.0 * this.avgFgStowerUtil());

        main.kpiOutboundWorkerUtilization.add(t, 100.0 * outboundWorkerBusyFraction());
        main.kpiOutboundDockUtilization.add(t, 100.0 * outboundDockBusyFraction());
    }

    // -------------------- Tick --------------------

    public void tickKpis() {
        if (!this.kpiEnabled())
            return;

        updateKpiServiceLevel();
        recordThroughputTime();
        recordOrderLeadTimes();
        recordWorkerUtilization();
        updateScrapRate();
        updateScrapCost();
        updateRmInventoryValue();
        recordBackLog();

        // Policy differentiators
        sampleInventoryAndCost();
    }

    // -------------------- Inventory / Cost differentiators --------------------

    public void sampleInventoryAndCost() {

        double rmOnHandTotal = 0.0;
        double rmInvPosTotal = 0.0;
        double rmOnHandShared = 0.0;
        double rmInvPosShared = 0.0;

        Map<String, Double> onHandSnap = main.liveOnHandBySkuId;
        if (onHandSnap != null && !onHandSnap.isEmpty()) {

            Map<String, Integer> onHandInt = snapToIntMap(onHandSnap);

            for (Map.Entry<String, Double> e : onHandSnap.entrySet()) {

                String skuId = e.getKey();
                if (skuId == null) continue;

                PRODUCT_TYPE rmType = PRODUCT_TYPE.fromSkuId(skuId);
                if (rmType == null) continue; // RM only

                double onHand = e.getValue() == null ? 0.0 : e.getValue();
                rmOnHandTotal += onHand;

                int invPos = main.services.procurementPolicy.inventoryPositionUnits(skuId, onHandInt);
                rmInvPosTotal += invPos;

                if (rmType.isSharedComponent()) {
                    rmOnHandShared += onHand;
                    rmInvPosShared += invPos;
                }

                updateStockoutState(skuId, onHand);
            }
        }

        main.kpiRmOnHandTotal.add(main.time(), rmOnHandTotal);
        main.kpiRmInvPosTotal.add(main.time(), rmInvPosTotal);
        main.kpiRmOnHandShared.add(main.time(), rmOnHandShared);
        main.kpiRmInvPosShared.add(main.time(), rmInvPosShared);

        // ---------- Costs (FIXED for 6-hour sampling) ----------
        // holdingRatePerDay is "per day", so scale by (sample hours / 24)
        double invValueNow = computeRmInventoryValueNow();
        double holdingCostThisTick = invValueNow * Constants.holdingRatePerDay * sampleIntervalDays();
        
        main.totalHoldingCost += holdingCostThisTick;

        main.kpiHoldingCost.add(main.time(), main.totalHoldingCost);
        main.kpiOrderingCost.add(main.time(), main.totalOrderingCost);
        main.kpiTotalCost.add(main.time(), main.totalHoldingCost + main.totalOrderingCost);
        
        main.kpiPoCreatedCountDs.add(main.time(), main.kpiPoCreatedCount);
        main.kpiPoCompletedCount.add(main.time(), main.kpiPoCount);

        /* // PO avg order size
        if (main.kpiPoCount > 0) {
            main.kpiPoAvgOrderSizeUnits.add(main.time(), main.kpiPoUnitsOrderedTotal / (double) main.kpiPoCount);
        } else {
            main.kpiPoAvgOrderSizeUnits.add(main.time(), 0.0);
        } */
        
        // PO avg order size (use PO CREATED count, not PO COMPLETED count)
        if (main.kpiPoCreatedCount > 0) {
            main.kpiPoAvgOrderSizeUnits.add(main.time(),
                    main.kpiPoUnitsOrderedTotal / (double) main.kpiPoCreatedCount);
        } else {
            main.kpiPoAvgOrderSizeUnits.add(main.time(), 0.0);
        }
    }

    private double sampleIntervalDays() {
    	return (Constants.KPI_SAMPLE_HOURS * main.hour()) / main.day();   // = 0.25 days
    }

    private Map<String, Integer> snapToIntMap(Map<String, Double> snap) {
        Map<String, Integer> out = new HashMap<>();
        for (Map.Entry<String, Double> e : snap.entrySet()) {
            if (e.getKey() == null) continue;
            int v = (int) Math.floor(e.getValue() == null ? 0.0 : e.getValue());
            out.put(e.getKey(), v);
        }
        return out;
    }

    private void updateStockoutState(String skuId, double onHand) {

        boolean currentlyOut = onHand <= 0.000001;
        boolean wasOut = Boolean.TRUE.equals(main.rmInStockout.getOrDefault(skuId, false));

        if (!wasOut && currentlyOut) {
            main.rmInStockout.put(skuId, true);
            main.rmStockoutStartTimeSec.put(skuId, main.time());
            main.kpiRmStockoutEvents.put(skuId, main.kpiRmStockoutEvents.getOrDefault(skuId, 0L) + 1L);
        } else if (wasOut && !currentlyOut) {
            main.rmInStockout.put(skuId, false);

            double start = main.rmStockoutStartTimeSec.getOrDefault(skuId, main.time());
            double durDays = (main.time() - start) / main.day();

            main.kpiRmStockoutTimeDays.put(
                    skuId,
                    main.kpiRmStockoutTimeDays.getOrDefault(skuId, 0.0) + durDays
            );
        }
    }

    private double computeRmInventoryValueNow() {
        double value = 0.0;
        if (main.liveOnHandBySkuId == null) return 0.0;

        for (Map.Entry<String, Double> e : main.liveOnHandBySkuId.entrySet()) {
            String skuId = e.getKey();
            if (skuId == null) continue;
            if (PRODUCT_TYPE.fromSkuId(skuId) == null) continue;

            double onHand = e.getValue() == null ? 0.0 : e.getValue();
            double cost = main.rmCostPriceBySkuId.getOrDefault(skuId, 0.0);

            value += onHand * cost;
        }
        return value;
    }

    // -------------------- PO hook --------------------

    public void onPoCreated(PurchaseOrderSim po) {
        if (po == null)
        	return;
        
        main.totalOrderingCost += Constants.orderingCostPerPO;
        main.kpiPoCreatedCount++;

        if (po.orderedUnitsBySkuId != null) {
            for (Map.Entry<String, Integer> e : po.orderedUnitsBySkuId.entrySet()) {
                String skuId = e.getKey();
                int qty = (e.getValue() == null) ? 0 : e.getValue();
                
                if (skuId == null || qty <= 0)
                	continue;
                
                main.kpiPoUnitsOrderedTotal += qty;
                main.kpiPoUnitsOrderedBySkuId.put(
                        skuId,
                        main.kpiPoUnitsOrderedBySkuId.getOrDefault(skuId, 0.0) + qty
                );
            }
        }
    }

    // -------------------- Util helpers (unchanged) --------------------

    private double avgRmPickerUtil() {
        if (main.rmPickers == null || main.rmPickers.size() == 0) return 0;
        double sum = 0;
        for (Picker p : main.rmPickers) sum += p.utilization();
        return sum / main.rmPickers.size();
    }

    private double avgFgPickerUtil() {
        if (main.fgPickers == null || main.fgPickers.size() == 0) return 0;
        double sum = 0;
        for (Picker p : main.fgPickers) sum += p.utilization();
        return sum / main.fgPickers.size();
    }

    private double avgRmStowerUtil() {
        if (main.rmStowers == null || main.rmStowers.size() == 0) return 0;
        double sum = 0;
        for (Stower s : main.rmStowers) sum += s.utilization();
        return sum / main.rmStowers.size();
    }

    private double avgFgStowerUtil() {
        if (main.fgStowers == null || main.fgStowers.size() == 0) return 0;
        double sum = 0;
        for (Stower s : main.fgStowers) sum += s.utilization();
        return sum / main.fgStowers.size();
    }

    private double outboundWorkerBusyFraction() {
        int total = 0, busy = 0;
        for (Resource r : main.operators) {
            if (r.category == RESOURCE_TYPE.OUTBOUND_WORKER) {
                total++;
                if (r.outboundWorkerBusy) busy++;
            }
        }
        return total == 0 ? 0 : (busy / (double) total);
    }

    private double outboundDockBusyFraction() {
        int total = main.outboundDocks.length;
        int busy = 0;
        for (OutboundDockState d : main.outboundDocks) {
            if (d != null && d.truckAtDock && !d.truckLeaving) busy++;
        }
        return total == 0 ? 0 : (busy / (double) total);
    }

    /** ********** Export the results at the end of simulation ********** */
    public void exportRunKpisToCsv(String policyName) {
        try {
            String dir = "kpi_exports";
            File d = new File(dir);
            if (!d.exists()) d.mkdirs();

            String tag = safeFileTag(policyName);
            String file = dir + "/kpis_" + tag + ".csv";

            try (PrintWriter out = new PrintWriter(new FileWriter(file))) {

                out.println("time_sec,service_level,co_lead_avg,rm_onhand_shared,rm_invpos_shared,total_cost,po_avg_order_size,mo_cycle_avg");

                int n = minLen(
                        main.kpiServiceLevel,
                        main.kpiCoLeadAvg,
                        main.kpiRmOnHandShared,
                        main.kpiRmInvPosShared,
                        main.kpiTotalCost,
                        main.kpiPoAvgOrderSizeUnits,
                        main.kpiMoCycleAvg
                );

                for (int i = 0; i < n; i++) {
                    double t = main.kpiServiceLevel.getX(i);

                    out.print(t); out.print(",");
                    out.print(main.kpiServiceLevel.getY(i)); out.print(",");
                    out.print(main.kpiCoLeadAvg.getY(i)); out.print(",");
                    out.print(main.kpiRmOnHandShared.getY(i)); out.print(",");
                    out.print(main.kpiRmInvPosShared.getY(i)); out.print(",");
                    out.print(main.kpiTotalCost.getY(i)); out.print(",");
                    out.print(main.kpiPoAvgOrderSizeUnits.getY(i)); out.print(",");
                    out.print(main.kpiMoCycleAvg.getY(i));
                    out.println();
                }
            }

            Logger.info("✅ Exported KPI CSV: ", file);

        } catch (Exception ex) {
            Logger.error("❌ exportRunKpisToCsv failed: ", ex);
        }
    }

    private int minLen(DataSet... ds) {
        int m = Integer.MAX_VALUE;
        for (DataSet d : ds) m = Math.min(m, d.size());
        return m == Integer.MAX_VALUE ? 0 : m;
    }

    private String safeFileTag(String policyName) {
        if (policyName == null) return "UNKNOWN";
        return policyName.trim().replaceAll("[^a-zA-Z0-9]+", "_");
    }
}]]></Text>
		</JavaClass>
