					<Properties Width="140" Height="30">
						<EntryAction><![CDATA[// Safety checks
if (currentCo == null) {
    Logger.warn("Outbound worker ", getIndex(), " got NEW_OUTBOUND_JOB but currentCo is null.");
    goOutboundSeatAndWait("ARRIVED_SEAT");
    return;
}

PointNode coStagingENode = main.CO_PACK_STAGING_E_NODE; // e.g. always the same node or round-robin
if (coStagingENode == null) {
    Logger.warn("No staging entry node defined; returning to seat.");
    goOutboundSeatAndWait("ARRIVED_SEAT");
    return;
}

// Start moving; when we arrive, ARRIVED_STAGING will be fired into this statechart.
if (this.reachedStaging) {
	armOutboundArrivalOrFireNow("PICKED_CUSTOMER_ORDER", currentCo.getX(), currentCo.getY());
} else {
	armOutboundArrivalOrFireNow("ARRIVED_STAGING", coStagingENode);
}
]]></EntryAction>
						<FillColor/>
					</Properties>
				</StatechartElement>
				<StatechartElement Class="State" ParentState="ROOT_NODE">
					<Id>1765628988489</Id>
					<Name><![CDATA[GoToDock]]></Name>
					<X>270</X><Y>270</Y>
					<Label><X>35</X><Y>15</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="140" Height="30">
						<EntryAction><![CDATA[if (currentCo == null) {
	Logger.warn("OutboundWorker(", getIndex(),") - GoToDock" ," lost currentOrder; returning to seat.");
    goOutboundSeatAndWait("ARRIVED_SEAT");
    return;
}

int idx = currentCo.outboundDockIndex;
if (idx < 0 || idx >= Constants.OUTBOUND_DOCK_STATIONS) {
    Logger.warn("OutboundWorker(", getIndex(), ") - GoToDock: invalid outboundDockIndex ", idx, " for ", currentCo);
    goOutboundSeatAndWait("ARRIVED_SEAT");
    return;
}

PointNode dockNode = main.OUTBOUND_DOCK_NODES[idx];
if (dockNode == null) {
    Logger.warn("GoToDock: invalid dockIdx=" + currentDockIndex);
    goOutboundSeatAndWait("ARRIVED_SEAT");
    return;
}

currentCo.carriedBy = this; 

// Start moving to the dock; when we arrive, ARRIVED_DOCK will be fired.
armOutboundArrivalOrFireNow("ARRIVED_DOCK", dockNode);
]]></EntryAction>
						<FillColor/>
					</Properties>
