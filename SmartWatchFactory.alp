							<Unit Class="RateUnits"><![CDATA[PER_SECOND]]></Unit>
						</Rate>
						<Id>1753899529589</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1764576000000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0.1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[24*3600]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[this.services.mfgConfig.planToday(24, 0.95);

// Kick MO generator once at the start of the day (no burst loop)
if (!this.mrpOrderGeneratorEvent.isActive()) {
    this.mrpOrderGeneratorEvent.restart(0);
}
]]></Action>
