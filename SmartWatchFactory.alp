		<!--   =========   Active Object Class   ========  -->
		<ActiveObjectClass>
			<Id>1765044625845</Id>
			<Name><![CDATA[MrpOrder]]></Name>
			<AdditionalClassCode><![CDATA[// --- One delivery end per order; who is working on it ---
private PointNode deliveryEnd = null;   // chosen once per order

// --- Status ---
private enum Status { QUEUED, ASSIGNED, PICKING, DELIVERED, COMPLETE }
private Status status = Status.QUEUED;

// --- Lines: component SKU -> required units (computed at initOrder) ---
private LinkedHashMap<String,Integer> linesBySkuId;

// --- Odoo MO ids per variant (created right after initOrder) ---
private int moId = 0;
private Map<Integer, Integer> serialToFgId = new HashMap<>();
private VARIANT moVariant = null;
private FG_SKU fgSkuVariant = null;
private int fgQuantity = 0;
private int fgSerial = 0;

// Track completions/scrap per variant (KPIs)
public int fgPackaged = 0;
public int fgScrap = 0;

// --- Planning ledger: for each MO -> component SKUs still needed ---
// Example: { moId -> { "DISP001": 3, "MC001": 3, "BA001": 3, "CA001-FW": 1, "ST001-FW": 1 } }
private LinkedHashMap<String,Integer> remainingInMo = new LinkedHashMap<>();

public double moStartAt = -1;
public double moDoneAt  = -1;

public double moCreateAt = -1;

// ------------------------------------------------------
// Lifecycle
// ------------------------------------------------------
public void initOrder(int fgqty, VARIANT variant, FG_SKU fgSkuVariant) {
	// Reset per-order counters/state
    this.moId       = 0;
    this.fgPackaged = 0;
    this.fgScrap    = 0;
    this.fgSerial   = 0;
    this.remainingInMo.clear();
    this.serialToFgId.clear();
    
    this.deliveryEnd = null;
	
	this.moVariant		= variant;
    this.fgSkuVariant	= fgSkuVariant;
    this.fgQuantity		= fgqty;
	
	this.linesBySkuId = createSkuLines();
	
	this.status = Status.QUEUED;
	
	this.moCreateAt = time();
	
	this.moStartAt = -1;
	this.moDoneAt  = -1;
	
	Logger.info("Order.initOrder -> Total qty = ", this.getTotalQuantity(),
				", Variant = ", this.moVariant, 
				" SKU ID = ", this.fgSkuVariant.skuId());
}

private LinkedHashMap<String,Integer> createSkuLines() {
	LinkedHashMap<String,Integer> skuLines = new LinkedHashMap<>();
	
	// Generic components (Display, Microchip, and Battery)
	skuLines.put(SHARED_SKU.DISPLAY.skuId(), this.fgQuantity);
	skuLines.put(SHARED_SKU.MICROCHIP.skuId(), this.fgQuantity);
	skuLines.put(SHARED_SKU.BATTERY.skuId(), this.fgQuantity);
	
	switch (this.moVariant) {
		case MET:
			skuLines.put(CASE_SKU.MET.skuId(), this.fgQuantity);
			skuLines.put(STRAP_SKU.MET.skuId(), this.fgQuantity);
			break;
		case FW:
			skuLines.put(CASE_SKU.FW.skuId(), this.fgQuantity);
			skuLines.put(STRAP_SKU.FW.skuId(), this.fgQuantity);
			break;
		case FB:
			skuLines.put(CASE_SKU.FB.skuId(), this.fgQuantity);
			skuLines.put(STRAP_SKU.FB.skuId(), this.fgQuantity);
			break;
	}
	return skuLines;
}

public void setIds(int moid, Map<Integer, Integer> serialToFgIds) {
	this.moId = moid;
	
	this.serialToFgId.clear();
    if (serialToFgIds != null) {
        this.serialToFgId = serialToFgIds;
    }
    
    this.fgSerial = 0;
    
    // Build remaining ledger right away so Main can use it immediately
    initMoAllocation();
}

/** Build the initial "needs" for this MO. Called from setIds(). */
private void initMoAllocation() {
    this.remainingInMo.clear();
	
	this.remainingInMo.put(SHARED_SKU.DISPLAY.skuId(), this.fgQuantity);
	this.remainingInMo.put(SHARED_SKU.MICROCHIP.skuId(), this.fgQuantity);
	this.remainingInMo.put(SHARED_SKU.BATTERY.skuId(), this.fgQuantity);
	
	switch (this.moVariant) {
		case MET:
			this.remainingInMo.put(CASE_SKU.MET.skuId(), this.fgQuantity);
			this.remainingInMo.put(STRAP_SKU.MET.skuId(), this.fgQuantity);
			break;
		case FW:
			this.remainingInMo.put(CASE_SKU.FW.skuId(), this.fgQuantity);
			this.remainingInMo.put(STRAP_SKU.FW.skuId(), this.fgQuantity);
			break;
		case FB:
			this.remainingInMo.put(CASE_SKU.FB.skuId(), this.fgQuantity);
			this.remainingInMo.put(STRAP_SKU.FB.skuId(), this.fgQuantity);
			break;
	}
}

// ------------------------------------------------------
// Accessors & small helpers
// ------------------------------------------------------
public PointNode getDeliveryNode()   { return this.deliveryEnd; }
public void setDeliveryNode(PointNode pn)   { this.deliveryEnd = pn; }

public int getTotalQuantity() { return this.fgQuantity; }

public int getMoId() { return this.moId; }

public void setSerialToFgId(Map<Integer, Integer> serialToFgId) {
	this.serialToFgId = serialToFgId;
}

public Integer getFgIdBySerialId(Integer serialId) { 
	if (this.serialToFgId == null || this.serialToFgId.isEmpty()) {
        Logger.warn("getFgIdBySerialId() called but fgIds is empty for order " + getIndex());
        return null;
    }

    if (serialId < 0 || serialId >= this.serialToFgId.size()) {
        Logger.warn("getFgId() index out of range: fgSerial=" + serialId +
                    " size=" + this.serialToFgId.size() + " for order " + getIndex());
        return null;
    }
    
	int fgId = this.serialToFgId.get(serialId);
	return fgId;
}

public int getFgSerial() {
	return this.fgSerial++;
}

public VARIANT getMoVariant() { return this.moVariant; }

public FG_SKU getFgSkuVariant() { return this.fgSkuVariant; }

public LinkedHashMap<String,Integer> getLinesBySkuId() { return this.linesBySkuId; }

public boolean isQueued()    { return status == Status.QUEUED; }
public boolean isAssigned()  { return status == Status.ASSIGNED; }
public boolean isPicking()   { return status == Status.PICKING; }
public boolean isDelivered() { return status == Status.DELIVERED; }
public boolean isComplete()  { return status == Status.COMPLETE; }

private void checkComplete() { // updateCompletion
	if (this.isComplete())
		this.status = Status.COMPLETE;
}

public boolean isDone() {
	return this.fgPackaged >= this.fgQuantity;
}

public boolean isPickInFlight() {
    return status == Status.ASSIGNED || status == Status.PICKING;
}

// ------------------------------------------------------
// Assignment state updates
// ------------------------------------------------------
public void markAssigned() {
	this.status = Status.ASSIGNED;
}

public void markPicking() { 
	this.status = Status.PICKING;
}

public void markDelivered(PointNode chosenEnd) {
	this.deliveryEnd = chosenEnd;
	this.status = Status.DELIVERED;
}

public void markRequeued() {
	this.status = Status.QUEUED;
}

// ------------------------------------------------------
// Flow callbacks (Option A policy)
// ------------------------------------------------------
private void onPackaged() {
    this.fgPackaged++;
    
    if (this.fgPackaged >= this.fgQuantity) { // && this.moDoneAt < 0) {
		// this.moDoneAt = main.time();
		if (this.moStartAt >= 0) {
			double ct = this.moDoneAt - this.moStartAt;
			main.kpiMoDoneCount++;
			main.kpiMoCycleSum += ct;
	  }
	}
    
	this.checkComplete();
}

private void onScrapped() {
	this.fgScrap++;
    
    if (main != null)
		main.services.moFlow.requestTopUpForScrap(this);
}

// ------------------------------------------------------
// If a pick plan is cancelled, restore MO needs
// ------------------------------------------------------
/** Expose the per-MO remaining ledger to Main’s planner (for clubbing components to the right MO). */
public LinkedHashMap<String,Integer> getRemainingInMo() { 
	return this.remainingInMo;
}

/** If a picker job/plan is canceled, restore the clubbed counts so a new plan can reuse them. */
public void restoreClubbedQuantities(List<PickStop> plan) {
    if (plan == null || this.remainingInMo == null)
    	return;
    
    for (PickStop ps : plan) {       
        this.remainingInMo.merge(ps.skuId, ps.unitsToPick, Integer::sum);
    }
}

// ------------------------------------------------------
// Initial lines (per SKU) from ordered quantities
// ------------------------------------------------------                                                                                                                                                                                      
// 1× BOM for a single finished unit of the given variant (generic parts + variant parts)
public Map<String, Integer> oneXBom(VARIANT v) {
	Map<String, Integer> m = new LinkedHashMap<>();
	m.put(SHARED_SKU.DISPLAY.skuId(), 1);
    m.put(SHARED_SKU.MICROCHIP.skuId(), 1);
    m.put(SHARED_SKU.BATTERY.skuId(), 1);
    switch (v) {
        case MET:
            m.put(CASE_SKU.MET.skuId(), 1);
            m.put(STRAP_SKU.MET.skuId(), 1);
            break;
        case FW:
            m.put(CASE_SKU.FW.skuId(), 1);
            m.put(STRAP_SKU.FW.skuId(), 1);
            break;
        case FB:
            m.put(CASE_SKU.FB.skuId(), 1);
            m.put(STRAP_SKU.FB.skuId(), 1);
            break;
    }
    return m;
}

/** Called when a unit exits PACKAGING as good. */
public void onPackagedExit(WipUnit wu) {
	if (wu.isFinishedPosted())
		return;
	    
    // Your existing KPI counter
    this.onPackaged();
}

/** Called when a unit is scrapped anywhere. */
public void onScrapExit(WipUnit wu) {
	if (wu.isScrapped())
		return;
	
	// Keep your existing order-level scrap handling
    this.onScrapped();
}

// In Order.java (or the Order agent)
public boolean hasPendingDemand() {
    if (this.getRemainingInMo() == null)
		return false;
	
	for (Integer q : this.getRemainingInMo().values())
    	if (q != null && q > 0)
    		return true;
    		
    return false;
}

public boolean isOrderComplete() {
	return this.fgQuantity == this.fgPackaged;
}
