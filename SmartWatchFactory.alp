		<JavaClass>
			<Id>1766267632075</Id>
			<Name><![CDATA[CustomerOrderFlowService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * CustomerOrderFlowService
 * 
 * skeleton to help split Main's Additional class code into services.
 * Purpose: Customer Order flow: CO creation, FG picking, packing station assignment, packing completion, staging for outbound.
 */

public class CustomerOrderFlowService {
	private final Main main;

    public CustomerOrderFlowService(Main main) {
        this.main = main;
    }

    public void onPickedOrderArrivedAtPackStation(CustomerOrder co) {
        if (co == null)
        	return;
        	
        // Commit FG reservations now that the picker completed the FG job
    	if (co.fgPickPlan != null && !co.fgPickPlan.isEmpty()) {
    	    for (PickStop ps : co.fgPickPlan) {
    	    	for (FgPickAlloc a : ps.fgAllocs) {
    	    	    Tray t = a.trayRes.getTray();
    	    	    if (t == null) continue;

    	    	    t.commitIds(a.ids);

    	    	    if (t.isEmpty()) {
    	    	        ps.fgSlotRef.recalc();
    	    	        a.trayRes.isEmpty = true;
    	    	        main.services.whDispatch.tryDispatchEmptyFgFromSlot(ps.fgSlotRef);
    	    	    }
    	    	}
    	    }
    	    co.fgPickPlan.clear();
    	}

        int st = co.packStationIndex;
        if (st < 0 || st >= Constants.CO_PACK_STATIONS) {
            Logger.warn("onPickedOrderArrivedAtPackStation: invalid station index ", st, " for ", co);
            return;
        }

        Logger.info("Order ", co, " arrived at packing station ", st);

        // Mark that picking is done and order is waiting to be packed
        co.markPicked();

        CustomerOrderPackStation ps = main.coPackStations[st];
    	ps.queue.addLast(co);

        // Try to start packing immediately if station is free
        this.tryStartPackingAtStation(ps);
    }

    public void enqueueForPacking(CustomerOrder co) {
        if (co == null)
        	return;
        	
        co.markPacking();
        main.pendingPackingOrders.add(co);
        main.services.whDispatch.tryDispatchPackedCO();
    }

    public void onPackingFinished(CustomerOrderPackStation ps, CustomerOrder co) {
        Logger.info("Packing finished at station ", ps.index, " for ", co);
        
        // Here we will treat CustomerOrder as "full boxes" ready for staging
        co.markPacked();
        
        // co is now “packed at station”; worker will move it to staging
        this.enqueueForOutboundMovement(co);
        
        main.services.outbound.tryStartTruckIfNeeded();

        // Start next order at this station if queue is non-empty
        this.tryStartPackingAtStation(ps);
    }
    
    private void tryStartPackingAtStation(CustomerOrderPackStation ps) {
    	if (ps == null)
    		return;
    		
        if (ps.isBusy())
    		return;
    		
        if (ps.queue.isEmpty())
    		return;

        CustomerOrder co = ps.queue.pollFirst();
        this.startPackingOnStation(ps, co);
    }

    private void startPackingOnStation(CustomerOrderPackStation ps, CustomerOrder co) {
    	ps.current = co;
        co.markPacking();
        
        // Place order at that station node for animation
        co.setXY(ps.node.getX(), ps.node.getY());

        double packTime = main.triangular(12, 18, 30); // triangular(120, 180, 300);
        ps.finishTime = main.time() + packTime;    
    }

    private void enqueueForOutboundMovement(CustomerOrder co) {
        if (co == null)
        	return;

        // For now: mark as staged and add to list.
        // Later we'll let trucks load from stagedCustomerOrders.
        co.markStaged();
        main.stagedCustomerOrders.add(co);
        
        // Move icon from pack station to intermediate staging visually
        RectangularNode node = main.coStagingArea;   // can be simple
        if (node != null) {
        	double x = main.uniform(main.coStagingArea.getX(),
        			main.coStagingArea.getX() + main.coStagingArea.getWidth());
            double y = main.uniform(main.coStagingArea.getY(),
            		main.coStagingArea.getY() + main.coStagingArea.getHeight());
            co.setXY(x, y);
        }
        
        // Logically: it’s now at intermediate CO staging
        main.coStagingQueue.addLast(co);
    }
    
    private void enqueueCustomerOrder(CustomerOrder co) {
        if (co == null) 
            return;

        main.pendingCustomerOrders.addLast(co);
        Logger.info("Enqueued customer order: ", co);
        
        // wake up FG picking immediately
        main.services.whDispatch.tryDispatchFgPicking(); 
    }
    
    
    public CustomerOrder createCustomerOrderFromDistributor(
            Resource distributor,
            FG_SKU sku,
            int boxes,
            boolean pushToOdoo
    ) {
        if (distributor == null || sku == null || boxes <= 0) {
            Logger.warn("createCustomerOrderFromDistributor: invalid args, skipping.");
            return null;
        }

        LinkedHashMap<FG_SKU, Integer> map = new LinkedHashMap<>();
        map.put(sku, boxes);

        return createCustomerOrderFromDistributor(distributor, map, pushToOdoo);
    }

    public CustomerOrder createCustomerOrderFromDistributor(
            Resource distributor,
            Map<FG_SKU, Integer> boxesBySku,
            boolean pushToOdoo
    ) {
        if (distributor == null || boxesBySku == null || boxesBySku.isEmpty()) {
            Logger.warn("createCustomerOrderFromDistributor (multi): invalid args, skipping.");
            return null;
        }

        List<CustomerOrderLine> lines = new ArrayList<>();

        for (Map.Entry<FG_SKU, Integer> e : boxesBySku.entrySet()) {
            FG_SKU sku = e.getKey();
            Integer boxesObj = e.getValue();
            int boxes = (boxesObj == null ? 0 : boxesObj.intValue());

            if (sku == null || boxes <= 0)
                continue;

            String skuId = sku.skuId();        
            int unitsPerBox = main.services.catalog.lookupUnitsPerBoxForSku(skuId);
            lines.add(new CustomerOrderLine(sku, skuId, boxes, unitsPerBox));
        }

        if (lines.isEmpty()) {
            Logger.warn("createCustomerOrderFromDistributor (multi): no valid lines, skipping.");
            return null;
        }
        
        CustomerOrder co = main.add_customerOrders();
        co.initMultiLine(distributor, lines);

        // ATP plan (must happen BEFORE Odoo push so dates are consistent)
        this.computeAtpPlan(co);

        main.services.routing.assignPackStationForCO(co); 
        this.enqueueCustomerOrder(co);

        if (pushToOdoo) {
            OdooSalesGateway.createSaleOrderForCustomer(main, co);
        }

        return co;
    }
    
    /**
     * Compute ATP (Available-To-Promise) plan & dates for a CustomerOrder.
     * - If enough FG stock exists: reserve IDs immediately (hard ATP)
     * - Else: estimate readiness from production (soft ATP)
     */
    private void computeAtpPlan(CustomerOrder co) {
        if (co == null) return;

        co.atpComputedAt = main.time();
        co.atpNote = "";

        // ---------------- (A) Try HARD ATP: reserve exact FG IDs now ----------------
        // We reuse your real pick planning logic because it already reserves tray IDs.
        List<PickStop> plan = main.services.pickPlanning.buildFgPickPlan(co);

        if (plan != null && !plan.isEmpty()) {
            // Hard reservation succeeded => the order is ATP-ready now
            co.atpHardReserved = true;
            co.atpReadyAt = main.time(); // co.createdAt;

            // Units "from stock"
            co.atpUnitsFromStock = co.getTotalUnits();
            co.atpUnitsFromFuture = 0;

            // Build a realistic warehouse timeline (you can tune these)
            double pickBufferSec = main.triangular(2*60, 5*60, 12*60);      // 2–12 min buffer
            double packSec       = main.triangular(4*60, 8*60, 15*60);      // 4–15 min packing
            double shipBufferSec = main.triangular(10*60, 25*60, 60*60);    // dock/wait/load buffer

            co.atpPickScheduledAt = co.atpReadyAt + pickBufferSec;
            co.atpPackScheduledAt = co.atpPickScheduledAt + packSec;
            co.atpShipScheduledAt = co.atpPackScheduledAt + shipBufferSec;

            // Customer delivery promise = ship time + transport lead time (tune this)
            double transportSec = main.triangular(24*3600, 48*3600, 96*3600); // 1–4 days, mode 2
            co.atpPromisedDeliveryAt = co.atpShipScheduledAt + transportSec;

            co.atpNote = "ATP HARD: reserved from stock";
            return;
        }

        // ---------------- (B) SOFT ATP: not enough FG in stock ----------------
        // buildFgPickPlan() already rolled back reservations when it failed.
        co.atpHardReserved = false;

        int total = co.getTotalUnits();
        co.atpUnitsFromStock = 0;
        co.atpUnitsFromFuture = total;

        // --- EXACT SOFT ATP for MULTI-LINE orders using "next completion" forecast ---
        double ready = main.time();

        co.atpUnitsFromStock = 0;
        co.atpUnitsFromFuture = 0;

        // optional: variant-specific build time fallback (keep your 20 min baseline)
        final double avgBuildSecPerUnit = 20 * 60;

        for (CustomerOrderLine line : co.lines) {
            if (line == null || line.sku == null || line.qty <= 0)
            	continue;

            FG_SKU sku = line.sku;
            String skuId = sku.skuId();
            int qtyNeeded = line.qty;

            // read-only on-hand count (does NOT reserve)
            int onHand = main.services.pickPlanning.countAvailableFgUnits(sku);

            int fromStock = Math.min(qtyNeeded, onHand);
            int additional = Math.max(0, qtyNeeded - onHand);

            co.atpUnitsFromStock += fromStock;
            co.atpUnitsFromFuture += additional;

            if (additional > 0) {
                double tNth = main.services.atpForecast.forecastNthCompletion(skuId, additional);

                if (tNth > 0) {
                    ready = Math.max(ready, tNth);
                } else {
                    // Fallback when forecast queue is not populated yet (early sim)
                    double fallback = co.createdAt + (additional * avgBuildSecPerUnit);
                    ready = Math.max(ready, fallback);
                }
            }
        }

        co.atpReadyAt = ready;

        // Then plan warehouse around that readiness
        double pickBufferSec = main.triangular(5*60, 12*60, 30*60);
        double packSec       = main.triangular(6*60, 12*60, 25*60);
        double shipBufferSec = main.triangular(30*60, 60*60, 4*3600);

        co.atpPickScheduledAt = co.atpReadyAt + pickBufferSec;
        co.atpPackScheduledAt = co.atpPickScheduledAt + packSec;
        co.atpShipScheduledAt = co.atpPackScheduledAt + shipBufferSec;

        double transportSec = main.triangular(48*3600, 72*3600, 120*3600); // 2–5 days, mode 3
        co.atpPromisedDeliveryAt = co.atpShipScheduledAt + transportSec;

        co.atpNote = "ATP SOFT: stock shortage, ETA estimated";
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1766268256788</Id>
			<Name><![CDATA[OutboundFlowService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * OutboundFlowService
 * 
 * skeleton to help split Main's Additional class code into services.
 * Purpose: Outbound docks & truck flow: start truck, fill from staging, dispatch outbound workers, depart truck callbacks.
 */	
public class OutboundFlowService {
	private final Main main;

    public OutboundFlowService(Main main) {
        this.main = main;
    }
    
    public void tryStartTruckIfNeeded() {
        // Nothing to ship → nothing to do
        if (main.coStagingQueue.isEmpty())
            return;

        // Find first dock with no truck
        int dockIdx = -1;
        for (int i = 0; i < Constants.OUTBOUND_DOCK_STATIONS; i++) {
            OutboundDockState ds = main.outboundDocks[i];
            if (ds != null && ds.truck == null) {
                dockIdx = i;
                break;
            }
        }
        if (dockIdx < 0)
            return; // all docks busy with active trucks

        // Spawn truck at that dock
        spawnOutboundTruckAtDock(dockIdx);

        // Fill truck with staged orders (subject to TRUCK_BOX_CAPACITY)
        fillTruckFromStaging(dockIdx);

        // If we assigned any orders to this dock, send outbound workers
        if (!main.waitingForDock[dockIdx].isEmpty()) {
            tryDispatchOutboundWorkers();
        }
    }

    public void spawnOutboundTruckAtDock(int dockIdx) {
        OutboundDockState ds = main.outboundDocks[dockIdx];
        if (ds.truck != null)
        	return; // already have a truck

        Resource truck = main.add_resources();         // your existing Resource population
        truck.category = RESOURCE_TYPE.TRUCK;

        // spawn at entry/exit node (your outboundTruckExitNode)
        PointNode start = (main.outboundTruckENode != null) ? main.outboundTruckENode : ds.node;
        truck.setXY(start.getX(), start.getY());
        
        ds.truck = truck;
        ds.truckAtDock = false;
        ds.truckLeaving = false;
        ds.loadedOrders.clear();
        ds.assignedBoxes = 0;
        ds.ordersAssigned = 0;
        ds.ordersLoaded = 0;
        
        truck.moveTo(ds.node);

        Logger.info("Spawned outbound truck ", truck, " at dock ", dockIdx);
    }

    public void fillTruckFromStaging(int dockIdx) {
        OutboundDockState ds = main.outboundDocks[dockIdx];
        if (ds.truck == null)
        	return;

        int remainingCapacity = Constants.TRUCK_BOX_CAPACITY - ds.assignedBoxes;

        while (remainingCapacity > 0 && !main.coStagingQueue.isEmpty()) {
            CustomerOrder co = main.coStagingQueue.peekFirst(); // don't remove yet
            if (co == null) {
            	main.coStagingQueue.pollFirst();
                continue;
            }

            int boxes = co.getTotalBoxes();
            if (boxes <= 0) {
                Logger.warn("fillTruckFromStaging: CO ", co, " has 0 boxes; skipping.");
                main.coStagingQueue.pollFirst();
                continue;
            }

            // If this order alone exceeds remaining capacity and we already have some load,
            // leave it for the next truck
            if (boxes > remainingCapacity && ds.assignedBoxes > 0) {
                break;
            }

            // Assign this order to this dock
            main.coStagingQueue.pollFirst();
            main.waitingForDock[dockIdx].addLast(co);

            ds.assignedBoxes += boxes;
            ds.ordersAssigned++;

            // also record on the CO
            co.outboundDockIndex = dockIdx;    // add this field to CustomerOrder if not there

            remainingCapacity = Constants.TRUCK_BOX_CAPACITY - ds.assignedBoxes;

            Logger.info("Assigned CO ", co, " to dock ", dockIdx,
                        " (boxes=", boxes, ", used=", ds.assignedBoxes, ")");
        }
    }

    public void tryDispatchOutboundWorkers() {
        // For each dock, dispatch as long as we have orders and workers
        for (int d = 0; d < Constants.OUTBOUND_DOCK_STATIONS; d++) {
        	OutboundDockState ds = main.outboundDocks[d];
            if (ds == null || ds.truck == null || !ds.truckAtDock || ds.truckLeaving)
                continue;
        	
            LinkedList<CustomerOrder> q = main.waitingForDock[d];
            if (q == null)
            	continue;

            while (!q.isEmpty()) {
                Resource ow = main.services.whDispatch.findIdleOutboundWorker();
                if (ow == null)
                	return; // no free workers

                CustomerOrder co = q.pollFirst();
                if (co == null)
                	continue;

                Logger.info("Assigning CO ", co, " to outbound worker ", ow.getIndex(),
                            " for dock ", d);

                ow.assignOutboundJob(co, d);
            }
        }
    }

    public void onOutboundOrderLoaded(CustomerOrder co, int dockIdx) {
        if (co == null)
        	return;
        	
        if (co.isComplete())
        	return;
        
        if (dockIdx < 0 || dockIdx >= Constants.OUTBOUND_DOCK_STATIONS)
        	return;

        OutboundDockState ds = main.outboundDocks[dockIdx];
        if (ds == null)
        	return;

        ds.ordersLoaded++;
        
        if (ds.truck != null) {
            co.carriedBy = ds.truck;
            if (!ds.loadedOrders.contains(co)) {
                ds.loadedOrders.add(co);
            }
        }
        
    	co.markLoaded();
    	
        Logger.info("CO ", co, " fully loaded at dock ", dockIdx,
                    " (loaded ", ds.ordersLoaded, "/", ds.ordersAssigned, ")");

        // Remove from any leftover queues just in case
        if (main.coStagingQueue != null)
        	main.coStagingQueue.remove(co);
        if (main.stagedCustomerOrders != null)
        	main.stagedCustomerOrders.remove(co);
        if (main.waitingForDock != null && main.waitingForDock[dockIdx] != null)
        	main.waitingForDock[dockIdx].remove(co);

        // When all assigned orders have been loaded, truck can depart
        if (ds.ordersLoaded >= ds.ordersAssigned) {
            this.departOutboundTruck(dockIdx);
        }
    }
    
    
    private void departOutboundTruck(int dockIdx) {
        OutboundDockState ds = main.outboundDocks[dockIdx];
        if (ds == null || ds.truck == null)
        	return;
        
        // Prevent double departure	
        if (ds.truckLeaving)
            return;
            
    	// Ship everything FIRST (don’t depart if any fails)
    	boolean allOk = true;
    	
    	// Collect successes but don’t mutate local state until we know allOk
    	List<CustomerOrder> success = new ArrayList<>();
    	
    	if (ds.loadedOrders != null && !ds.loadedOrders.isEmpty()) {
    	
    	    for (CustomerOrder co : ds.loadedOrders) {
    	        if (co == null)
    	        	continue;
    	
    	        boolean shippedOk = OdooSalesGateway.shipCustomerOrder(main, co);
    	        if (!shippedOk) {
    	            allOk = false;
    	            Logger.warn("Odoo shipping failed for ", co, " soId=", co.saleOrderId, " pickingId=", co.pickingId);
    	            break;
    	        }
    	
    	        boolean fgOk = OdooMrpGateway.markFgsShippedByIds(
    	        		main,
    	        		co.pickedFgIds,
    	        		co.saleOrderId,
    	        		co.pickingId,
    	        		main.time()
    	        );
    	
    	        if (!fgOk) {
    	            allOk = false;
    	            Logger.warn("FG ship-update failed for ", co);
    	            break;
    	        }
    	
    	        success.add(co);
    	    }
    	}
    	
    	// If any failed, don’t depart truck; keep everything as-is for retry
    	if (!allOk) {
    	    Logger.warn("Truck departure aborted on dock ", dockIdx,
    	                " because Odoo shipping/FG-update failed. Retrying later.");
    	    return;
    	}
    	
    	// Commit local simulation state only after all succeeded
    	for (CustomerOrder co : success) {
    	    co.markShipped();
    	    main.shippedCustomerOrders.add(co);
    	    co.pickedFgIds.clear();
    	}
    	
    	// Remove shipped orders from loadedOrders
    	ds.loadedOrders.removeAll(success);
        
        // Now depart truck	
        ds.truckLeaving = true;
        ds.truckAtDock = false;
        
        if (main.outboundTruckENode != null) {
            ds.truck.moveTo(main.outboundTruckENode);
        } else {
            ds.truck.deleteSelf(); // fallback
            ds.truck = null;
        }
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1766952397542</Id>
			<Name><![CDATA[MotherBox]]></Name>
			<Folder>1771726185934</Folder>
			<Text><![CDATA[/**
 * MotherBox (aligned)
 *
 * remainingUnits = total physical units remaining in box
 * reservedUnits  = reserved subset of remainingUnits
 */

public class MotherBox {
    private final PRODUCT_TYPE skuType;
    private final int id;
    private final String skuId;
    private final int unitsPerBox;
    private final double weight;

    private int remainingUnits;
    private int reservedUnits;
    
    private boolean isInRmSlot;

    public MotherBox(PRODUCT_TYPE skuType, int pid, String skuId, int upb, double wt) {
        this.skuType = skuType;
        this.id = pid;
        this.skuId = skuId;
        this.unitsPerBox = upb;
        this.weight = wt;

        this.remainingUnits = upb;  // always start full (clear + deterministic)
        this.reservedUnits = 0;
    }

    public PRODUCT_TYPE getSkuType() { return skuType; }
    public int getId() { return id; }
    public String getSkuId() { return skuId; }
    public int getUnitsPerBox() { return unitsPerBox; }
    public double getWeight() { return weight; }

    public int totalUnits() { return Math.max(0, remainingUnits); }
    public int reservedUnits() { return Math.max(0, reservedUnits); }
    
    public boolean getInRmSlot() { return this.isInRmSlot; }

    public boolean isEmpty() { return remainingUnits <= 0; }

    public int availableUnits() {
        return Math.max(0, remainingUnits - reservedUnits);
    }

    public int reserveUnits(int want) {
        int take = Math.min(Math.max(0, want), availableUnits());
        reservedUnits += take;
        return take;
    }

    public void releaseUnits(int qty) {
        reservedUnits = Math.max(0, reservedUnits - Math.max(0, qty));
    }

    public void commitPick(int qty) {
        qty = Math.max(0, qty);

        int fromReserved = Math.min(qty, reservedUnits);
        reservedUnits -= fromReserved;

        remainingUnits = Math.max(0, remainingUnits - qty);
    }
    
    public void setInRmSlot(boolean is) { this.isInRmSlot = is; }
}
]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1766954527991</Id>
			<Name><![CDATA[MotherBoxAssignment]]></Name>
			<Folder>1771726185934</Folder>
			<Text><![CDATA[/**
 * MotherBoxAssignment (aligned)
 *
 * - markIncomingReserved() increments slot.incomingBoxes (by 1) AND slot.incoming (by upb)
 * - rollbackIncomingReservation() decrements both
 */
public class MotherBoxAssignment {
    public final Resource mbRes;
    public final RmSlot targetSlot;
    public final int rackIdx;

    public final MotherBox mbPayload;
    public final String skuId;
    public final int unitsPerBox;
    public final int unitsToStore;  // actual units (for unit-capacity, supports partial boxes)

    private boolean incomingReserved = false;

    public MotherBoxAssignment(Resource mbRes, RmSlot targetSlot, int rackIdx) {
        this.mbRes = mbRes;
        this.targetSlot = targetSlot;
        this.rackIdx = rackIdx;

        this.mbPayload = (mbRes != null) ? mbRes.getMotherBox() : null;
        this.skuId = (mbPayload != null) ? mbPayload.getSkuId() : null;
        this.unitsPerBox = (mbPayload != null) ? mbPayload.getUnitsPerBox() : 0;
        this.unitsToStore = (mbPayload != null) ? mbPayload.totalUnits() : 0;
    }

    public boolean isValid() {
        if (mbRes == null || mbPayload == null || targetSlot == null) return false;
        if (unitsPerBox <= 0 || unitsPerBox > Constants.RM_MAX_UNITS_PER_SLOT) return false;
        if (targetSlot.freeBoxesFor(unitsPerBox) <= 0) return false;
        if (targetSlot.freeUnitCapacity() < unitsToStore) return false;
        return true;
    }

    public void markIncomingReserved() {
        if (incomingReserved) return;
        if (targetSlot == null) return;
        
        targetSlot.reserveIncomingBox(unitsToStore); // unitsPerBox
        incomingReserved = true;
    }

    public void rollbackIncomingReservation(String reason) {
        if (!incomingReserved) return;
        if (targetSlot == null) return;

        targetSlot.rollbackIncomingBox(unitsToStore, reason); // unitsPerBox
        incomingReserved = false;
    }
}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
