		<JavaClass>
			<Id>1767737958853</Id>
			<Name><![CDATA[MasterDataService]]></Name>
			<Folder>1771288398617</Folder>
			<Text><![CDATA[/**
 * MasterDataService
 */
import java.util.*;

public class MasterDataService {

	private final Main main;

    public MasterDataService(Main main) {
        this.main = main;
    }

    public void initializeDatabaseAndMasters() {
        this.initializeDatabase();
    }
    
    public void initializeMasters() {
    	this.loadProductMasterFromDb();		//// fetch master based on Product table
    	this.loadWorkCentersFromDb();
    	this.reconcileVendorsFromDb();		//// build/update the vendor population
    	this.reconcileDistributorsFromDb();	
    }
    
    private void initializeDatabase() {
    	Logger.info("**********************************");
    	Logger.info("**** Initializing database... ****");
    	main.m_dbConn = DatabaseUtils.getEmbeddedConnection(main);
    	if (!DatabaseUtils.executeSqlScriptFromFile(main, "init_table.sql")) {
    		return;
    	}
    	main.m_odooSession = OdooUtils.connectAndPrepare();
    	if (main.m_odooSession == null) {
    		DatabaseUtils.executeSqlScriptFromFile(main, "insert_master_data.sql");
    	} else {
    		Logger.info("Workcenters upserted: " + OdooSyncService.updateWorkCenters(main));
    		Logger.info("Distributors upserted: " + OdooSyncService.updateDistributors(main)); 
    		Logger.info("Vendors upserted: " + OdooSyncService.updateVendors(main));
    		Logger.info("Products upserted: " + OdooSyncService.updateProducts(main));
    		Logger.info("Products-Vendor upserted: " + OdooSyncService.updateProductVendorMapping(main));
    	}
    	
    	this.initializeMasters();

    	int companyId = OdooLiveService.resolveCompanyId(main);

    	main.stockLocationId = OdooLiveService.resolveStockLocationId(main, Constants.DEFAULT_WAREHOUSE_CODE);
    	if (main.stockLocationId > 0) {
    		main.odooHeartbeat.restart(Constants.HEARTBEAT_BASE_SEC); // start the polling event
    	} else {
    		Logger.warn("Stock location not resolved; live polling disabled.");
    	}

    	/* main.productionLocationId = OdooGateway.ensureProductionLocation(main);
    	if (main.productionLocationId <= 0) {
    		Logger.warn("Production location not resolved; MOs can’t be created.");
    	} */

    	Logger.info("**** Database is ready. ****");
    	Logger.info("**********************************");
    	Logger.log(null);
    }
    
    private void loadProductMasterFromDb() {
    	// ----- clear existing -----
        main.productIdBySkuId.clear();
        main.skuRawTypeBySkuId.clear();
        main.weightBySkuId.clear();
        main.unitsPerBoxBySkuId.clear();
        main.skuIdsBySkuType.clear();
        main.rmCostPriceBySkuId.clear();

        main.saleableProductIdBySkuId.clear();
        main.saleableProductTmplIdBySkuId.clear();
        main.saleableProductUnitsPerBoxBySkuId.clear();
        main.fgSalesPriceBySkuId.clear();
        main.fgCostPriceBySkuId.clear();

    	try (ResultSet rs = main.selectResultSet(
    			"SELECT product_id, sku_id, sku_name, units_per_box, unit_weight, cost_price, active, purchase_ok, sale_ok "
    			+ "FROM products "
    			+ "WHERE active = ? AND purchase_ok = ?", true, true)) {

    		while (rs.next()) {
    			String skuId = rs.getString("sku_id");
    			
    			String rawType = rs.getString("sku_name");
    			PRODUCT_TYPE skuType;
    			try {
    			    skuType = PRODUCT_TYPE.parse(rawType);
    			} catch (Exception ex) {
    			    Logger.warn("Skipping row: unknown sku_name='", rawType, "' for sku_id=", skuId);
    			    continue;
    			}
    			
    			if (skuId == null || skuId.isEmpty())
    				continue;
    			
    			main.productIdBySkuId.put(skuId, rs.getInt("product_id"));
    			main.skuRawTypeBySkuId.put(skuId, skuType.getLabel());
    			main.weightBySkuId.put(skuId, rs.getDouble("unit_weight"));
    			main.unitsPerBoxBySkuId.put(skuId, rs.getInt("units_per_box"));
    			main.rmCostPriceBySkuId.put(skuId, rs.getDouble("cost_price"));
    			
    			// Store SKU IDs grouped by SKU name
    			main.skuIdsBySkuType
    				.computeIfAbsent(skuType, k -> new ArrayList<>())
    				.add(skuId);
    	    }
    	} catch (Exception ex) {
    		Logger.error("Failed to execute purachasable products loadProductMaster: ", ex);
    	}

    	try (ResultSet rs = main.selectResultSet(
    			"SELECT product_id, sku_id, product_tmpl_id, units_per_box, cost_price, sales_price "
    			+ "FROM products "
    			+ "WHERE active = ? AND sale_ok = ?", true, true)) {

    		while (rs.next()) {
    			String fgSkuId = rs.getString("sku_id");
    			if (fgSkuId == null || fgSkuId.isEmpty())
    				continue;
    			FG_SKU fgSku = FG_SKU.getBySkuId(fgSkuId);
    			
    			main.saleableProductIdBySkuId.put(fgSkuId, rs.getInt("product_id"));
    			main.saleableProductTmplIdBySkuId.put(fgSkuId, rs.getInt("product_tmpl_id"));
    			main.saleableProductUnitsPerBoxBySkuId.put(fgSkuId, rs.getInt("units_per_box"));
    			main.fgSalesPriceBySkuId.put(fgSkuId, rs.getDouble("sales_price"));
                main.fgCostPriceBySkuId.put(fgSkuId, rs.getDouble("cost_price"));
    	    }
    	} catch (Exception ex) {
    		Logger.error("Failed to execute saleable products loadProductMaster: ", ex);
    	}
    }
    
    private void loadWorkCentersFromDb() {
    	main.workCentersByCode.clear();

    	try (ResultSet rs = main.selectResultSet(
    			"SELECT wc_id, wc_name, wc_code "
    			+ "FROM work_centers "
    			+ "WHERE active = ?", true)) {

    		while (rs.next()) {
    			int wcId = rs.getInt("wc_id");
    			STAGE wcCode = STAGE.valueOf(rs.getString("wc_code"));
    			String wcName = rs.getString("wc_name");
    			
    			main.workCentersByCode.put(wcCode, wcId);
    	    }
    	} catch (Exception ex) {
    		Logger.error("Failed to execute workCenters loadWorkCenters: ", ex);
    	}
    }
    
    private void reconcileVendorsFromDb() {
    	HashSet<Integer> seen = new HashSet<>();

    	int created = 0, updated = 0, deactivated = 0;

    	try (ResultSet rs = main.selectResultSet(
    			"SELECT vendor_id, vendor_sim_name, vendor_name, vendor_address, " +
    			"       vendor_pincode, vendor_city, vendor_country, active " +
    			"FROM vendors")) {

    		while (rs.next()) {
    			int vendorId    = rs.getInt("vendor_id");
    			String simName  = rs.getString("vendor_sim_name");
    			String name     = rs.getString("vendor_name");
    			String address  = rs.getString("vendor_address");
    			String pincode  = rs.getString("vendor_pincode");
    			String city     = rs.getString("vendor_city");
    			String country  = rs.getString("vendor_country");
    			boolean active  = rs.getBoolean("active");
    			
    			seen.add(vendorId);

    			Resource v = main.vendorsById.get(vendorId);
    			
    			if (v == null) {
    				if (!active)
    					continue; // don’t spawn inactive
    				
    				// your population factory (auto-generated by AnyLogic)
    				Resource nv = main.add_vendors();
    				nv.category = RESOURCE_TYPE.VENDOR;
    				nv.setVendor(vendorId, 
    							 simName,
    							 name,
    							 address,
    							 pincode,
    							 city,
    							 country);
    				nv.initVendorStartPoint();
    				nv.active = active;
    				nv.displayName = nv.toString();
    				main.vendorsById.put(vendorId, nv);
    				
    				main.vendorsById.put(vendorId, nv);
    				created++;
    			} else {
    				// update in place (no re-adding)
    				boolean changed = false;
    				if (!Objects.equals(v.simName, simName)) { v.simName = simName; changed = true; }
    				if (!Objects.equals(v.name,    name))    { v.name    = name;    changed = true; }
    				if (!Objects.equals(v.address, address)) { v.address = address; changed = true; }
    				if (!Objects.equals(v.pincode, pincode)) { v.pincode = pincode; changed = true; }
    				if (!Objects.equals(v.city,    city))    { v.city    = city;    changed = true; }
    				if (!Objects.equals(v.country, country)) { v.country = country; changed = true; }
    				if (v.active != active) { v.active = active; changed = true; }

    				if (changed) {
    					v.displayName = v.toString();
    					updated++;
    				}
    			}
    		}
    	} catch (Exception e) {
    		Logger.error("Error reconciling vendors: ", e);
    	}

    	// Deactivate vendors that disappeared from DB
    	for (Map.Entry<Integer, Resource> e : main.vendorsById.entrySet()) {
    		int id = e.getKey();
    		Resource v = e.getValue();
    		
    		if (!seen.contains(id) && v.active) {
    			v.active = false;
    			deactivated++;
    		}
    	}

    	// Load product-vendor mappings in ONE query and attach to Vendor agents
    	try (ResultSet rs = main.selectResultSet( // "SELECT vendor_id, product_id, min_qty, delay_days FROM product_vendor_map")) {
    		"SELECT m.vendor_id, m.product_id, p.sku_id AS product_sku, m.min_qty, m.delay " +
    	    "FROM product_vendor_map m " +
    	    "JOIN products p ON p.product_id = m.product_id")) {
    		
    		// Clear all existing lists/maps first (for a clean refresh)
    		for (Resource v : main.vendors) {
    			v.suppliedProducts.clear();
    			v.minQtyByProduct.clear();
    			v.delayDaysByProduct.clear();
    			v.suppliedSkus.clear();
    	    	v.productIdBySku.clear();
    		}
    		
    		while (rs.next()) {
    			int vendorId   = rs.getInt("vendor_id");
    			int productId  = rs.getInt("product_id");
    			String sku     = rs.getString("product_sku");
    			double minQty  = rs.getDouble("min_qty");
    			double delayDays  = rs.getDouble("delay");
    			
    			Resource v = main.vendorsById.get(vendorId);
    			
    			if (v == null || !v.active)
    				continue;  // ignore mappings for non-existent/inactive vendors
    			
    			v.suppliedProducts.add(productId);
    			v.minQtyByProduct.put(productId, minQty);
    			v.delayDaysByProduct.put(productId, delayDays);
    			
    			// SKU-friendly mappings for UI/debug/logic
    			if (sku != null && !sku.isEmpty()) {
    				v.suppliedSkus.add(sku);
    				v.productIdBySku.put(sku, productId);
    			}
    		}
    	} catch (Exception e) {
    		Logger.error("Error loading product-vendor map: ", e);
    	}

    	Logger.info("Vendors sync -> created:", created,
    				" updated:", updated,
    				" deactivated:", deactivated,
    				" total active:", main.vendorsById.values().stream().filter(x -> x.active).count(),
    				". Mappings attached for all active vendors.");
    }
    
    private void reconcileDistributorsFromDb() {
    	HashSet<Integer> seen = new HashSet<>();

    	int created = 0, updated = 0, deactivated = 0;

    	try (ResultSet rs = main.selectResultSet(
    	        "SELECT partner_id, distributor_sim_name, customer_name, " +
    	    	"       customer_address, customer_pincode, customer_city, " +
    	    	"       customer_country, active " +
    	    	"FROM distributors")) {

    	    while (rs.next()) {
    	        int partnerId   = rs.getInt("partner_id");
    	        String simName  = rs.getString("distributor_sim_name");
    	        String name     = rs.getString("customer_name");
    	        String address  = rs.getString("customer_address");
    	        String pincode  = rs.getString("customer_pincode");
    	        String city     = rs.getString("customer_city");
    	        String country  = rs.getString("customer_country");
    	        boolean active  = rs.getBoolean("active");

    	        seen.add(partnerId);

    	        Resource d = main.distributorsById.get(partnerId);

    	        if (d == null) {
    	            // New distributor
    	            if (!active)
    	                continue;

    	            // AnyLogic auto-generated factory for the distributors population
    	            Resource nd = main.add_distributors();
    	            nd.category = RESOURCE_TYPE.DISTRIBUTOR;
    	            nd.setDistributor(partnerId,
    	            					simName,
    	            					name,
    	            					address,
    	            					pincode,
    	            					city,
    	            					country
    	            );
    	            nd.active             = active;
    	            nd.displayName        = nd.toString();

    	            main.distributorsById.put(partnerId, nd);
    	            created++;
    	        } else {
    	            // Existing distributor: update in place
    	            boolean changed = false;

    	            if (!Objects.equals(d.simName, simName)) { d.simName = simName; changed = true; }
    	            if (!Objects.equals(d.name, name)) { d.name = name; changed = true; }
    	            if (!Objects.equals(d.address, address)) { d.address = address; changed = true; }
    	            if (!Objects.equals(d.pincode, pincode)) { d.pincode = pincode; changed = true; }
    	            if (!Objects.equals(d.city, city)) { d.city = city; changed = true; }
    	            if (!Objects.equals(d.country, country)) { d.country = country; changed = true; }
    	            if (d.active != active) { d.active = active; changed = true; }

    	            if (changed) {
    	                d.displayName = d.toString();
    	                updated++;
    	            }
    	        }
    	    }
    	} catch (Exception e) {
    	    Logger.error("Error reconciling distributors: ", e);
    	}

    	// Deactivate distributors that disappeared from DB
    	for (Map.Entry<Integer, Resource> e : main.distributorsById.entrySet()) {
    	    int id = e.getKey();
    	    Resource d = e.getValue();

    	    if (!seen.contains(id) && d.active) {
    	        d.active = false;
    	        deactivated++;
    	    }
    	}

    	Logger.info(
    	    "Distributors sync -> created:", created,
    	    " updated:", updated,
    	    " deactivated:", deactivated,
    	    " total active:", main.distributorsById.values().stream().filter(x -> x.active).count()
    	);
    }
}]]></Text>
		</JavaClass>
