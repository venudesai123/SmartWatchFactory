		<!--   =========   Active Object Class   ========  -->
		<ActiveObjectClass>
			<Id>1755740376754</Id>
			<Name><![CDATA[WipUnit]]></Name>
			<AdditionalClassCode><![CDATA[public MrpOrder orderRef;				// parent order
public int moId				  = -1;        // optional: which MO it belongs to
public int fgId				  = -1;
public int serialId			  = -1;
public String skuId			  = "";
public FG_SKU fgSku = null;
public String  moName		  = "";       // optional label

public int workcenterId = -1;
private double tStart = 0, tEnd = 0;

private ConveyorPath convIn = null;

// --- identity / linkage ---
private VARIANT variant;			// "MET" | "FW" | "FB"
private STAGE stage = STAGE.KIT;	// KIT, ASSEMBLY, SW, QC1, REWORK1, QC2, REWORK2, PACKAGING, SCRAP, DONE

// --- QC bookkeeping ---
private int qc1Attempts = 0;
private boolean lastQc1Pass = false;

private int qc2Attempts = 0;
private boolean lastQc2Pass = false;

// ---- Scrap Information ----
private SCRAP_REASON scrapReason; // Optional, if you want reasons in KPIs:
private boolean routeToScrap = false;
private boolean scrapped = false;

// Posting guards (protect against duplicate Odoo calls)
private boolean rawPosted    = false;
private boolean finishedPosted = false;

public void initWipUnit(MrpOrder moRef, VARIANT v) {
	this.orderRef = moRef;
	this.moId = moRef.getMoId();
	this.serialId = moRef.getFgSerial();
	this.fgId = moRef.getFgIdBySerialId(serialId);
	
	this.moName = (this.moId > 0 ? "MO_" + this.moId : "");
	
	this.variant = v;
	this.setSkuName();
	this.applyVisualImage();
	this.applyVisualTheme();
	
	// set the delivery path
	this.setConveyorPath(moRef.getDeliveryNode());
}

/* private int rmEndToConveyorIndex(PointNode n) {
    if (n == main.endNodeDisplay)   return 0;
    if (n == main.endNodeMicrochip) return 1;
    if (n == main.endNodeBattery)   return 2;
    if (n == main.endNodeCase)      return 3;
    if (n == main.endNodeStrap)     return 4;
    return 0; // fallback
} */

private void setConveyorPath(PointNode chosenNode) {
	int idx = Arrays.asList(main.RM_RACK_ENDS).indexOf(chosenNode); // rmEndToConveyorIndex(chosenNode); // 
    if (idx < 0 || idx >= main.CONVEYOR_IN.length) {
        Logger.warn("setConveyorPath: chosen node not mapped to a conveyor; defaulting to index 0.");
        idx = 0;
    }
    this.convIn = main.CONVEYOR_IN[idx];
}

public ConveyorPath getConveyorInPath() {
	return this.convIn;
}

public VARIANT getVariant() {
	return this.variant;
}

private void setStage(STAGE stage) {
	this.stage = stage;
	this.applyVisualTheme();
}

public void setScrapReason(SCRAP_REASON scrapReason) {
	this.scrapReason = scrapReason;
}

public SCRAP_REASON getScrapReason() {
	return this.scrapReason;
}

public void flagToScrap(SCRAP_REASON r) { 
	this.routeToScrap = true; 
	this.scrapReason = r;
}

public boolean isScrapped()   { 
	return this.scrapped;
}

public boolean isFlaggedToScrap() {
	return routeToScrap;
}

public void clearScrapFlag() {
	this.routeToScrap = false;
}

public boolean getLastQc2Passed() {
	return this.lastQc2Pass;
}

public int getQc2Attempts() {
	return this.qc2Attempts;
}

public boolean isRawPosted()     { return rawPosted; }
public void   flagRawPosted()    { this.rawPosted = true; }
public boolean isFinishedPosted(){ return finishedPosted; }

// --- decisions (called from blocks) ---
public boolean qcPassAndUpdate(STAGE stage) {
	double prob = 0.0;
	
	switch(stage) {
		case QC1:
			this.qc1Attempts++;
			prob = (this.qc1Attempts == 1) ? ManufacturingConfigService.passAttemptS1 : ManufacturingConfigService.passAttemptS2;
			this.lastQc1Pass = uniform(0, 1) < prob;
			return this.lastQc1Pass;
		case QC2:
			this.qc2Attempts++;
			prob = (this.qc2Attempts == 1) ? ManufacturingConfigService.passAttemptC1 : ManufacturingConfigService.passAttemptC2;
			this.lastQc2Pass = uniform(0, 1) < prob;
			return this.lastQc2Pass;
		default:
            throw new IllegalArgumentException("Unknown stage: " + stage);
	}
}

public boolean qcExceedMax(STAGE stage) {
	switch(stage) {
		case QC1: return this.qc1Attempts >= ManufacturingConfigService.qcMaxAttempts;
		case QC2: return this.qc2Attempts >= ManufacturingConfigService.qcMaxAttempts;
		default: throw new IllegalArgumentException("Unknown stage: " + stage);
	}
}

// Apply visual and visual colors
private void applyVisualImage() {
	this.variantMet.setVisible(false);
	this.variantFW.setVisible(false);
	this.variantFB.setVisible(false);
    if (this.variant == null)
    	return;
    	
    switch (this.variant) {
        case MET: this.variantMet.setVisible(true); break;
        case FW:  this.variantFW.setVisible(true);  break;
        case FB:  this.variantFB.setVisible(true);  break;
    }
}

private void applyVisualTheme() {
	if (this.variant == null)
		return;
	
	Color c = stage.color();
	switch (this.variant) {
		case MET: this.variantMet.setFillColor(c); break;
		case FW:  this.variantFW.setFillColor(c);  break;
		case FB:  this.variantFB.setFillColor(c);  break;
    }
}

private void setSkuName() {
    if (this.variant == null)
    	return;
    	
    this.fgSku = FG_SKU.valueOf(this.variant.name());
    this.skuId = this.fgSku.skuId();
}

// ---- Unified stage change that ALSO triggers Order callbacks ----
public void onEnterStage(STAGE stage) {
	// close previous stage if any
    if (this.stage != null) {
        this.onExitStage(this.stage);
    }
    
    // enter new stage
    this.setStage(stage);
    
    if (stage != STAGE.KIT && 
    	stage != STAGE.SCRAP &&
    	stage != STAGE.DONE) {
	    Integer wc = main.workCentersByCode.get(stage);
	    if (wc != null)
	    	this.workcenterId = wc;
	    
	    // set time
	    this.tStart = time();
		this.tEnd = 0;
		
		if (this.orderRef != null && this.orderRef.moStartAt < 0)
			this.orderRef.moStartAt = this.tStart;
	
		// Odoo call
		OdooMrpGateway.sendSimStartToOdoo(main, this, null);
    }
    
    Logger.info("WIP ", serialId, " entered ", stage, " at t=", String.format("%.3f", time()));
}

public void onExitStage(STAGE stage) {
	// set time
	this.tEnd = time();
	
	if (stage != STAGE.KIT && 
		stage != STAGE.SCRAP &&
		stage != STAGE.DONE) {
		
		double dur = this.tEnd - this.tStart; // seconds
    	main.kpiStepCount.put(stage, main.kpiStepCount.get(stage) + 1);
    	main.kpiStepSum.put(stage, main.kpiStepSum.get(stage) + dur);
		
		// Odoo call
		OdooMrpGateway.sendSimFinishToOdoo(main, this, null, false);
	}
}

// Good unit at PACKAGING exit → mark DONE (posts happen in Order)
public void markPackaged() {
    if (this.finishedPosted)
    	return; // safety
    
    // Your existing KPI Counter in Order
    this.orderRef.onPackagedExit(this);
    
    if (this.orderRef != null && this.orderRef.moStartAt > 0 && this.orderRef.moDoneAt < 0 && this.orderRef.isOrderComplete())
		this.orderRef.moDoneAt = this.tEnd;
    
    main.kpiGoodByVariant.put(this.fgSku, main.kpiGoodByVariant.get(this.fgSku) + 1);
    
	main.kpiUnitDoneCount++;
	main.kpiUnitThroughputSum += this.tEnd - this.tStart;
    
    this.setStage(STAGE.DONE);
    this.finishedPosted = true;
    
    main.services.atpForecast.onFgCompleted(this.skuId, main.time());
    
	// clear
	this.tStart = 0;
	this.tEnd = 0;
}

public void markScrapped() {
	if (this.scrapped)
		return;
	
	// close whichever stage we were in
    this.onExitStage(this.stage);
    this.setStage(STAGE.SCRAP);
	this.scrapped = true;
    
	// clear
	this.tStart = 0;
	this.tEnd = 0;
	
	// If you didn’t already set a reason upstream, you can default here:
	if (this.scrapReason == null)
		this.scrapReason = SCRAP_REASON.OTHER;
		
	if (this.scrapReason == SCRAP_REASON.QC1_MAX_ATTEMPTS)
		main.kpiScrapQC1Max++;
	else if (this.scrapReason == SCRAP_REASON.QC2_MAX_ATTEMPTS)
		main.kpiScrapQC2Max++;
	else
		main.kpiScrapOther++;
	
	main.kpiScrapByVariant.put(this.fgSku, main.kpiScrapByVariant.get(this.fgSku) + 1);
		
	OdooMrpGateway.sendSimScrapToOdoo(main, this, time());
	this.orderRef.setSerialToFgId(OdooMrpGateway.fetchSerialToFgMap(main, moId));
}

public void skipStage(STAGE stage) {
	// set time
	Integer wcId = main.workCentersByCode.get(stage);
    if (wcId != null) {
    	OdooMrpGateway.sendSimSkipToOdoo(main, this, wcId, time());
    }
}

public double getStartTime() { return this.tStart; }

public double getEndTime() { return this.tEnd; }
