				<StatechartElement Class="State" ParentState="ROOT_NODE">
					<Id>1754780068846</Id>
					<Name><![CDATA[GoToNextRackOrDeliver]]></Name>
					<X>70</X><Y>400</Y>
					<Label><X>14.039</X><Y>15</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="196.11650485436894" Height="30">
						<EntryAction><![CDATA[Logger.debug("Next decision: stopIdx=", this.stopIdx, " of ", this.stops.size());
this.cancelPendingArrival();

if (this.stopIdx < this.stops.size()) {
    PickStop ps = this.stops.get(this.stopIdx);
    this.goToEntryForStopAndWait(ps, "ARRIVED_ENTRY_FOR_STOP");
} else {
	// choose delivery end nearest & least crowded from current position
	Logger.debug("All stops completed, moving to delivery.");
	
	if (currentCustomerOrder != null) { // FG customer order → go to fgDropNode
        int st = currentCustomerOrder.packStationIndex;
        if (st < 0 || st >= Constants.CO_PACK_STATIONS) {
            Logger.warn("FG job: invalid packStationIndex ", st, " for ", currentCustomerOrder);
        	return;
        }
        PointNode station = main.PACK_STATION_NODES[st];
        Logger.info("FG job: moving to FG drop node " + station.getName());
        this.armArrivalOrFireNow("ARRIVED_DELIVERY", station);

    } else if (currentOrder != null) { // RM job → old behavior
        double cx = this.getX(), cy = this.getY();
        // this.deliveryEnd = this.chooseDeliveryEndWeighted(cx, cy);
        this.deliveryEnd = this.chooseDeliveryEndSmart(cx, cy);
        this.currentOrder.setDeliveryNode(this.deliveryEnd);

        Logger.info("RM job: moving to delivery area at " + this.deliveryEnd.getName());
        this.armArrivalOrFireNow("ARRIVED_DELIVERY", this.deliveryEnd);

    } else {
        Logger.warn("GoToNextRackOrDeliver: no currentOrder/currentCustomerOrder; returning to seat.");
        this.goSeatAndWait("ARRIVED_SEAT");
    } 
}
]]></EntryAction>
