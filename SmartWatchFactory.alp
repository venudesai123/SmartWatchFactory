								<Code><![CDATA[ProcurementOrder po = (ProcurementOrder)agent;

// Put the PO job at the dock position so "sendResources" sends workers to dock
if (po.dockIdx >= 0) {
	po.jumpTo(this.INBOUND_DOCK_NODES[po.dockIdx]);
}
]]></Code>
