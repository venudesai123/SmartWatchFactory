public double avgOrderGapHours = 48;  // average 2 days between orders
public double orderGapJitter   = 24;  // +/- 1 day around the mean

public void setDistributor(int partnerId,
                			String simName,
                			String name,
                			String address,
                			String pincode,
                			String city,
                			String country) {
	this.id = partnerId;
	this.simName = simName;
	this.name = name;
	this.address = address;
	this.pincode = pincode;
	this.city = city;
	this.country = country;
}

/** Simple helper: sample an order size (single SKU for now). */
public int sampleCOBoxes() {
    int min = Math.max(1, Constants.minOrderQty);
    int max = Math.max(min, Constants.maxOrderQty);
    return uniform_discr(min, max);
}

