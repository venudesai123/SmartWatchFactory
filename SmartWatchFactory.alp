			<Name><![CDATA[OutboundDockState]]></Name>
			<Folder>1771726185934</Folder>
			<Text><![CDATA[/**
 * OutboundDockState
 */	
public class OutboundDockState {
	public int index;
    public PointNode node;           // odn1 / odn2 / odn3
    public Resource truck;           // null if no truck present

    public int assignedBoxes = 0;    // total boxes assigned to this truck
    public int ordersAssigned = 0;   // how many COs assigned
    public int ordersLoaded  = 0;    // how many COs fully loaded
    
    public boolean truckAtDock = false;
    public boolean truckLeaving = false;
    public ArrayList<CustomerOrder> loadedOrders = new ArrayList<>();
}]]></Text>
