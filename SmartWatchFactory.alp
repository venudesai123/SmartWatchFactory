						<Parameter>
							<Name><![CDATA[pushProtocol]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[Resource trayRes = (Resource) agent;

TrayAssignment task = trayRes.fgStowTask;
if (task != null) {
    task.rollbackIncomingReservation("FG terminated");
    trayRes.fgStowTask = null;
} else {
    // fallback (should rarely happen)
    Tray tray = trayRes.getTray();
    if (tray != null) {
        FgSlot slot = services.slotting.getFgSlot(
            tray.getFgSkuVariant(),
            trayRes.rackTargetRow, 
            trayRes.rackTargetCell,
            trayRes.rackTargetLevel
        );
        if (slot != null) {
        	int units = tray.totalUnits();
		    if (slot.incomingTrays <= 0) {
		        Logger.warn("FG incoming underflow rollback sku=" + tray.getFgSkuVariant()
		            + " incoming=" + slot.incomingTrays + " rollback=" + units);
		    }
        
        	slot.rollbackIncomingTray(tray.totalUnits(), "FG terminated (no task)");
        }
    }
}

// Cleanup + requeue
trayRes.hasRackTarget = false;
trayRes.itemAssigned = false;

if (!trayRes.itemQueued) {
    trayRes.itemQueued = true;
    waitingFgTrays.addLast(trayRes);
}

this.services.whDispatch.tryDispatchFgStowing();
]]></Code>
